# ═══════════════ JSON Utils ═══════════════

def _try_parse_json(raw: str) -> Optional[dict | list]:
    """Parse JSON from LLM response, stripping markdown fences if present."""
    if not raw:
        return None

    # Strip markdown code fences
    cleaned = re.sub(r'^```(?:json)?\s*\n?', '', raw.strip())
    cleaned = re.sub(r'\n?```\s*$', '', cleaned)
    cleaned = cleaned.strip()

    try:
        return json.loads(cleaned)
    except json.JSONDecodeError:
        # Try to find JSON array or object within the text
        for pattern in [r'\[[\s\S]*\]', r'\{[\s\S]*\}']:
            match = re.search(pattern, cleaned)
            if match:
                try:
                    return json.loads(match.group())
                except json.JSONDecodeError:
                    continue
        return None


def _save_checkpoint(filepath: str, data) -> None:
    """Save JSON checkpoint."""
    os.makedirs(os.path.dirname(filepath) or ".", exist_ok=True)
    with open(filepath, 'w', encoding='utf-8') as f:
        json.dump(data, f, indent=2, ensure_ascii=False)


def _load_checkpoint(filepath: str):
    """Load JSON checkpoint if it exists."""
    if not os.path.isfile(filepath):
        return None
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            return json.load(f)
    except (json.JSONDecodeError, OSError):
        return None


def _parse_style_section(style_name: str, styles_dir: str, section_name: str) -> str:
    """Extract a === SECTION NAME === block from a style .txt file."""
    if not style_name or not styles_dir:
        return ""
    style_path = os.path.join(styles_dir, f"{style_name}.txt")
    if not os.path.isfile(style_path):
        return ""
    try:
        content = load_style_content(style_path)
        if not content:
            return ""
        pattern = rf'===\s*{re.escape(section_name)}\s*===\s*\n(.+?)(?:\n===|\nMandatory\s+Style|\nNegative\s+Prompt|$)'
        m = re.search(pattern, content, re.DOTALL | re.IGNORECASE)
        return m.group(1).strip() if m else ""
    except Exception:
        return ""


def _parse_style_summary(style_name: str, styles_dir: str) -> str:
    """Extract === STYLE SUMMARY === section from a style .txt file."""
    return _parse_style_section(style_name, styles_dir, "STYLE SUMMARY")


def _parse_location_style(style_name: str, styles_dir: str) -> str:
    """Extract === LOCATION STYLE === section from a style .txt file."""
    return _parse_style_section(style_name, styles_dir, "LOCATION STYLE")


