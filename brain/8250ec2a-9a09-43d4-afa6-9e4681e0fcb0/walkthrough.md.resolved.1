    # ══════════════ Label Management ══════════════

    def _extract_valid_labels(self):
        """Extract valid labels from Step 2 output as source of truth."""
        self.valid_labels = {
            "characters": [c.get("label", "") for c in self.characters_data.get("characters", []) if c.get("label")],
            "locations": [l.get("label", "") for l in self.locations_data.get("locations", []) if l.get("label")],
        }
        self._log(f"[Labels] {len(self.valid_labels['characters'])} chars, "
                  f"{len(self.valid_labels['locations'])} locations")

    def _build_labels_block(self) -> str:
        """Build AVAILABLE LABELS block for Step 3/4 prompts."""
        parts = ["=== AVAILABLE LABELS (USE EXACTLY AS WRITTEN) ==="]
        if self.valid_labels["characters"]:
            parts.append(f"Characters: {', '.join(self.valid_labels['characters'])}")
        if self.valid_labels["locations"]:
            parts.append(f"Locations: {', '.join(self.valid_labels['locations'])}")
        parts.append("RULES: Use ONLY labels from this list. Do NOT create new labels.")
        parts.append("=== END LABELS ===")
        return "\n".join(parts)

    @staticmethod
    def _fuzzy_match(name: str, valid_set: list) -> str:
        """Find closest match for a label using simple substring matching."""
        name_lower = name.lower().strip()
        for v in valid_set:
            if v.lower() == name_lower:
                return v
        # Substring match
        for v in valid_set:
            if name_lower in v.lower() or v.lower() in name_lower:
                return v
        return ""

    def _validate_scene_labels(self, scene: dict):
        """Validate and fix labels in a scene dict."""
        # Fix character labels
        fixed_chars = []
        for char in scene.get("character_labels", []):
            if char in self.valid_labels["characters"]:
                fixed_chars.append(char)
            else:
                closest = self._fuzzy_match(char, self.valid_labels["characters"])
                if closest:
                    self._log(f"  ⚠ Fixed char label: '{char}' → '{closest}'")
                    fixed_chars.append(closest)
                else:
                    self._log(f"  ⚠ Unknown char label: '{char}' — skipped")
        scene["character_labels"] = fixed_chars

        # Fix location
        loc = scene.get("locked_location", "") or ""
        if loc and loc not in self.valid_labels["locations"]:
            closest = self._fuzzy_match(loc, self.valid_labels["locations"])
            if closest:
                scene["locked_location"] = closest

    # ══════════════ Step 3: Scene Design (1 call per sequence) ══════════════

    def _build_visual_reference(self) -> str:
        """Build VISUAL REFERENCE section for Step 3 prompt."""
        parts = []
        parts.append("=== VISUAL REFERENCE: CHARACTERS ===")
        for c in self.characters_data.get("characters", []):
            parts.append(f"- [{c.get('group', 'NAMED')}] {c.get('label', '?')}: {c.get('visual_description', '')}")
        parts.append("\n=== VISUAL REFERENCE: LOCATIONS ===")
        for loc in self.locations_data.get("locations", []):
            parts.append(f"- {loc.get('label', '?')}: {loc.get('bible_description', '')} Lighting: {loc.get('default_lighting', '')}")
        # World Bible
        if self.world_bible:
            ctx = self.world_bible["historical_context"]
            parts.append("\n=== WORLD BIBLE ===")
            parts.append(f"Era: {ctx['era']}")
            parts.append(f"Date Range: {ctx.get('date_range', '')}")
            parts.append(f"Geography: {ctx.get('geography', '')}")
            for faction in self.world_bible.get("factions", []):
                parts.append(f"  Faction: {faction.get('name', '?')}")
                parts.append(f"    Heraldry: {faction.get('heraldry', '')}")
                parts.append(f"    Colors: {', '.join(faction.get('primary_colors', []))}")
                parts.append(f"    Armor: {faction.get('armor', '')}")
                parts.append(f"    Weapons: {', '.join(faction.get('weapons', []))}")
                # Role variants
                role_vars = faction.get("role_variants", {})
                if role_vars:
                    parts.append(f"    --- Role Variants ---")
                    for role, desc in role_vars.items():
                        parts.append(f"    [{role}]: {desc}")
                # Crowd archetypes (value can be string or array of variants)
                crowd = faction.get("crowd_archetypes", {})
                if crowd:
                    parts.append(f"    --- Crowd Archetypes ---")
                    for role, desc in crowd.items():
                        if isinstance(desc, list):
                            for variant in desc:
                                parts.append(f"    [{role}]: {variant}")
                        else:
                            parts.append(f"    [{role}]: {desc}")
            # Architecture
            for arch in self.world_bible.get("architecture", []):
                if isinstance(arch, dict):
                    name = arch.get('name', '?')
                    parts.append(f"  Architecture/{name}:")
                    parts.append(f"    Exterior: {arch.get('exterior', '')}")
                    parts.append(f"    Facade: {arch.get('facade', '')}")
                    parts.append(f"    Interior: {arch.get('interior', '')}")
                    parts.append(f"    Street: {arch.get('street', '')}")
            # Landscape
            landscape = self.world_bible.get("landscape", {})
            if landscape:
                parts.append("\n=== LANDSCAPE ===")
                for k, v in landscape.items():
                    if v:
                        parts.append(f"  {k}: {v}")
            # Transport
            transport = self.world_bible.get("transport", {})
            if transport:
                parts.append("\n=== TRANSPORT ===")
                for k, v in transport.items():
                    if v:
                        parts.append(f"  {k}: {v}")
            # Cultural markers
            markers = self.world_bible.get("cultural_markers", {})
            if markers:
                parts.append("\n=== CULTURAL MARKERS ===")
                for k, v in markers.items():
                    if v:
                        parts.append(f"  {k}: {v}")
        return "\n".join(parts)

    def _validate_scenes(self, seq_data: dict, scenes: list) -> list:
        """Validate scene timing and apply Tail Correction."""
        target_dur = seq_data.get("total_sequence_duration", 0) or seq_data.get("total_duration", 0)
        if not target_dur or not scenes:
            return scenes
        actual_dur = sum(s.get("duration", 0) for s in scenes)
        diff = target_dur - actual_dur
        error_pct = abs(diff) / target_dur * 100 if target_dur > 0 else 0
        if error_pct <= 10:
            if abs(diff) > 0.01:
                last = scenes[-1]
                new_dur = last["duration"] + diff
                if new_dur > float(self.scene_max) or new_dur < 1.0:
                    n = min(3, len(scenes))
                    per_scene = diff / n
                    for s in scenes[-n:]:
                        s["duration"] = round(s["duration"] + per_scene, 2)
                else:
                    last["duration"] = round(new_dur, 2)
                self._log(f"  [Tail] {seq_data.get('sequence_id', '?')}: fixed {round(diff, 2)}s ({round(error_pct, 1)}%)")
            return scenes
        else:
            self._log(f"  ⚠ {seq_data.get('sequence_id', '?')}: timing error {round(error_pct, 1)}% > 10% — REJECTED")
            return []

    def _process_sequence_step3(self, seq: dict, seq_idx: int, total: int) -> dict:
        """Process ONE sequence through Step 3 (scene design)."""
        if self._is_stopped():
            return {}

        labels_block = self._build_labels_block()
        visual_ref = self._build_visual_reference()


        user_msg = f"{labels_block}\n\n{visual_ref}\n\n"
        if self.style_summary:
            user_msg += f"=== STYLE SUMMARY ===\n{self.style_summary}\n\n"
        user_msg += f"=== SEQUENCE TO STORYBOARD ===\n{json.dumps(seq, ensure_ascii=False, indent=2)}"

        self._log(f"  [{seq_idx+1}/{total}] {seq.get('sequence_id', '?')} ({round(seq.get('total_duration', 0), 1)}s)")

        # Inject dynamic scene_max into prompt
        step3_prompt = STEP3_SYSTEM_PROMPT.replace("{SCENE_MAX}", str(self.scene_max))

        for attempt in range(2):
            raw = self._send_llm(step3_prompt, user_msg, tier=self.tier_step13,
                                 max_tokens=16384, step_label=f"step3_seq{seq_idx}")
            if not raw:
                continue
            parsed = _try_parse_json(raw)
            if not parsed or not isinstance(parsed, dict):
                self._log(f"  [{seq_idx+1}] Retry {attempt+1}: JSON parse failed")
                continue

            scenes = parsed.get("scenes", [])
            # Validate labels in each scene
            for scene in scenes:
                scene["locked_location"] = parsed.get("locked_location", "")
                self._validate_scene_labels(scene)

            validated = self._validate_scenes(parsed, scenes)
            if validated:
                parsed["scenes"] = validated
                return parsed

        self._log(f"  [{seq_idx+1}] ❌ Failed after 2 attempts")
        return {}

    def _run_step3(self) -> bool:
        """Scene design: 1 LLM call per sequence."""
        self._update_step("step3", "running")

        ckpt = self._checkpoint_path("_step3_scenes.json")
        existing = _load_checkpoint(ckpt)
        if existing:
            self.scenes_data = existing
            total_scenes = sum(len(s.get("scenes", [])) for s in existing)
            self._update_step("step3", "done", f"{total_scenes} scenes loaded")
            self._log(f"[Step 3] ⏭ Loaded: {total_scenes} scenes")
            return True

        if self._is_stopped():
            return False

        total = len(self.sequences)
        self._log(f"[Step 3] Processing {total} sequences (1 call each)...")

        all_results = []
        if self.threads <= 1:
            for i, seq in enumerate(self.sequences):
                if self._is_stopped():
                    return False
                result = self._process_sequence_step3(seq, i, total)
                if result:
                    all_results.append(result)
        else:
            with ThreadPoolExecutor(max_workers=self.threads) as pool:
                futures = {pool.submit(self._process_sequence_step3, seq, i, total): i
                           for i, seq in enumerate(self.sequences)}
                indexed = [None] * total
                for future in as_completed(futures):
                    idx = futures[future]
                    try:
                        indexed[idx] = future.result()
                    except Exception as e:
                        self._log(f"  [{idx+1}] ❌ Error: {e}")
                all_results = [r for r in indexed if r]

        if not all_results:
            self._update_step("step3", "failed", "No scenes generated")
            return False

        # Enrich with full_text from Step 1
        seq_lookup = {s.get("sequence_id", ""): s for s in self.sequences}
        for seq_result in all_results:
            sid = seq_result.get("sequence_id", "")
            if sid in seq_lookup:
                seq_result.setdefault("full_text", seq_lookup[sid].get("full_text", ""))
                seq_result.setdefault("total_duration", seq_lookup[sid].get("total_duration", 0))

        self.scenes_data = all_results
        _save_checkpoint(ckpt, all_results)

        total_scenes = sum(len(s.get("scenes", [])) for s in all_results)
        self._update_step("step3", "done", f"{total_scenes} scenes")
        self._log(f"[Step 3] ✅ {total_scenes} scenes across {len(all_results)} sequences")
        self._dump("step3", "all_scenes", all_results, "json")
        return True


    # ══════════════ Step 4: Prompt Writing (LLM) ══════════════

    def _build_mini_bible(self, seq_data: dict, prev_seq: dict = None, next_seq: dict = None) -> str:
        """Build mini-bible containing only characters/locations used in this sequence + neighbors."""
        needed_chars = set()
        needed_locs = set()

        for src in [seq_data, prev_seq, next_seq]:
            if not src:
                continue
            needed_locs.add(src.get("locked_location", ""))
            for scene in src.get("scenes", []):
                needed_chars.update(scene.get("character_labels", []))
                needed_locs.add(scene.get("locked_location", ""))

        parts = []
        # Characters
        for c in self.characters_data.get("characters", []):
            if c.get("label") in needed_chars:
                parts.append(f"[{c['label']}]: {c.get('visual_description', '')}. "
                             f"Default costume: {c.get('default_costume', c.get('visual_description', ''))}")
        # Locations
        for loc in self.locations_data.get("locations", []):
            if loc.get("label") in needed_locs:
                parts.append(f"[{loc['label']}]: {loc.get('bible_description', '')}. "
                             f"Lighting: {loc.get('default_lighting', '')}")
        # World Bible (compact)
        if self.world_bible and self.world_bible.get("factions"):
            ctx = self.world_bible["historical_context"]
            wb_parts = [f"World: {ctx['era']}"]
            for faction in self.world_bible.get("factions", []):
                wb_parts.append(f"  {faction.get('name', '?')}: colors={', '.join(faction.get('primary_colors', []))}, armor={faction.get('armor', '')}")
            parts.append(" | ".join(wb_parts))

        return "\n".join(parts) if parts else "(no references needed)"

    def _build_scene_context(self, seq_idx: int) -> str:
        """Build prev/next sequence context for Step 4."""
        parts = []
        if seq_idx > 0:
            prev = self.scenes_data[seq_idx - 1]
            prev_scenes = prev.get("scenes", [])
            if prev_scenes:
                last_scene = prev_scenes[-1]
                parts.append(f"PREVIOUS: {last_scene.get('shot_type', '')} — "
                             f"{last_scene.get('physical_action', '')}")
        else:
            parts.append("PREVIOUS: (start of video)")

        if seq_idx < len(self.scenes_data) - 1:
            next_ = self.scenes_data[seq_idx + 1]
            next_scenes = next_.get("scenes", [])
            if next_scenes:
                first_scene = next_scenes[0]
                parts.append(f"NEXT: {first_scene.get('shot_type', '')} — "
                             f"{first_scene.get('physical_action', '')}")
        else:
            parts.append("NEXT: (end of video)")

        return "\n".join(parts)

    def _resolve_character_info(self, labels: list) -> str:
        """Map character labels to original name + description for Excel readability."""
        if not labels or not self.characters_data:
            return ""
        char_map = {}
        for c in self.characters_data.get("characters", []):
            lbl = c.get("label", "")
            if lbl:
                name = c.get("original_name", "")
                desc = c.get("visual_description", "")
                char_map[lbl] = f"{name}: {desc}" if name else desc
        infos = []
        for lbl in labels:
            info = char_map.get(lbl, "")
            if info:
                infos.append(f"[{lbl}] = {info}")
            else:
                infos.append(f"[{lbl}]")
        return "\n".join(infos)

    def _process_sequence_step4(self, seq_data: dict, seq_idx: int, total: int) -> list:
        """Process ONE sequence through Step 4 (prompt writing)."""
        if self._is_stopped():
            return []

        seq_id = seq_data.get("sequence_id", f"SEQ_{seq_idx+1:02d}")
        scenes = seq_data.get("scenes", [])
        if not scenes:
            return []

        # Determine chapter info
        chapter_info = "N/A"
        if self.sequences:
            for orig_seq in self.sequences:
                if orig_seq.get("sequence_id") == seq_id:
                    # Find chapter from sentence_ids
                    sids = orig_seq.get("sentence_ids", [])
                    if sids:
                        sent_map = {s["sentence_id"]: s for s in self.sentences}
                        first_sent = sent_map.get(sids[0], {})
                        chapter_info = first_sent.get("chapter_name", "N/A")
                    break

        # Build scenes data text
        scenes_text_parts = []
        for i, scene in enumerate(scenes):
            scenes_text_parts.append(
                f"Scene {i+1}: {scene.get('global_scene_id', '')}\n"
                f"  Shot: {scene.get('shot_type', '')} | Camera: {scene.get('camera_motion', 'Static')} | "
                f"Duration: {scene.get('duration', 0)}s | Roll: {scene.get('roll_type', 'A-Roll')}\n"
                f"  Time: {scene.get('time_of_day', 'midday')}\n"
                f"  Characters: {', '.join(scene.get('character_labels', []))}\n"
                f"  Action: {scene.get('physical_action', '')}\n"
                f"  Costume: {scene.get('costume_note', 'default')}\n"
                f"  Background: {scene.get('background_and_extras', '')}\n"
                f"  Lighting: {scene.get('lighting_and_atmosphere', '')}"
            )

        prev_seq = self.scenes_data[seq_idx - 1] if seq_idx > 0 else None
        next_seq = self.scenes_data[seq_idx + 1] if seq_idx < len(self.scenes_data) - 1 else None

        user_msg = STEP4_USER_TEMPLATE.format(
            mini_bible=self._build_mini_bible(seq_data, prev_seq, next_seq),
            sequence_id=seq_id,
            chapter_info=chapter_info,
            location=seq_data.get("locked_location", ""),
            visual_event=seq_data.get("visual_event", ""),
            scenes_data="\n\n".join(scenes_text_parts),
            context=self._build_scene_context(seq_idx),
        )

        self._log(f"  [{seq_idx+1}/{total}] {seq_id} ({len(scenes)} scenes)")

        for attempt in range(2):
            raw = self._send_llm(self.style_content, user_msg, tier=self.tier_step13,
                                 max_tokens=16384, step_label=f"step4_seq{seq_idx}")
            if not raw:
                continue
            parsed = _try_parse_json(raw)
            if not parsed or not isinstance(parsed, list):
                self._log(f"  [{seq_idx+1}] Retry {attempt+1}: JSON parse failed")
                continue

            # Match flat_prompts to scenes
            prompt_map = {p.get("scene_id", ""): p for p in parsed}
            results = []
            for scene in scenes:
                scene_id = scene.get("global_scene_id", "")
                prompt_data = prompt_map.get(scene_id, {})
                if not prompt_data:
                    # Try by index
                    idx_in_seq = scenes.index(scene)
                    if idx_in_seq < len(parsed):
                        prompt_data = parsed[idx_in_seq]

                flat_prompt = prompt_data.get("flat_prompt", "") if isinstance(prompt_data, dict) else ""

                results.append({
                    "global_scene_id": scene_id,
                    "duration": scene.get("duration", 0),
                    "characters": ", ".join(scene.get("character_labels", [])),
                    "character_info": self._resolve_character_info(scene.get("character_labels", [])),
                    "location": seq_data.get("locked_location", ""),
                    "chapter": chapter_info,
                    "character_blocking": prompt_data.get("character_blocking", "") if isinstance(prompt_data, dict) else "",
                    "emotion": prompt_data.get("emotion", "") if isinstance(prompt_data, dict) else "",
                    "key_props": prompt_data.get("key_props", []) if isinstance(prompt_data, dict) else [],
                    "camera_angle": prompt_data.get("camera_angle", "") if isinstance(prompt_data, dict) else "",
                    "effects": prompt_data.get("effects", "") if isinstance(prompt_data, dict) else "",
                    "crowd_description": prompt_data.get("crowd_description", "") if isinstance(prompt_data, dict) else "",
                    "flat_prompt": flat_prompt,
                })
            return results

        self._log(f"  [{seq_idx+1}] ❌ Failed after 2 attempts")
        return []

    def _run_step4(self) -> bool:
        """Prompt writing: LLM writes flat_prompt for each sequence's scenes."""
        self._update_step("step4", "running")

        ckpt = self._checkpoint_path("_step4_prompts.json")
        existing = _load_checkpoint(ckpt)
        if existing:
            self.final_prompts = existing
            self._update_step("step4", "done", f"{len(existing)} prompts loaded")
            self._log(f"[Step 4] ⏭ Loaded: {len(existing)} prompts")
            return True

        if self._is_stopped():
            return False

        # Load full style content for system prompt
        if self.style_name and self.styles_dir:
            style_path = os.path.join(self.styles_dir, f"{self.style_name}.txt")
            self.style_content = load_style_content(style_path)

        if not self.style_content:
            self._log("[Step 4] ⚠ No style content loaded, using generic prompt")
            self.style_content = "You are a visual prompt expert for AI video generation."

        # Inject video-specific constraints (Safety, Quality, Historical)
        # Insert BEFORE Mandatory Style / Negative Prompt to avoid regex contamination
        constraint_parts = []
        active_constraints = []
        prompts_dir = os.path.join(os.path.dirname(os.path.dirname(__file__)), "prompts")
        constraint_map = {
            "safety": "video_constraint_safety.txt",
            "quality": "video_constraint_quality.txt",
            "historical": "video_constraint_historical.txt",
        }
        for key, filename in constraint_map.items():
            if self.constraints.get(key):
                fpath = os.path.join(prompts_dir, filename)
                if os.path.isfile(fpath):
                    with open(fpath, "r", encoding="utf-8") as f:
                        txt = f.read().strip()
                    if txt:
                        constraint_parts.append(txt)
                        active_constraints.append(key)
        if constraint_parts:
            # Find Mandatory Style or Negative Prompt marker and insert before it
            constraint_block = "\n\n" + "\n\n".join(constraint_parts)
            insert_match = re.search(r'\n(?=Mandatory\s+Style|Negative\s+Prompt)', self.style_content, re.IGNORECASE)
            if insert_match:
                pos = insert_match.start()
                self.style_content = self.style_content[:pos] + constraint_block + self.style_content[pos:]
            else:
                self.style_content += constraint_block
            self._log(f"[Step 4] Constraints injected: {', '.join(active_constraints)}")

        total = len(self.scenes_data)
        self._log(f"[Step 4] Writing prompts for {total} sequences...")

        all_prompts = []
        if self.threads <= 1:
            for i, seq in enumerate(self.scenes_data):
                if self._is_stopped():
                    return False
                results = self._process_sequence_step4(seq, i, total)
                all_prompts.extend(results)
        else:
            with ThreadPoolExecutor(max_workers=self.threads) as pool:
                futures = {pool.submit(self._process_sequence_step4, seq, i, total): i
                           for i, seq in enumerate(self.scenes_data)}
                indexed = [None] * total
                for future in as_completed(futures):
                    idx = futures[future]
                    try:
                        indexed[idx] = future.result()
                    except Exception as e:
                        self._log(f"  [{idx+1}] ❌ Error: {e}")
                        indexed[idx] = []
                for batch in indexed:
                    if batch:
                        all_prompts.extend(batch)

        if not all_prompts:
            self._update_step("step4", "failed", "No prompts generated")
            return False

        # Append mandatory style suffix + negative prompt
        mandatory_style = ""
        negative_prompt = ""
        if self.style_content:
            ms = re.search(r'Mandatory\s+Style[:\s]*(.+?)(?:Negative|$)', self.style_content, re.DOTALL | re.IGNORECASE)
            if ms:
                mandatory_style = ms.group(1).strip()
            np_m = re.search(r'Negative\s+Prompt[:\s]*(.+?)$', self.style_content, re.DOTALL | re.IGNORECASE)
            if np_m:
                negative_prompt = np_m.group(1).strip()

        for i, p in enumerate(all_prompts):
            p["index"] = i + 1
            if mandatory_style and p.get("flat_prompt"):
                p["flat_prompt"] = f"{p['flat_prompt']} {mandatory_style}"
            p["negative_prompt"] = negative_prompt

        self.final_prompts = all_prompts
        _save_checkpoint(ckpt, all_prompts)

        self._update_step("step4", "done", f"{len(all_prompts)} prompts")
        self._log(f"[Step 4] ✅ {len(all_prompts)} prompts written by LLM")
        self._dump("step4", "final_prompts", all_prompts, "json")
        return True


    # ══════════════ Step 5: Export ══════════════

    def _run_step5(self) -> bool:
        """Export final prompts to Excel."""
        self._update_step("step5", "running")
        self._export_excel(self.final_prompts)
        self._update_step("step5", "done", f"Excel exported")
        return True

    def _export_excel(self, prompts: list):
        """Export prompts to Excel file with Reference Images sheet."""
        try:
            from openpyxl import Workbook
            from openpyxl.styles import Font, Alignment, PatternFill, Border, Side

            wb = Workbook()

            # ── Shared styles ──
            header_fill = PatternFill(start_color="1F2937", end_color="1F2937", fill_type="solid")
            header_font = Font(name="Segoe UI", size=11, bold=True, color="FFFFFF")
            data_font = Font(name="Segoe UI", size=10)
            wrap_align = Alignment(wrap_text=True, vertical="top")
            center_align = Alignment(horizontal="center", vertical="top")
            thin_border = Border(
                left=Side(style="thin", color="4B5563"),
                right=Side(style="thin", color="4B5563"),
                top=Side(style="thin", color="4B5563"),
                bottom=Side(style="thin", color="4B5563"),
            )

            def _write_headers(ws, headers):
                for col_idx, h in enumerate(headers, 1):
                    cell = ws.cell(row=1, column=col_idx, value=h)
                    cell.font = header_font
                    cell.fill = header_fill
                    cell.alignment = Alignment(horizontal="center", vertical="center")
                    cell.border = thin_border

            # ══════════ Sheet 1: Video Prompts ══════════
            ws1 = wb.active
            ws1.title = "Video Prompts"

            _write_headers(ws1, ["#", "Chapter", "Scene ID", "Duration", "Characters", "Character Info", "Location", "Flat Prompt", "Negative Prompt"])

            for row_idx, p in enumerate(prompts, 2):
                ws1.cell(row=row_idx, column=1, value=p.get("index", row_idx - 1)).alignment = center_align
                ws1.cell(row=row_idx, column=2, value=p.get("chapter", "")).alignment = wrap_align
                ws1.cell(row=row_idx, column=3, value=p.get("global_scene_id", "")).alignment = center_align
                ws1.cell(row=row_idx, column=4, value=p.get("duration", "")).alignment = center_align
                ws1.cell(row=row_idx, column=5, value=p.get("characters", "")).alignment = wrap_align
                ws1.cell(row=row_idx, column=6, value=p.get("character_info", "")).alignment = wrap_align
                ws1.cell(row=row_idx, column=7, value=p.get("location", "")).alignment = wrap_align
                ws1.cell(row=row_idx, column=8, value=p.get("flat_prompt", "")).alignment = wrap_align
                ws1.cell(row=row_idx, column=9, value=p.get("negative_prompt", "")).alignment = wrap_align
                for col_idx in range(1, 10):
                    ws1.cell(row=row_idx, column=col_idx).font = data_font
                    ws1.cell(row=row_idx, column=col_idx).border = thin_border

            ws1.column_dimensions["A"].width = 5
            ws1.column_dimensions["B"].width = 25
            ws1.column_dimensions["C"].width = 18
            ws1.column_dimensions["D"].width = 9
            ws1.column_dimensions["E"].width = 25
            ws1.column_dimensions["F"].width = 40
            ws1.column_dimensions["G"].width = 20
            ws1.column_dimensions["H"].width = 80
            ws1.column_dimensions["I"].width = 40
            ws1.freeze_panes = "A2"

            # ══════════ Sheet 2: Reference Images ══════════
            ws2 = wb.create_sheet("Reference Images")
            _write_headers(ws2, ["#", "Type", "Label", "Original Name", "Description", "Prompt (gen ảnh tham chiếu)", "Negative Prompt"])

            # Get style sections
            mandatory_style = ""
            negative_prompt = ""
            loc_style = self.location_style or ""
            if self.style_name and self.styles_dir:
                style_path = os.path.join(self.styles_dir, f"{self.style_name}.txt")
                sc = load_style_content(style_path)
                if sc:
                    ms = re.search(r'Mandatory\s+Style[:\s]*(.+?)(?:Negative|$)', sc, re.DOTALL | re.IGNORECASE)
                    if ms:
                        mandatory_style = ms.group(1).strip()
                    np_m = re.search(r'Negative\s+Prompt[:\s]*(.+?)$', sc, re.DOTALL | re.IGNORECASE)
                    if np_m:
                        negative_prompt = np_m.group(1).strip()

            row = 2
            # Characters
            for c in self.characters_data.get("characters", []):
                label = c.get("label", "")
                original_name = c.get("original_name", "")
                visual_desc = c.get("visual_description", "")
                sheet_prompt = c.get("sheet_prompt", "")
                if not sheet_prompt:
                    desc = c.get("visual_description", "")
                    sheet_prompt = f"Character reference sheet on clean white background. Three neutral standing views: front view, 3/4 angle, side profile. {desc}. Label '{label}'."
                flat = f"{mandatory_style}. {sheet_prompt}" if mandatory_style else sheet_prompt

                ws2.cell(row=row, column=1, value=row - 1).alignment = center_align
                ws2.cell(row=row, column=2, value="Character").alignment = center_align
                ws2.cell(row=row, column=3, value=label).alignment = wrap_align
                ws2.cell(row=row, column=4, value=original_name).alignment = wrap_align
                ws2.cell(row=row, column=5, value=visual_desc).alignment = wrap_align
                ws2.cell(row=row, column=6, value=flat).alignment = wrap_align
                ws2.cell(row=row, column=7, value=negative_prompt).alignment = wrap_align
                for col_idx in range(1, 8):
                    ws2.cell(row=row, column=col_idx).font = data_font
                    ws2.cell(row=row, column=col_idx).border = thin_border
                row += 1

            # Locations — use LOCATION STYLE (no character appearance)
            for loc in self.locations_data.get("locations", []):
                label = loc.get("label", "")
                desc = loc.get("bible_description", "")
                lighting = loc.get("default_lighting", "")
                loc_prompt = f"Wide establishing shot, eye-level perspective, centered composition. {desc}. {lighting}." if lighting else f"Wide establishing shot, eye-level perspective, centered composition. {desc}."
                # Use location_style instead of mandatory_style
                if loc_style:
                    flat = f"{loc_style} {loc_prompt}"
                else:
                    flat = loc_prompt

                ws2.cell(row=row, column=1, value=row - 1).alignment = center_align
                ws2.cell(row=row, column=2, value="Location").alignment = center_align
                ws2.cell(row=row, column=3, value=label).alignment = wrap_align
                ws2.cell(row=row, column=4, value="").alignment = wrap_align
                ws2.cell(row=row, column=5, value=desc).alignment = wrap_align
                ws2.cell(row=row, column=6, value=flat).alignment = wrap_align
                ws2.cell(row=row, column=7, value=negative_prompt).alignment = wrap_align
                for col_idx in range(1, 8):
                    ws2.cell(row=row, column=col_idx).font = data_font
                    ws2.cell(row=row, column=col_idx).border = thin_border
                row += 1

            ws2.column_dimensions["A"].width = 5
            ws2.column_dimensions["B"].width = 12
            ws2.column_dimensions["C"].width = 30
            ws2.column_dimensions["D"].width = 25
            ws2.column_dimensions["E"].width = 40
            ws2.column_dimensions["F"].width = 100
            ws2.column_dimensions["G"].width = 40
            ws2.freeze_panes = "A2"

            # Save
            base = os.path.splitext(os.path.basename(self.srt_path))[0]
            xlsx_path = os.path.join(self.output_dir, f"{base}_video_prompts.xlsx")
            wb.save(xlsx_path)
            self._log(f"[Step 5] 📊 Excel: {xlsx_path}")
            self._log(f"         Sheet 1: Video Prompts ({len(prompts)} rows)")
            self._log(f"         Sheet 2: Reference Images ({row - 2} items)")

        except Exception as e:
            self._log(f"[Step 5] ⚠ Excel export failed: {e}")

    # ══════════════ Main Run ══════════════

    def run(self):
        """Execute the full pipeline (called in background thread)."""
        self.state = PipelineState.RUNNING
        self._stop_event.clear()
        os.makedirs(self.output_dir, exist_ok=True)

        # Load style data once
        self.style_summary = _parse_style_summary(self.style_name, self.styles_dir)
        self.location_style = _parse_location_style(self.style_name, self.styles_dir)

        # Init debug dump directory
        self._init_debug_dir()

        # Define step sequence with label extraction between Step 2b and Step 3
        self._log("=" * 50)
        n_files = len(self.srt_paths)
        self._log(f"🎬 Video Pipeline Start: {n_files} file(s)")
        for fp in self.srt_paths:
            self._log(f"   📄 {os.path.basename(fp)}")
        self._log(f"   Output: {self.output_dir}")
        self._log(f"   Style: {self.style_name}")
        if self.style_summary:
            self._log(f"   Style Summary: loaded ({len(self.style_summary)} chars)")
        if self.location_style:
            self._log(f"   Location Style: loaded ({len(self.location_style)} chars)")
        self._log(f"   Tier Step2={self.tier_step2}, Step3/4={self.tier_step13}, Threads={self.threads}, SceneMax={self.scene_max}s")
        self._log("=" * 50)

        steps = [
            ("step0", self._run_step0),
            ("step1", self._run_step1),
            ("step2a", self._run_step2a),   # World Bible
            ("step2b", self._run_step2b),   # Characters
            ("step2c", self._run_step2c),   # Locations
            ("_labels", lambda: (self._extract_valid_labels(), True)[1]),  # Extract labels after Step 2
            ("step3", self._run_step3),
            ("step4", self._run_step4),
            ("step5", self._run_step5),
        ]

        for key, step_fn in steps:
            if self._is_stopped():
                self._log("⏹ Pipeline stopped by user")
                self.state = PipelineState.STOPPED
                return

            if key.startswith("_"):
                # Internal step (no UI update)
                step_fn()
                continue

            try:
                success = step_fn()
            except Exception as e:
                import traceback
                tb = traceback.format_exc()
                self._log(f"❌ EXCEPTION at {self.steps[key].step}: {e}")
                self._log(f"   Traceback:\n{tb}")
                self._update_step(key, "failed", str(e)[:100])
                self.state = PipelineState.ERROR
                return
            if not success:
                self._log(f"❌ Pipeline failed at {self.steps[key].step}")
                self.state = PipelineState.ERROR
                return

        self.state = PipelineState.DONE
        self._log("=" * 50)
        self._log(f"🎬 Pipeline COMPLETE: {len(self.final_prompts)} video prompts ready")
        self._log("=" * 50)

    def stop(self):
        """Signal pipeline to stop."""
        self._stop_event.set()
        self.state = PipelineState.STOPPED

    def start_async(self):
        """Start pipeline in a background thread."""
        t = threading.Thread(target=self.run, daemon=True)
        t.start()
        return t
