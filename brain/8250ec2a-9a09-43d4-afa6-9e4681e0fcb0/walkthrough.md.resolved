        btn_img.clicked.connect(self._browse_images)
        r1b.addWidget(btn_img)
        r1b.addStretch()
        config_layout.addLayout(r1b)

        # Row 2: Style + Constraints + Log API
        r2 = QHBoxLayout()
        r2.setSpacing(6)

        lbl_style = QLabel("🎨 Style:")
        lbl_style.setFont(QFont("Segoe UI", 11))
        r2.addWidget(lbl_style)
        self.style_combo = SearchableCombo(self, width=220)
        r2.addWidget(self.style_combo)

        btn_refresh = self._make_btn("Refresh", "#475569", "#64748B", 65)
        btn_refresh.clicked.connect(self._refresh_styles)
        r2.addWidget(btn_refresh)

        btn_open = self._make_btn("Open", "#475569", "#64748B", 50)
        btn_open.clicked.connect(lambda: os.startfile(self.styles_dir) if os.path.isdir(self.styles_dir) else None)
        r2.addWidget(btn_open)

        r2.addSpacing(12)
        self.safety_var = QCheckBox("Safety")
        self.safety_var.setChecked(True)
        r2.addWidget(self.safety_var)
        self.quality_var = QCheckBox("Quality")
        self.quality_var.setChecked(True)
        r2.addWidget(self.quality_var)
        self.historical_var = QCheckBox("Historical")
        self.historical_var.setChecked(True)
        r2.addWidget(self.historical_var)

        r2.addSpacing(12)
        self.log_api_var = QCheckBox("Log API")
        r2.addWidget(self.log_api_var)

        r2.addStretch()

        btn_save = self._make_btn("💾 Save Config", "#2563EB", "#1D4ED8", 110, 28, 11)
        btn_save.clicked.connect(self._save_config)
        r2.addWidget(btn_save)

        config_layout.addLayout(r2)
        layout.addWidget(config_frame)

        # ═══════════ PROJECTS SECTION ═══════════
        proj_frame = QFrame()
        proj_frame.setStyleSheet("QFrame { border: 1px solid #334155; border-radius: 6px; padding: 6px; }")
        proj_layout = QVBoxLayout(proj_frame)
        proj_layout.setSpacing(3)

        # Header
        proj_header = QHBoxLayout()
        proj_title = QLabel("📂  Projects")
        proj_title.setFont(QFont("Segoe UI", 11, QFont.Weight.DemiBold))
        proj_header.addWidget(proj_title)
        proj_header.addStretch()

        btn_scan = self._make_btn("📂 Scan Folder", "#D97706", "#B45309", 110)
        btn_scan.clicked.connect(self._scan_folder)
        proj_header.addWidget(btn_scan)

        btn_clear = self._make_btn("🗑 Clear All", "#DC2626", "#B91C1C", 85)
        btn_clear.clicked.connect(self._clear_all)
        proj_header.addWidget(btn_clear)

        proj_layout.addLayout(proj_header)

        # Tree
        self.tree = QTreeWidget()
        self.tree.setHeaderLabels(["Name", "Style", "Status", "Progress"])
        self.tree.setAlternatingRowColors(True)
        self.tree.setRootIsDecorated(True)
        self.tree.setSelectionMode(QTreeWidget.SelectionMode.ExtendedSelection)

        h = self.tree.header()
        h.setStretchLastSection(False)
        h.setSectionResizeMode(0, QHeaderView.ResizeMode.Stretch)
        h.setSectionResizeMode(1, QHeaderView.ResizeMode.ResizeToContents)
        h.setSectionResizeMode(2, QHeaderView.ResizeMode.ResizeToContents)
        h.setSectionResizeMode(3, QHeaderView.ResizeMode.ResizeToContents)

        proj_layout.addWidget(self.tree, 1)

        # Bottom toolbar
        toolbar = QHBoxLayout()

        btn_remove = self._make_btn("✖ Remove", "#DC2626", "#B91C1C", 70, 26)
        btn_remove.clicked.connect(self._remove_selected)
        toolbar.addWidget(btn_remove)

        btn_add = self._make_btn("➕ Add SRT", "#16A34A", "#15803D", 80, 26)
        btn_add.clicked.connect(self._add_srt_files)
        toolbar.addWidget(btn_add)

        btn_apply = self._make_btn("🎨 Apply Style", "#7C3AED", "#6D28D9", 95, 26)
        btn_apply.clicked.connect(self._apply_style_selected)
        toolbar.addWidget(btn_apply)

        btn_apply_all = self._make_btn("🎨 Apply All", "#7C3AED", "#6D28D9", 85, 26)
        btn_apply_all.clicked.connect(self._apply_style_all)
        toolbar.addWidget(btn_apply_all)

        toolbar.addStretch()
        proj_layout.addLayout(toolbar)

        layout.addWidget(proj_frame, 1)

        # ═══════════ ACTIONS ═══════════
        actions = QHBoxLayout()
        actions.setSpacing(6)

        self.btn_run = self._make_btn("▶ Run All", "#16A34A", "#15803D", 90, 34, 11)
        self.btn_run.clicked.connect(self._run_all)
        actions.addWidget(self.btn_run)

        self.btn_run_sel = self._make_btn("▶ Run Selected", "#2563EB", "#1D4ED8", 110, 34, 11)
        self.btn_run_sel.clicked.connect(self._run_selected)
        actions.addWidget(self.btn_run_sel)

        self.btn_stop = self._make_btn("■ Stop", "#DC2626", "#B91C1C", 70, 34, 11)
        self.btn_stop.setEnabled(False)
        self.btn_stop.clicked.connect(self._stop_pipeline)
        actions.addWidget(self.btn_stop)

        actions.addStretch()

        self.btn_open_out = self._make_btn("📂 Open Output", "#D97706", "#B45309", 110, 28, 10)
        self.btn_open_out.clicked.connect(self._open_output)
        actions.addWidget(self.btn_open_out)

        btn_rename_ref = self._make_btn("🏷 Rename Ref", "#7C3AED", "#6D28D9", 100, 28, 10)
        btn_rename_ref.clicked.connect(self._rename_ref_images)
        actions.addWidget(btn_rename_ref)

        layout.addLayout(actions)

        # ═══════════ LOG ═══════════
        self.log_section = LogSection(self)
        layout.addWidget(self.log_section)

        # Init
        self._refresh_styles()

    # ── Project Management ──

    def _scan_folder(self):
        folder = QFileDialog.getExistingDirectory(self, "Select folder containing SRT files")
        if not folder:
            return

        srt_files = {}
        for root, dirs, files in os.walk(folder):
            for f in sorted(files, key=lambda x: [int(c) if c.isdigit() else c.lower() for c in re.split(r'(\d+)', x)]):
                if f.lower().endswith(('.srt', '.txt')):
                    full_path = os.path.join(root, f)
                    if full_path in self._known_paths:
                        continue
                    rel_dir = os.path.relpath(root, folder)
                    if rel_dir == ".":
                        rel_dir = os.path.basename(folder)
                    if rel_dir not in srt_files:
                        srt_files[rel_dir] = []
                    srt_files[rel_dir].append((f, full_path))

        if not srt_files:
            self.log_section.log("[SCAN] No new SRT files found")
            return

        total = 0
        for dir_name, files in srt_files.items():
            if len(files) == 1 and len(srt_files) == 1:
                f_name, f_path = files[0]
                self._add_file_node(None, f_name, f_path)
                total += 1
            else:
                folder_item = self._find_or_create_folder(dir_name)
                for f_name, f_path in files:
                    self._add_file_node(folder_item, f_name, f_path)
                    total += 1
                self._update_folder_summary(folder_item)
                folder_item.setExpanded(True)

        self.log_section.log(f"[SCAN] Added {total} SRT files")

    def _add_srt_files(self):
        files, _ = QFileDialog.getOpenFileNames(
            self, "Select SRT file(s)", "",
            "Script files (*.srt *.txt);;SRT files (*.srt);;TXT files (*.txt);;All files (*.*)"
        )
        for path in files:
            if path in self._known_paths:
                continue
            name = os.path.basename(path)
            self._add_file_node(None, name, path)

    def _find_or_create_folder(self, dir_name: str) -> QTreeWidgetItem:
        for i in range(self.tree.topLevelItemCount()):
            item = self.tree.topLevelItem(i)
            if item.text(0) == dir_name and item.data(0, Qt.ItemDataRole.UserRole) is None:
                return item
        folder_item = QTreeWidgetItem(self.tree, [dir_name, "", "", ""])
        folder_item.setFont(0, QFont("Segoe UI", 10, QFont.Weight.Bold))
        return folder_item

    def _add_file_node(self, parent, filename: str, full_path: str):
        if full_path in self._known_paths:
            return
        if parent:
            item = QTreeWidgetItem(parent, [filename, "", "Pending", ""])
        else:
            item = QTreeWidgetItem(self.tree, [filename, "", "Pending", ""])
        item.setData(0, Qt.ItemDataRole.UserRole, full_path)
        self._known_paths.add(full_path)

    def _update_folder_summary(self, folder_item: QTreeWidgetItem):
        count = folder_item.childCount()
        folder_item.setText(2, f"{count} files")

    def _remove_selected(self):
        for item in self.tree.selectedItems():
            self._remove_item_and_track(item)

    def _remove_item_and_track(self, item: QTreeWidgetItem):
        path = item.data(0, Qt.ItemDataRole.UserRole)
        if path:
            self._known_paths.discard(path)
        # Remove children too
        for i in range(item.childCount()):
            child = item.child(i)
            if child:
                cp = child.data(0, Qt.ItemDataRole.UserRole)
                if cp:
                    self._known_paths.discard(cp)
        parent = item.parent()
        if parent:
            parent.removeChild(item)
            self._update_folder_summary(parent)
        else:
            idx = self.tree.indexOfTopLevelItem(item)
            if idx >= 0:
                self.tree.takeTopLevelItem(idx)

    def _clear_all(self):
        self.tree.clear()
        self._known_paths.clear()

    def _apply_style_selected(self):
        style = self.style_combo.get()
        if not style or style == "(no styles)":
            return
        for item in self.tree.selectedItems():
            if item.data(0, Qt.ItemDataRole.UserRole):  # file item
                item.setText(1, style)

    def _apply_style_all(self):
        style = self.style_combo.get()
        if not style or style == "(no styles)":
            return
        for item in self._iter_file_items():
            item.setText(1, style)

    def _iter_file_items(self):
        """Iterate all file items (leaf nodes with srt_path)."""
        for i in range(self.tree.topLevelItemCount()):
            item = self.tree.topLevelItem(i)
            if item.data(0, Qt.ItemDataRole.UserRole):
                yield item
            for j in range(item.childCount()):
                child = item.child(j)
                if child and child.data(0, Qt.ItemDataRole.UserRole):
                    yield child

    def _get_projects(self, selected_only=False) -> list:
        """Get list of projects [{name, srt_path, style, item}, ...]."""
        projects = []
        items = self.tree.selectedItems() if selected_only else list(self._iter_file_items())
        for item in items:
            srt_path = item.data(0, Qt.ItemDataRole.UserRole)
            if not srt_path:
                continue
            projects.append({
                "name": item.text(0),
                "srt_path": srt_path,
                "style": item.text(1),
                "item": item,
            })
        return projects

    def _update_project_status(self, item: QTreeWidgetItem, status: str, progress: str = ""):
        self._sig_func.emit(lambda i=item, s=status, p=progress: (i.setText(2, s), i.setText(3, p)))

    # ── Config ──

    def _refresh_styles(self):
        styles = scan_styles_folder(self.styles_dir)
        if styles:
            self.style_combo.configure_values(styles)
        else:
            self.style_combo.configure_values(["(no styles)"])

    def _browse_output(self):
        path = QFileDialog.getExistingDirectory(self, "Select Output Directory")
        if path:
            self.output_edit.setText(path)

    def _browse_images(self):
        start = self.images_edit.text().strip() or self.output_edit.text().strip() or ""
        path = QFileDialog.getExistingDirectory(self, "Select Reference Images Folder", start)
        if path:
            self.images_edit.setText(path)

    def _save_config(self):
        config = {
            "output_dir": self.output_edit.text(),
            "images_dir": self.images_edit.text(),
            "style": self.style_combo.get(),
            "tier": self.tier_combo.currentText(),
            "threads": self.threads_spin.value(),
            "scene_max": self.scene_max_spin.value(),
            "log_api": self.log_api_var.isChecked(),
            "constraint_safety": self.safety_var.isChecked(),
            "constraint_quality": self.quality_var.isChecked(),
            "constraint_historical": self.historical_var.isChecked(),
        }
        try:
            with open(self.config_file, 'w', encoding='utf-8') as f:
                json.dump(config, f, indent=4, ensure_ascii=False)
            self.log_section.log("[CONFIG] ✅ Saved video_config.json")
        except Exception as e:
            self.log_section.log(f"[CONFIG] ❌ Save failed: {e}")

    def _load_config(self):
        if not os.path.exists(self.config_file):
            return
        try:
            with open(self.config_file, 'r', encoding='utf-8') as f:
                config = json.load(f)
            self.output_edit.setText(config.get("output_dir", ""))
            self.images_edit.setText(config.get("images_dir", ""))
            style = config.get("style", "")
            if style:
                self.style_combo.set(style)
            self.tier_combo.setCurrentText(config.get("tier", "Flash"))
            self.threads_spin.setValue(config.get("threads", 2))
            self.scene_max_spin.setValue(config.get("scene_max", 6))
            self.log_api_var.setChecked(config.get("log_api", False))
            self.safety_var.setChecked(config.get("constraint_safety", True))
            self.quality_var.setChecked(config.get("constraint_quality", True))
            self.historical_var.setChecked(config.get("constraint_historical", True))
        except Exception:
            pass

    # ── Pipeline Actions ──

    def _thread_safe_log(self, msg: str):
        self._sig_log.emit(msg)

    def _thread_safe_step(self, key: str, step_status):
        self._sig_step.emit(key, step_status.status, step_status.message)

    def _set_processing_state(self, is_processing: bool):
        self._is_processing = is_processing
        self.btn_run.setEnabled(not is_processing)
        self.btn_run_sel.setEnabled(not is_processing)
        self.btn_stop.setEnabled(is_processing)

    def _resolve_output_dir(self, srt_path: str) -> str:
        """Get output dir: use global setting, or derive from SRT path."""
        out = self.output_edit.text().strip()
        if out:
            # Per-SRT subfolder inside global output
            base = os.path.splitext(os.path.basename(srt_path))[0]
            sub = os.path.join(out, base)
            os.makedirs(sub, exist_ok=True)
            return sub
        else:
            # Default: video_prompt/ next to SRT file
            sub = os.path.join(os.path.dirname(srt_path), "video_prompt")
            os.makedirs(sub, exist_ok=True)
            return sub

    def _run_all(self):
        self._run_projects(self._get_projects(selected_only=False))

    def _run_selected(self):
        self._run_projects(self._get_projects(selected_only=True))

    def _run_projects(self, projects: list):
        if not projects:
            self.log_section.log("[WARN] No SRT files to process!")
            return

        # Validate style
        default_style = self.style_combo.get()
        if not default_style or default_style == "(no styles)":
            self.log_section.log("[WARN] Please select a style first!")
            return

        self._set_processing_state(True)
        self.log_section.set_status("Running...", "#FF9800")
        self.pipeline = None  # Will track current pipeline for stop

        tier = self.tier_combo.currentText()
        threads = self.threads_spin.value()
        log_api = self.log_api_var.isChecked()
        constraints = {
            "safety": self.safety_var.isChecked(),
            "quality": self.quality_var.isChecked(),
            "historical": self.historical_var.isChecked(),
        }

        def _run():
            # Group projects by parent folder for multi-chapter merge
            folder_groups = {}  # folder_path -> [projects]
            for proj in projects:
                folder = os.path.dirname(proj["srt_path"])
                folder_groups.setdefault(folder, []).append(proj)

            total_groups = len(folder_groups)
            success_count = 0

            for grp_idx, (folder, group_projects) in enumerate(folder_groups.items()):
                if self._is_processing is False:
                    break

                # Sort files by natural numeric order (Chapter 1, 2, ... 10, 11)
                def _natural_key(p):
                    import re as _re
                    return [int(c) if c.isdigit() else c.lower()
                            for c in _re.split(r'(\d+)', p["name"])]
                group_projects.sort(key=_natural_key)
                srt_paths = [p["srt_path"] for p in group_projects]
                style = group_projects[0].get("style") or default_style
                items = [p["item"] for p in group_projects]

                # Output directory: use first file's folder or global output
                out_dir = self._resolve_output_dir(srt_paths[0])

                n_files = len(srt_paths)
                group_name = os.path.basename(folder) if n_files > 1 else group_projects[0]["name"]

                self._thread_safe_log(f"\n{'='*50}")
                self._thread_safe_log(f"🎬 [{grp_idx+1}/{total_groups}] {group_name} ({n_files} file(s))")
                self._thread_safe_log(f"   Style: {style}  |  Output: {out_dir}")
                for item in items:
                    self._update_project_status(item, "⏳ Running...", "")

                # Create pipeline with all files in this folder group
                scene_max = self.scene_max_spin.value()
                pipeline = VideoPipeline(
                    api_client=self.api_client,
                    srt_paths=srt_paths,
                    output_dir=out_dir,
                    style_name=style,
                    styles_dir=self.styles_dir,
                    tier_step2="Pro",
                    tier_step13=tier,
                    threads=threads,
                    scene_max=scene_max,
                    constraints=constraints,
                    log_api=log_api,
                    on_log=self._thread_safe_log,
                    on_step_updated=self._thread_safe_step,
                    on_all_failed=self.on_all_failed,
                )
                self.pipeline = pipeline
                pipeline.run()

                if pipeline.state == PipelineState.DONE:
                    n = len(pipeline.final_prompts)
                    for item in items:
                        self._update_project_status(item, "✅ Done", f"{n} prompts")
                    success_count += 1
                elif pipeline.state == PipelineState.STOPPED:
                    for item in items:
                        self._update_project_status(item, "⏹ Stopped", "")
                    break
                else:
                    for item in items:
                        self._update_project_status(item, "❌ Error", "")

            self._thread_safe_log(f"\n{'='*50}")
            self._thread_safe_log(f"🎬 Batch Complete: {success_count}/{total_groups} succeeded")
            self._sig_func.emit(lambda: self._on_batch_finished(success_count, total_groups))

        threading.Thread(target=_run, daemon=True).start()


    def _stop_pipeline(self):
        self._is_processing = False
        if self.pipeline:
            self.pipeline.stop()
            self.log_section.log("[STOP] Pipeline stop requested...")

    def _on_batch_finished(self, success: int, total: int):
        self._set_processing_state(False)
        if success == total:
            self.log_section.set_status(f"Done ✅ ({success}/{total})", "#16A34A")
        elif success > 0:
            self.log_section.set_status(f"Partial ⚠ ({success}/{total})", "#FF9800")
        else:
            self.log_section.set_status(f"Failed ❌ ({success}/{total})", "#DC2626")

    def _rename_ref_images(self):
        """Rename reference images to match labels from Excel Reference Images sheet."""
        # 1. Find Excel from Output dir
        out_dir = self.output_edit.text().strip()
        if not out_dir or not os.path.isdir(out_dir):
            self.log_section.log("[RENAME] ❌ Output dir not set or invalid!")
            return

        xlsx_path = None
        for f in os.listdir(out_dir):
            if f.endswith("_video_prompts.xlsx"):
                xlsx_path = os.path.join(out_dir, f)
                break

        if not xlsx_path:
            self.log_section.log(f"[RENAME] ❌ No _video_prompts.xlsx found in Output dir!")
            return

        # 2. Get images folder from Images input
        images_dir = self.images_edit.text().strip()
        if not images_dir or not os.path.isdir(images_dir):
            self.log_section.log("[RENAME] ❌ Images folder not set or invalid!")
            return

        # 3. Read Reference Images sheet
        try:
            from openpyxl import load_workbook
            wb = load_workbook(xlsx_path, read_only=True)
            ws = wb["Reference Images"]
            label_map = {}  # {row_number: (type, label)}
            for row in ws.iter_rows(min_row=2, values_only=True):
                if row and len(row) >= 3 and row[0] is not None:
                    num = int(row[0])
                    ref_type = str(row[1] or "").strip()
                    label = str(row[2] or "").strip()
                    if label:
                        label_map[num] = (ref_type, label)
            wb.close()
        except Exception as e:
            self.log_section.log(f"[RENAME] ❌ Cannot read Excel: {e}")
            return

        if not label_map:
            self.log_section.log("[RENAME] ❌ No labels found in Reference Images sheet!")
            return

        self.log_section.log(f"[RENAME] Read {len(label_map)} labels from: {os.path.basename(xlsx_path)}")
        self.log_section.log(f"[RENAME] Images folder: {images_dir}")

        # 4. Create subfolder in Output dir and copy + rename
        import shutil
        ref_dir = os.path.join(out_dir, "ref_images")
        os.makedirs(ref_dir, exist_ok=True)

        IMAGE_EXTS = {'.png', '.jpg', '.jpeg', '.webp', '.gif', '.bmp'}
        copied = 0
        skipped = 0
        for f in sorted(os.listdir(images_dir)):
            ext = os.path.splitext(f)[1].lower()
            if ext not in IMAGE_EXTS:
                continue
            # Extract leading number
            match = re.match(r'^(\d+)', f)
            if not match:
                continue
            num = int(match.group(1))
            if num not in label_map:
                self.log_section.log(f"[RENAME] ⚠ #{num} not in label map, skipping: {f}")
                skipped += 1
                continue

            ref_type, label = label_map[num]
            safe_label = re.sub(r'[<>:"/\\|?*]', '_', label)
            new_name = f"{safe_label}{ext}"
            src_path = os.path.join(images_dir, f)
            dst_path = os.path.join(ref_dir, new_name)

            if os.path.exists(dst_path):
                self.log_section.log(f"[RENAME] ⏭ Already exists: {new_name}")
                skipped += 1
                continue

            try:
                shutil.copy2(src_path, dst_path)
                self.log_section.log(f"[RENAME] ✅ {f} → ref_images/{new_name}")
                copied += 1
            except Exception as e:
                self.log_section.log(f"[RENAME] ❌ Error copying {f}: {e}")

        self.log_section.log(f"[RENAME] Done: {copied} copied, {skipped} skipped → {ref_dir}")

    def _open_output(self):
        out = self.output_edit.text().strip()
        if out and os.path.isdir(out):
            os.startfile(out)
        else:
            # Try to open output of selected project
            for item in self.tree.selectedItems():
                srt_path = item.data(0, Qt.ItemDataRole.UserRole)
                if srt_path:
                    out_dir = self._resolve_output_dir(srt_path)
                    if os.path.isdir(out_dir):
                        os.startfile(out_dir)
                        return
            self.log_section.log("[WARN] Output directory not found!")
===
"""
Video Prompt Tab UI — PyQt6
Tab for the Video Prompt Pipeline: SRT → Sequences → Scenes → Final Prompts.
Supports multi-SRT project management (scan folder / add individual files).
Pipeline Progress is logged only (no visual panel).
"""
import os
import re
import json
import threading

from PyQt6.QtWidgets import (
    QWidget, QVBoxLayout, QHBoxLayout, QLabel, QPushButton,
    QLineEdit, QComboBox, QCheckBox, QFileDialog, QSpinBox,
    QFrame, QTreeWidget, QTreeWidgetItem, QHeaderView,
)
from PyQt6.QtGui import QFont
from PyQt6.QtCore import Qt, pyqtSignal

from core.api_client import APIClient
from core.prompt_generator import scan_styles_folder
from core.video_pipeline import VideoPipeline, PipelineState
from ui.searchable_combo import SearchableCombo
from ui.log_section import LogSection


class VideoPromptTab(QWidget):
    """Tab for Video Prompt Pipeline — multi-SRT project management."""

    _sig_log = pyqtSignal(str)
    _sig_step = pyqtSignal(str, str, str)  # key, status, message
    _sig_func = pyqtSignal(object)

    def __init__(self, parent=None, app_dir: str = "", api_client: APIClient = None,
                 on_all_failed=None):
        super().__init__(parent)
        self.app_dir = app_dir
        self.styles_dir = os.path.join(app_dir, "video_styles")
        os.makedirs(self.styles_dir, exist_ok=True)
        self.api_client = api_client
        self.on_all_failed = on_all_failed
        self.config_file = os.path.join(app_dir, "video_config.json")
        self.pipeline: VideoPipeline = None
        self._known_paths = set()
        self._is_processing = False

        self._build_ui()
        self._load_config()

        # Connect signals
        self._sig_log.connect(self._on_sig_log)
        self._sig_step.connect(self._on_sig_step)
        self._sig_func.connect(self._on_sig_func)

    # ── Signal handlers (main thread) ──

    def _on_sig_log(self, msg: str):
        try:
            self.log_section.log(msg)
        except Exception:
            pass

    def _on_sig_step(self, key: str, status: str, message: str):
        """Step updates → log only."""
        icons = {
            "pending": "⬜", "running": "⏳", "done": "✅",
            "failed": "❌", "skipped": "⏭",
        }
        icon = icons.get(status, "⬜")
        self._on_sig_log(f"  {icon} {key.upper()}: {message}" if message else f"  {icon} {key.upper()}: {status}")

    def _on_sig_func(self, fn):
        try:
            fn()
        except Exception:
            pass

    # ── Build UI ──

    def _make_btn(self, text, color, hover, min_w=60, h=28, font_size=10):
        btn = QPushButton(text)
        btn.setMinimumWidth(min_w)
        btn.setFixedHeight(h)
        btn.setStyleSheet(f"""
            QPushButton {{
                background-color: {color}; color: white;
                border-radius: 4px; padding: 2px 8px;
                font-size: {font_size}px; font-weight: bold;
            }}
            QPushButton:hover {{ background-color: {hover}; }}
        """)
        return btn

    def _build_ui(self):
        layout = QVBoxLayout(self)
        layout.setContentsMargins(10, 8, 10, 8)
        layout.setSpacing(4)

        # ═══════════ CONFIG SECTION ═══════════
        config_frame = QFrame()
        config_frame.setStyleSheet("QFrame { border: 1px solid #334155; border-radius: 6px; padding: 6px; }")
        config_layout = QVBoxLayout(config_frame)
        config_layout.setSpacing(4)

        # Row 1: Output + Tier + Threads
        r1 = QHBoxLayout()
        r1.setSpacing(6)

        lbl_out = QLabel("📁 Output:")
        lbl_out.setFont(QFont("Segoe UI", 11))
        r1.addWidget(lbl_out)
        self.output_edit = QLineEdit()
        self.output_edit.setPlaceholderText("Output folder (auto-derived if empty)...")
        self.output_edit.setFixedHeight(28)
