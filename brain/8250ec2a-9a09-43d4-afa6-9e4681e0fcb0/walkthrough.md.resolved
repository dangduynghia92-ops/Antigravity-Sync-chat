        r2.addWidget(self.style_combo)

        btn_refresh = self._make_btn("Refresh", "#475569", "#64748B", 65)
        btn_refresh.clicked.connect(self._refresh_styles)
        r2.addWidget(btn_refresh)

        btn_open = self._make_btn("Open", "#475569", "#64748B", 50)
        btn_open.clicked.connect(lambda: os.startfile(self.styles_dir) if os.path.isdir(self.styles_dir) else None)
        r2.addWidget(btn_open)

