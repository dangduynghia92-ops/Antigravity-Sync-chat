        btn_img = QPushButton("...")
        btn_img.setFixedSize(30, 28)
        btn_img.setStyleSheet("QPushButton { background-color: #475569; border-radius: 4px; font-weight: bold; } QPushButton:hover { background-color: #64748B; }")
        btn_img.clicked.connect(self._browse_images)
        r1b.addWidget(btn_img)
        r1b.addStretch()
