        "servant": "Head: ... Upper: ... Lower: ... Feet: ... Acc: ..."
      }},
      "crowd_archetypes": {{
        "soldier": [
          "Type1 — Head: ... Upper: ... Lower: ... Feet: ... Acc: ...",
          "Type2 — Head: ... Upper: ... Lower: ... Feet: ... Acc: ...",
          "Type3 — Head: ... Upper: ... Lower: ... Feet: ... Acc: ..."
