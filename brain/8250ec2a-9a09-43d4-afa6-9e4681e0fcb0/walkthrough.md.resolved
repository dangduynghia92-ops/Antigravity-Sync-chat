    # ── Project Management ──

    def _scan_folder(self):
        folder = QFileDialog.getExistingDirectory(self, "Select folder containing SRT + TXT files")
        if not folder:
            return

        # Step 1: Scan all .srt files
        srt_files = {}  # basename -> full_path
        for root, dirs, files in os.walk(folder):
            for f in sorted(files, key=lambda x: [int(c) if c.isdigit() else c.lower() for c in re.split(r'(\d+)', x)]):
                if f.lower().endswith('.srt'):
                    full_path = os.path.join(root, f)
                    if full_path in self._known_paths:
                        continue
                    basename = os.path.splitext(f)[0]
                    srt_files[basename] = full_path

        if not srt_files:
            self.log_section.log("[SCAN] No SRT files found")
            return

        # Step 2: For each SRT, look for matching TXT
        total = 0
        for basename, srt_path in srt_files.items():
            srt_dir = os.path.dirname(srt_path)
            txt_path = os.path.join(srt_dir, f"{basename}.txt")
            has_txt = os.path.exists(txt_path)

            # Create tree row
            item = QTreeWidgetItem(self.tree, [
                basename,
                "✅ .srt",
                "✅ .txt" if has_txt else "❌ missing",
                "Ready" if has_txt else "Missing TXT",
            ])
            # Store both paths in UserRole
            item.setData(0, Qt.ItemDataRole.UserRole, {
                "srt_path": srt_path,
                "txt_path": txt_path if has_txt else None,
                "basename": basename,
            })
            self._known_paths.add(srt_path)

            # Highlight missing TXT
            if not has_txt:
                for col in range(4):
                    item.setForeground(col, Qt.GlobalColor.red)

            total += 1

        self.log_section.log(f"[SCAN] Added {total} SRT files")

    def _add_srt_files(self):
        files, _ = QFileDialog.getOpenFileNames(
            self, "Select SRT file(s)", "",
            "SRT files (*.srt);;All files (*.*)"
        )
        for path in files:
            if path in self._known_paths:
                continue
            basename = os.path.splitext(os.path.basename(path))[0]
            srt_dir = os.path.dirname(path)
            txt_path = os.path.join(srt_dir, f"{basename}.txt")
            has_txt = os.path.exists(txt_path)

            item = QTreeWidgetItem(self.tree, [
                basename,
                "✅ .srt",
                "✅ .txt" if has_txt else "❌ missing",
                "Ready" if has_txt else "Missing TXT",
            ])
            item.setData(0, Qt.ItemDataRole.UserRole, {
                "srt_path": path,
                "txt_path": txt_path if has_txt else None,
                "basename": basename,
            })
            self._known_paths.add(path)
            if not has_txt:
                for col in range(4):
                    item.setForeground(col, Qt.GlobalColor.red)

    def _find_or_create_folder(self, dir_name: str) -> QTreeWidgetItem:
        for i in range(self.tree.topLevelItemCount()):
            item = self.tree.topLevelItem(i)
            if item.text(0) == dir_name and item.data(0, Qt.ItemDataRole.UserRole) is None:
                return item
        folder_item = QTreeWidgetItem(self.tree, [dir_name, "", "", ""])
        folder_item.setFont(0, QFont("Segoe UI", 10, QFont.Weight.Bold))
        return folder_item

    def _add_file_node(self, parent, filename: str, full_path: str):
        """Legacy add file node — stores path as string for backward compat."""
        if full_path in self._known_paths:
            return
        basename = os.path.splitext(filename)[0]
        if parent:
            item = QTreeWidgetItem(parent, [basename, "", "", "Pending"])
        else:
            item = QTreeWidgetItem(self.tree, [basename, "", "", "Pending"])
        item.setData(0, Qt.ItemDataRole.UserRole, full_path)
        self._known_paths.add(full_path)

    def _update_folder_summary(self, folder_item: QTreeWidgetItem):
        count = folder_item.childCount()
        folder_item.setText(3, f"{count} files")

    def _remove_selected(self):
        for item in self.tree.selectedItems():
            self._remove_item_and_track(item)

    def _remove_item_and_track(self, item: QTreeWidgetItem):
        path = item.data(0, Qt.ItemDataRole.UserRole)
        if path:
            self._known_paths.discard(path)
        # Remove children too
        for i in range(item.childCount()):
            child = item.child(i)
            if child:
                cp = child.data(0, Qt.ItemDataRole.UserRole)
                if cp:
                    self._known_paths.discard(cp)
        parent = item.parent()
        if parent:
            parent.removeChild(item)
            self._update_folder_summary(parent)
        else:
            idx = self.tree.indexOfTopLevelItem(item)
            if idx >= 0:
                self.tree.takeTopLevelItem(idx)

    def _clear_all(self):
        self.tree.clear()
        self._known_paths.clear()

    def _iter_file_items(self):
        """Iterate all file items (leaf nodes with data)."""
        for i in range(self.tree.topLevelItemCount()):
            item = self.tree.topLevelItem(i)
            if item.data(0, Qt.ItemDataRole.UserRole):
                yield item
            for j in range(item.childCount()):
                child = item.child(j)
                if child and child.data(0, Qt.ItemDataRole.UserRole):
                    yield child

    def _get_projects(self, selected_only=False) -> list:
        """Get list of projects [{name, srt_path, txt_path, item} ...]."""
        projects = []
        items = self.tree.selectedItems() if selected_only else list(self._iter_file_items())
        for item in items:
            data = item.data(0, Qt.ItemDataRole.UserRole)
            if not data:
                continue
            # New format: data is a dict with srt_path, txt_path
            if isinstance(data, dict):
                projects.append({
                    "name": data.get("basename", item.text(0)),
                    "srt_path": data["srt_path"],
                    "txt_path": data.get("txt_path"),
                    "item": item,
                })
            else:
                # Legacy: data is a string path
                projects.append({
                    "name": item.text(0),
                    "srt_path": data,
                    "txt_path": None,
                    "item": item,
                })
        return projects

    def _update_project_status(self, item: QTreeWidgetItem, status: str, progress: str = ""):
        self._sig_func.emit(lambda i=item, s=status: i.setText(3, s))

    # ── Config ──

    def _refresh_styles(self):
        styles = scan_styles_folder(self.styles_dir)
        if styles:
            self.style_combo.configure_values(styles)
        else:
            self.style_combo.configure_values(["(no styles)"])

    def _browse_output(self):
        path = QFileDialog.getExistingDirectory(self, "Select Output Directory")
        if path:
            self.output_edit.setText(path)

    def _browse_images(self):
        start = self.images_edit.text().strip() or self.output_edit.text().strip() or ""
        path = QFileDialog.getExistingDirectory(self, "Select Reference Images Folder", start)
        if path:
            self.images_edit.setText(path)

    def _save_config(self):
        config = {
            "output_dir": self.output_edit.text(),
            "images_dir": self.images_edit.text(),
            "style": self.style_combo.get(),
            "tier": self.tier_combo.currentText(),
            "threads": self.threads_spin.value(),
            "scene_max": self.scene_max_spin.value(),
            "log_api": self.log_api_var.isChecked(),
            "constraint_safety": self.safety_var.isChecked(),
            "constraint_quality": self.quality_var.isChecked(),
            "constraint_historical": self.historical_var.isChecked(),
        }
        try:
            with open(self.config_file, 'w', encoding='utf-8') as f:
                json.dump(config, f, indent=4, ensure_ascii=False)
            self.log_section.log("[CONFIG] ✅ Saved video_config.json")
        except Exception as e:
            self.log_section.log(f"[CONFIG] ❌ Save failed: {e}")

    def _load_config(self):
        if not os.path.exists(self.config_file):
            return
        try:
            with open(self.config_file, 'r', encoding='utf-8') as f:
                config = json.load(f)
            self.output_edit.setText(config.get("output_dir", ""))
            self.images_edit.setText(config.get("images_dir", ""))
            style = config.get("style", "")
            if style:
                self.style_combo.set(style)
            self.tier_combo.setCurrentText(config.get("tier", "Flash"))
            self.threads_spin.setValue(config.get("threads", 2))
            self.scene_max_spin.setValue(config.get("scene_max", 6))
            self.log_api_var.setChecked(config.get("log_api", False))
            self.safety_var.setChecked(config.get("constraint_safety", True))
            self.quality_var.setChecked(config.get("constraint_quality", True))
            self.historical_var.setChecked(config.get("constraint_historical", True))
        except Exception:
            pass

    # ── Pipeline Actions ──

    def _thread_safe_log(self, msg: str):
        self._sig_log.emit(msg)

    def _thread_safe_step(self, key: str, step_status):
        self._sig_step.emit(key, step_status.status, step_status.message)

    def _set_processing_state(self, is_processing: bool):
        self._is_processing = is_processing
        self.btn_run.setEnabled(not is_processing)
        self.btn_run_sel.setEnabled(not is_processing)
        self.btn_stop.setEnabled(is_processing)

    def _resolve_output_dir(self, srt_path: str) -> str:
        """Get output dir: use global setting, or derive from SRT path."""
        out = self.output_edit.text().strip()
        if out:
            # Per-SRT subfolder inside global output
            base = os.path.splitext(os.path.basename(srt_path))[0]
            sub = os.path.join(out, base)
            os.makedirs(sub, exist_ok=True)
            return sub
        else:
            # Default: video_prompt/ next to SRT file
            sub = os.path.join(os.path.dirname(srt_path), "video_prompt")
            os.makedirs(sub, exist_ok=True)
            return sub

    def _run_all(self):
        self._run_projects(self._get_projects(selected_only=False))

    def _run_selected(self):
        self._run_projects(self._get_projects(selected_only=True))

    def _run_projects(self, projects: list):
        if not projects:
            self.log_section.log("[WARN] No SRT files to process!")
            return

        # Validate style
        default_style = self.style_combo.get()
        if not default_style or default_style == "(no styles)":
            self.log_section.log("[WARN] Please select a style first!")
            return

        self._set_processing_state(True)
        self.log_section.set_status("Running...", "#FF9800")
        self.pipeline = None  # Will track current pipeline for stop

        tier = self.tier_combo.currentText()
        threads = self.threads_spin.value()
        log_api = self.log_api_var.isChecked()
        constraints = {
            "safety": self.safety_var.isChecked(),
            "quality": self.quality_var.isChecked(),
            "historical": self.historical_var.isChecked(),
        }

        def _run():
          try:
            # Group projects by parent folder for multi-chapter merge
            folder_groups = {}  # folder_path -> [projects]
            for proj in projects:
                folder = os.path.dirname(proj["srt_path"])
                folder_groups.setdefault(folder, []).append(proj)

            total_groups = len(folder_groups)
            success_count = 0

            for grp_idx, (folder, group_projects) in enumerate(folder_groups.items()):
                if self._is_processing is False:
                    break

                # Sort files by natural numeric order (Chapter 1, 2, ... 10, 11)
                def _natural_key(p):
                    import re as _re
                    return [int(c) if c.isdigit() else c.lower()
                            for c in _re.split(r'(\d+)', p["name"])]
                group_projects.sort(key=_natural_key)
                srt_paths = [p["srt_path"] for p in group_projects]
                items = [p["item"] for p in group_projects]

                # Build chapter_pairs if ALL have txt_path
                chapter_pairs = []
                has_all_txt = True
                for p in group_projects:
                    if p.get("txt_path"):
                        chapter_pairs.append({"srt_path": p["srt_path"], "txt_path": p["txt_path"]})
                    else:
                        has_all_txt = False

                if not has_all_txt:
                    # Validation: block if any TXT is missing
                    missing = [p["name"] for p in group_projects if not p.get("txt_path")]
                    self._thread_safe_log(f"\n❌ Cannot run: {len(missing)} chapter(s) missing TXT pair:")
                    for m in missing[:5]:
                        self._thread_safe_log(f"   - {m}")
                    for item in items:
                        self._update_project_status(item, "❌ Missing TXT")
                    continue

                style = group_projects[0].get("style") or default_style

                # Output directory: use first file's folder or global output
                out_dir = self._resolve_output_dir(srt_paths[0])

                n_files = len(srt_paths)
                group_name = os.path.basename(folder) if n_files > 1 else group_projects[0]["name"]

                self._thread_safe_log(f"\n{'='*50}")
                self._thread_safe_log(f"🎬 [{grp_idx+1}/{total_groups}] {group_name} ({n_files} file(s))")
                self._thread_safe_log(f"   Style: {style}  |  Output: {out_dir}")
                for item in items:
                    self._update_project_status(item, "⏳ Running...")

                # Create pipeline with all files in this folder group
                scene_max = self.scene_max_spin.value()
                pipeline = VideoPipeline(
                    api_client=self.api_client,
                    srt_paths=srt_paths,
                    chapter_pairs=chapter_pairs if has_all_txt else None,
                    output_dir=out_dir,
                    style_name=style,
                    styles_dir=self.styles_dir,
                    tier_pro="Pro",
                    tier_user=tier,
                    threads=threads,
                    scene_max=scene_max,
                    constraints=constraints,
                    log_api=log_api,
                    on_log=self._thread_safe_log,
                    on_step_updated=self._thread_safe_step,
                    on_all_failed=self.on_all_failed,
                )
                self.pipeline = pipeline
                pipeline.run()

                if pipeline.state == PipelineState.DONE:
                    n = len(pipeline.final_prompts)
                    for item in items:
                        self._update_project_status(item, "✅ Done", f"{n} prompts")
                    success_count += 1
                elif pipeline.state == PipelineState.STOPPED:
                    for item in items:
                        self._update_project_status(item, "⏹ Stopped", "")
                    break
                else:
                    for item in items:
                        self._update_project_status(item, "❌ Error", "")

            self._thread_safe_log(f"\n{'='*50}")
            self._thread_safe_log(f"🎬 Batch Complete: {success_count}/{total_groups} succeeded")
            self._sig_func.emit(lambda: self._on_batch_finished(success_count, total_groups))
          except Exception as e:
            import traceback
            self._thread_safe_log(f"\n❌ PIPELINE CRASH: {e}")
            self._thread_safe_log(traceback.format_exc())
            self._sig_func.emit(lambda: self._on_batch_finished(0, 1))

        threading.Thread(target=_run, daemon=True).start()


    def _stop_pipeline(self):
        self._is_processing = False
        if self.pipeline:
            self.pipeline.stop()
            self.log_section.log("[STOP] Pipeline stop requested...")

    def _on_batch_finished(self, success: int, total: int):
        self._set_processing_state(False)
        if success == total:
            self.log_section.set_status(f"Done ✅ ({success}/{total})", "#16A34A")
        elif success > 0:
            self.log_section.set_status(f"Partial ⚠ ({success}/{total})", "#FF9800")
        else:
            self.log_section.set_status(f"Failed ❌ ({success}/{total})", "#DC2626")

    def _rename_ref_images(self):
        """Rename reference images to match labels from Excel Reference Images sheet."""
        # 1. Find Excel from Output dir
        out_dir = self.output_edit.text().strip()
        if not out_dir or not os.path.isdir(out_dir):
            self.log_section.log("[RENAME] ❌ Output dir not set or invalid!")
            return

        xlsx_path = None
        for f in os.listdir(out_dir):
            if f.endswith("_video_prompts.xlsx"):
                xlsx_path = os.path.join(out_dir, f)
                break

        if not xlsx_path:
            self.log_section.log(f"[RENAME] ❌ No _video_prompts.xlsx found in Output dir!")
            return

        # 2. Get images folder from Images input
        images_dir = self.images_edit.text().strip()
        if not images_dir or not os.path.isdir(images_dir):
            self.log_section.log("[RENAME] ❌ Images folder not set or invalid!")
            return

        # 3. Read Reference Images sheet
        try:
            from openpyxl import load_workbook
            wb = load_workbook(xlsx_path, read_only=True)
            ws = wb["Reference Images"]
            label_map = {}  # {row_number: (type, label)}
            for row in ws.iter_rows(min_row=2, values_only=True):
                if row and len(row) >= 3 and row[0] is not None:
                    num = int(row[0])
                    ref_type = str(row[1] or "").strip()
                    label = str(row[2] or "").strip()
                    if label:
                        label_map[num] = (ref_type, label)
            wb.close()
        except Exception as e:
            self.log_section.log(f"[RENAME] ❌ Cannot read Excel: {e}")
            return

        if not label_map:
            self.log_section.log("[RENAME] ❌ No labels found in Reference Images sheet!")
            return

        self.log_section.log(f"[RENAME] Read {len(label_map)} labels from: {os.path.basename(xlsx_path)}")
        self.log_section.log(f"[RENAME] Images folder: {images_dir}")

        # 4. Create subfolder in Output dir and copy + rename
        import shutil
        ref_dir = os.path.join(out_dir, "ref_images")
        os.makedirs(ref_dir, exist_ok=True)

        IMAGE_EXTS = {'.png', '.jpg', '.jpeg', '.webp', '.gif', '.bmp'}
        copied = 0
        skipped = 0
        for f in sorted(os.listdir(images_dir)):
            ext = os.path.splitext(f)[1].lower()
            if ext not in IMAGE_EXTS:
                continue
            # Extract leading number
            match = re.match(r'^(\d+)', f)
            if not match:
                continue
            num = int(match.group(1))
            if num not in label_map:
                self.log_section.log(f"[RENAME] ⚠ #{num} not in label map, skipping: {f}")
                skipped += 1
                continue

            ref_type, label = label_map[num]
            safe_label = re.sub(r'[<>:"/\\|?*]', '_', label)
            new_name = f"{safe_label}{ext}"
            src_path = os.path.join(images_dir, f)
            dst_path = os.path.join(ref_dir, new_name)

            if os.path.exists(dst_path):
                self.log_section.log(f"[RENAME] ⏭ Already exists: {new_name}")
                skipped += 1
                continue

            try:
                shutil.copy2(src_path, dst_path)
                self.log_section.log(f"[RENAME] ✅ {f} → ref_images/{new_name}")
                copied += 1
            except Exception as e:
                self.log_section.log(f"[RENAME] ❌ Error copying {f}: {e}")

        self.log_section.log(f"[RENAME] Done: {copied} copied, {skipped} skipped → {ref_dir}")

    def _open_output(self):
        out = self.output_edit.text().strip()
        if out and os.path.isdir(out):
            os.startfile(out)
        else:
            # Try to open output of selected project
            for item in self.tree.selectedItems():
                srt_path = item.data(0, Qt.ItemDataRole.UserRole)
                if srt_path:
                    out_dir = self._resolve_output_dir(srt_path)
                    if os.path.isdir(out_dir):
                        os.startfile(out_dir)
                        return
            self.log_section.log("[WARN] Output directory not found!")
```

- **Tree columns**: `[Name, Style, Status, Progress]` → `[Chapter, SRT, TXT, Status]`
- **Scan logic**: Scans `.srt` files first, auto-pairs `.txt` by matching basename. Missing TXT shown in red.
- **Run validation**: Blocks pipeline if any chapter missing TXT pair
- **Removed**: Apply Style / Apply All buttons (style set via global combo)
- **Data format**: Tree items now store `{"srt_path", "txt_path", "basename"}` dict

## Data Flow

```
User scans folder with SRT + TXT files
    ↓
UI: Shows [Chapter | ✅ SRT | ✅/❌ TXT | Status]
    ↓
User clicks Run → validation checks all pairs
    ↓
Step 0 Phase A (per-chapter):
    SRT cues + TXT text → LLM → corrected text → code verify
    → save to aligned/ch_XX.srt
    ↓
Step 0 Phase B:
    Parse aligned/*.srt → sentences (punctuation now exists)
    ↓
Steps 1-5: unchanged
```

## Testing
- All 3 files pass syntax check ✅
- Awaiting runtime test with Saladin ch_01 SRT+TXT pair
