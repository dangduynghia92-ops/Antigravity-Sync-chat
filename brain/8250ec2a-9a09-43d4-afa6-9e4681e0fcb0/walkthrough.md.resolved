        self.tree.setSelectionMode(QTreeWidget.SelectionMode.ExtendedSelection)

        h = self.tree.header()
        h.setStretchLastSection(False)
        h.setSectionResizeMode(0, QHeaderView.ResizeMode.Stretch)
