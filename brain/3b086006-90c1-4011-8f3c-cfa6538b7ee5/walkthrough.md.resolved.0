        self._spin_threads = QSpinBox()
        self._spin_threads.setRange(1, 8)
        self._spin_threads.setValue(3)
        self._spin_threads.setSizePolicy(QSizePolicy.Policy.Fixed, QSizePolicy.Policy.Fixed)
        rw_row1.addWidget(self._spin_threads)
        rw_row1.addSpacing(4)

        self._lbl_country = QLabel("Country:")
        rw_row1.addWidget(self._lbl_country)
        self._combo_country = QComboBox()
        self._combo_country.addItems(["US", "EU"])
        self._combo_country.setSizePolicy(QSizePolicy.Policy.Fixed, QSizePolicy.Policy.Fixed)
        rw_row1.addWidget(self._combo_country)
        self._lbl_country.setVisible(False)
        self._combo_country.setVisible(False)
        rw_row1.addStretch()
        main_layout.addLayout(rw_row1)

        # ── Row 3: Word count ──
        wc_row = QHBoxLayout()
        wc_row.setSpacing(4)

        def _make_wc_pair(label, default_min, default_max):
            wc_row.addWidget(QLabel(label))
            sp_min = QSpinBox()
            sp_min.setRange(0, 5000)
            sp_min.setValue(default_min)
            sp_min.setSingleStep(100)
            sp_min.setSpecialValueText("—")
            sp_min.setSizePolicy(QSizePolicy.Policy.Fixed, QSizePolicy.Policy.Fixed)
            wc_row.addWidget(sp_min)
            wc_row.addWidget(QLabel("~"))
            sp_max = QSpinBox()
            sp_max.setRange(0, 5000)
            sp_max.setValue(default_max)
            sp_max.setSingleStep(100)
            sp_max.setSpecialValueText("—")
            sp_max.setSizePolicy(QSizePolicy.Policy.Fixed, QSizePolicy.Policy.Fixed)
            wc_row.addWidget(sp_max)
            return sp_min, sp_max

        # ── Chapters range ──
        wc_row.addWidget(QLabel("Ch:"))
        self._ch_min = QSpinBox()
        self._ch_min.setRange(0, 50)
        self._ch_min.setValue(0)
        self._ch_min.setSpecialValueText("—")
        self._ch_min.setSizePolicy(QSizePolicy.Policy.Fixed, QSizePolicy.Policy.Fixed)
        wc_row.addWidget(self._ch_min)
        wc_row.addWidget(QLabel("~"))
        self._ch_max = QSpinBox()
        self._ch_max.setRange(0, 50)
        self._ch_max.setValue(0)
        self._ch_max.setSpecialValueText("—")
        self._ch_max.setSizePolicy(QSizePolicy.Policy.Fixed, QSizePolicy.Policy.Fixed)
        wc_row.addWidget(self._ch_max)
        wc_row.addSpacing(10)

        self._wc_open_min, self._wc_open_max = _make_wc_pair("Open:", 0, 0)
        wc_row.addSpacing(10)
        self._wc_body_min, self._wc_body_max = _make_wc_pair("Body:", 0, 0)
        wc_row.addSpacing(10)
        self._wc_end_min, self._wc_end_max = _make_wc_pair("End:", 0, 0)
        wc_row.addStretch()
        main_layout.addLayout(wc_row)

        # ── Row 4: Actions ──
        btn_row = QHBoxLayout()
        btn_row.setSpacing(4)

        btn_scan = QPushButton("📂 Scan Folder")
        btn_scan.setToolTip("Scan a folder for .txt chapter files")
        btn_scan.clicked.connect(self._scan_folder)
        btn_row.addWidget(btn_scan)

        btn_add = QPushButton("+ Add")
        btn_add.setToolTip("Add individual .txt file(s)")
        btn_add.clicked.connect(self._add_single_file)
        btn_row.addWidget(btn_add)

        self._btn_rewrite = QPushButton("▶ Rewrite")
        self._btn_rewrite.setProperty("class", "btn-accent")
        self._btn_rewrite.clicked.connect(self._do_rewrite)
        btn_row.addWidget(self._btn_rewrite)

        self._btn_new_content = QPushButton("✦ New Content")
        self._btn_new_content.setProperty("class", "btn-success")
        self._btn_new_content.setToolTip(
            "Research a topic from scratch → Generate blueprint → Write new script\n"
            "No source files needed — just enter a topic name."
        )
        self._btn_new_content.clicked.connect(self._do_new_content)
        btn_row.addWidget(self._btn_new_content)

        self._btn_rech = QPushButton("🔄 Re-ch")
        self._btn_rech.setToolTip("Rewrite checked chapter(s) using existing pipeline data")
        self._btn_rech.clicked.connect(self._do_rewrite_chapter)
        btn_row.addWidget(self._btn_rech)

        self._btn_stop = QPushButton("■ Stop")
        self._btn_stop.clicked.connect(self._do_stop)
        btn_row.addWidget(self._btn_stop)

        self._btn_retry = QPushButton("🔄 Retry")
        self._btn_retry.setToolTip("Retry failed/error/stopped folders")
        self._btn_retry.clicked.connect(self._do_retry)
        btn_row.addWidget(self._btn_retry)

        self._btn_save = QPushButton("Save Config")
        self._btn_save.clicked.connect(self._save_config)
        btn_row.addWidget(self._btn_save)

        self._chk_excel_update = QCheckBox("📊 Excel")
        self._chk_excel_update.setChecked(True)
        self._chk_excel_update.setToolTip("Update Rewrite status in Excel after completion")
        btn_row.addWidget(self._chk_excel_update)

        self._chk_transitions = QCheckBox("↔ Transitions")
        self._chk_transitions.setChecked(True)
        self._chk_transitions.setToolTip(
            "Add bridge sentences between chapters.\n"
            "OFF = open each chapter directly with topic name (Top/List only)"
        )
        btn_row.addWidget(self._chk_transitions)

        self._chk_cut_video = QCheckBox("🎬 Cut Video")
        self._chk_cut_video.setChecked(True)
        self._chk_cut_video.setToolTip(
            "After rewrite, download YouTube video and cut into chapter clips.\n"
            "Requires YouTube URL in merge file. Skips if already cut."
        )
        btn_row.addWidget(self._chk_cut_video)

        self._chk_google_check = QCheckBox("🔍 Google Check")
        self._chk_google_check.setChecked(True)
        self._chk_google_check.setToolTip(
            "Use Google Search to verify facts and enrich data.\n"
            "Firearms: also looks up prices. Mystery: verifies sources & dates.\n"
            "Requires Gemini API key(s) in header bar."
        )
        btn_row.addWidget(self._chk_google_check)

        self._chk_auto_patch = QCheckBox("🩹 Auto-Patch")
        self._chk_auto_patch.setChecked(False)
        self._chk_auto_patch.setToolTip(
            "Auto-fix critical/major cross-chapter issues after review.\n"
            "OFF = review only (log issues, no changes).\n"
            "ON = automatically patch chapters (may alter tone)."
        )
        btn_row.addWidget(self._chk_auto_patch)

        btn_row.addStretch()

        self._lbl_stats = QLabel("")
        btn_row.addWidget(self._lbl_stats)
        main_layout.addLayout(btn_row)

        # ── Split: Folder list (left) + Chapter tree (right) ──
        from PyQt6.QtWidgets import QSplitter
        self._splitter = QSplitter(Qt.Orientation.Horizontal)

        # Folder list (left)
        self._folder_tree = QTreeWidget()
        self._folder_tree.setHeaderLabels(["#", "Folder", "Status", "Progress"])
        self._folder_tree.setColumnCount(4)
        jh = self._folder_tree.header()
        jh.setStretchLastSection(False)
        jh.setSectionResizeMode(0, QHeaderView.ResizeMode.Fixed)
        jh.resizeSection(0, 30)
        jh.setSectionResizeMode(1, QHeaderView.ResizeMode.Stretch)
        for c in (2, 3):
            jh.setSectionResizeMode(c, QHeaderView.ResizeMode.ResizeToContents)
        self._folder_tree.setRootIsDecorated(False)
        self._folder_tree.setAlternatingRowColors(True)
        self._folder_tree.currentItemChanged.connect(self._on_folder_selected)
        self._folder_tree.clicked.connect(lambda: setattr(self, '_last_active_panel', self._folder_tree))
        self._folder_tree.setSelectionMode(QTreeWidget.SelectionMode.ExtendedSelection)
        self._folder_tree.setContextMenuPolicy(Qt.ContextMenuPolicy.CustomContextMenu)
        self._folder_tree.customContextMenuRequested.connect(self._on_folder_tree_context_menu)
        self._splitter.addWidget(self._folder_tree)

        # Chapter tree (right)
        self._tree = QTreeWidget()
        self._tree.setHeaderLabels(["Chapter", "Status", "Progress"])
        self._tree.setColumnCount(3)
        header = self._tree.header()
        header.setStretchLastSection(False)
        header.setSectionResizeMode(0, QHeaderView.ResizeMode.Stretch)
        for c in (1, 2):
            header.setSectionResizeMode(c, QHeaderView.ResizeMode.ResizeToContents)
        self._tree.setRootIsDecorated(False)
        self._tree.setAlternatingRowColors(True)
        self._tree.itemChanged.connect(self._on_item_changed)
        self._tree.clicked.connect(lambda: setattr(self, '_last_active_panel', self._tree))
        self._tree.setSelectionMode(QTreeWidget.SelectionMode.ExtendedSelection)
        self._tree.setContextMenuPolicy(Qt.ContextMenuPolicy.CustomContextMenu)
        self._tree.customContextMenuRequested.connect(self._on_chapter_tree_context_menu)
        self._propagating = False
        self._last_active_panel = self._tree  # default
        self._splitter.addWidget(self._tree)

        self._splitter.setSizes([350, 650])  # 35/65
        main_layout.addWidget(self._splitter, 1)

        # ── Row 5: Tree management buttons (below splitter) ──
        tree_btn_row = QHBoxLayout()
        tree_btn_row.setSpacing(4)

        self._btn_open = QPushButton("📂 Open")
        self._btn_open.clicked.connect(self._open_output_folder)
        tree_btn_row.addWidget(self._btn_open)

        self._btn_clear = QPushButton("Clear")
        self._btn_clear.clicked.connect(self._clear_tree)
        tree_btn_row.addWidget(self._btn_clear)

        btn_remove = QPushButton("Remove")
        btn_remove.setToolTip("Remove checked chapters from list")
        btn_remove.clicked.connect(self._remove_checked)
        tree_btn_row.addWidget(btn_remove)

        self._btn_all = QPushButton("All")
        self._btn_all.clicked.connect(self._select_all)
        tree_btn_row.addWidget(self._btn_all)

        self._btn_none = QPushButton("None")
        self._btn_none.clicked.connect(self._deselect_all)
        tree_btn_row.addWidget(self._btn_none)

        self._btn_resume = QPushButton("▶ Resume")
        self._btn_resume.setToolTip(
            "Resume an interrupted pipeline from its last checkpoint.\n"
            "Set Output path to the existing output folder first."
        )
        self._btn_resume.clicked.connect(self._do_resume)
        tree_btn_row.addWidget(self._btn_resume)

        tree_btn_row.addStretch()
        main_layout.addLayout(tree_btn_row)

        # ── Log ──
        self._log = LogSection()
        main_layout.addWidget(self._log, 0)

    # ── Signals ────────────────────────────────────────────────────

    def _connect_signals(self):
        self.progress_text.connect(self._on_progress_text)
        self.tree_refresh.connect(self._refresh_tree)
        self.job_update.connect(self._refresh_folder_tree)

    # ── Style dropdown ─────────────────────────────────────────────

    def _refresh_style_dropdown(self):
        """Scan styles/ folder and populate dropdown, filtered by current mode."""
        current = self._combo_style.currentText() if self._combo_style.count() else ""
        self._combo_style.blockSignals(True)
        self._combo_style.clear()

        mode = self._combo_mode.currentText()
        if mode == "Top/List Review":
            target_pipeline = "review"
        else:
            target_pipeline = "narrative"

        styles_dir = os.path.join(
            os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
            "styles"
        )
        if os.path.isdir(styles_dir):
            for fname in sorted(os.listdir(styles_dir)):
                if fname.endswith(".json"):
                    # Read pipeline field to filter
                    fpath = os.path.join(styles_dir, fname)
                    try:
                        with open(fpath, "r", encoding="utf-8") as f:
                            sd = json.load(f)
                        file_pipeline = sd.get("pipeline", "narrative")
                    except Exception:
                        file_pipeline = "narrative"

                    if file_pipeline == target_pipeline:
                        style_name = fname.replace(".json", "").replace("_", " ").title()
                        self._combo_style.addItem(f"✦ {style_name}", fname)

        if self._combo_style.count() == 0:
            self._combo_style.addItem("(no styles found)")

        if current:
            idx = self._combo_style.findText(current)
            if idx >= 0:
                self._combo_style.setCurrentIndex(idx)
        self._combo_style.blockSignals(False)

    def _show_style_popup(self):
        self._refresh_style_dropdown()
        QComboBox.showPopup(self._combo_style)

    def _get_style_filename(self):
        """Return the selected style JSON filename, e.g. 'my_style.json'."""
        idx = self._combo_style.currentIndex()
        if idx >= 0:
            data = self._combo_style.itemData(idx)
            if data:
                return data
        # Fallback for items without data
        text = self._combo_style.currentText()
        if text.startswith("✦ "):
            return text[2:].strip().lower().replace(" ", "_") + ".json"
        return None

    # ── Lang ───────────────────────────────────────────────────────

    _LANG_MAP = {"Tiếng Anh": "english", "Tiếng Tây Ban Nha": "español", "Tiếng Việt": "tiếng việt", "Tiếng Nga": "русский"}
    _LANG_NAMES = {"en": "English", "es": "Spanish", "vi": "Vietnamese", "ru": "Russian"}

    def _get_lang_code(self):
        return self._LANG_MAP.get(self._combo_lang.currentText(), "english")

    # ── Word Count ─────────────────────────────────────────────────

    def _get_word_count_rule(self, section="body"):
        pairs = {
            "open": (self._wc_open_min, self._wc_open_max),
            "body": (self._wc_body_min, self._wc_body_max),
            "end": (self._wc_end_min, self._wc_end_max),
        }
        sp_min, sp_max = pairs.get(section, pairs["body"])
        return build_word_count_rule(sp_min.value(), sp_max.value())

    def _get_chapter_range_rule(self):
        """Build chapter count instruction string from Ch min/max."""
        v_min = self._ch_min.value()
        v_max = self._ch_max.value()
        if v_min > 0 and v_max > 0:
            return f"between {v_min} and {v_max} chapters"
        elif v_min > 0:
            return f"at least {v_min} chapters"
        elif v_max > 0:
            return f"at most {v_max} chapters"
        return ""

    # ── File / Folder Browsing ─────────────────────────────────────

    def _browse(self, target):
        start_dir = ""
        if target == "output":
            start_dir = self._txt_output.text()
        elif target == "unused":
            start_dir = self._txt_unused_dir.text()
        d = QFileDialog.getExistingDirectory(self, f"Select {target} folder", start_dir)
        if d:
            if target == "output":
                self._txt_output.setText(d)
            elif target == "unused":
                self._txt_unused_dir.setText(d)

    def _delete_unused_chapters(self):
        """Delete files in unused chapters folder with state-dependent warnings."""
        # Check pipeline state
        if self._running:
            QMessageBox.warning(
                self, "Unused Chapters",
                "Pipeline đang chạy.\n"
                "Vui lòng đợi hoàn thành trước khi xoá."
            )
            return
        unused_dir = self._txt_unused_dir.text().strip()
        if not unused_dir:
            QMessageBox.information(
                self, "Unused Chapters",
                "Chưa chọn thư mục unused chapters."
            )
            return
        if not os.path.isdir(unused_dir):
            QMessageBox.information(
                self, "Unused Chapters",
                f"Thư mục không tồn tại:\n{unused_dir}"
            )
            return
        # Count txt files
        txt_files = [f for f in os.listdir(unused_dir)
                     if f.lower().endswith(".txt")]
        if not txt_files:
            QMessageBox.information(
                self, "Unused Chapters",
                "Thư mục rỗng \u2014 không có file .txt nào để xoá."
            )
            return
        # Confirm deletion
        reply = QMessageBox.warning(
            self, "Xác nhận xoá",
            f"Xoá {len(txt_files)} file .txt trong:\n{unused_dir}\n\n"
            "Không thể hoàn tác!",
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No,
            QMessageBox.StandardButton.No
        )
        if reply == QMessageBox.StandardButton.Yes:
            deleted = 0
            for f in txt_files:
                try:
                    os.remove(os.path.join(unused_dir, f))
                    deleted += 1
                except Exception:
                    pass
            self._log.log(f"[Style] Deleted {deleted} file(s) from unused folder")

    def _open_output_folder(self):
        out = self._txt_output.text().strip()
        if not out:
            out = os.path.join(self._group_path, "style_rewrite") if self._group_path else ""
        if out and os.path.isdir(out):
            os.startfile(out)

    def _resolve_output_dir(self, ref_filepath=None):
        """Resolve output directory. If empty, auto-create 'style_rewrite/' in source file dir."""
        output_dir = self._txt_output.text().strip()
        if output_dir:
            return output_dir
        # Use the source file's directory
        if ref_filepath:
            src_dir = os.path.dirname(ref_filepath)
        elif self._chapters:
            src_dir = os.path.dirname(self._chapters[0]["filepath"])
        elif self._group_path and os.path.isdir(self._group_path):
            src_dir = self._group_path
        else:
            self._log.log("[Style] Input folder not set")
            return ""
        output_dir = os.path.join(src_dir, "style_rewrite")
        os.makedirs(output_dir, exist_ok=True)
        self._log.log(f"[Style] Output → {output_dir}")
        return output_dir

    def _active_panel(self):
        """Return whichever panel was last clicked."""
        return getattr(self, '_last_active_panel', self._tree)

    def _clear_tree(self):
        self._tree.clear()
        self._folder_tree.clear()
        self._chapters = []
        self._status = {}
        self._group_path = ""
        self._lbl_stats.setText("")
        self._log.log("[Style] Cleared")

    def _remove_checked(self):
        """Remove checked items from the focused panel."""
        panel = self._active_panel()
        if panel is self._folder_tree:
            # Remove checked folders and their chapters
            removed_groups = []
            for i in range(panel.topLevelItemCount()):
                item = panel.topLevelItem(i)
                if item and item.checkState(1) == Qt.CheckState.Checked:
                    g = item.data(1, Qt.ItemDataRole.UserRole)
                    if g:
                        removed_groups.append(g)
            if not removed_groups:
                self._log.log("[Style] No folders selected to remove")
                return
            before = len(self._chapters)
            self._chapters = [c for c in self._chapters if c.get("group") not in removed_groups]
            removed = before - len(self._chapters)
            self._log.log(f"[Style] Removed {len(removed_groups)} folder(s), {removed} chapter(s)")
            self._refresh_tree()
        else:
            # Remove checked chapters from current folder
            checked = self._get_checked_chapters()
            if not checked:
                self._log.log("[Style] No chapters selected to remove")
                return
            checked_paths = {c["filepath"] for c in checked}
            before = len(self._chapters)
            self._chapters = [c for c in self._chapters if c["filepath"] not in checked_paths]
            removed = before - len(self._chapters)
            self._log.log(f"[Style] Removed {removed} chapter(s)")
            self._refresh_tree()

    def _on_folder_tree_context_menu(self, pos):
        """Right-click context menu for folder tree."""
        selected = self._folder_tree.selectedItems()
        if not selected:
            return
        menu = QMenu(self)
        action_remove = menu.addAction(f"🗑 Remove {len(selected)} folder(s)")
        action_retry = menu.addAction(f"🔄 Retry {len(selected)} folder(s)")
        action = menu.exec(self._folder_tree.viewport().mapToGlobal(pos))
        if action == action_remove:
            groups_to_remove = set()
            for item in selected:
                g = item.data(1, Qt.ItemDataRole.UserRole)
                if g:
                    groups_to_remove.add(g)
            if groups_to_remove:
                before = len(self._chapters)
                self._chapters = [c for c in self._chapters if c.get("group") not in groups_to_remove]
                removed = before - len(self._chapters)
                self._log.log(f"[Style] Removed {len(groups_to_remove)} folder(s), {removed} chapter(s)")
                self._refresh_tree()
        elif action == action_retry:
            groups_to_retry = []
            for item in selected:
                g = item.data(1, Qt.ItemDataRole.UserRole)
                if g:
                    groups_to_retry.append(g)
            if groups_to_retry:
                self._do_retry(specific_folders=groups_to_retry)

    def _on_chapter_tree_context_menu(self, pos):
        """Right-click context menu for chapter tree."""
        selected = self._tree.selectedItems()
        if not selected:
            return
        menu = QMenu(self)
        action_remove = menu.addAction(f"🗑 Remove {len(selected)} chapter(s)")
        action = menu.exec(self._tree.viewport().mapToGlobal(pos))
        if action == action_remove:
            paths_to_remove = set()
            for item in selected:
                ch = item.data(0, Qt.ItemDataRole.UserRole)
                if ch and isinstance(ch, dict) and "filepath" in ch:
                    paths_to_remove.add(ch["filepath"])
            if paths_to_remove:
                self._chapters = [c for c in self._chapters if c["filepath"] not in paths_to_remove]
                self._log.log(f"[Style] Removed {len(paths_to_remove)} chapter(s)")
                self._refresh_tree()

    # ── Config Save/Load ───────────────────────────────────────────

    def _save_config(self):
        cfg = {
            "output": self._txt_output.text(),
            "unused_dir": self._txt_unused_dir.text(),
            "mode": self._combo_mode.currentText(),
            "style": self._combo_style.currentText(),
            "framework": self._combo_framework.currentText(),
            "lang": self._combo_lang.currentText(),
            "tier": self._combo_tier.currentText(),
            "threads": self._spin_threads.value(),
            "country": self._combo_country.currentText(),
            "ch_min": self._ch_min.value(),
            "ch_max": self._ch_max.value(),
            "wc_open_min": self._wc_open_min.value(),
            "wc_open_max": self._wc_open_max.value(),
            "wc_body_min": self._wc_body_min.value(),
            "wc_body_max": self._wc_body_max.value(),
            "wc_end_min": self._wc_end_min.value(),
            "wc_end_max": self._wc_end_max.value(),
            "excel_update": self._chk_excel_update.isChecked(),
            "transitions": self._chk_transitions.isChecked(),
            "cut_video": self._chk_cut_video.isChecked(),
            "google_check": self._chk_google_check.isChecked(),
            "auto_patch": self._chk_auto_patch.isChecked(),
        }
        save_config(self.CONFIG_NAME, cfg)

        # Also save per-niche settings (style-specific)
        style_file = self._get_style_filename()
        if style_file:
            niche_cfg = {
                "lang": self._combo_lang.currentText(),
                "framework": self._combo_framework.currentText(),
                "tier": self._combo_tier.currentText(),
                "threads": self._spin_threads.value(),
                "country": self._combo_country.currentText(),
                "ch_min": self._ch_min.value(),
                "ch_max": self._ch_max.value(),
                "wc_open_min": self._wc_open_min.value(),
                "wc_open_max": self._wc_open_max.value(),
                "wc_body_min": self._wc_body_min.value(),
                "wc_body_max": self._wc_body_max.value(),
                "wc_end_min": self._wc_end_min.value(),
                "wc_end_max": self._wc_end_max.value(),
                "excel_update": self._chk_excel_update.isChecked(),
                "transitions": self._chk_transitions.isChecked(),
                "cut_video": self._chk_cut_video.isChecked(),
                "google_check": self._chk_google_check.isChecked(),
                "auto_patch": self._chk_auto_patch.isChecked(),
            }
            save_niche_config(style_file, niche_cfg)
        self._log.log("[Style] Config saved")

    def _apply_niche_config(self):
        """Load and apply per-niche config for the currently selected style."""
        # Skip during initial config load to avoid signal cascade
        if not getattr(self, '_config_loaded', False):
            return  # Skip silently during init
        style_file = self._get_style_filename()
        if not style_file:
            self._log.log("[Style] Niche skip: no style file")
            return
        niche = load_niche_config(style_file)
        if not niche:
            self._log.log(f"[Style] Niche skip: no config for {style_file}")
            return
        self._log.log(f"[Style] Niche loaded: {style_file} → lang={niche.get('lang')}, wc_body_min={niche.get('wc_body_min')}")
        # Apply niche-specific settings
        if niche.get("lang"):
            idx = self._combo_lang.findText(niche["lang"])
            if idx >= 0:
                self._combo_lang.setCurrentIndex(idx)
        if niche.get("framework"):
            idx = self._combo_framework.findText(niche["framework"])
            if idx >= 0:
                self._combo_framework.setCurrentIndex(idx)
        if niche.get("tier"):
            idx = self._combo_tier.findText(niche["tier"])
            if idx >= 0:
                self._combo_tier.setCurrentIndex(idx)
        if niche.get("threads"):
            self._spin_threads.setValue(niche["threads"])
        if niche.get("country"):
            idx = self._combo_country.findText(niche["country"])
            if idx >= 0:
                self._combo_country.setCurrentIndex(idx)
        if "ch_min" in niche:
            self._ch_min.setValue(niche["ch_min"])
        if "ch_max" in niche:
            self._ch_max.setValue(niche["ch_max"])
        for key in ("wc_open_min", "wc_open_max", "wc_body_min",
                     "wc_body_max", "wc_end_min", "wc_end_max"):
            w = getattr(self, f"_{key}", None)
            if w and key in niche:
                w.setValue(niche[key])
        # Restore checkbox states per-niche
        for key, chk in (("excel_update", self._chk_excel_update),
                         ("transitions", self._chk_transitions),
                         ("cut_video", self._chk_cut_video),
                         ("google_check", self._chk_google_check),
                         ("auto_patch", self._chk_auto_patch)):
            if key in niche:
                chk.setChecked(niche[key])
        # Legacy migration: old price_check/enrich_data → google_check
        if "google_check" not in niche:
            if "enrich_data" in niche or "price_check" in niche:
                _legacy = niche.get("enrich_data", niche.get("price_check", True))
                self._chk_google_check.setChecked(_legacy)

    def _load_saved_config(self):
        cfg = load_config(self.CONFIG_NAME)
        if not cfg:
            return
        # Restore text fields
        if cfg.get("output"):
            self._txt_output.setText(cfg["output"])
        if cfg.get("unused_dir"):
            self._txt_unused_dir.setText(cfg["unused_dir"])
        if cfg.get("mode"):
            idx = self._combo_mode.findText(cfg["mode"])
            if idx >= 0:
                self._combo_mode.setCurrentIndex(idx)
        if cfg.get("style"):
            idx = self._combo_style.findText(cfg["style"])
            if idx >= 0:
                self._combo_style.setCurrentIndex(idx)
        if cfg.get("framework"):
            idx = self._combo_framework.findText(cfg["framework"])
            if idx >= 0:
                self._combo_framework.setCurrentIndex(idx)
        if cfg.get("lang"):
            idx = self._combo_lang.findText(cfg["lang"])
            if idx >= 0:
                self._combo_lang.setCurrentIndex(idx)
        if cfg.get("tier"):
            idx = self._combo_tier.findText(cfg["tier"])
            if idx >= 0:
                self._combo_tier.setCurrentIndex(idx)
        if cfg.get("threads"):
            self._spin_threads.setValue(cfg["threads"])
        if cfg.get("country"):
            idx = self._combo_country.findText(cfg["country"])
            if idx >= 0:
                self._combo_country.setCurrentIndex(idx)
        if "ch_min" in cfg:
            self._ch_min.setValue(cfg["ch_min"])
        if "ch_max" in cfg:
            self._ch_max.setValue(cfg["ch_max"])
        for key in ("wc_open_min", "wc_open_max", "wc_body_min",
                     "wc_body_max", "wc_end_min", "wc_end_max"):
            w = getattr(self, f"_{key}", None)
            if w and key in cfg:
                w.setValue(cfg[key])
        self._chk_excel_update.setChecked(cfg.get("excel_update", True))
        self._chk_transitions.setChecked(cfg.get("transitions", True))
        self._chk_cut_video.setChecked(cfg.get("cut_video", True))
        self._chk_google_check.setChecked(cfg.get("google_check", True))
        self._chk_auto_patch.setChecked(cfg.get("auto_patch", False))
        self._config_loaded = True

    # ── Natural sort helper ────────────────────────────────────────

    @staticmethod
    def _natural_sort_key(name):
        import re
        return [int(c) if c.isdigit() else c.lower()
                for c in re.split(r'(\d+)', name)]

    # ── Scan Folder ────────────────────────────────────────────────

    def _scan_folder(self):
        from ui.multi_folder_dialog import select_multiple_folders
        selected_dirs = select_multiple_folders(
            self, "Select folder(s)",
            self._group_path if hasattr(self, '_group_path') and self._group_path else ""
        )
        if not selected_dirs:
            return

        SKIP_PATTERNS = [
            "_SUMMARY", "_VERIFY", "_STATUS", "_MERGE", "_REORDER",
            "FULL_SCRIPT", "_PREVIEW", "_STYLE_", "_REWRITE_STATUS",
        ]

        for d in selected_dirs:
            if not os.path.isdir(d):
                continue
            self._group_path = d

            chapters = []
            for dirpath, dirnames, filenames in os.walk(d):
                dirnames[:] = [dn for dn in dirnames if not dn.startswith(".")]
                rel = os.path.relpath(dirpath, d)
                if rel == ".":
                    label = os.path.basename(d)
                else:
                    label = rel.replace("\\", "/")

                txt_files = sorted(
                    (f for f in filenames
                     if f.lower().endswith(".txt")
                     and not f.lower().startswith("tts_")
                     and not any(skip in f.upper() for skip in SKIP_PATTERNS)),
                    key=self._natural_sort_key
                )

                for fname in txt_files:
                    fpath = os.path.join(dirpath, fname)
                    try:
                        with open(fpath, "r", encoding="utf-8") as f:
                            text = f.read()
                    except Exception:
                        continue
                    chapters.append({
                        "filename": fname,
                        "filepath": fpath,
                        "text": text,
                        "group": label,
                    })

            if not chapters:
                self._log.log(f"[Style] No .txt files in {os.path.basename(d)}")
                continue

            root_name = os.path.basename(d)
            self._chapters = [c for c in self._chapters if c.get("group") != root_name]
            self._chapters.extend(chapters)

            folders = set(c["group"] for c in chapters)
            self._log.log(
                f"[Style] Loaded {len(chapters)} files in {len(folders)} folder(s) from {root_name}"
            )

        self._refresh_tree()

    # ── Add single files ───────────────────────────────────────────

    def _add_single_file(self):
        files, _ = QFileDialog.getOpenFileNames(
            self, "Select script files", "", "Text files (*.txt);;All (*)"
        )
        if not files:
            return
        for fpath in files:
            fname = os.path.basename(fpath)
            if any(c["filepath"] == fpath for c in self._chapters):
                continue
            with open(fpath, "r", encoding="utf-8") as f:
                text = f.read()
            self._chapters.append({
                "filename": fname,
                "filepath": fpath,
                "text": text,
                "group": "(Added)",
            })
        self._log.log(f"[Style] Added {len(files)} file(s)")
        self._refresh_tree()

    # ── Tree helpers ───────────────────────────────────────────────

    def _refresh_tree(self):
        """Populate folder list (left) and chapter list (right) for selected folder."""
        from collections import OrderedDict
        groups = OrderedDict()
        for ch in self._chapters:
            g = ch.get("group", "")
            if g not in groups:
                groups[g] = []
            groups[g].append(ch)

        # Update folder list (left panel)
        self._folder_tree.blockSignals(True)
        prev_selected = getattr(self, "_selected_group", None)
        self._folder_tree.clear()

        first_item = None
        select_item = None
        for group_name, group_chapters in groups.items():
            # Get job status for this folder if it exists
            job = self._get_job_for_group(group_name)
            if job:
                status = self._JOB_STATUS_MAP.get(job["status"], job["status"])
                progress = job.get("progress", "")
            else:
                status = ""
                progress = f"{len(group_chapters)} ch"

            task_num = str(job.get("task_num", "")) if job else ""
            item = QTreeWidgetItem([task_num, group_name, status, progress])
            item.setFlags(item.flags() | Qt.ItemFlag.ItemIsUserCheckable)
            item.setCheckState(1, Qt.CheckState.Checked)
            item.setData(1, Qt.ItemDataRole.UserRole, group_name)
            self._folder_tree.addTopLevelItem(item)
            if first_item is None:
                first_item = item
            if group_name == prev_selected:
                select_item = item

        self._folder_tree.blockSignals(False)

        # Restore or select first folder
        if select_item:
            self._folder_tree.setCurrentItem(select_item)
        elif first_item:
            self._folder_tree.setCurrentItem(first_item)

        # Stats
        total = len(self._chapters)
        g_count = len(groups)
        if g_count > 1:
            self._lbl_stats.setText(f"{g_count} folders, {total} ch")
        else:
            self._lbl_stats.setText(f"{total} ch")

    def _get_job_for_group(self, group_name):
        """Find the most recent job matching this folder group."""
        for jid in reversed(list(self._jobs)):
            job = self._jobs[jid]
            if job["folder_name"] == group_name:
                return job
            # Check merged groups
            if group_name in job.get("merged_groups", []):
                return job
        return None

    _STATUS_MAP = {
        "pending": "⏳ Pending",
        "processing": "⚙ Processing",
        "writing": "✍ Writing",
        "rewritten": "✍ Rewritten",
        "verified": "✓ Done",
        "error": "✗ Error",
    }

    _JOB_STATUS_MAP = {
        "running": "⚙ Running",
        "queued": "⏳ Queued",
        "done": "✅ Done",
        "error": "❌ Error",
        "stopped": "⏹ Stopped",
    }

    def _refresh_folder_tree(self):
        """Update folder statuses in-place (called via job_update signal)."""
        for i in range(self._folder_tree.topLevelItemCount()):
            item = self._folder_tree.topLevelItem(i)
            if not item:
                continue
            group_name = item.data(1, Qt.ItemDataRole.UserRole)
            if not group_name:
                continue
            job = self._get_job_for_group(group_name)
            if job:
                item.setText(0, str(job.get("task_num", "")))
                item.setText(2, self._JOB_STATUS_MAP.get(
                    job["status"], job["status"]))
                item.setText(3, job.get("progress", ""))
            else:
                item.setText(0, "")
                item.setText(2, "")
                # keep chapter count as-is

    def _on_folder_selected(self, current, previous):
        """When user clicks a folder on the left, show its chapters on the right."""
        if not current:
            return
        group_name = current.data(1, Qt.ItemDataRole.UserRole)
        if not group_name:
            return
        self._selected_group = group_name

        # Find chapters for this group
        chapters_data = self._status.get("chapters", {})
        self._tree.blockSignals(True)
        self._tree.clear()
        for ch in self._chapters:
            if ch.get("group") != group_name:
                continue
            fname = ch["filename"]
            ch_st = chapters_data.get(fname, {})
            status_text = ch_st.get("status", "pending")
            display = self._STATUS_MAP.get(status_text, status_text)
            progress_text = ch_st.get("progress", "")
            item = QTreeWidgetItem([fname, display, progress_text])
            item.setFlags(item.flags() | Qt.ItemFlag.ItemIsUserCheckable)
            item.setCheckState(0, Qt.CheckState.Checked)
            item.setData(0, Qt.ItemDataRole.UserRole, ch)
            self._tree.addTopLevelItem(item)
        self._tree.blockSignals(False)

    def _on_item_changed(self, item, column):
        if column != 0 or self._propagating:
            return
        # Propagate check state to children
        if item.childCount() > 0:
            self._propagating = True
            state = item.checkState(0)
            for i in range(item.childCount()):
                item.child(i).setCheckState(0, state)
            self._propagating = False

    def _on_progress_text(self, filename, text):
        def _find(parent):
            for i in range(parent.topLevelItemCount() if hasattr(parent, 'topLevelItemCount') else parent.childCount()):
                item = parent.topLevelItem(i) if hasattr(parent, 'topLevelItem') else parent.child(i)
                if item.text(0) == filename:
                    item.setText(2, text)
                    return True
                if item.childCount() > 0:
                    for j in range(item.childCount()):
                        child = item.child(j)
                        if child.text(0) == filename:
                            child.setText(2, text)
                            return True
            return False
        _find(self._tree)



    def _select_all(self):
        panel = self._active_panel()
        col = 1 if panel is self._folder_tree else 0
        for i in range(panel.topLevelItemCount()):
            item = panel.topLevelItem(i)
            if item.flags() & Qt.ItemFlag.ItemIsUserCheckable:
                item.setCheckState(col, Qt.CheckState.Checked)

    def _deselect_all(self):
        panel = self._active_panel()
        col = 1 if panel is self._folder_tree else 0
        for i in range(panel.topLevelItemCount()):
            item = panel.topLevelItem(i)
            if item.flags() & Qt.ItemFlag.ItemIsUserCheckable:
                item.setCheckState(col, Qt.CheckState.Unchecked)

    def _get_checked_chapters(self):
        result = []
        def _collect(parent):
            count = parent.topLevelItemCount() if hasattr(parent, 'topLevelItemCount') else parent.childCount()
            for i in range(count):
                item = parent.topLevelItem(i) if hasattr(parent, 'topLevelItem') else parent.child(i)
                ch = item.data(0, Qt.ItemDataRole.UserRole)
                if ch and item.checkState(0) == Qt.CheckState.Checked:
                    result.append(ch)
                if item.childCount() > 0:
                    _collect(item)
        _collect(self._tree)
        return result

    # ── Status ─────────────────────────────────────────────────────

    def _save_status_safe(self, group_path):
        if not group_path:
            return
        try:
            status_path = os.path.join(group_path, "_status.json")
            with self._lock:
                with open(status_path, "w", encoding="utf-8") as f:
                    json.dump(self._status, f, indent=2, ensure_ascii=False)
        except Exception:
            pass

    def _do_cut_video_for_group(self, job):
        """Post-rewrite: Cut downloaded video into chapter clips.
        
        Simple flow:
          1. Find video .mp4 in project dir (parent of group_path/01_chapters)
          2. Parse timecodes from merge file
          3. ffmpeg cut into chapter clips
        """
        from core.video_cutter import (
            find_merge_file, parse_merge_timecodes, download_video, cut_video,
            extract_youtube_url_from_merge,
        )
        log_prefix = job.get("log_prefix", "[Cut]")
        stop_event = job.get("stop_event")
        _log_cb = job.get("_log_callback")

        def log(msg):
            if _log_cb:
                _log_cb(f"{log_prefix} {msg}")
            else:
                self._log.log(f"{log_prefix} {msg}")

        def stop_check():
            return stop_event and stop_event.is_set()

        # Determine the chapters directory (contains merge file + chapter text files)
        chapters_dir = job.get("group_path", "")
        if not chapters_dir or not os.path.isdir(chapters_dir):
            log("🎬 Skip video cut: no group_path")
            return

        # Project dir = parent of 01_chapters
        project_dir = os.path.dirname(chapters_dir)

        # 1. Find merge file  
        merge_path = find_merge_file(chapters_dir)
        if not merge_path:
            log(f"🎬 ⚠ No merge file found, skip video cut")
            return

        # 2. Check if already cut
        video_out_dir = os.path.join(project_dir, "02_video_chapters")
        if os.path.isdir(video_out_dir):
            existing_mp4 = [f for f in os.listdir(video_out_dir) if f.endswith(".mp4")]
            if existing_mp4:
                log(f"🎬 ⏭ Already cut ({len(existing_mp4)} clips)")
                return

        # 3. Parse timecodes
        chapters_tc = parse_merge_timecodes(merge_path)
        if not chapters_tc:
            log(f"🎬 ⚠ No timecodes in merge file")
            return

        # 4. Find video file (look in project dir, then chapters dir)
        video_path = ""
        for search_dir in [project_dir, chapters_dir]:
            if not os.path.isdir(search_dir):
                continue
            for vf in os.listdir(search_dir):
                if vf.endswith((".mp4", ".mkv", ".webm")) and not vf.startswith("Ch_"):
                    candidate = os.path.join(search_dir, vf)
                    if os.path.getsize(candidate) > 1_000_000:  # >1MB
                        video_path = candidate
                        log(f"🎬 Found video: {vf}")
                        break
            if video_path:
                break

        # 5. No local video → try download via YouTube URL in merge file
        if not video_path:
            yt_url = extract_youtube_url_from_merge(merge_path)
            if not yt_url:
                log(f"🎬 ⚠ No video file found and no YouTube URL in merge file")
                return
            log(f"🎬 Downloading video: {yt_url}")
            import tempfile
            _tmp_dir = tempfile.mkdtemp(prefix="cutter_")
            video_path = download_video(
                yt_url, _tmp_dir, log_callback=log, stop_check=stop_check
            )
            if not video_path or not os.path.isfile(video_path):
                log(f"🎬 ❌ Download failed")
                return

        if stop_check():
            return

        # 6. Cut!
        log(f"🎬 Cutting {len(chapters_tc)} chapters...")
        saved = cut_video(
            video_path, chapters_tc, video_out_dir,
            log_callback=log, stop_check=stop_check,
        )
        log(f"🎬 ✅ Done: {len(saved)}/{len(chapters_tc)} clips → 02_video_chapters/")

    def _update_input_chapters_status(self, checked, status_text, chapters_data, progress=""):
        """Update all input chapters to a given status and refresh UI."""
        for ch in checked:
            fname = ch["filename"]
            ch_st = chapters_data.setdefault(fname, {})
            ch_st["status"] = status_text
            if progress:
                ch_st["progress"] = progress
        self.tree_refresh.emit()

    def _do_retry(self, specific_folders=None):
        """Retry failed/error/stopped folders."""
        if specific_folders:
            retry_groups = specific_folders
        else:
            # Find folders with failed/error/stopped status
            retry_groups = []
            for i in range(self._folder_tree.topLevelItemCount()):
                item = self._folder_tree.topLevelItem(i)
                if not item:
                    continue
                group_name = item.data(1, Qt.ItemDataRole.UserRole)
                if not group_name:
                    continue
                job = self._get_job_for_group(group_name)
                if job and job["status"] in ("error", "stopped"):
                    retry_groups.append(group_name)

        if not retry_groups:
            self._log.log("[Style] No failed/stopped folders to retry")
            return

        # Reset status for these folders
        for gn in retry_groups:
            job = self._get_job_for_group(gn)
            if job:
                # Remove old job so _do_rewrite can create new one
                jid = job.get("id")
                if jid and jid in self._jobs:
                    del self._jobs[jid]
            # Reset chapter statuses for this group
            for ch in self._chapters:
                if ch.get("group") == gn:
                    fname = ch["filename"]
                    if fname in self._status:
                        # Reset error/failed chapters
                        ch_st = self._status[fname]
                        if ch_st.get("status") in ("error", "pending"):
                            self._status.pop(fname, None)

        self._log.log(f"[Style] Retrying {len(retry_groups)} folder(s): {', '.join(g.split(']_', 1)[-1][:30] if ']_' in g else g[:30] for g in retry_groups)}")

        # Check the retry folders in the folder tree
        retry_set = set(retry_groups)
        for i in range(self._folder_tree.topLevelItemCount()):
            item = self._folder_tree.topLevelItem(i)
            if not item:
                continue
            gn = item.data(1, Qt.ItemDataRole.UserRole)
            if gn in retry_set:
                item.setCheckState(1, Qt.CheckState.Checked)
            else:
                item.setCheckState(1, Qt.CheckState.Unchecked)

        self.job_update.emit()
        # Trigger rewrite for checked folders
        self._do_rewrite()

    def _do_stop(self):
        running_jobs = {jid: j for jid, j in self._jobs.items() if j["status"] == "running"}
        if not running_jobs:
            self._stop_flag = True  # legacy fallback
            self._log.log("[Style] Stopping...")
            return

        if len(running_jobs) == 1:
            # Only 1 job — stop it directly
            jid, job = next(iter(running_jobs.items()))
            job["stop_event"].set()
            job["status"] = "stopped"
            job["progress"] = "Stopped"
            self._log.log(f"[Job] Stopping: {job['folder_name']}")
            self.job_update.emit()
        else:
            # Multiple jobs — show menu
            from PyQt6.QtWidgets import QMenu
            menu = QMenu(self)
            for jid, job in running_jobs.items():
                action = menu.addAction(f"Stop: {job['folder_name']}")
                action.setData(jid)
            menu.addSeparator()
            stop_all = menu.addAction("■ Stop All")
            stop_all.setData("__all__")

            action = menu.exec(self._btn_stop.mapToGlobal(self._btn_stop.rect().bottomLeft()))
            if action:
                chosen = action.data()
                if chosen == "__all__":
                    for jid, job in running_jobs.items():
                        job["stop_event"].set()
                        job["status"] = "stopped"
                        job["progress"] = "Stopped"
                    self._log.log("[Job] Stopping ALL jobs")
                else:
                    job = self._jobs.get(chosen)
                    if job:
                        job["stop_event"].set()
                        job["status"] = "stopped"
                        job["progress"] = "Stopped"
                        self._log.log(f"[Job] Stopping: {job['folder_name']}")
                self.job_update.emit()

    # ── Build Style Prompt ─────────────────────────────────────────

    def _build_style_prompt(self, wc_rule, lang, chapter_idx=None,
                            total=None, prev_context=""):
        """Build the system prompt from the selected style JSON."""
        style_file = self._get_style_filename()
        if not style_file:
            return None, "No style selected"

        styles_dir = os.path.join(
            os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
            "styles"
        )
        style_path = os.path.join(styles_dir, style_file)
        if not os.path.isfile(style_path):
            return None, f"Style file not found: {style_file}"

        with open(style_path, "r", encoding="utf-8") as f:
            style_json = f.read()

        lang_name = self._LANG_NAMES.get(lang, lang)

        parts = [
            "You are a professional script writer. "
            "Follow these writing rules EXACTLY:\n\n",
            style_json, "\n\n",
            f"WORD COUNT RULE: {wc_rule}\n\n",
            f"IMPORTANT: Write ALL output in {lang_name}.\n",
        ]
        if chapter_idx is not None and total is not None:
            parts.append(f"This is chapter {chapter_idx + 1} of {total}.\n")
        parts.append(
            "Rewrite the chapter below following the rules above. "
            "Output ONLY the rewritten chapter text, nothing else."
        )
        if prev_context:
            parts.append(
                f"\n\nPREVIOUS CHAPTERS CONTEXT (maintain continuity):\n{prev_context}"
            )

        return "".join(parts), style_file

    # ── Main Dispatch ──────────────────────────────────────────────

    def _on_mode_changed(self, mode_text):
        is_review = (mode_text == "Top/List Review")

        # Always show framework combo
        self._lbl_framework.setVisible(True)
        self._combo_framework.setVisible(True)
        self._lbl_threads.setVisible(False)
        self._spin_threads.setVisible(False)

        # Country only for review
        self._lbl_country.setVisible(is_review)
        self._combo_country.setVisible(is_review)
        self._chk_transitions.setVisible(is_review)

        # Defaults per mode — always update when switching
        self._chk_cut_video.setChecked(is_review)
        self._chk_cut_video.setVisible(is_review)
        self._chk_excel_update.setChecked(is_review)
        self._chk_excel_update.setVisible(is_review)
        self._chk_google_check.setChecked(True)
        self._chk_google_check.setVisible(True)

        # Filter styles by mode
        self._refresh_style_dropdown()

        # Populate framework combo from first available style
        style_json_raw, _ = self._load_style_json_raw()
        if style_json_raw:
            try:
                sd = json.loads(style_json_raw)
                fw_names = [fw.get("name", "") for fw in sd.get("frameworks", []) if fw.get("enabled", True)]
                if fw_names:
                    self._combo_framework.blockSignals(True)
                    current = self._combo_framework.currentText()
                    self._combo_framework.clear()
                    self._combo_framework.addItem("Auto (detect & switch)")
                    for name in fw_names:
                        self._combo_framework.addItem(name)
                    idx = self._combo_framework.findText(current)
                    if idx >= 0:
                        self._combo_framework.setCurrentIndex(idx)
                    self._combo_framework.blockSignals(False)
            except (json.JSONDecodeError, AttributeError):
                pass

        # Update button + default word counts per mode
        if is_review:
            self._btn_rewrite.setText("▶ Rewrite")
            self._btn_rewrite.setToolTip(
                "Extract blueprint → Recommend framework → Check → Convert → Outline → Write → Verify"
            )
            # Review defaults: shorter chapters, more of them
            if not self._config_loaded:
                self._ch_min.setValue(7)
                self._ch_max.setValue(10)
                self._wc_open_min.setValue(0)    # —
                self._wc_open_max.setValue(200)
                self._wc_body_min.setValue(0)    # —
                self._wc_body_max.setValue(400)
                self._wc_end_min.setValue(0)     # —
                self._wc_end_max.setValue(200)
        else:
            self._btn_rewrite.setText("▶ Rewrite")
            self._btn_rewrite.setToolTip(
                "Detect framework → Extract blueprint → New framework → Write new"
            )
            # Narrative defaults: longer chapters, fewer
            if not self._config_loaded:
                self._ch_min.setValue(5)
                self._ch_max.setValue(20)
                self._wc_open_min.setValue(1300)
                self._wc_open_max.setValue(1800)
                self._wc_body_min.setValue(1300)
                self._wc_body_max.setValue(1800)
                self._wc_end_min.setValue(1200)
                self._wc_end_max.setValue(1500)

        # Load per-niche config (overrides mode defaults if saved)
        self._apply_niche_config()

    def _show_fw_ranking_dialog(self, rankings, original_fw):
        """Show framework ranking popup on the main thread.
        rankings: list of dicts with 'name', 'score', 'reason'.
        original_fw: the detected original framework (may be greyed out).
        """
        try:
            import winsound
            winsound.MessageBeep(winsound.MB_ICONEXCLAMATION)
        except Exception:
            pass
        dlg = QDialog(self)
        dlg.setWindowTitle("Xếp hạng Framework — Phân tích AI")
        dlg.setMinimumWidth(520)
        layout = QVBoxLayout(dlg)

        # Parse original framework info
        try:
            fw_info = json.loads(original_fw)
            fw_name = fw_info.get("name", "Unknown")
            fw_conf = fw_info.get("confidence", "?")
            fw_reason = fw_info.get("reasoning", "")
        except (json.JSONDecodeError, TypeError):
            fw_name = str(original_fw)
            fw_conf = "?"
            fw_reason = ""

        header_text = (
            f"<b>AI đã phân tích nội dung và xếp hạng các framework.</b><br><br>"
            f"<b>Framework kịch bản gốc:</b> {fw_name} "
            f"(độ tin cậy: {fw_conf})"
        )
        if fw_reason:
            header_text += f"<br><i>{fw_reason}</i>"

        header = QLabel(header_text)
        header.setWordWrap(True)
        layout.addWidget(header)
        layout.addSpacing(8)

        # Scrollable area for framework list
        scroll = QScrollArea()
        scroll.setWidgetResizable(True)
        scroll.setMaximumHeight(450)
        scroll.setStyleSheet("QScrollArea { border: none; }")
        scroll_widget = QWidget()
        scroll_layout = QVBoxLayout(scroll_widget)
        scroll_layout.setContentsMargins(0, 0, 0, 0)

        btn_group = QButtonGroup(dlg)
        radios = []
        for i, r in enumerate(rankings):
            name = r.get("name", "")
            score = r.get("score", 0)
            reason = r.get("reason", "")
            is_original = (name == fw_name)

            label_text = f"{name}  —  {score}/10"
            if is_original:
                label_text += "  (gốc)"

            radio = QRadioButton(label_text)
            radio.setStyleSheet("font-weight: bold; font-size: 13px;")
            if i == 0:
                radio.setChecked(True)

            reason_lbl = QLabel(f"    {reason}")
            reason_lbl.setWordWrap(True)
            reason_lbl.setStyleSheet("color: #888; margin-left: 24px; margin-bottom: 8px;")

            btn_group.addButton(radio, i)
            radios.append((radio, name))
            scroll_layout.addWidget(radio)
            scroll_layout.addWidget(reason_lbl)

        scroll_layout.addStretch()
        scroll.setWidget(scroll_widget)
        layout.addWidget(scroll)

        layout.addSpacing(12)
        buttons = QDialogButtonBox()
        btn_ok = buttons.addButton("Chọn", QDialogButtonBox.ButtonRole.AcceptRole)
        btn_cancel = buttons.addButton("Hủy", QDialogButtonBox.ButtonRole.RejectRole)
        buttons.accepted.connect(dlg.accept)
        buttons.rejected.connect(dlg.reject)
        layout.addWidget(buttons)

        if dlg.exec() == QDialog.DialogCode.Accepted:
            checked_id = btn_group.checkedId()
            if 0 <= checked_id < len(radios):
                self._fw_ranking_result = radios[checked_id][1]
            else:
                self._fw_ranking_result = rankings[0]["name"]
        else:
            self._fw_ranking_result = None  # user cancelled

        self._fw_ranking_event.set()

    # ═══════════════════════════════════════════════════════════════
    # SHARED: Outline → Audit → Write → Review → Patch → Merge
    # Called by BOTH _do_new_content and _do_rewrite / _run_fw_pipeline
    # ═══════════════════════════════════════════════════════════════
    def _run_shared_fw_pipeline(
        self, *,
        fw_name, fw_output_dir, fw_pipeline_dir, fw_log,
        blueprint, style_json_raw, endpoints, tier, lang, niche,
        stop_check, get_wc_rule, get_ch_range,
        log_api=None,
        on_chapter_saved=None,   # callback(out_fname, fw_name) for Rewrite UI tracking
        auto_patch=True,
        resume=False,
    ):
        """Shared pipeline: outline → audit → write → review → patch → merge.
        Used by both New Content and Rewrite pipelines to avoid code duplication.
        """
        _log_api = log_api or (lambda *a: None)
        os.makedirs(fw_output_dir, exist_ok=True)
        os.makedirs(fw_pipeline_dir, exist_ok=True)

        # ── Step A: Phase Planning (biography only) ──
        _BIO_KW = ("biography", "tiểu sử", "nhân vật", "chân dung", "cuộc đời")
        _is_biography = any(kw in (niche or "").lower() for kw in _BIO_KW)

        phase_plan = None
        ch_range = get_ch_range()
        if _is_biography:
            split_path = os.path.join(fw_pipeline_dir, "_phase_plan_final.json")
            validated_path = os.path.join(fw_pipeline_dir, "_phase_plan_validated.json")
            phase_plan_path = os.path.join(fw_pipeline_dir, "_phase_plan.json")

            if resume and os.path.isfile(split_path):
                # Resume: load final split plan (all A steps done)
                with open(split_path, "r", encoding="utf-8") as f:
                    phase_plan = json.load(f)
                fw_log("✓ [Resume] Phase plan loaded from _phase_plan_final.json")
            elif resume and os.path.isfile(validated_path):
                # Resume: validated exists but not split → run A3 only
                with open(validated_path, "r", encoding="utf-8") as f:
                    phase_plan = json.load(f)
                fw_log("✓ [Resume] Validated plan loaded — running split only")
                phase_plan.pop("_validation_log", None)
                phase_plan = apply_chapter_splits(phase_plan, log_callback=lambda m: fw_log(m))
                with open(split_path, "w", encoding="utf-8") as f:
                    json.dump(phase_plan, f, indent=2, ensure_ascii=False)
            elif resume and os.path.isfile(phase_plan_path):
                # Resume: phase plan exists but not validated → run A2+A3
                with open(phase_plan_path, "r", encoding="utf-8") as f:
                    phase_plan = json.load(f)
                fw_log("✓ [Resume] Phase plan loaded — running validate + split")
                phase_plan = validate_phase_plan_sub_keys(
                    phase_plan, blueprint, endpoints,
                    log_callback=lambda m: fw_log(m), stop_check=stop_check,
                )
                with open(validated_path, "w", encoding="utf-8") as f:
                    json.dump(phase_plan, f, indent=2, ensure_ascii=False)
                val_log = phase_plan.pop("_validation_log", None)
                if val_log:
                    val_log_path = os.path.join(fw_pipeline_dir, "_validation_reasoning.json")
                    with open(val_log_path, "w", encoding="utf-8") as f:
                        json.dump(val_log, f, indent=2, ensure_ascii=False)
                if stop_check():
                    return
                phase_plan = apply_chapter_splits(phase_plan, log_callback=lambda m: fw_log(m))
                with open(split_path, "w", encoding="utf-8") as f:
                    json.dump(phase_plan, f, indent=2, ensure_ascii=False)
            else:
                # Normal flow: run A1+A2+A3
                fw_log(f"Planning phases for '{fw_name}'...")
                api_phase = APIClient(endpoints, log_api=_log_api, tier=tier, stop_check=stop_check)
                ch_range = get_ch_range()
                phase_plan = generate_narrative_phase_plan(
                    blueprint, style_json_raw, fw_name, api_phase,
                    chapter_range=ch_range, lang=lang,
                    log_callback=lambda m: fw_log(m), niche=niche,
                )
                phase_plan_path = os.path.join(fw_pipeline_dir, "_phase_plan.json")
                with open(phase_plan_path, "w", encoding="utf-8") as f:
                    json.dump(phase_plan, f, indent=2, ensure_ascii=False)

                if stop_check():
                    return

                # Step A2: Validate
                fw_log("Validating sub_key_data classifications...")
                phase_plan = validate_phase_plan_sub_keys(
                    phase_plan, blueprint, endpoints,
                    log_callback=lambda m: fw_log(m), stop_check=stop_check,
                )
                validated_path = os.path.join(fw_pipeline_dir, "_phase_plan_validated.json")
                with open(validated_path, "w", encoding="utf-8") as f:
                    json.dump(phase_plan, f, indent=2, ensure_ascii=False)
                val_log = phase_plan.pop("_validation_log", None)
                if val_log:
                    val_log_path = os.path.join(fw_pipeline_dir, "_validation_reasoning.json")
                    with open(val_log_path, "w", encoding="utf-8") as f:
                        json.dump(val_log, f, indent=2, ensure_ascii=False)
                    fw_log(f"  📄 Saved validation reasoning → _validation_reasoning.json")

                if stop_check():
                    return

                # Step A3: Split
                fw_log("Splitting phases into chapters...")
                phase_plan = apply_chapter_splits(phase_plan, log_callback=lambda m: fw_log(m))
                split_path = os.path.join(fw_pipeline_dir, "_phase_plan_final.json")
                with open(split_path, "w", encoding="utf-8") as f:
                    json.dump(phase_plan, f, indent=2, ensure_ascii=False)

            if stop_check():
                return
        else:
            pass  # non-biography: no phase planning needed

        # ── Step B+C: Outline + Audit ──
        outline_path = os.path.join(fw_pipeline_dir, "_renew_outline.json")
        audited_path = os.path.join(fw_pipeline_dir, "_renew_outline_audited.json")

        _skip_audit = False
        if resume and os.path.isfile(audited_path):
            # Resume: audited outline exists → load it
            with open(audited_path, "r", encoding="utf-8") as f:
                outline = json.load(f)
            out_chapters = outline.get("chapters", [])
            _skip_audit = True
            total = len(out_chapters)
            fw_log(f"✓ [Resume] Audited outline loaded ({total} chapters)")
        elif resume and os.path.isfile(outline_path):
            # Resume: outline exists but not audited → run audit only
            with open(outline_path, "r", encoding="utf-8") as f:
                outline = json.load(f)
            fw_log("✓ [Resume] Outline loaded — running audit only")
            out_chapters = outline.get("chapters", [])
            total = len(out_chapters)
            # Falls through to audit below
        else:
            # Normal flow: generate outline
            fw_log(f"Generating outline with '{fw_name}'...")
            api_out = APIClient(endpoints, log_api=_log_api, tier=tier, stop_check=stop_check)
            outline = generate_narrative_outline(
                blueprint, style_json_raw, fw_name, api_out,
                chapter_range=ch_range, lang=lang,
                log_callback=lambda m: fw_log(m), niche=niche,
                phase_plan=phase_plan,
            )
            out_chapters = outline.get("chapters", [])
            total = len(out_chapters)
            arc = outline.get("narrative_arc", "")[:100]
            fw_log(f"✓ Outline: {total} chapters")
            if arc:
                fw_log(f"  Arc: {arc}...")
            outline_path = os.path.join(fw_pipeline_dir, "_renew_outline.json")
            with open(outline_path, "w", encoding="utf-8") as f:
                json.dump(outline, f, indent=2, ensure_ascii=False)

        if stop_check() or total == 0:
            return

        # ── Audit (skip if already loaded audited outline via resume) ──
        if not _skip_audit:
            fw_log("Auditing outline structure...")
            api_audit = APIClient(endpoints, log_api=_log_api, tier="flash", stop_check=stop_check)
            audited_outline, audit_issues = audit_outline(
                outline, blueprint, style_json_raw, fw_name, api_audit,
                log_callback=lambda m: fw_log(m), niche=niche,
                chapter_range=ch_range,
            )
            audit_path = os.path.join(fw_pipeline_dir, "_audit.json")
            with open(audit_path, "w", encoding="utf-8") as f:
                json.dump({"issues": audit_issues}, f, indent=2, ensure_ascii=False)
            if audit_issues:
                outline = audited_outline
                out_chapters = outline.get("chapters", [])
                total = len(out_chapters)
            audited_path = os.path.join(fw_pipeline_dir, "_renew_outline_audited.json")
            with open(audited_path, "w", encoding="utf-8") as f:
                json.dump(outline, f, indent=2, ensure_ascii=False)
            fw_log(f"📄 Saved audited outline ({total} chapters)")
        if stop_check() or total == 0:
            return
        # ── Save phase_data for inspection ──
        phase_plan = outline.get("phase_chapter_plan", [])

        # Fallback: auto-generate phase_chapter_plan from chapters if AI omitted it
        if not phase_plan and out_chapters:
            from collections import OrderedDict
            step_map = OrderedDict()
            for ch in out_chapters:
                step = ch.get("framework_step", "Unknown")
                ch_num = ch.get("chapter_number", 0)
                if step not in step_map:
                    step_map[step] = []
                step_map[step].append(ch_num)
            phase_plan = []
            for step_name, ch_nums in step_map.items():
                phase_plan.append({
                    "phase": step_name,
                    "chapters": ch_nums,
                    "reason_for_split": f"Auto-grouped {len(ch_nums)} chapters" if len(ch_nums) > 1 else None,
                })
            outline["phase_chapter_plan"] = phase_plan
            # Re-save the outline with phase_chapter_plan
            audited_path = os.path.join(fw_pipeline_dir, "_renew_outline_audited.json")
            with open(audited_path, "w", encoding="utf-8") as f:
                json.dump(outline, f, indent=2, ensure_ascii=False)
            fw_log(f"⚠️ phase_chapter_plan was missing — auto-generated from framework_step ({len(phase_plan)} phases)")

        if phase_plan:
            phase_data_dir = os.path.join(fw_pipeline_dir, "_phase_data")
            os.makedirs(phase_data_dir, exist_ok=True)

            summary_lines = []
            for idx, phase in enumerate(phase_plan):
                phase_name = phase.get("phase", f"phase_{idx}")
                safe_name = "".join(c if c.isalnum() or c in " _-" else "_" for c in phase_name).strip().replace(" ", "_")
                phase_file = os.path.join(phase_data_dir, f"phase_{idx+1:02d}_{safe_name}.json")
                with open(phase_file, "w", encoding="utf-8") as f:
                    json.dump(phase, f, indent=2, ensure_ascii=False)

                # Build summary line
                node_count = phase.get("node_count", phase.get("pacing_evaluation", {}).get("node_count", "?"))
                cap_check = phase.get("capacity_check", phase.get("pacing_evaluation", {}).get("capacity_check", ""))
                chs = phase.get("chapters", [])
                split_reason = phase.get("reason_for_split", "null")
                action = "SPLIT" if len(chs) > 1 else "KEEP"
                summary_lines.append(
                    f"[{action}] Phase {idx+1}: {phase_name}\n"
                    f"       Chapters: {chs} | Main beats: {node_count}\n"
                    f"       Capacity: {cap_check}\n"
                    f"       Reason: {split_reason}"
                )

            # Save readable summary
            summary_path = os.path.join(phase_data_dir, "_summary.txt")
            with open(summary_path, "w", encoding="utf-8") as f:
                f.write(f"Phase Chapter Plan Summary\n")
                f.write(f"Framework: {outline.get('framework_used', '?')}\n")
                f.write(f"Total chapters: {total}\n")
                f.write(f"Total phases: {len(phase_plan)}\n")
                f.write(f"{'='*60}\n\n")
                f.write("\n\n".join(summary_lines))

            fw_log(f"📂 Saved {len(phase_plan)} phase plans to _phase_data/")

        # ── Write chapters ──
        fw_log(f"Writing {total} chapters...")
        rewritten_texts = []
        out_filenames = []
        chapter_titles = []
        renew_outline_str = json.dumps(outline, indent=2, ensure_ascii=False)

        for i, ch_outline in enumerate(out_chapters):
            if stop_check():
                break

            ch_type = ch_outline.get("chapter_type", "body")
            if ch_type == "hook":
                raw_name = "Intro"
            elif ch_type == "end":
                raw_name = "Outro_CTA"
            else:
                prods = ch_outline.get("products_covered", [])
                if prods and len(prods) <= 2:
                    raw_name = " vs ".join(prods) if len(prods) == 2 else prods[0]
                else:
                    raw_name = ch_outline.get("title", f"chapter_{i+1}")
            safe_title = "".join(
                c if c.isalnum() or c in " _-" else "_"
                for c in raw_name
            ).strip().replace(" ", "_")[:60]
            out_fname = f"ch_{i+1:02d}_{safe_title}.txt"

            if i == 0:
                wc_section = "open"
            elif i == total - 1:
                wc_section = "end"
            else:
                wc_section = "body"
            wc_rule = get_wc_rule(wc_section)

            if wc_rule == "SKIP":
                fw_log(f"⏭ Ch.{i+1}/{total}: skipped ({wc_section} = SKIP)")
                continue

            out_filenames.append(out_fname)
            chapter_titles.append(raw_name)

            # Resume: check if this chapter already exists
            out_path = os.path.join(fw_output_dir, out_fname)
            if resume and os.path.isfile(out_path):
                with open(out_path, "r", encoding="utf-8") as f:
                    existing_text = f.read()
                rewritten_texts.append(existing_text)
                fw_log(f"✓ [Resume] Ch.{i+1}/{total}: {raw_name} — loaded from disk")
                continue

            prev_context = ""
            if rewritten_texts:
                prev_context = "\n---\n".join(rewritten_texts[-2:])

            try:
                api_w = APIClient(endpoints, log_api=_log_api, tier=tier, stop_check=stop_check)
                rewritten = write_from_blueprint(
                    blueprint=blueprint,
                    style_json=style_json_raw,
                    framework_name=fw_name,
                    chapter_outline=ch_outline,
                    chapter_number=i + 1,
                    total_chapters=total,
                    api_client=api_w,
                    word_count_rule=wc_rule,
                    lang=lang,
                    previous_context=prev_context,
                    full_outline=renew_outline_str,
                    log_callback=lambda m: fw_log(m),
                    niche=niche,
                    save_dir=fw_pipeline_dir,
                )
                rewritten_texts.append(rewritten)

                lines = rewritten.split("\n", 1)
                body_only = lines[1].lstrip("\n") if len(lines) > 1 else rewritten
                out_path = os.path.join(fw_output_dir, out_fname)
                with open(out_path, "w", encoding="utf-8") as f:
                    f.write(body_only)

                if on_chapter_saved:
                    on_chapter_saved(out_fname, fw_name)
                fw_log(f"✓ Ch.{i+1}/{total}: {raw_name}")

            except Exception as e:
                rewritten_texts.append("")
                out_filenames[-1] = ""
                fw_log(f"✗ Ch.{i+1}/{total}: {e}")

        if stop_check():
            fw_log("Stopped")
            return

        # ── Cross-chapter Review + Patch ──
        fw_log("Cross-chapter review...")
        rw_chapters = []
        rw_index_map = []
        for i in range(len(rewritten_texts)):
            if rewritten_texts[i]:
                rw_chapters.append({
                    "filename": out_filenames[i] if i < len(out_filenames) else f"ch_{i+1:02d}.txt",
                    "text": rewritten_texts[i],
                    "title": chapter_titles[i] if i < len(chapter_titles) else "",
                })
                rw_index_map.append(i)

        if len(rw_chapters) >= 2:
            try:
                api_rev = APIClient(endpoints, log_api=_log_api, tier=tier, stop_check=stop_check)
                review_result = review_narrative_full(
                    rw_chapters, api_rev,
                    log_callback=lambda m: fw_log(m),
                    niche=niche, lang=lang,
                )

                issues = review_result.get("issues", [])
                auto_patched_count = 0
                if auto_patch and issues:
                    for issue in issues:
                        if issue.get("severity") in ("critical", "major"):
                            fc = issue.get("fix_chapter")
                            if not fc:
                                involved = issue.get("chapters_involved", [])
                                if involved:
                                    fc = involved[0]
                            if not fc:
                                continue
                            try:
                                fix_ch_num = int(fc)
                            except (ValueError, TypeError):
                                continue
                            if 1 <= fix_ch_num <= len(rw_chapters):
                                rw_idx = fix_ch_num - 1
                                full_ctx = "\n\n".join(
                                    f"=== Ch.{j+1} ===\n{c['text']}"
                                    for j, c in enumerate(rw_chapters)
                                )
                                api_p = APIClient(endpoints, log_api=_log_api, tier="flash", stop_check=stop_check)
                                patched = patch_chapter_overlap(
                                    rw_chapters[rw_idx]["text"], issue, full_ctx, api_p,
                                    log_callback=lambda m: fw_log(m),
                                )
                                rw_chapters[rw_idx]["text"] = patched
                                rewritten_texts[rw_index_map[rw_idx]] = patched
                                patched_fname = out_filenames[rw_index_map[rw_idx]]
                                if patched_fname:
                                    patched_path = os.path.join(fw_output_dir, patched_fname)
                                    with open(patched_path, "w", encoding="utf-8") as f:
                                        _lines = patched.split("\n", 1)
                                        _body = _lines[1].lstrip("\n") if len(_lines) > 1 else patched
                                        f.write(_body)
                                auto_patched_count += 1
                elif issues and not auto_patch:
                    n_crit = len([i for i in issues if i.get('severity') in ('critical','major')])
                    fw_log(f"⚠ {n_crit} critical/major issues found — auto-patch OFF")

                if auto_patched_count:
                    fw_log(f"✓ Auto-patched {auto_patched_count} issues")
                flow_score = review_result.get("overall_flow_score", 0)
                fw_log(f"✓ Review done! flow={flow_score}, issues={len(issues)}")

                rev_path = os.path.join(fw_pipeline_dir, "_review.json")
                with open(rev_path, "w", encoding="utf-8") as f:
                    json.dump(review_result, f, indent=2, ensure_ascii=False)
            except Exception as e:
                fw_log(f"⚠ Review failed (non-fatal): {e}")
        else:
            fw_log("Skipped review (< 2 chapters)")

        # ── Merge FULL_SCRIPT.txt ──
        if rw_chapters:
            full_path = os.path.join(fw_output_dir, "FULL_SCRIPT.txt")
            with open(full_path, "w", encoding="utf-8") as f:
                for j, c in enumerate(rw_chapters):
                    if j > 0:
                        f.write("\n\n" + "=" * 60 + "\n\n")
                    ch_title = c.get("title", "").strip()
                    if not ch_title:
                        ch_lines = c["text"].split("\n", 1)
                        ch_title = ch_lines[0].strip() if ch_lines else f"Chapter {j+1}"
                    ch_lines = c["text"].split("\n", 1)
                    ch_body = ch_lines[1].lstrip("\n") if len(ch_lines) > 1 else c["text"]
                    f.write(f"Chapter {j+1}: {ch_title}\n\n{ch_body}")
            fw_log(f"✓ Merged → FULL_SCRIPT.txt ({len(rw_chapters)} chapters)")

        fw_log(f"✓ Complete! '{fw_name}'")

    def _do_resume(self):
        """Resume an interrupted pipeline from its last checkpoint."""
        output_dir = self._txt_output.text().strip()
        if not output_dir or not os.path.isdir(output_dir):
            self._log.log("[Resume] ✗ No valid Output path — set Output folder first")
            return

        # Find _resume.json (could be in root _pipeline/ or one level up)
        pipeline_dir = os.path.join(output_dir, "_pipeline")
        resume_path = os.path.join(pipeline_dir, "_resume.json")
        if not os.path.isfile(resume_path):
            self._log.log("[Resume] ✗ No _resume.json found — this folder has no resume data")
            return

        with open(resume_path, "r", encoding="utf-8") as f:
            resume_meta = json.load(f)

        r_mode = resume_meta.get("mode", "")
        r_type = resume_meta.get("type", "")
        r_niche = resume_meta.get("niche", "")
        r_style = resume_meta.get("style", "")
        r_lang = resume_meta.get("lang", "")

        if r_mode != "Narrative":
            self._log.log(f"[Resume] ✗ Resume only supports Narrative mode (found: {r_mode})")
            return
        if r_type != "new_content":
            self._log.log(f"[Resume] ✗ Resume only supports New Content type (found: {r_type})")
            return

        self._log.log(f"[Resume] ▶ Resuming: mode={r_mode}, niche={r_niche}, style={r_style}")

        # Load style JSON
        style_path = os.path.join("styles", r_style)
        if not os.path.isfile(style_path):
            self._log.log(f"[Resume] ✗ Style file not found: {style_path}")
            return
        with open(style_path, "r", encoding="utf-8") as f:
            style_data = json.load(f)
        style_json_raw = json.dumps(style_data, ensure_ascii=False, indent=2)

        # Load blueprint (must exist for resume)
        bp_path = os.path.join(pipeline_dir, "_blueprint.json")
        if not os.path.isfile(bp_path):
            self._log.log("[Resume] ✗ No blueprint found — research not complete, cannot resume")
            return
        with open(bp_path, "r", encoding="utf-8") as f:
            blueprint = json.load(f)
        self._log.log(f"[Resume] ✓ Blueprint loaded ({len(json.dumps(blueprint)):,} chars)")

        # Detect version directories
        version_dirs = sorted([
            d for d in os.listdir(output_dir)
            if os.path.isdir(os.path.join(output_dir, d)) and re.match(r'^v\d+_', d)
        ])
        if not version_dirs:
            self._log.log("[Resume] ✗ No version folders (v1_*, v2_*) found")
            return

        # Check which versions need resume
        versions_to_resume = []
        for vdir in version_dirs:
            full_script = os.path.join(output_dir, vdir, "FULL_SCRIPT.txt")
            if os.path.exists(full_script):
                self._log.log(f"[Resume] ✓ {vdir} already complete — skip")
            else:
                # Extract framework name from dir: v1_Sử_Thi → Sử Thi
                fw_name = re.sub(r'^v\d+_', '', vdir).replace('_', ' ')
                versions_to_resume.append((vdir, fw_name))
                self._log.log(f"[Resume] ⟳ {vdir} needs resume (framework: {fw_name})")

        if not versions_to_resume:
            self._log.log("[Resume] ✓ All versions already complete — nothing to resume")
            return

        # Get settings from UI
        lang = r_lang or self._get_lang_code()
        tier = self._combo_tier.currentText().lower()
        endpoints = load_api_keys()
        if not endpoints:
            self._log.log("[Resume] ✗ No API keys configured")
            return

        _wc_cache = {
            "open": (self._wc_open_min.value(), self._wc_open_max.value()),
            "body": (self._wc_body_min.value(), self._wc_body_max.value()),
            "end": (self._wc_end_min.value(), self._wc_end_max.value()),
        }
        _ch_min = self._ch_min.value()
        _ch_max = self._ch_max.value()
        _do_patch = self._chk_auto_patch.isChecked()

        def _get_wc_rule(section="body"):
            wc_min, wc_max = _wc_cache.get(section, _wc_cache["body"])
            return build_word_count_rule(wc_min, wc_max)

        def _get_ch_range():
            if _ch_min > 0 and _ch_max > 0:
                return f"between {_ch_min} and {_ch_max} chapters"
            elif _ch_min > 0:
                return f"at least {_ch_min} chapters"
            elif _ch_max > 0:
                return f"at most {_ch_max} chapters"
            return "a suitable number of chapters"

        self._stop_flag = False
        log = lambda m: self._log.log(f"[Resume] {m}")

        def _resume_worker():
            try:
                _stopped = lambda: self._stop_flag
                self._log.set_status(f"Resuming {len(versions_to_resume)} version(s)...", False)

                if len(versions_to_resume) == 1:
                    vdir, fw_name = versions_to_resume[0]
                    fw_output_dir = os.path.join(output_dir, vdir)
                    fw_pipeline_dir = os.path.join(fw_output_dir, "_pipeline")
                    fw_log = lambda m, _pfx=f"[{vdir}]": log(f"{_pfx} {m}")
                    self._run_shared_fw_pipeline(
                        fw_name=fw_name,
                        fw_output_dir=fw_output_dir,
                        fw_pipeline_dir=fw_pipeline_dir,
                        fw_log=fw_log,
                        blueprint=blueprint,
                        style_json_raw=style_json_raw,
                        endpoints=endpoints,
                        tier=tier,
                        lang=lang,
                        niche=r_niche,
                        stop_check=_stopped,
                        get_wc_rule=_get_wc_rule,
                        get_ch_range=_get_ch_range,
                        auto_patch=_do_patch,
                        resume=True,
                    )
                else:
                    from concurrent.futures import ThreadPoolExecutor, as_completed
                    log(f"🔀 Resuming {len(versions_to_resume)} versions in PARALLEL...")
                    with ThreadPoolExecutor(max_workers=len(versions_to_resume)) as executor:
                        futures = {}
                        for vdir, fw_name in versions_to_resume:
                            fw_output_dir = os.path.join(output_dir, vdir)
                            fw_pipeline_dir = os.path.join(fw_output_dir, "_pipeline")
                            fw_log = lambda m, _pfx=f"[{vdir}]": log(f"{_pfx} {m}")
                            futures[executor.submit(
                                self._run_shared_fw_pipeline,
                                fw_name=fw_name,
                                fw_output_dir=fw_output_dir,
                                fw_pipeline_dir=fw_pipeline_dir,
                                fw_log=fw_log,
                                blueprint=blueprint,
                                style_json_raw=style_json_raw,
                                endpoints=endpoints,
                                tier=tier,
                                lang=lang,
                                niche=r_niche,
                                stop_check=_stopped,
                                get_wc_rule=_get_wc_rule,
                                get_ch_range=_get_ch_range,
                                auto_patch=_do_patch,
                                resume=True,
                            )] = vdir
                        for future in as_completed(futures):
                            vdir = futures[future]
                            try:
                                future.result()
                            except Exception as e:
                                log(f"❌ {vdir} failed: {e}")

                log("✦ Resume complete!")
                self._log.set_status("✓ Resume complete", True)
            except Exception as e:
                import traceback
                log(f"❌ Error: {e}")
                log(traceback.format_exc())
                self._log.set_status(f"❌ Resume error: {e}", True)

        threading.Thread(target=_resume_worker, daemon=True).start()

    def _do_new_content(self):
        """Launch new content creation from scratch — research topic → write script."""
        # ── 1. Popup: ask for topic ──
        topic, ok = QInputDialog.getText(
            self, "✦ New Content — Research & Write",
            "Nhập đề tài / tên nhân vật:\n(VD: Albert Einstein, Napoleon Bonaparte, Van Gogh)",
        )
        if not ok or not topic.strip():
            return
        topic = topic.strip()

        # ── 2. Validate style selection ──
        style_info = self._combo_style.currentData()  # actual filename stored as itemData
        if not style_info:
            style_info = self._combo_style.currentText()  # fallback
        if not style_info or style_info == "(no styles found)":
            QMessageBox.warning(self, "No Style", "Please select a style JSON first.")
            return

        style_path = os.path.join("styles", style_info)
        if not os.path.isfile(style_path):
            QMessageBox.warning(self, "Style not found", f"{style_path} not found")
            return

        with open(style_path, "r", encoding="utf-8") as f:
            style_data = json.load(f)
        style_json_raw = json.dumps(style_data, ensure_ascii=False, indent=2)

        # ── 3. Build output directory ──
        user_output = self._txt_output.text().strip()

        if user_output and os.path.isdir(user_output):
            # User specified an existing folder → use it directly
            output_dir = user_output
        else:
            # Auto-generate: Documents/{niche}_{topic}_{timestamp}
            _DEFAULT_BASE = os.path.join(os.path.expanduser("~"), "OneDrive", "Documents")
            if not os.path.isdir(_DEFAULT_BASE):
                _DEFAULT_BASE = os.path.join(os.path.expanduser("~"), "Documents")

            niche_raw = (style_data.get("niche", "") or "").strip().lower()
            _NICHE_LABELS = {
                "biography": "Biography", "tiểu sử": "Biography", "nhân vật": "Biography",
                "chân dung": "Biography", "cuộc đời": "Biography",
                "mystery": "Mystery", "bí ẩn": "Mystery", "enigma": "Mystery",
                "battle": "Battle", "military": "Military", "trận": "Battle", "chiến": "Battle",
                "firearms": "Firearms",
            }
            niche_label = "Content"
            for keyword, label in _NICHE_LABELS.items():
                if keyword in niche_raw:
                    niche_label = label
                    break
            topic_safe = re.sub(r'[<>:"/\\|?*]', '_', topic).replace(' ', '_')[:50]
            timestamp = datetime.now().strftime("%Y%m%d_%H%M")
            folder_name = f"{niche_label}_{topic_safe}_{timestamp}"
            output_dir = os.path.join(_DEFAULT_BASE, folder_name)

        pipeline_dir = os.path.join(output_dir, "_pipeline")
        research_dir = os.path.join(pipeline_dir, "_research_sections")

        # ── 4. Check if blueprint already exists (skip research) ──
        bp_path = os.path.join(pipeline_dir, "_blueprint.json")
        skip_research = os.path.isfile(bp_path)

        # ── 5. Collect settings & launch worker ──
        mode = self._combo_mode.currentText()
        is_review = (mode == "Top/List Review")
        lang_full = self._combo_lang.currentText() if hasattr(self, '_combo_lang') else "Tiếng Anh"
        lang = self._LANG_MAP.get(lang_full, "english")

        user_framework = self._combo_framework.currentText()
        framework_names = [
            self._combo_framework.itemText(i)
            for i in range(self._combo_framework.count())
            if self._combo_framework.itemText(i) != "Auto (detect & switch)"
        ]
        tier = self._combo_tier.currentText().lower() if hasattr(self, '_combo_tier') else "pro"
        _niche = (style_data.get("niche", "") or "").lower()

        endpoints = load_api_keys()
        if not endpoints:
            QMessageBox.warning(self, "No API Keys", "No API keys configured.")
            return

        # Cache word count settings
        _wc_cache = {
            "open": (self._wc_open_min.value(), self._wc_open_max.value()),
            "body": (self._wc_body_min.value(), self._wc_body_max.value()),
            "end": (self._wc_end_min.value(), self._wc_end_max.value()),
        }
        _ch_min = self._ch_min.value()
        _ch_max = self._ch_max.value()
        _do_patch = self._chk_auto_patch.isChecked()

        def _get_wc_rule(section="body"):
            wc_min, wc_max = _wc_cache.get(section, _wc_cache["body"])
            return build_word_count_rule(wc_min, wc_max)

        def _get_ch_range():
            if _ch_min > 0 and _ch_max > 0:
                return f"between {_ch_min} and {_ch_max} chapters"
            elif _ch_min > 0:
                return f"at least {_ch_min} chapters"
            elif _ch_max > 0:
                return f"at most {_ch_max} chapters"
            return "a suitable number of chapters"

        self._stop_flag = False
        log_prefix = f"[New] {topic[:30]}"
        log = lambda m: self._log.log(f"{log_prefix} {m}")

        log(f"✦ New Content: '{topic}'")
        log(f"  Style: {style_info} | Mode: {mode} | Lang: {lang}")
        log(f"  Output: {output_dir}")
        self._log.set_status(f"New Content: {topic[:40]}...", False)

        def _new_content_worker():
            try:
                _stopped = lambda: self._stop_flag
                os.makedirs(pipeline_dir, exist_ok=True)
                os.makedirs(research_dir, exist_ok=True)

                # Save resume metadata (step 0)
                _resume_meta = {
                    "mode": mode,
                    "type": "new_content",
                    "niche": _niche,
                    "style": style_info,
                    "lang": lang,
                    "started_at": datetime.now().isoformat(timespec="seconds"),
                }
                _resume_path = os.path.join(pipeline_dir, "_resume.json")
                with open(_resume_path, "w", encoding="utf-8") as f:
                    json.dump(_resume_meta, f, indent=2, ensure_ascii=False)

                # ═══════════════════════════════════════
                # Step 1: Research blueprint (Plan A)
                # ═══════════════════════════════════════
                if skip_research:
                    log("Step 1/6: Loading existing blueprint (skip research)...")
                    with open(bp_path, "r", encoding="utf-8") as f:
                        blueprint = json.load(f)
                    chars = len(json.dumps(blueprint, ensure_ascii=False))
                    log(f"✓ Blueprint loaded: {chars:,} chars")
                else:
                    log("Step 1/6: Researching topic (Plan A: multi-section)...")
                    blueprint = research_blueprint_multicall(
                        topic=topic,
                        api_endpoints=endpoints,
                        lang="english",  # Always research in English for max AI knowledge recall
                        save_dir=research_dir,
                        log_callback=log,
                        stop_check=_stopped,
                        niche=_niche,
                    )
                    # Save blueprint
                    with open(bp_path, "w", encoding="utf-8") as f:
                        json.dump(blueprint, f, indent=2, ensure_ascii=False)
                    log(f"📄 Saved: _pipeline/_blueprint.json")

                if _stopped():
                    log("⛔ Stopped by user")
                    return

                # ═══════════════════════════════════════
                # Step 2: Select frameworks (AI ranking)
                # ═══════════════════════════════════════
                log("Step 2/6: Selecting framework...")

                if user_framework != "Auto (detect & switch)":
                    selected_fws = [user_framework]
                    log(f"✓ User selected: '{user_framework}'")
                else:
                    api_sel = APIClient(endpoints, log_api=lambda *a: None, tier="pro", stop_check=_stopped)
                    rec_result = recommend_framework_new_content(
                        blueprint, style_data, api_sel, lang=lang,
                        log_callback=log, niche=_niche,
                    )
                    rankings = rec_result.get("rankings", [])
                    for r in rankings:
                        if "framework" in r and "name" not in r:
                            r["name"] = r.pop("framework")
                    if rankings:
                        rankings = [r for r in rankings if r.get("name") in framework_names]
                    if not rankings:
                        rankings = [{"name": fw, "score": 5, "reason": "N/A"} for fw in framework_names]
                    rankings.sort(key=lambda x: x.get("score", 0), reverse=True)

                    rank_path = os.path.join(pipeline_dir, "_rankings.json")
                    with open(rank_path, "w", encoding="utf-8") as f:
                        json.dump({"rankings": rankings}, f, indent=2, ensure_ascii=False)
                    log(f"AI ranking: " + ", ".join(f"{r['name']}={r.get('score', '?')}" for r in rankings))

                    _SCORE_THRESHOLD = 8.5
                    _niche_str = style_data.get("niche", "").lower()
                    _BIO_KEYWORDS = ("biography", "tiểu sử", "nhân vật", "chân dung", "cuộc đời")
                    _is_bio = any(kw in _niche_str for kw in _BIO_KEYWORDS)

                    if _is_bio:
                        # Biography: v1 = best of General, v2 = best of Specialized
                        _GENERAL_FWS = {"Sử Thi", "Sự Lụi Tàn"}
                        generals = [r for r in rankings if r.get("name") in _GENERAL_FWS]
                        specials = [r for r in rankings if r.get("name") not in _GENERAL_FWS]
                        generals.sort(key=lambda x: x.get("score", 0), reverse=True)
                        specials.sort(key=lambda x: x.get("score", 0), reverse=True)

                        if generals:
                            selected_fws = [generals[0]["name"]]
                            log(f"  ✓ Auto-selected v1: '{generals[0]['name']}' (score={generals[0].get('score', '?')}) [bio: general]")
                        else:
                            selected_fws = [rankings[0]["name"]]
                            log(f"  ✓ Auto-selected v1: '{rankings[0]['name']}' (score={rankings[0].get('score', '?')}) [fallback]")

                        if specials and specials[0].get("score", 0) >= _SCORE_THRESHOLD:
                            selected_fws.append(specials[0]["name"])
                            log(f"  ✓ Auto-selected v2: '{specials[0]['name']}' (score={specials[0].get('score', '?')}) [bio: specialized]")
                        elif specials:
                            log(f"  ⊘ Skipped v2: '{specials[0]['name']}' (score={specials[0].get('score', '?')} < {_SCORE_THRESHOLD})")
                    else:
                        # Non-biography: top framework always, #2 only if score >= threshold
                        selected_fws = [rankings[0]["name"]]
                        log(f"  ✓ Auto-selected v1: '{rankings[0]['name']}' (score={rankings[0].get('score', '?')})")
                        if len(rankings) >= 2 and rankings[1].get("score", 0) >= _SCORE_THRESHOLD:
                            selected_fws.append(rankings[1]["name"])
                            log(f"  ✓ Auto-selected v2: '{rankings[1]['name']}' (score={rankings[1].get('score', '?')})")

                if _stopped():
                    return

                # ═══════════════════════════════════════
                # Steps 3-6: Outline → Audit → Write → Review (per framework)
                # Uses shared pipeline — same code as Rewrite
                # Run in PARALLEL when multiple frameworks selected
                # ═══════════════════════════════════════
                def _run_single_fw(fw_idx, fw_name):
                    """Run one framework pipeline (called from thread)."""
                    safe_fw = "".join(c if c.isalnum() or c in " _-" else "_" for c in fw_name).strip().replace(" ", "_")
                    fw_output_dir = os.path.join(output_dir, f"v{fw_idx}_{safe_fw}")
                    fw_pipeline_dir = os.path.join(fw_output_dir, "_pipeline")

                    fw_log = lambda m, _pfx=f"[v{fw_idx} {fw_name[:20]}]": log(f"{_pfx} {m}")

                    self._run_shared_fw_pipeline(
                        fw_name=fw_name,
                        fw_output_dir=fw_output_dir,
                        fw_pipeline_dir=fw_pipeline_dir,
                        fw_log=fw_log,
                        blueprint=blueprint,
                        style_json_raw=style_json_raw,
                        endpoints=endpoints,
                        tier=tier,
                        lang=lang,
                        niche=_niche,
                        stop_check=_stopped,
                        get_wc_rule=_get_wc_rule,
                        get_ch_range=_get_ch_range,
                        auto_patch=_do_patch,
                    )

                if len(selected_fws) == 1:
                    _run_single_fw(1, selected_fws[0])
                else:
                    # Parallel execution for 2+ frameworks
                    from concurrent.futures import ThreadPoolExecutor, as_completed
                    log(f"🔀 Running {len(selected_fws)} frameworks in PARALLEL...")
                    with ThreadPoolExecutor(max_workers=len(selected_fws)) as executor:
                        futures = {
                            executor.submit(_run_single_fw, idx, name): name
                            for idx, name in enumerate(selected_fws, 1)
                        }
                        for future in as_completed(futures):
                            fw = futures[future]
                            try:
                                future.result()
                            except Exception as e:
                                log(f"❌ Framework '{fw}' failed: {e}")

                log(f"\n✦ New Content complete!")
                log(f"📁 Output: {output_dir}")
                self._log.set_status(f"✓ New Content: {topic[:40]}", True)

            except Exception as e:
                import traceback
                log(f"❌ Error: {e}")
                log(traceback.format_exc())
                self._log.set_status(f"❌ Error: {e}", True)

        threading.Thread(target=_new_content_worker, daemon=True).start()

    def _do_rewrite(self):
        """Create rewrite jobs for checked folders (with merge option)."""
        mode = self._combo_mode.currentText()

        # Get checked folders from left panel (checkbox on column 1)
        checked_folders = []
        for i in range(self._folder_tree.topLevelItemCount()):
            item = self._folder_tree.topLevelItem(i)
            if item and item.checkState(1) == Qt.CheckState.Checked:
                group_name = item.data(1, Qt.ItemDataRole.UserRole)
                if group_name:
                    checked_folders.append(group_name)

        if not checked_folders:
            self._log.log("[Style] No folders checked")
            return

        # If multiple folders → ask Rewrite Each or Merge
        merge = False
        if len(checked_folders) > 1:
            from PyQt6.QtWidgets import QMessageBox
            msg = QMessageBox(self)
            msg.setWindowTitle("Chọn chế độ Rewrite")
            msg.setText(
                f"Đã chọn {len(checked_folders)} thư mục.\n"
                "Bạn muốn rewrite kiểu nào?"
            )
            btn_each = msg.addButton(
                "⚡ Rewrite riêng", QMessageBox.ButtonRole.ActionRole)
            btn_merge = msg.addButton(
                "🔗 Gộp && Rewrite", QMessageBox.ButtonRole.ActionRole)
            btn_cancel = msg.addButton("Hủy", QMessageBox.ButtonRole.RejectRole)
            msg.exec()
            clicked = msg.clickedButton()
            if clicked == btn_merge:
                merge = True
            elif clicked != btn_each:
                return  # cancelled

        # ── Style-content niche check via Flash AI (per folder) ──
        try:
            import json as _json, threading
            from PyQt6.QtWidgets import QMessageBox
            from PyQt6.QtWidgets import QApplication

            style_file = self._get_style_filename() or ""
            styles_dir = os.path.join(
                os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
                "styles"
            )
            style_path = os.path.join(styles_dir, style_file)

            # Read style niche from JSON
            style_niche = ""
            if os.path.isfile(style_path):
                try:
                    with open(style_path, "r", encoding="utf-8") as _f:
                        _sdata = _json.load(_f)
                        style_niche = _sdata.get("niche", "")
                        self._style_topic_keywords = _sdata.get("topic_keywords", [])
                except Exception:
                    pass

            if style_niche and checked_folders:
                self._log.log(f"[Niche] Checking {len(checked_folders)} folder(s) against style: {style_niche}")
                style_niche_lower = style_niche.lower()
                style_words = set(style_niche_lower.split())
                if hasattr(self, '_style_topic_keywords'):
                    style_words |= set(k.lower() for k in self._style_topic_keywords)

                matched_folders = []
                mismatched_folders = []  # [(folder_name, detected_niche)]

                endpoints = load_api_keys()

                for folder_idx, gn in enumerate(checked_folders):
                    # Collect sample from this folder
                    ch_titles = []
                    ch_sample = ""
                    for ch in self._chapters:
                        if ch.get("group") == gn:
                            ch_titles.append(ch.get("filename", ""))
                            if not ch_sample and ch.get("text"):
                                words = ch["text"].split()[:200]
                                ch_sample = " ".join(words)

                    if not ch_titles:
                        matched_folders.append(gn)
                        continue

                    folder_display = gn.split("]_", 1)[-1] if "]_" in gn else gn
                    folder_display = folder_display[:50]
                    self._log.log(f"[Niche] ({folder_idx+1}/{len(checked_folders)}) Detecting: {folder_display}...")

                    titles_str = "\n".join(ch_titles[:10])
                    prompt = (
                        "Based on these chapter titles and sample text, "
                        "what is the CONTENT GENRE / NICHE TYPE? "
                        "Return the GENRE (e.g. 'biography', 'mystery history'), "
                        "NOT the specific topic (e.g. NOT 'albert einstein'). "
                        "Reply with ONLY a short phrase (2-5 words). Examples:\n"
                        "- 'biography' (for any person's life story)\n"
                        "- 'mystery history' (for historical mysteries)\n"
                        "- 'battle analysis' (for military battles)\n"
                        "- 'firearms review' (for gun reviews)\n"
                        "- 'tech gadgets' (for technology reviews)\n\n"
                        f"Chapter titles:\n{titles_str}\n\n"
                        f"Sample text (first 200 words):\n{ch_sample[:800]}"
                    )

                    api = APIClient(endpoints, log_api=False, tier="flash")
                    result = [None]

                    def _detect(api_ref=api, prompt_ref=prompt):
                        result[0] = api_ref.call_api(
                            [{"role": "user", "content": prompt_ref}],
                            temperature=0.1, max_tokens=30, timeout=15
                        )

                    t = threading.Thread(target=_detect, daemon=True)
                    t.start()
                    import time as _time
                    _deadline = _time.time() + 15
                    while t.is_alive() and _time.time() < _deadline:
                        QApplication.processEvents()
                        _time.sleep(0.1)

                    if result[0] and result[0].get("success"):
                        detected_niche = result[0]["content"].strip().strip("\"'").lower()
                        detected_words = set(detected_niche.split())
                        overlap = detected_words & style_words

                        if overlap:
                            self._log.log(f"[Niche]   ✓ '{detected_niche}' — matches style")
                            matched_folders.append(gn)
                        else:
                            self._log.log(f"[Niche]   ✗ '{detected_niche}' — does NOT match style")
                            mismatched_folders.append((gn, detected_niche))
                    else:
                        self._log.log(f"[Niche]   ⚠ Detection failed — treating as matched")
                        matched_folders.append(gn)

                # Show summary if any mismatches
                if mismatched_folders:
                    self._log.log(f"[Niche] Result: {len(matched_folders)} matched, {len(mismatched_folders)} mismatched")

                    mismatch_lines = []
                    for gn, det in mismatched_folders:
                        short = gn.split("]_", 1)[-1] if "]_" in gn else gn
                        mismatch_lines.append(f"  ✗ {short[:60]}\n     → detected: {det}")

                    match_lines = []
                    for gn in matched_folders:
                        short = gn.split("]_", 1)[-1] if "]_" in gn else gn
                        match_lines.append(f"  ✓ {short[:60]}")

                    warn_msg = (
                        f"Style niche: {style_niche}\n\n"
                        f"✗ Không khớp ({len(mismatched_folders)}):\n"
                        + "\n".join(mismatch_lines)
                    )
                    if match_lines:
                        warn_msg += (
                            f"\n\n✓ Khớp ({len(matched_folders)}):\n"
                            + "\n".join(match_lines)
                        )

                    msg = QMessageBox(self)
                    msg.setWindowTitle("⚠ Niche Check Results")
                    msg.setIcon(QMessageBox.Icon.Warning)
                    msg.setText(warn_msg)

                    btn_all = msg.addButton("▶ Chạy tất cả", QMessageBox.ButtonRole.AcceptRole)
                    if matched_folders:
                        btn_matched = msg.addButton(
                            f"▶ Chỉ chạy {len(matched_folders)} folder khớp",
                            QMessageBox.ButtonRole.ActionRole
                        )
                    else:
                        btn_matched = None
                    btn_cancel = msg.addButton("Hủy", QMessageBox.ButtonRole.RejectRole)
                    msg.exec()

                    clicked = msg.clickedButton()
                    if clicked == btn_cancel:
                        self._log.log("[Niche] ⛔ Cancelled by user")
                        return
                    elif clicked == btn_matched and btn_matched:
                        checked_folders = matched_folders
                        self._log.log(f"[Niche] Running {len(matched_folders)} matched folder(s) only")
                    else:
                        self._log.log(f"[Niche] Running all {len(checked_folders)} folder(s)")
                else:
                    self._log.log(f"[Niche] ✓ All {len(checked_folders)} folder(s) match style")
        except Exception as e:
            self._log.log(f"[Niche] ⚠ Check error: {e}")

        if merge:
            self._do_rewrite_merge(checked_folders, mode)
        else:
            self._do_rewrite_each(checked_folders, mode)

    def _do_rewrite_merge(self, checked_folders, mode):
        """Merge all checked folders into a single job."""
        # Merge requires explicit output path
        if not self._txt_output.text().strip():
            QMessageBox.warning(
                self, "Merge",
                "Chế độ Merge bắt buộc phải chọn thư mục Output.\n"
                "Vui lòng chọn đường dẫn output trước khi merge."
            )
            return
        all_chapters = []
        for gn in checked_folders:
            chs = [c for c in self._chapters if c.get("group") == gn]
            all_chapters.extend(chs)
        if not all_chapters:
            self._log.log("[Style] No chapters in checked folders")
            return

        # Use first folder's path for output
        group_path = os.path.dirname(all_chapters[0]["filepath"])
        merged_name = " + ".join(gn[:20] for gn in checked_folders[:3])
        if len(checked_folders) > 3:
            merged_name += f" +{len(checked_folders)-3} more"

        self._task_counter += 1
        task_num = self._task_counter
        self._create_and_submit_job(
            folder_name=merged_name, group_path=group_path,
            mode=mode, chapters=all_chapters, task_num=task_num,
            merged_groups=list(checked_folders),
        )
        self.job_update.emit()
        self._log.log(
            f"[Task {task_num}] Merged {len(checked_folders)} folders "
            f"({len(all_chapters)} chapters) → 1 job"
        )

    def _do_rewrite_each(self, checked_folders, mode):
        """Create 1 job per checked folder."""
        jobs_created = 0
        for group_name in checked_folders:
            folder_chapters = [
                ch for ch in self._chapters
                if ch.get("group") == group_name
            ]
            if not folder_chapters:
                continue
            group_path = os.path.dirname(folder_chapters[0]["filepath"])
            self._task_counter += 1
            self._create_and_submit_job(
                folder_name=group_name, group_path=group_path,
                mode=mode, chapters=folder_chapters,
                task_num=self._task_counter,
            )
            jobs_created += 1

        if jobs_created > 0:
            self.job_update.emit()
            self._log.log(f"[Job] {jobs_created} job(s) submitted")
        else:
            self._log.log("[Style] No chapters found in checked folders")

    def _do_rewrite_chapter(self):
        """Rewrite selected chapters using existing pipeline data."""
        checked = self._get_checked_chapters()
        if not checked:
            self._log.log("[Re-ch] No chapters checked")
            return

        # Find the output directory (style_rewrite/) from checked files
        first_path = checked[0]["filepath"]
        output_dir = os.path.dirname(first_path)
        pipeline_dir = os.path.join(output_dir, "_pipeline")

        # If _pipeline/ not found here, the checked file may be an INPUT file
        # → look in style_rewrite/ under the input file's directory instead
        if not os.path.isdir(pipeline_dir):
            alt_output = os.path.join(output_dir, "style_rewrite")
            alt_pipeline = os.path.join(alt_output, "_pipeline")
            if os.path.isdir(alt_pipeline):
                output_dir = alt_output
                pipeline_dir = alt_pipeline
                self._log.log("[Re-ch] Found pipeline in style_rewrite/")

        if not os.path.isdir(pipeline_dir):
            self._log.log("[Re-ch] ✗ No _pipeline/ folder found — run full pipeline first")
            return

        # Detect mode: review has _review_outline*.json, narrative has _renew_outline*.json
        is_review = os.path.isfile(os.path.join(pipeline_dir, "_review_outline.json"))
        is_narrative = os.path.isfile(os.path.join(pipeline_dir, "_renew_outline.json"))

        if not is_review and not is_narrative:
            self._log.log("[Re-ch] ✗ No outline found in _pipeline/")
            return

        mode_label = "review" if is_review else "narrative"
        self._log.log(f"[Re-ch] Mode: {mode_label}, {len(checked)} chapter(s) selected")

        # Load pipeline data
        try:
            # Blueprint
            bp_path = os.path.join(pipeline_dir, "_blueprint.json")
            if not os.path.isfile(bp_path):
                bp_path = os.path.join(pipeline_dir, "_blueprint_converted.json")
            with open(bp_path, "r", encoding="utf-8") as f:
                blueprint = json.load(f)
            self._log.log(f"[Re-ch] ✓ Loaded blueprint")

            # Outline (prefer audited version)
            if is_review:
                outline_path = os.path.join(pipeline_dir, "_review_outline_audited.json")
                if not os.path.isfile(outline_path):
                    outline_path = os.path.join(pipeline_dir, "_review_outline.json")
            else:
                outline_path = os.path.join(pipeline_dir, "_renew_outline_audited.json")
                if not os.path.isfile(outline_path):
                    outline_path = os.path.join(pipeline_dir, "_renew_outline.json")
            with open(outline_path, "r", encoding="utf-8") as f:
                outline = json.load(f)
            out_chapters = outline.get("chapters", [])
            self._log.log(f"[Re-ch] ✓ Loaded outline ({len(out_chapters)} chapters)")

            # Style JSON
            style_json_raw, style_info = self._load_style_json_raw()
            if style_json_raw is None:
                self._log.log(f"[Re-ch] ✗ {style_info}")
                return

            # Extract niche from style filename (same as _do_renew_style)
            _niche = style_info.replace(".json", "").split("_", 1)[-1].replace("_", " ") if "_" in style_info else ""
            if _niche:
                self._log.log(f"[Re-ch] Niche: {_niche}")

            # Framework name from outline
            selected_fw = outline.get("framework", outline.get("target_framework", ""))
            if not selected_fw:
                # Try detection file
                det_path = os.path.join(pipeline_dir, "_detection.json")
                if os.path.isfile(det_path):
                    with open(det_path, "r", encoding="utf-8") as f:
                        det = json.load(f)
                    selected_fw = det.get("detected_framework", "Unknown")
            self._log.log(f"[Re-ch] Framework: {selected_fw}")

        except Exception as e:
            self._log.log(f"[Re-ch] ✗ Failed to load pipeline data: {e}")
            return

        # Settings
        lang = self._get_lang_code()
        tier = self._combo_tier.currentText().lower()
        target_country = self._combo_country.currentText()
        outline_json_str = json.dumps(outline, indent=2, ensure_ascii=False)

        # Build list of all output chapter files in order
        all_ch_files = sorted(
            [f for f in os.listdir(output_dir)
             if f.startswith("ch_") and f.endswith(".txt")],
            key=lambda x: x
        )

        # Submit as background job
        self._task_counter += 1
        task_num = self._task_counter
        log_prefix = f"[Task {task_num}]"
        stop_event = threading.Event()

        def _run():
            log = lambda m: self._log.log(f"{log_prefix} {m}")
            endpoints = load_api_keys()
            log_api = False
            _use_transitions = self._chk_transitions.isChecked()

            for ch_data in checked:
                if stop_event.is_set():
                    log("Stopped")
                    return

                fname = ch_data["filename"]
                # Parse index from filename: ch_05_xxx.txt → 4 (0-indexed)
                try:
                    ch_idx = int(fname.split("_")[1]) - 1
                except (IndexError, ValueError):
                    log(f"✗ Cannot parse chapter index from '{fname}'")
                    continue

                if ch_idx < 0 or ch_idx >= len(out_chapters):
                    log(f"✗ Chapter index {ch_idx+1} out of range (outline has {len(out_chapters)} chapters)")
                    continue

                ch_outline = out_chapters[ch_idx]
                ch_type = ch_outline.get("chapter_type", "body")
                total = len(out_chapters)

                # Word count
                if ch_type == "hook":
                    wc_section = "open"
                elif ch_type == "end":
                    wc_section = "end"
                elif ch_idx == 0:
                    wc_section = "open"
                elif ch_idx == total - 1:
                    wc_section = "end"
                else:
                    wc_section = "body"
                wc_rule = _get_wc_rule_s(wc_section)

                # SKIP: if both min/max = 0, skip this chapter
                if wc_rule == "SKIP":
                    fw_log(f"⏭ Ch.{ch_idx+1}/{total}: skipped ({wc_section} = SKIP)")
                    continue

                # Build previous context (hook = none, body/end = adjacent chapters)
                prev_context = ""
                if ch_type != "hook" and ch_idx > 0:
                    context_parts = []
                    # Read ch[i-1]
                    if ch_idx - 1 >= 0 and ch_idx - 1 < len(all_ch_files):
                        prev_file = os.path.join(output_dir, all_ch_files[ch_idx - 1])
                        if os.path.isfile(prev_file):
                            with open(prev_file, "r", encoding="utf-8") as f:
                                context_parts.append(f.read())
                    # Read ch[i+1] for context
                    if ch_idx + 1 < len(all_ch_files):
                        next_file = os.path.join(output_dir, all_ch_files[ch_idx + 1])
                        if os.path.isfile(next_file):
                            with open(next_file, "r", encoding="utf-8") as f2:
                                context_parts.append(f2.read())
                    prev_context = "\n---\n".join(context_parts)

                log(f"Rewriting ch.{ch_idx+1}/{total}: {fname} (type={ch_type})")

                try:
                    api_w = APIClient(
                        endpoints, log_api=log_api, tier=tier,
                        stop_check=lambda: stop_event.is_set()
                    )

                    if is_review:
                        rewritten = write_review_chapter(
                            blueprint=blueprint,
                            style_json=style_json_raw,
                            framework_name=selected_fw,
                            chapter_outline=ch_outline,
                            chapter_number=ch_idx + 1,
                            total_chapters=total,
                            api_client=api_w,
                            word_count_rule=wc_rule,
                            lang=lang,
                            previous_context=prev_context,
                            target_country=target_country,
                            full_outline=outline_json_str,
                            log_callback=lambda m: log(m),
                            use_transitions=_use_transitions,
                        )
                    else:
                        rewritten = write_from_blueprint(
                            blueprint=blueprint,
                            style_json=style_json_raw,
                            framework_name=selected_fw,
                            chapter_outline=ch_outline,
                            chapter_number=ch_idx + 1,
                            total_chapters=total,
                            api_client=api_w,
                            word_count_rule=wc_rule,
                            lang=lang,
                            previous_context=prev_context,
                            full_outline=outline_json_str,
                            log_callback=lambda m: log(m),
                            niche=_niche,
                            save_dir=pipeline_dir,
                        )

                    # Write output (overwrite)
                    out_path = os.path.join(output_dir, fname)
                    with open(out_path, "w", encoding="utf-8") as f:
                        f.write(rewritten)
                    log(f"✓ Rewrote: {fname}")

                except Exception as e:
                    log(f"✗ Failed: {fname} — {e}")

            log("✓ Re-ch complete")

        # Submit to thread pool
        self._job_counter += 1
        jid = f"job_{self._job_counter}"
        job = {
            "id": jid,
            "task_num": task_num,
            "folder_name": f"Re-ch ({len(checked)} ch)",
            "group_path": output_dir,
            "mode": "Re-ch",
            "stop_event": stop_event,
            "status": "running",
            "progress": "Starting...",
            "checked": checked,
            "future": None,
            "log_prefix": log_prefix,
        }
        self._jobs[jid] = job

        def _wrapper():
            try:
                _run()
                if not stop_event.is_set():
                    job["status"] = "done"
                    job["progress"] = "✓ Complete"
                else:
                    job["status"] = "stopped"
                    job["progress"] = "Stopped"
            except Exception as e:
                job["status"] = "error"
                job["progress"] = str(e)[:50]
            self.job_update.emit()

        future = self._job_pool.submit(_wrapper)
        job["future"] = future
        self._log.log(f"[Task {task_num}] Re-ch started: {len(checked)} chapter(s)")
        self.job_update.emit()


    def _create_and_submit_job(self, folder_name, group_path, mode,
                               chapters, task_num, merged_groups=None):
        """Create a job dict and submit to the thread pool."""
        self._job_counter += 1
        jid = f"job_{self._job_counter}"
        stop_event = threading.Event()
        job = {
            "id": jid,
            "task_num": task_num,
            "folder_name": folder_name,
            "group_path": group_path,
            "mode": mode,
            "stop_event": stop_event,
            "status": "running",
            "progress": "Starting...",
            "checked": list(chapters),
            "future": None,
            "log_prefix": f"[Task {task_num}]",
            # Cache UI values for thread-safe access in worker
            "_cached_wc_open": (self._wc_open_min.value(), self._wc_open_max.value()),
            "_cached_wc_body": (self._wc_body_min.value(), self._wc_body_max.value()),
            "_cached_wc_end": (self._wc_end_min.value(), self._wc_end_max.value()),
            "_cached_ch_min": self._ch_min.value(),
            "_cached_ch_max": self._ch_max.value(),
            "_cached_transitions": self._chk_transitions.isChecked(),
            "_cached_google_check": self._chk_google_check.isChecked(),
            "_cached_auto_patch": self._chk_auto_patch.isChecked(),
        }
        if merged_groups:
            job["merged_groups"] = merged_groups
        self._jobs[jid] = job

        def _job_wrapper(j=job, m=mode, se=stop_event):
            try:
                if m == "Top/List Review":
                    self._do_renew_review(job=j)
                else:
                    self._do_renew_style(job=j)
                if not se.is_set():
                    # Post-rewrite: Video cutting
                    if self._chk_cut_video.isChecked():
                        self._do_cut_video_for_group(j)
                    j["status"] = "done"
                    j["progress"] = "✓ Complete"
                else:
                    j["status"] = "stopped"
                    j["progress"] = "Stopped"
            except Exception as e:
                j["status"] = "error"
                j["progress"] = str(e)[:50]
            self.job_update.emit()

        future = self._job_pool.submit(_job_wrapper)
        job["future"] = future
        self._log.log(f"[Task {task_num}] Started: {folder_name} ({mode})")

    @staticmethod
    def _strip_source_tags(obj):
        """Recursively strip source tags: {'value': X, 'source': ...} → X."""
        if isinstance(obj, dict):
            if "value" in obj and "source" in obj and len(obj) == 2:
                return obj["value"]
            return {k: ScriptCreationTab._strip_source_tags(v) for k, v in obj.items()}
        if isinstance(obj, list):
            return [ScriptCreationTab._strip_source_tags(item) for item in obj]
        return obj

    def _load_style_json_raw(self):
        """Load the raw style JSON string for the selected style."""
        style_file = self._get_style_filename()
        if not style_file:
            return None, "No style selected"
        styles_dir = os.path.join(
            os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
            "styles"
        )
        style_path = os.path.join(styles_dir, style_file)
        if not os.path.isfile(style_path):
            return None, f"Style file not found: {style_file}"
        with open(style_path, "r", encoding="utf-8") as f:
            return f.read(), style_file

    def _do_renew_style(self, job=None):
        checked = job["checked"] if job else self._get_checked_chapters()
        if not checked:
            self._log.log(f"{job.get('log_prefix', '[Renew]') if job else '[Renew]'} No chapters selected")
            return
        output_dir = (job.get("_cached_output_dir") if job else None) or self._resolve_output_dir(checked[0]["filepath"])
        if not output_dir:
            return

        # Use cached style JSON from job (Auto Pipeline) or load from widget
        if job and job.get("_cached_style_raw"):
            style_json_raw = job["_cached_style_raw"]
            style_info = job.get("_cached_style_info", "auto")
        else:
            style_json_raw, style_info = self._load_style_json_raw()
        if style_json_raw is None:
            self._log.log(f"[Renew] ✗ {style_info}")
            return

        # Parse style JSON to get framework names
        try:
            style_data = json.loads(style_json_raw)
            framework_names = [
                fw.get("name", "") for fw in style_data.get("frameworks", [])
                if fw.get("enabled", True)
            ]
        except (json.JSONDecodeError, AttributeError):
            framework_names = []

        if not framework_names:
            self._log.log(f"{job.get('log_prefix', '[Renew]') if job else '[Renew]'} ✗ No frameworks found in style guide")
            return

        group_path = job["group_path"] if job else self._group_path
        stop_event = job["stop_event"] if job else None
        log_prefix = job["log_prefix"] if job else "[Renew]"
        if not job:
            self._running = True
        tier = job.get("_cached_tier", self._combo_tier.currentText().lower()) if job else self._combo_tier.currentText().lower()
        log_api = False
        lang = job.get("_cached_lang", self._get_lang_code()) if job else self._get_lang_code()
        user_framework = job.get("_cached_framework", self._combo_framework.currentText()) if job else self._combo_framework.currentText()

        # Cached word count / chapter count / transitions (thread-safe)
        if job:
            _wc_cache = {
                "open": job.get("_cached_wc_open", (0, 0)),
                "body": job.get("_cached_wc_body", (0, 0)),
                "end": job.get("_cached_wc_end", (0, 0)),
            }
            _ch_min = job.get("_cached_ch_min", 0)
            _ch_max = job.get("_cached_ch_max", 0)
            _use_transitions = job.get("_cached_transitions", True)
        else:
            _wc_cache = {
                "open": (self._wc_open_min.value(), self._wc_open_max.value()),
                "body": (self._wc_body_min.value(), self._wc_body_max.value()),
                "end": (self._wc_end_min.value(), self._wc_end_max.value()),
            }
            _ch_min = self._ch_min.value()
            _ch_max = self._ch_max.value()
            _use_transitions = self._chk_transitions.isChecked()

        def _get_wc_rule_s(section="body"):
            wc_min, wc_max = _wc_cache.get(section, _wc_cache["body"])
            return build_word_count_rule(wc_min, wc_max)

        def _get_ch_range_s():
            if _ch_min > 0 and _ch_max > 0:
                return f"between {_ch_min} and {_ch_max} chapters"
            elif _ch_min > 0:
                return f"at least {_ch_min} chapters"
            elif _ch_max > 0:
                return f"at most {_ch_max} chapters"
            return "a suitable number of chapters"

        self._log.log(
            f"{log_prefix} Starting pipeline: {len(checked)} input(s), "
            f"style={style_info}, {len(framework_names)} frameworks"
        )
        self._log.set_status(f"{log_prefix} detecting framework...", False)

        def _run():
            # Per-job stop check
            def _stopped():
                if stop_event and stop_event.is_set():
                    return True
                return self._stop_flag
            # Patch self._stop_flag for backward compat with API clients
            # that use lambda: self._stop_flag
            if not job:
                self._stop_flag = False

            def _update_job_progress(text):
                if job:
                    job["progress"] = text
                    self.job_update.emit()

            # Log wrapper: auto-prefix all messages with [Task N]
            log = lambda m: self._log.log(f"{log_prefix} {m}")

            try:
                endpoints = load_api_keys()
                chapters_data = self._status.setdefault("chapters", {})

                # Mark all input chapters as processing
                self._update_input_chapters_status(
                    checked, "processing", chapters_data, "Step 1/8"
                )
                _update_job_progress("Step 1/8")

                # ── Step 1: Concatenate all text ──
                full_text = ""
                for i, ch in enumerate(checked, 1):
                    full_text += f"\n\n=== PART {i}: {ch['filename']} ===\n{ch['text']}"

                log(f"Step 1/8: Full text {len(full_text):,} chars")
                _update_job_progress("Step 1/8")

                if _stopped():
                    return

                # Get niche from style JSON (consistent with Review mode)
                _niche = (style_data.get("niche", "") or "").lower()
                if not _niche:
                    # Fallback: extract from style filename
                    _niche = style_info.replace(".json", "").split("_", 1)[-1].replace("_", " ") if "_" in style_info else ""

                # ── Step 2: Detect original framework ──
                log("Step 2/8: Detecting original framework...")
                _update_job_progress("Step 2/8")

                api_det = APIClient(endpoints, log_api=log_api, tier="flash", stop_check=_stopped)
                detection = detect_framework(
                    full_text, api_det,
                    log_callback=lambda m: log(m),
                    frameworks_list=style_data.get("frameworks", []),
                )
                original_fw = detection.get("detected_framework", "")
                confidence = detection.get("confidence", "?")
                log(
                    f"✓ Original framework: '{original_fw}' (confidence: {confidence})"                )

                # Save detection result
                os.makedirs(output_dir, exist_ok=True)
                pipeline_dir = os.path.join(output_dir, "_pipeline")
                os.makedirs(pipeline_dir, exist_ok=True)
                det_path = os.path.join(pipeline_dir, "_detection.json")
                with open(det_path, "w", encoding="utf-8") as f:
                    json.dump(detection, f, indent=2, ensure_ascii=False)
                log(f"📄 Saved: _pipeline/_detection.json")
                if _stopped():
                    return

                # ── Step 3: Extract blueprint ──
                log("Step 3/8: Extracting content blueprint...")
                _update_job_progress("Step 3/8")

                self._log.set_status("Renew: extracting blueprint...", False)
                api_bp = APIClient(endpoints, log_api=log_api, tier=tier, stop_check=_stopped)
                blueprint = extract_blueprint(
                    full_text, api_bp, lang=lang,
                    log_callback=lambda m: log(m),
                    niche=_niche,
                )
                # Log niche-appropriate blueprint summary
                bp_parts = []
                for field, label in [
                    ("life_phases", "life phases"), ("battle_phases", "battle phases"),
                    ("key_facts", "facts"), ("key_events", "events"),
                    ("achievements", "achievements"), ("conflicts", "conflicts"),
                    ("turning_points", "turning points"), ("systemic_opposition", "systemic opposition"),
                    ("key_relationships", "relationships"),
                ]:
                    n = len(blueprint.get(field, []))
                    if n > 0:
                        bp_parts.append(f"{n} {label}")
                log(f"✓ Blueprint: {', '.join(bp_parts) if bp_parts else 'extracted'}")

                # Save blueprint for reference
                bp_path = os.path.join(pipeline_dir, "_blueprint.json")
                with open(bp_path, "w", encoding="utf-8") as f:
                    json.dump(blueprint, f, indent=2, ensure_ascii=False)

                if _stopped():
                    return

                # ── Step 3.5: Enrich empty blueprint fields ──
                # Always runs: Google Check ON → Google Search, OFF → AI knowledge
                _google_check_on = job.get("_cached_google_check", self._chk_google_check.isChecked()) if job else self._chk_google_check.isChecked()
                _gemini_keys = load_gemini_keys()
                if _gemini_keys:
                    _src = "Google Search fallback" if _google_check_on else "AI knowledge only"
                    log(f"Step 3.5: Enriching blueprint ({_src})...")
                    self._log.set_status("Enriching blueprint data...", False)
                    try:
                        enrich_result = enrich_blueprint_google(
                            blueprint, _gemini_keys,
                            niche=_niche,
                            lang=lang,
                            log_callback=lambda m: log(m),
                            stop_check=_stopped,
                            use_google_search=_google_check_on,
                            api_endpoints=endpoints,
                        )
                        # Save enrichment result
                        er_path = os.path.join(pipeline_dir, "_enrichment.json")
                        with open(er_path, "w", encoding="utf-8") as f:
                            json.dump(enrich_result, f, indent=2, ensure_ascii=False)
                        log(f"📄 Saved: _enrichment.json")

                        # Re-save enriched blueprint
                        if enrich_result.get("fields_filled", 0) > 0:
                            with open(bp_path, "w", encoding="utf-8") as f:
                                json.dump(blueprint, f, indent=2, ensure_ascii=False)
                            log(f"✓ Blueprint updated with {enrich_result['fields_filled']} enriched field(s)")
                    except Exception as e:
                        log(f"⚠️ Enrichment failed (non-fatal): {e}")
                else:
                    log("⚠ No Gemini API keys — skipping enrichment")

                if _stopped():
                    return

                # ── Step 4: Select frameworks ──
                if user_framework != "Auto (detect & switch)":
                    # User explicitly chose a framework
                    selected_fws = [user_framework]
                    log(
                        f"✓ User selected framework: '{user_framework}'"                    )
                else:
                    # Auto mode: AI ranks all frameworks
                    available = framework_names

                    # Rewrite mode: always use generic AI-only framework recommendation
                    api_sel = APIClient(
                        endpoints, log_api=log_api, tier="pro",
                        stop_check=_stopped
                    )
                    rec_result = recommend_framework(
                        blueprint, style_data, api_sel, lang=lang,
                        log_callback=lambda m: log(m)
                    )

                    rankings = rec_result.get("rankings", [])

                    # Normalize keys: API may return "framework" or "name"
                    for r in rankings:
                        if "framework" in r and "name" not in r:
                            r["name"] = r.pop("framework")
                        if "reasoning" in r and "reason" not in r:
                            r["reason"] = r.pop("reasoning")

                    if rankings:
                        # Filter to only valid framework names
                        rankings = [r for r in rankings if r.get("name") in available]
                        if not rankings:
                            rankings = [{"name": fw, "score": 5, "reason": "Không có đánh giá"} for fw in available]
                    else:
                        # Fallback: equal scores
                        rankings = [{"name": fw, "score": 5, "reason": "AI không thể đánh giá"} for fw in available]
                        log("⚠ AI ranking failed, showing equal scores")

                    # Sort by score descending
                    rankings.sort(key=lambda x: x.get("score", 0), reverse=True)

                    # Save rankings
                    rank_path = os.path.join(pipeline_dir, "_rankings.json")
                    with open(rank_path, "w", encoding="utf-8") as f:
                        json.dump({
                            "original_framework": original_fw,
                            "original_confidence": confidence,
                            "rankings": rankings
                        }, f, indent=2, ensure_ascii=False)
                    log(f"📄 Saved: _pipeline/_rankings.json")
                    log(
                        f"AI ranking: "                        + ", ".join(f"{r['name']}={r.get('score', '?')}" for r in rankings)
                    )

                    # ── Auto-select frameworks ──
                    _niche_str = style_data.get("niche", "").lower()
                    _BATTLE_KEYWORDS = ("battle", "war", "military", "combat")
                    _is_battle = any(kw in _niche_str for kw in _BATTLE_KEYWORDS)

                    if _is_battle:
                        # Battle niche: ALWAYS include "The Investigative Deep-Dive"
                        # + add best of REMAINING frameworks only if score >= 8.5
                        _MUST_HAVE = "The Investigative Deep-Dive"
                        _SCORE_THRESHOLD = 8.5
                        selected_fws = [_MUST_HAVE]
                        inv_score = next((r.get("score", "?") for r in rankings if r["name"] == _MUST_HAVE), "?")
                        log(f"  ✓ Auto-selected v1: '{_MUST_HAVE}' (score={inv_score}) [battle: must-have]")

                        # Best from remaining (excluding Investigative)
                        remaining = [r for r in rankings if r["name"] != _MUST_HAVE]
                        if remaining:
                            best = remaining[0]
                            if best.get("score", 0) >= _SCORE_THRESHOLD:
                                selected_fws.append(best["name"])
                                log(f"  ✓ Auto-selected v2: '{best['name']}' (score={best.get('score', '?')}) [battle: top remaining]")
                            else:
                                log(f"  ⊘ Skipped v2: '{best['name']}' (score={best.get('score', '?')} < {_SCORE_THRESHOLD})")
                    else:
                        _SCORE_THRESHOLD = 8.5
                        _BIO_KEYWORDS = ("biography", "tiểu sử", "nhân vật", "chân dung", "cuộc đời")
                        _is_bio = any(kw in _niche_str for kw in _BIO_KEYWORDS)

                        if _is_bio:
                            # Biography: v1 = best of General, v2 = best of Specialized
                            _GENERAL_FWS = {"Sử Thi", "Sự Lụi Tàn"}
                            generals = [r for r in rankings if r.get("name") in _GENERAL_FWS]
                            specials = [r for r in rankings if r.get("name") not in _GENERAL_FWS]
                            generals.sort(key=lambda x: x.get("score", 0), reverse=True)
                            specials.sort(key=lambda x: x.get("score", 0), reverse=True)

                            if generals:
                                selected_fws = [generals[0]["name"]]
                                log(f"  ✓ Auto-selected v1: '{generals[0]['name']}' (score={generals[0].get('score', '?')}) [bio: general]")
                            else:
                                selected_fws = [rankings[0]["name"]]
                                log(f"  ✓ Auto-selected v1: '{rankings[0]['name']}' (score={rankings[0].get('score', '?')}) [fallback]")

                            if specials and specials[0].get("score", 0) >= _SCORE_THRESHOLD:
                                selected_fws.append(specials[0]["name"])
                                log(f"  ✓ Auto-selected v2: '{specials[0]['name']}' (score={specials[0].get('score', '?')}) [bio: specialized]")
                            elif specials:
                                log(f"  ⊘ Skipped v2: '{specials[0]['name']}' (score={specials[0].get('score', '?')} < {_SCORE_THRESHOLD})")
                        else:
                            # Non-biography/non-battle: top framework always, #2 only if score >= threshold
                            selected_fws = [rankings[0]["name"]]
                            log(f"  ✓ Auto-selected v1: '{rankings[0]['name']}' (score={rankings[0].get('score', '?')})")

                            if len(rankings) >= 2:
                                v2_score = rankings[1].get("score", 0)
                                if v2_score >= _SCORE_THRESHOLD:
                                    selected_fws.append(rankings[1]["name"])
                                    log(f"  ✓ Auto-selected v2: '{rankings[1]['name']}' (score={v2_score})")
                                else:
                                    log(f"  ⊘ Skipped v2: '{rankings[1]['name']}' (score={v2_score} < {_SCORE_THRESHOLD})")

                if _stopped():
                    return

                # ── Helper: build version directory name ──
                def _fw_dir_name(idx, fw_name):
                    safe = "".join(
                        c if c.isalnum() or c in " _-" else "_"
                        for c in fw_name
                    ).strip().replace(" ", "_")
                    # Add score from rankings if available
                    _score_map = {r["name"]: r.get("score", 0) for r in rankings} if 'rankings' in dir() else {}
                    _s = _score_map.get(fw_name, 0)
                    score_suffix = f"_{_s}" if _s else ""
                    return f"v{idx}_{safe}{score_suffix}"

                # ── Helper: run Steps 5-8 for one framework ──
                def _run_fw_pipeline(fw_name, fw_output_dir, fw_pipeline_dir, fw_log):
                    """Steps 5-8 for a single framework — delegates to shared pipeline."""
                    _do_patch = job.get("_cached_auto_patch", False) if job else self._chk_auto_patch.isChecked()

                    def _on_ch_saved(out_fname, _fw_name):
                        with self._lock:
                            chapters_data[out_fname] = {
                                "status": "rewritten",
                                "rewritten_at": datetime.now().strftime("%Y-%m-%d %H:%M"),
                                "lang": lang,
                                "rewrite_mode": "renew",
                                "framework": _fw_name,
                                "original_framework": original_fw,
                                "output_file": out_fname,
                            }
                        self._save_status_safe(group_path)

                    self._run_shared_fw_pipeline(
                        fw_name=fw_name,
                        fw_output_dir=fw_output_dir,
                        fw_pipeline_dir=fw_pipeline_dir,
                        fw_log=fw_log,
                        blueprint=blueprint,
                        style_json_raw=style_json_raw,
                        endpoints=endpoints,
                        tier=tier,
                        lang=lang,
                        niche=_niche,
                        stop_check=_stopped,
                        get_wc_rule=_get_wc_rule_s,
                        get_ch_range=_get_ch_range_s,
                        log_api=log_api,
                        on_chapter_saved=_on_ch_saved,
                        auto_patch=_do_patch,
                    )

                # ── Execute framework pipeline(s) ──
                if len(selected_fws) == 1:
                    # Single framework → flat output (backward compatible)
                    _update_job_progress("Steps 5-8")
                    _run_fw_pipeline(
                        selected_fws[0], output_dir, pipeline_dir,
                        fw_log=log
                    )
                else:
                    # Dual framework → parallel execution in versioned dirs
                    from concurrent.futures import ThreadPoolExecutor as _FwTPE, as_completed as _fw_ac

                    fw_tasks = []
                    for idx, fw_name in enumerate(selected_fws, 1):
                        dir_name = _fw_dir_name(idx, fw_name)
                        fw_out = os.path.join(output_dir, dir_name)
                        fw_pipe = os.path.join(fw_out, "_pipeline")
                        tag = f"[v{idx}]"
                        fw_log_fn = lambda m, _tag=tag: log(f"{_tag} {m}")
                        fw_tasks.append((fw_name, fw_out, fw_pipe, fw_log_fn))

                    log(f"🔀 Running {len(fw_tasks)} frameworks in parallel:")
                    for fw_name, fw_out, _, _ in fw_tasks:
                        log(f"  → {fw_name} → {os.path.basename(fw_out)}/")

                    _update_job_progress("Steps 5-8 (dual)")

                    with _FwTPE(max_workers=len(fw_tasks), thread_name_prefix="fw") as fw_pool:
                        futs = []
                        for fw_name, fw_out, fw_pipe, fw_log_fn in fw_tasks:
                            futs.append(
                                fw_pool.submit(
                                    _run_fw_pipeline,
                                    fw_name, fw_out, fw_pipe, fw_log_fn
                                )
                            )
                        for fut in _fw_ac(futs):
                            try:
                                fut.result()
                            except Exception as e:
                                log(f"⚠️ Framework pipeline error: {e}")

                self._log.set_status("Done", False)
                log(
                    f"✓ All done! {len(selected_fws)} version(s): "
                    + ", ".join(selected_fws)
                )
                self._update_input_chapters_status(
                    checked, "verified", chapters_data, "✓ Done"
                )
                try:
                    import winsound
                    winsound.MessageBeep(winsound.MB_ICONASTERISK)
                except Exception:
                    pass

                # ── Excel update: Rewrite = Done ──
                self._update_excel_rewrite(group_path)

            except Exception as e:
                log(f"Error: {e}")
                self._log.set_status("Error", True)
                self._update_input_chapters_status(
                    checked, "error", chapters_data, str(e)[:50]
                )
                try:
                    import winsound
                    winsound.MessageBeep(winsound.MB_ICONHAND)
                except Exception:
                    pass
            finally:
                if not job:
                    self._running = False

        if job:
            _run()  # ThreadPoolExecutor handles threading
        else:
            threading.Thread(target=_run, daemon=True).start()

    def _extract_video_id_from_path(self, folder_path):
        """Extract video ID from folder name. Supports [videoID] bracket format."""
        import re
        folder_name = os.path.basename(folder_path)
        # Try bracket format: [videoID]
        m = re.search(r'\[([A-Za-z0-9_-]+)\]', folder_name)
        if m:
            return m.group(1)
        # Fallback: 11 chars after STT_
        m = re.match(r'^\d{3,}_', folder_name)
        if m:
            rest = folder_name[m.end():]
            if len(rest) >= 11:
                candidate = rest[:11]
                after = rest[11:12] if len(rest) > 11 else ""
                if after in ('_', '') and re.match(r'^[A-Za-z0-9_-]+$', candidate):
                    return candidate
        return ""

    def _update_excel_rewrite(self, group_path):
        """Update Excel Rewrite column after successful rewrite."""
        if not self._chk_excel_update.isChecked():
            return
        video_id = self._extract_video_id_from_path(group_path)
        log_fn = lambda m: self._log.log(f"[Excel] {m}")
        if not video_id:
            log_fn("Could not extract video ID from folder name")
            return
        yt_cfg = load_config("youtube_config")
        excel_folder = yt_cfg.get("excel_folder", "") if yt_cfg else ""
        if not excel_folder:
            log_fn("Excel folder not set in YouTube config")
            return
        excel_path = find_excel_for_video_id(excel_folder, video_id)
        if not excel_path:
            log_fn(f"No Excel entry found for {video_id}")
            return
        try:
            update_excel_rewrite_status(excel_path, video_id, log_cb=log_fn)
            log_fn(f"✅ Rewrite = Done ({os.path.basename(excel_path)})")
        except PermissionError:
            log_fn(f"⚠ Excel is locked — Rewrite status not updated")

    # ── Review Pipeline (separate from narrative) ──────────────────

    def _do_renew_review(self, job=None):
        """Review pipeline: extract → recommend → check → convert → outline → write → verify."""
        checked = job["checked"] if job else self._get_checked_chapters()
        if not checked:
            log("No chapters selected")
            return
        output_dir = (job.get("_cached_output_dir") if job else None) or self._resolve_output_dir(checked[0]["filepath"])
        if not output_dir:
            return

        # Use cached style JSON from job (Auto Pipeline) or load from widget
        if job and job.get("_cached_style_raw"):
            style_json_raw = job["_cached_style_raw"]
            style_info = job.get("_cached_style_info", "auto")
        else:
            style_json_raw, style_info = self._load_style_json_raw()
        if style_json_raw is None:
            if _log_callback:
                _log_callback(f"[Review] ✗ {style_info}")
            else:
                self._log.log(f"[Review] ✗ {style_info}")
            return

        try:
            style_data = json.loads(style_json_raw)
            _niche = (style_data.get("niche", "") or "").lower()
            framework_names = [
                fw.get("name", "") for fw in style_data.get("frameworks", [])
                if fw.get("enabled", True)
            ]
        except (json.JSONDecodeError, AttributeError):
            _niche = ""
            framework_names = []

        if not framework_names:
            log("✗ No frameworks found in style guide")
            return

        group_path = job["group_path"] if job else self._group_path
        stop_event = job["stop_event"] if job else None
        log_prefix = job["log_prefix"] if job else "[Review]"
        if not job:
            self._running = True
        # Use cached values from job dict (thread-safe) or read from widgets
        tier = job.get("_cached_tier", self._combo_tier.currentText().lower()) if job else self._combo_tier.currentText().lower()
        log_api = False
        lang = job.get("_cached_lang", self._get_lang_code()) if job else self._get_lang_code()
        target_country = job.get("_cached_country", self._combo_country.currentText()) if job else self._combo_country.currentText()
        user_framework = job.get("_cached_framework", self._combo_framework.currentText()) if job else self._combo_framework.currentText()
        _log_callback = job.get("_log_callback") if job else None
        # Auto-dual: enabled when called from Auto Pipeline OR when user selects "Auto" in Style Rewrite
        _auto_dual = (job.get("_auto_dual", False) if job else False) or user_framework == "Auto (detect & switch)"

        # Cached word count / chapter count / transitions (thread-safe)
        if job:
            _wc_cache = {
                "open": job.get("_cached_wc_open", (0, 0)),
                "body": job.get("_cached_wc_body", (0, 0)),
                "end": job.get("_cached_wc_end", (0, 0)),
            }
            _ch_min = job.get("_cached_ch_min", 0)
            _ch_max = job.get("_cached_ch_max", 0)
            _use_transitions = job.get("_cached_transitions", True)
        else:
            _wc_cache = {
                "open": (self._wc_open_min.value(), self._wc_open_max.value()),
                "body": (self._wc_body_min.value(), self._wc_body_max.value()),
                "end": (self._wc_end_min.value(), self._wc_end_max.value()),
            }
            _ch_min = self._ch_min.value()
            _ch_max = self._ch_max.value()
            _use_transitions = self._chk_transitions.isChecked()

        def _get_wc_rule(section="body"):
            wc_min, wc_max = _wc_cache.get(section, _wc_cache["body"])
            return build_word_count_rule(wc_min, wc_max)

        def _get_ch_range():
            if _ch_min > 0 and _ch_max > 0:
                return f"between {_ch_min} and {_ch_max} chapters"
            elif _ch_min > 0:
                return f"at least {_ch_min} chapters"
            elif _ch_max > 0:
                return f"at most {_ch_max} chapters"
            return "a suitable number of chapters"

        if _log_callback:
            _log_callback(
                f"{log_prefix} Starting review: {len(checked)} input(s), "
                f"style={style_info}, country={target_country}"
            )
        else:
            self._log.log(
                f"{log_prefix} Starting review: {len(checked)} input(s), "
                f"style={style_info}, country={target_country}"
            )
            self._log.set_status(f"{log_prefix} starting...", False)

        def _run():
            nonlocal output_dir  # May be reassigned in dual-framework mode
            # Per-job stop check
            def _stopped():
                if stop_event and stop_event.is_set():
                    return True
                return self._stop_flag
            if not job:
                self._stop_flag = False

            def _update_job_progress(text):
                if job:
                    job["progress"] = text
                    self.job_update.emit()

            # Log wrapper: forward to Auto tab if available, else Style Rewrite tab
            def log(m):
                if _log_callback:
                    _log_callback(f"{log_prefix} {m}")
                else:
                    self._log.log(f"{log_prefix} {m}")

            try:
                endpoints = load_api_keys()
                chapters_data = self._status.setdefault("chapters", {})

                # Validate unused chapters folder (required in manual mode only)
                if not job:
                    unused_dir_check = self._txt_unused_dir.text().strip()
                    if not unused_dir_check:
                        log("⛔ Chưa chọn thư mục Unused chapters. Vui lòng chọn trước khi chạy.")
                        return

                # Mark all input chapters as processing
                self._update_input_chapters_status(
                    checked, "processing", chapters_data, "Step 1/12"
                )
                _update_job_progress("Step 1/12")

                # ── Step 1: Concatenate all text ──
                _cached_full_text = job.get("_cached_full_text") if job else None
                if _cached_full_text:
                    full_text = _cached_full_text
                    log(f"Step 1/12: Using cached text ({len(full_text):,} chars)")
                else:
                    full_text = ""
                    for i, ch in enumerate(checked, 1):
                        full_text += f"\n\n=== PART {i}: {ch['filename']} ===\n{ch['text']}"

                log(f"Step 1/12: Full text {len(full_text):,} chars")
                _update_job_progress("Step 1/12")

                if _stopped():
                    return

                # ── Step 2 & 3: Detect framework + Extract blueprint ──
                _cached_blueprint = job.get("_cached_blueprint") if job else None
                if _cached_blueprint:
                    # v2 path: skip Steps 2-3, reuse shared data from v1
                    blueprint = _cached_blueprint
                    n_products = len(blueprint.get("product_evaluation", []))
                    log(f"Step 2/12: Skipped (using v1 detection)")
                    log(f"Step 3/12: Using cached blueprint ({n_products} products)")
                    os.makedirs(output_dir, exist_ok=True)
                    pipeline_dir = os.path.join(output_dir, "_pipeline")
                    os.makedirs(pipeline_dir, exist_ok=True)
                else:
                    # v1 / standalone path: run Steps 2-3 normally
                    log("Step 2/12: Detecting original framework...")
                    _update_job_progress("Step 2/12")

                    if not _log_callback:
                        self._log.set_status("Review: detecting framework...", False)
                    api_det = APIClient(
                        endpoints, log_api=log_api, tier="flash",
                        stop_check=_stopped
                    )
                    detection = detect_framework(
                        full_text, api_det,
                        log_callback=lambda m: log(m),
                        frameworks_list=style_data.get("frameworks", []),
                    )
                    original_fw = detection.get("detected_framework", "Unknown")
                    fw_confidence = detection.get("confidence", "?")
                    fw_reasoning = detection.get("reasoning", "")
                    log(
                        f"✓ Original framework: '{original_fw}' (confidence: {fw_confidence})"
                    )

                    # Save detection
                    os.makedirs(output_dir, exist_ok=True)
                    pipeline_dir = os.path.join(output_dir, "_pipeline")
                    os.makedirs(pipeline_dir, exist_ok=True)
                    det_path = os.path.join(pipeline_dir, "_detection.json")
                    with open(det_path, "w", encoding="utf-8") as f:
                        json.dump(detection, f, indent=2, ensure_ascii=False)
                    log("📄 Saved: _detection.json")

                    if _stopped():
                        return

                    # ── Step 3: Extract blueprint ──
                    log("Step 3/12: Extracting blueprint...")
                    _update_job_progress("Step 3/12")

                    if not _log_callback:
                        self._log.set_status("Review: extracting blueprint...", False)
                    api_bp = APIClient(
                        endpoints, log_api=log_api, tier=tier,
                        stop_check=_stopped
                    )
                    blueprint = extract_blueprint_review(
                        full_text, api_bp, lang=lang,
                        log_callback=lambda m: log(m),
                        niche=_niche,
                    )

                    n_products = len(blueprint.get("product_evaluation", []))
                    log(
                        f"✓ Blueprint: {n_products} product(s) extracted"
                    )

                    # Save raw blueprint (with source tags)
                    bp_raw_path = os.path.join(pipeline_dir, "_blueprint_raw.json")
                    with open(bp_raw_path, "w", encoding="utf-8") as f:
                        json.dump(blueprint, f, indent=2, ensure_ascii=False)
                    log("📄 Saved: _blueprint_raw.json")

                    if _stopped():
                        return

                # ── Step 4: Recommend framework ──
                if user_framework != "Auto (detect & switch)":
                    selected_fw = user_framework
                    log(f"✓ User selected framework: '{selected_fw}'")
                elif len(framework_names) == 1:
                    # Only 1 framework — auto-select, no popup needed
                    selected_fw = framework_names[0]
                    log(f"✓ Auto-selected (single framework): '{selected_fw}'")
                else:

                    log("Step 4/12: Ranking frameworks...")
                    _update_job_progress("Step 4/12")

                    if not _log_callback:
                        self._log.set_status("Review: ranking frameworks...", False)
                    api_rec = APIClient(
                        endpoints, log_api=log_api, tier="pro",
                        stop_check=_stopped
                    )
                    rec_result = recommend_framework(
                        blueprint, style_data, api_rec, lang=lang,
                        log_callback=lambda m: log(m)
                    )

                    # Build rankings for popup
                    rankings = rec_result.get("rankings", [])

                    # Normalize keys: API may return "framework" or "name", "reasoning" or "reason"
                    for r in rankings:
                        if "framework" in r and "name" not in r:
                            r["name"] = r.pop("framework")
                        if "reasoning" in r and "reason" not in r:
                            r["reason"] = r.pop("reasoning")

                    if not rankings:
                        rankings = [{"name": fw, "score": 5, "reason": "Không có đánh giá"}
                                    for fw in framework_names]

                    # Filter to valid names
                    rankings = [r for r in rankings if r.get("name") in framework_names]
                    if not rankings:
                        rankings = [{"name": fw, "score": 5, "reason": "Không có đánh giá"}
                                    for fw in framework_names]

                    rankings.sort(key=lambda x: x.get("score", 0), reverse=True)

                    # Save rankings
                    rank_path = os.path.join(pipeline_dir, "_rankings.json")
                    with open(rank_path, "w", encoding="utf-8") as f:
                        json.dump(rec_result, f, indent=2, ensure_ascii=False)
                    log("📄 Saved: _rankings.json")

                    log(
                        "[Review] Ranking: "
                        + ", ".join(f"{r['name']}={r.get('score', '?')}" for r in rankings[:5])
                    )

                    # ── Auto-dual mode: auto-select top 2, #2 only if score >= 8.5 ──
                    _SCORE_THRESHOLD = 8.5
                    if _auto_dual and len(rankings) >= 2:
                        selected_fw = rankings[0]["name"]
                        v2_score = rankings[1].get("score", 0)
                        if v2_score >= _SCORE_THRESHOLD:
                            top2 = [rankings[0]["name"], rankings[1]["name"]]
                            log(f"✓ Auto-dual: selected top 2 → {top2[0]} & {top2[1]}")
                        else:
                            top2 = [selected_fw]
                            log(f"✓ Auto: selected → {selected_fw}")
                            log(f"  ⊘ Skipped v2: '{rankings[1]['name']}' (score={v2_score} < {_SCORE_THRESHOLD})")
                    elif _auto_dual:
                        selected_fw = rankings[0]["name"]
                        log(f"✓ Auto: selected → {selected_fw}")
                    else:
                        # Show popup for user selection
                        self._fw_ranking_event.clear()
                        self._fw_ranking_result = None
                        fw_info_json = json.dumps({
                            "name": original_fw,
                            "confidence": fw_confidence,
                            "reasoning": fw_reasoning
                        }, ensure_ascii=False)
                        self._fw_ranking_request.emit(rankings, fw_info_json)
                        self._fw_ranking_event.wait()

                        if self._fw_ranking_result is None:
                            log("✗ User cancelled framework selection")
                            if not _log_callback:
                                self._log.set_status("Cancelled", True)
                            return

                        selected_fw = self._fw_ranking_result
                        log(f"✓ User selected: '{selected_fw}'")
                if _stopped():
                    return

                # Store top2 for dual-framework second pass
                _dual_second_fw = None
                if _auto_dual and 'top2' in dir() and len(top2) >= 2:
                    _dual_second_fw = top2[1]

                # ── Start v2 in parallel thread (before Step 5) ──
                if _dual_second_fw and not _stopped():
                    import re as _re_mod
                    import threading as _th
                    log(f"\n{'='*50}")
                    log(f"🔄 Dual-framework: v1={selected_fw}, v2={_dual_second_fw}")
                    log(f"{'='*50}")

                    # Create v1 subfolder and redirect output_dir
                    safe_fw1 = _re_mod.sub(r'[<>:"/\\|?*]', '', selected_fw)[:40]
                    # Look up ranking scores for directory suffix
                    _score_map = {r["name"]: r.get("score", 0) for r in rankings} if 'rankings' in dir() else {}
                    _s1 = _score_map.get(selected_fw, 0)
                    _s1_suffix = f"_{_s1}" if _s1 else ""
                    v1_dir = os.path.join(output_dir, f"v1_{safe_fw1}{_s1_suffix}")
                    os.makedirs(v1_dir, exist_ok=True)

                    # Create v2 subfolder
                    safe_fw2 = _re_mod.sub(r'[<>:"/\\|?*]', '', _dual_second_fw)[:40]
                    _s2 = _score_map.get(_dual_second_fw, 0)
                    _s2_suffix = f"_{_s2}" if _s2 else ""
                    v2_dir = os.path.join(output_dir, f"v2_{safe_fw2}{_s2_suffix}")
                    os.makedirs(v2_dir, exist_ok=True)

                    # Redirect v1 output and metadata to its subfolder
                    output_dir = v1_dir
                    pipeline_dir = os.path.join(v1_dir, "_pipeline")
                    os.makedirs(pipeline_dir, exist_ok=True)

                    # Build v2 job — use existing job or create minimal one for manual mode
                    if job:
                        v2_job = dict(job)
                    else:
                        v2_job = {
                            "id": f"manual_v2_{id(self)}",
                            "checked": checked,
                            "group_path": group_path,
                            "mode": "Top/List Review",
                            "status": "running",
                            "progress": "v2...",
                            "log_prefix": "[Review-v2]",
                            "_cached_tier": tier,
                            "_cached_lang": lang,
                            "_cached_country": target_country,
                            "_cached_style_raw": style_json_raw,
                            "_cached_style_info": style_info,
                            "_cached_google_check": self._chk_google_check.isChecked(),
                            "_cached_transitions": _use_transitions,
                            "_cached_ch_min": _ch_min,
                            "_cached_ch_max": _ch_max,
                            "_cached_wc_open": _wc_cache["open"],
                            "_cached_wc_body": _wc_cache["body"],
                            "_cached_wc_end": _wc_cache["end"],
                        }
                    v2_job["_auto_dual"] = False  # Prevent recursion
                    v2_job["_cached_framework"] = _dual_second_fw
                    v2_job["_cached_output_dir"] = v2_dir
                    v2_job["log_prefix"] = f"[Review-v2]"
                    # v2 gets its own stop_event (independent of v1 completion)
                    v2_stop = _th.Event()
                    v2_job["stop_event"] = v2_stop
                    # Pass shared data so v2 skips Steps 1-3
                    import copy as _copy
                    v2_job["_cached_full_text"] = full_text
                    v2_job["_cached_blueprint"] = _copy.deepcopy(blueprint)
                    v2_job["_cached_niche"] = _niche

                    _v2_thread = _th.Thread(
                        target=self._do_renew_review,
                        kwargs={"job": v2_job},
                        daemon=True,
                    )
                    _v2_thread.start()
                    log(f"✓ v2 thread started — both pipelines running in parallel")

                # Get the selected framework dict
                selected_fw_dict = None
                for fw in style_data.get("frameworks", []):
                    if fw.get("name") == selected_fw:
                        selected_fw_dict = fw
                        break

                # ── Step 5: Reality check blueprint ──
                log(
                    f"Step 5/12: Reality-checking blueprint "
                    f"(framework: {selected_fw})..."
                )
                _update_job_progress("Step 5/12")
                if not _log_callback:
                    self._log.set_status("Review: verifying & enriching data...", False)
                api_rc = APIClient(
                    endpoints, log_api=log_api, tier="flash",
                    stop_check=_stopped
                )
                try:
                    rc_result = reality_check_blueprint(
                        blueprint, api_rc, lang=lang,
                        log_callback=lambda m: log(m),
                        niche=_niche,
                    )

                    # Save full verification result
                    rc_path = os.path.join(pipeline_dir, "_reality_check.json")
                    verification = rc_result.get("verification", rc_result)
                    with open(rc_path, "w", encoding="utf-8") as f:
                        json.dump(verification, f, indent=2, ensure_ascii=False)
                    log("📄 Saved: _reality_check.json")

                    # ── Apply verification results to blueprint programmatically ──
                    # Step A: Strip source tags
                    blueprint = self._strip_source_tags(blueprint)

                    # Step B: Apply corrections from ai_knowledge_checks
                    products = blueprint.get("product_evaluation", [])
                    n_corrections = 0
                    n_enriched = 0
                    for vp in verification.get("products", []):
                        vp_name = vp.get("product_name", "")
                        # Find matching product in blueprint
                        bp_prod = None
                        for p in products:
                            pn = p.get("product_name", p.get("name", ""))
                            if pn and vp_name and pn.lower() == vp_name.lower():
                                bp_prod = p
                                break
                        if not bp_prod:
                            continue

                        # Apply corrections
                        for chk in vp.get("ai_knowledge_checks", []):
                            if chk.get("verified") is False and chk.get("correct_value"):
                                field = chk.get("field", "")
                                correct = chk["correct_value"]
                                if field and field in bp_prod:
                                    bp_prod[field] = correct
                                    n_corrections += 1
                                else:
                                    # Try nested: field could be dot-notation
                                    parts = field.split(".")
                                    target = bp_prod
                                    for part in parts[:-1]:
                                        if isinstance(target, dict) and part in target:
                                            target = target[part]
                                        else:
                                            target = None
                                            break
                                    if target and isinstance(target, dict) and parts[-1] in target:
                                        target[parts[-1]] = correct
                                        n_corrections += 1

                        # Apply enrichments
                        for enr in vp.get("enriched_data", []):
                            field = enr.get("field", "")
                            value = enr.get("value", "")
                            if field and value:
                                if field not in bp_prod or not bp_prod[field]:
                                    bp_prod[field] = value
                                    n_enriched += 1
                                else:
                                    # Try nested
                                    parts = field.split(".")
                                    target = bp_prod
                                    for part in parts[:-1]:
                                        if isinstance(target, dict) and part in target:
                                            target = target[part]
                                        elif isinstance(target, dict):
                                            target[part] = {}
                                            target = target[part]
                                        else:
                                            target = None
                                            break
                                    if target and isinstance(target, dict):
                                        if parts[-1] not in target or not target[parts[-1]]:
                                            target[parts[-1]] = value
                                            n_enriched += 1

                    # Save cleaned + corrected blueprint
                    bp_path = os.path.join(pipeline_dir, "_blueprint.json")
                    with open(bp_path, "w", encoding="utf-8") as f:
                        json.dump(blueprint, f, indent=2, ensure_ascii=False)
                    log(f"📄 Saved: _blueprint.json (stripped, {n_corrections} corrections, {n_enriched} enrichments)")

                    # Export to CSV
                    csv_path = os.path.join(pipeline_dir, "_reality_check.csv")
                    with open(csv_path, "w", encoding="utf-8-sig", newline="") as cf:
                        writer = csv.writer(cf)
                        writer.writerow([
                            "Product", "Type", "Field",
                            "AI Value", "Verified", "Correct Value", "Issue Type"
                        ])
                        for prod in verification.get("products", []):
                            pname = prod.get("product_name", "?")
                            for chk in prod.get("ai_knowledge_checks", []):
                                writer.writerow([
                                    pname, "AI_CHECK",
                                    chk.get("field", ""),
                                    chk.get("ai_value", ""),
                                    chk.get("verified", ""),
                                    chk.get("correct_value", ""),
                                    chk.get("issue_type", "")
                                ])
                            for fa in prod.get("enriched_data", []):
                                writer.writerow([
                                    pname, "ENRICHED",
                                    fa.get("field", ""),
                                    fa.get("value", ""),
                                    fa.get("confidence", ""),
                                    "", ""
                                ])
                    log("📄 Saved: _reality_check.csv")

                    # Log summary
                    assessment = verification.get("overall_assessment", {})
                    n_fudd = assessment.get("fudd_lore_found", assessment.get("myths_found", 0))
                    n_anac = assessment.get("anachronisms_found", 0)
                    log(
                        f"✓ Reality check: "
                        f"{n_fudd} myths/Fudd-lore, {n_anac} anachronisms, "
                        f"{n_corrections} corrected, {n_enriched} enriched"
                    )

                except Exception as e:
                    log(f"⚠️ Reality check failed (non-fatal): {e}")
                    log("Stripping source tags and continuing...")
                    blueprint = self._strip_source_tags(blueprint)
                    bp_path = os.path.join(pipeline_dir, "_blueprint.json")
                    with open(bp_path, "w", encoding="utf-8") as f:
                        json.dump(blueprint, f, indent=2, ensure_ascii=False)

                if _stopped():
                    return

                # Niche detection for spec/price steps
                _SPEC_NICHES = {"gun", "firearm", "ammo", "ammunition",
                                 "weapon", "rifle", "pistol", "shotgun",
                                 "súng", "đạn", "vũ khí",
                                 "military", "quân sự", "thiết bị"}
                _PRICE_NICHES = {"gun", "firearm", "ammo", "ammunition",
                                 "weapon", "rifle", "pistol", "shotgun",
                                 "súng", "đạn", "vũ khí"}
                _niche_words = set(_niche.lower().split())
                _is_spec_niche = bool(_niche_words & _SPEC_NICHES)
                _is_price_niche = bool(_niche_words & _PRICE_NICHES)

                # ── Step 5a+5b+5c: Google Check + Enrich ──
                _google_check_enabled = job.get("_cached_google_check", self._chk_google_check.isChecked()) if job else self._chk_google_check.isChecked()

                from concurrent.futures import ThreadPoolExecutor as _TPE, as_completed
                import threading as _threading

                _google_tasks = []
                _bp_write_lock = _threading.Lock()

                # Step 5a: Spec verify — only when Google Check ON + spec niche
                if _google_check_enabled and _is_spec_niche:
                    def _run_spec_verify():
                        """Step 5a: Spec verification via Google Search."""
                        gemini_keys_5a = load_gemini_keys()
                        if not gemini_keys_5a:
                            return
                        log("Step 5a: Verifying specs via Google Search...")
                        try:
                            spec_result = verify_specs_google(
                                blueprint, gemini_keys_5a,
                                lang=lang,
                                log_callback=lambda m: log(m),
                                stop_check=_stopped,
                            )
                            if spec_result:
                                spec_path = os.path.join(pipeline_dir, "_spec_verification.json")
                                with open(spec_path, "w", encoding="utf-8") as f:
                                    json.dump(spec_result, f, indent=2, ensure_ascii=False)
                                log("📄 Saved: _spec_verification.json")
                        except Exception as e:
                            log(f"⚠️ Spec verification failed (non-fatal): {e}")
                    _google_tasks.append(_run_spec_verify)

                # Step 5b: Price enrich — only when Google Check ON + price niche
                if _google_check_enabled and _is_price_niche:
                    def _run_price_enrich():
                        """Step 5b: Price enrichment via Google Search."""
                        gemini_keys_5b = load_gemini_keys()
                        if not gemini_keys_5b:
                            log("⚠ Google Check enabled but no Gemini API keys — skipping prices")
                            return
                        log("Step 5b: Enriching prices via Google Search...")
                        try:
                            price_result = enrich_prices_google(
                                blueprint, gemini_keys_5b,
                                lang=lang,
                                log_callback=lambda m: log(m),
                                stop_check=_stopped,
                            )
                            pe_path = os.path.join(pipeline_dir, "_price_enrichment.json")
                            with open(pe_path, "w", encoding="utf-8") as f:
                                json.dump(price_result, f, indent=2, ensure_ascii=False)
                            log("📄 Saved: _price_enrichment.json")

                            with _bp_write_lock:
                                bp_path = os.path.join(pipeline_dir, "_blueprint.json")
                                with open(bp_path, "w", encoding="utf-8") as f:
                                    json.dump(blueprint, f, indent=2, ensure_ascii=False)
                            log(f"✓ Price enrichment: {price_result.get('price_summary', '?')}")
                        except Exception as e:
                            log(f"⚠️ Price enrichment failed (non-fatal): {e}")
                    _google_tasks.append(_run_price_enrich)

                # Step 5c: Blueprint enrich — ALWAYS runs
                # Google Check ON → Google Search, OFF → AI knowledge
                def _run_blueprint_enrich():
                    """Step 5c: Blueprint enrichment (always runs)."""
                    gemini_keys_5c = load_gemini_keys()
                    if not gemini_keys_5c:
                        log("⚠ No Gemini API keys — skipping enrichment")
                        return
                    _src = "Google Search" if _google_check_enabled else "AI knowledge"
                    log(f"Step 5c: Enriching blueprint via {_src}...")
                    try:
                        enrich_result = enrich_blueprint_google(
                            blueprint, gemini_keys_5c,
                            niche=_niche,
                            lang=lang,
                            log_callback=lambda m: log(m),
                            stop_check=_stopped,
                            use_google_search=_google_check_enabled,
                            api_endpoints=endpoints,
                        )
                        er_path = os.path.join(pipeline_dir, "_enrichment.json")
                        with open(er_path, "w", encoding="utf-8") as f:
                            json.dump(enrich_result, f, indent=2, ensure_ascii=False)
                        log("📄 Saved: _enrichment.json")

                        if enrich_result.get("fields_filled", 0) > 0:
                            with _bp_write_lock:
                                bp_path = os.path.join(pipeline_dir, "_blueprint.json")
                                with open(bp_path, "w", encoding="utf-8") as f:
                                    json.dump(blueprint, f, indent=2, ensure_ascii=False)
                            log(f"✓ Blueprint enriched: {enrich_result['fields_filled']} field(s) filled")
                    except Exception as e:
                        log(f"⚠️ Blueprint enrichment failed (non-fatal): {e}")
                _google_tasks.append(_run_blueprint_enrich)

                # Step 5d: Rhetoric transform — generate alternative rhetoric
                def _run_rhetoric_transform():
                    """Step 5d: Transform original rhetoric into culturally-adapted alternatives."""
                    gemini_keys_5d = load_gemini_keys()
                    log(f"Step 5d: Transforming rhetoric for {target_country}...")
                    try:
                        rt_result = transform_rhetoric(
                            blueprint,
                            niche=_niche,
                            lang=lang,
                            target_country=target_country,
                            log_callback=lambda m: log(m),
                            stop_check=_stopped,
                            api_endpoints=endpoints,
                            gemini_keys=gemini_keys_5d,
                        )
                        rt_path = os.path.join(pipeline_dir, "_rhetoric_transform.json")
                        with open(rt_path, "w", encoding="utf-8") as f:
                            json.dump(rt_result, f, indent=2, ensure_ascii=False)
                        log("📄 Saved: _rhetoric_transform.json")

                        if rt_result.get("products_transformed", 0) > 0:
                            with _bp_write_lock:
                                bp_path = os.path.join(pipeline_dir, "_blueprint.json")
                                with open(bp_path, "w", encoding="utf-8") as f:
                                    json.dump(blueprint, f, indent=2, ensure_ascii=False)
                            log(f"✓ Rhetoric: {rt_result['products_transformed']} product(s) transformed")
                    except Exception as e:
                        log(f"⚠️ Rhetoric transform failed (non-fatal): {e}")
                _google_tasks.append(_run_rhetoric_transform)

                _update_job_progress("Step 5: Enrich data")
                if not _log_callback:
                    self._log.set_status("Review: enriching data...", False)

                with _TPE(max_workers=min(3, len(_google_tasks)),
                          thread_name_prefix="gcheck") as vpool:
                    futs = [vpool.submit(fn) for fn in _google_tasks]
                    for fut in as_completed(futs):
                        try:
                            fut.result()
                        except Exception:
                            pass

                log("✓ Step 5 complete")

                if _stopped():
                    return


                # ── Step 6: Check blueprint completeness ──
                if selected_fw_dict:
                    log("Step 6/12: Checking blueprint completeness...")
                    _update_job_progress("Step 6/12")

                    if not _log_callback:
                        self._log.set_status("Review: checking data...", False)
                    api_chk = APIClient(
                        endpoints, log_api=log_api, tier="flash",
                        stop_check=_stopped
                    )
                    check_result = check_blueprint(
                        blueprint, selected_fw_dict, api_chk, lang=lang,
                        log_callback=lambda m: log(m),
                        niche=_niche,
                    )

                    status_str = check_result.get("overall_status", "UNKNOWN")
                    log(f"✓ Data completeness: {status_str}")
                    # Save check result
                    chk_path = os.path.join(pipeline_dir, "_completeness_check.json")
                    with open(chk_path, "w", encoding="utf-8") as f:
                        json.dump(check_result, f, indent=2, ensure_ascii=False)
                    log("📄 Saved: _completeness_check.json")

                    if status_str == "INSUFFICIENT":
                        self._log.log(
                            "[Review] ⚠ Blueprint data is insufficient for this framework. "
                            "Continuing anyway — results may have gaps."
                        )
                else:
                    log("Step 6/12: Skipped (framework dict not found)")
                    _update_job_progress("Step 6/12")


                if _stopped():
                    return

                # ── Step 7: Convert units ──
                log(f"Step 7/12: Converting units for {target_country}...")
                _update_job_progress("Step 7/12")

                blueprint = convert_units(blueprint, target_country, style_data=style_data)
                if style_data and style_data.get("units"):
                    log(f"✓ Units: using style-defined system (skipped auto-conversion)")
                else:
                    log(f"✓ Units converted to {target_country}")
                # Save converted blueprint
                bp_conv_path = os.path.join(pipeline_dir, "_blueprint_converted.json")
                with open(bp_conv_path, "w", encoding="utf-8") as f:
                    json.dump(blueprint, f, indent=2, ensure_ascii=False)

                if _stopped():
                    return

                # ── Step 8-9: Create review outline + Audit ──
                _resume_mode = job.get("_resume_mode", False) if job else False
                _cached_audited_outline = None
                if _resume_mode:
                    _audited_path = os.path.join(pipeline_dir, "_review_outline_audited.json")
                    if os.path.isfile(_audited_path):
                        try:
                            with open(_audited_path, "r", encoding="utf-8") as _f:
                                _cached_audited_outline = json.load(_f)
                        except Exception:
                            _cached_audited_outline = None

                if _cached_audited_outline:
                    # Resume: load cached audited outline, skip steps 8-9
                    outline = _cached_audited_outline
                    out_chapters = outline.get("chapters", [])
                    total = len(out_chapters)
                    log(f"Step 8/12: ⏭ Cached outline ({total} chapters)")
                    log(f"Step 9/12: ⏭ Cached audit")
                    _update_job_progress("Step 9/12")
                else:
                    # Normal: run steps 8-9
                    log(f"Step 8/12: Creating outline with '{selected_fw}'...")
                    _update_job_progress("Step 8/12")

                    if not _log_callback:
                        self._log.set_status(f"Review: outline ({selected_fw})...", False)
                    api_out = APIClient(
                        endpoints, log_api=log_api, tier=tier,
                        stop_check=_stopped
                    )

                    # Detect niche to choose outline function
                    _is_mystery = "mystery" in _niche or "bí ẩn" in _niche

                    if _is_mystery:
                        # Mystery history: no product shuffling needed
                        log(f"[Mystery] Using mystery outline for niche '{_niche}'")
                        outline = create_review_outline(
                            blueprint, style_data, selected_fw, api_out,
                            lang=lang,
                            chapter_range=_get_ch_range(),
                            log_callback=lambda m: log(m),
                            niche=_niche,
                        )
                    else:
                        # Product review: shuffle products & strip ordering clues
                        import random
                        outline_blueprint = json.loads(json.dumps(blueprint))  # deep copy
                        products_for_outline = outline_blueprint.get("product_evaluation", [])
                        random.shuffle(products_for_outline)
                        # Strip per-product fields that create ordering chains
                        for prod in products_for_outline:
                            prod.pop("comparisons", None)
                            prod.pop("narrative_moments", None)
                            prod.pop("source_parts", None)
                            vp = prod.get("value_proposition", {})
                            if isinstance(vp, dict):
                                vp.pop("comparison_value", None)
                        outline_blueprint["product_evaluation"] = products_for_outline
                        # Strip top-level ordering hints
                        outline_blueprint.pop("original_order", None)
                        outline_blueprint.pop("ranking_criteria", None)
                        outline_blueprint.pop("key_claims", None)
                        log(f"✓ Shuffled {len(products_for_outline)} products, stripped ordering clues")
                        outline = create_review_outline(
                            outline_blueprint, style_data, selected_fw, api_out,
                            lang=lang,
                            chapter_range=_get_ch_range(),
                            log_callback=lambda m: log(m),
                            niche=_niche,
                        )

                    out_chapters = outline.get("chapters", [])
                    total = len(out_chapters)
                    log(f"✓ Outline: {total} chapters")
                    # Save outline
                    outline_path = os.path.join(pipeline_dir, "_review_outline.json")
                    with open(outline_path, "w", encoding="utf-8") as f:
                        json.dump(outline, f, indent=2, ensure_ascii=False)
                    log("📄 Saved: _review_outline.json")

                    # Post-process: remove hook/end chapters when their wc = SKIP
                    _skip_open = _get_wc_rule("open") == "SKIP"
                    _skip_end = _get_wc_rule("end") == "SKIP"
                    if _skip_open or _skip_end:
                        filtered = []
                        removed = []
                        for ch in out_chapters:
                            ct = ch.get("chapter_type", "body")
                            if _skip_open and ct == "hook":
                                removed.append("hook")
                                continue
                            if _skip_end and ct == "end":
                                removed.append("end")
                                continue
                            filtered.append(ch)
                        if removed:
                            out_chapters = filtered
                            outline["chapters"] = out_chapters
                            total = len(out_chapters)
                            log(f"✂ Removed {', '.join(removed)} chapter(s) (wc=SKIP) → {total} chapters")

                    if _stopped() or total == 0:
                        return

                    # ── Step 9: Audit outline ──
                    log("Step 9/12: Auditing outline...")
                    _update_job_progress("Step 9/12")

                    if not _log_callback:
                        self._log.set_status("Review: auditing outline...", False)
                    api_audit = APIClient(
                        endpoints, log_api=log_api, tier="flash",
                        stop_check=_stopped
                    )
                    audit_result = audit_outline_review(
                        blueprint, outline, selected_fw_dict or {}, style_json_raw, api_audit,
                        chapter_range=_get_ch_range(),
                        log_callback=lambda m: log(m),
                        niche=_niche,
                    )
                    # audit_outline_review now returns the outline directly
                    # (falls back to original outline on JSON parse error)
                    audited_outline = audit_result

                    # Always update to audited version (may be same as original if no issues)
                    outline = audited_outline
                    out_chapters = outline.get("chapters", [])
                    total = len(out_chapters)
                    audited_path = os.path.join(pipeline_dir, "_review_outline_audited.json")
                    with open(audited_path, "w", encoding="utf-8") as f:
                        json.dump(outline, f, indent=2, ensure_ascii=False)
                    log(f"📄 Saved audited outline ({total} chapters)")

                if _stopped() or total == 0:
                    return

                # Filter blueprint to only include products selected in outline
                selected_products = set()
                for ch in out_chapters:
                    for p in ch.get("products_covered", []):
                        selected_products.add(p)
                if selected_products:
                    writer_blueprint = json.loads(json.dumps(blueprint))
                    writer_blueprint["product_evaluation"] = [
                        p for p in writer_blueprint.get("product_evaluation", [])
                        if p.get("product_name") in selected_products
                    ]
                    writer_blueprint.pop("original_order", None)
                    writer_blueprint.pop("ranking_criteria", None)
                    writer_blueprint.pop("key_claims", None)
                    # Strip source_parts from writer blueprint
                    for wp in writer_blueprint.get("product_evaluation", []):
                        wp.pop("source_parts", None)
                    log(
                        f"✓ Filtered blueprint: {len(selected_products)} products for writer"                    )
                else:
                    writer_blueprint = blueprint

                # ── Unused chapters detection (copy deferred to end) ──
                unused_product_names = set()
                _unused_bp_product_lookup = {}
                if selected_products:
                    all_bp_products = blueprint.get("product_evaluation", [])
                    all_product_names = {p.get("product_name") for p in all_bp_products}
                    unused_product_names = all_product_names - selected_products

                    if unused_product_names:
                        log(f"⚠ {len(unused_product_names)} unused product(s): {', '.join(sorted(unused_product_names))}")

                    # Helper: map product → source chapter (source_parts first, text fallback)
                    def _find_source_chapter(product_dict, product_name):
                        """Find source chapter for a product using source_parts or text match."""
                        source_parts = product_dict.get("source_parts", [])
                        if source_parts:
                            import re
                            for sp in source_parts:
                                m = re.search(r'(\d+)', sp)
                                if m:
                                    idx = int(m.group(1)) - 1
                                    if 0 <= idx < len(checked):
                                        return checked[idx]
                        # Fallback: text matching
                        for ch in checked:
                            if product_name.lower() in ch.get("text", "").lower():
                                return ch
                        return None

                    # Build lookup for later use
                    _unused_bp_product_lookup = {
                        p.get("product_name"): p for p in all_bp_products
                    }

                    # Multi-folder check for merge mode (early exit)
                    is_merge = job and job.get("merged_groups")
                    if is_merge:
                        used_folders = set()
                        for pname in sorted(selected_products):
                            pd = _unused_bp_product_lookup.get(pname, {})
                            ch = _find_source_chapter(pd, pname)
                            if ch:
                                used_folders.add(ch.get("group", ""))
                        if len(used_folders) < 2:
                            log("⚠ Merge cảnh báo: Tất cả items được chọn đều từ 1 nguồn. "
                                "Merge không có ý nghĩa — hãy chạy riêng folder đó.")
                            log("⛔ Dừng pipeline.")
                            return

                if _stopped():
                    return

                # ── Step 10: Write each chapter ──
                log(f"Step 10/12: Writing {total} chapters...")
                _update_job_progress("Step 10/12")

                if not _log_callback:
                    self._log.set_status("Review: writing chapters...", False)
                rewritten_texts = []
                out_filenames = []
                chapter_titles = []
                outline_json_str = json.dumps(
                    outline, indent=2, ensure_ascii=False
                )

                for i, ch_outline in enumerate(out_chapters):
                    if _stopped():
                        break

                    # Filename: hook→Intro, end→Outro_CTA, body→product name
                    ch_type = ch_outline.get("chapter_type", "body")
                    if ch_type == "hook":
                        raw_name = "Intro"
                    elif ch_type == "end":
                        raw_name = "Outro_CTA"
                    else:
                        # Use product name for body; fall back to title
                        prods = ch_outline.get("products_covered", [])
                        if prods and len(prods) <= 2:
                            raw_name = " vs ".join(prods) if len(prods) == 2 else prods[0]
                        else:
                            raw_name = ch_outline.get("title", f"chapter_{i+1}")
                    safe_title = "".join(
                        c if c.isalnum() or c in " _-" else "_"
                        for c in raw_name
                    ).strip().replace(" ", "_")[:60]
                    out_fname = f"ch_{i+1:02d}_{safe_title}.txt"

                    # Word count by position — prioritize chapter_type over position
                    ch_type = ch_outline.get("chapter_type", "body")
                    if ch_type == "hook":
                        wc_section = "open"
                    elif ch_type == "end":
                        wc_section = "end"
                    elif i == 0 and _get_wc_rule("open") != "SKIP":
                        wc_section = "open"
                    elif i == total - 1 and _get_wc_rule("end") != "SKIP":
                        wc_section = "end"
                    else:
                        wc_section = "body"
                    wc_rule = _get_wc_rule(wc_section)

                    # SKIP: if both min/max = 0, skip this chapter
                    if wc_rule == "SKIP":
                        log(f"⏭ Ch.{i+1}/{total}: skipped ({wc_section} = SKIP)")
                        continue

                    # Append filename AFTER skip check to keep indices aligned
                    # with rewritten_texts (which also skips these chapters)
                    out_filenames.append(out_fname)
                    chapter_titles.append(raw_name)

                    # Previous context — end chapter gets ALL chapters for accurate summary
                    prev_context = ""
                    if rewritten_texts:
                        if ch_type == "end":
                            prev_context = "\n---\n".join(rewritten_texts)
                        else:

                            prev_context = "\n---\n".join(rewritten_texts[-2:])

                    try:
                        api_w = APIClient(
                            endpoints, log_api=log_api, tier=tier,
                            stop_check=_stopped
                        )
                        rewritten = write_review_chapter(
                            blueprint=writer_blueprint,
                            style_json=style_json_raw,
                            framework_name=selected_fw,
                            chapter_outline=ch_outline,
                            chapter_number=i + 1,
                            total_chapters=total,
                            api_client=api_w,
                            word_count_rule=wc_rule,
                            lang=lang,
                            previous_context=prev_context,
                            target_country=target_country,
                            full_outline=outline_json_str,
                            log_callback=lambda m: log(m),
                            use_transitions=_use_transitions,
                        )
                        rewritten_texts.append(rewritten)

                        out_path = os.path.join(output_dir, out_fname)
                        with open(out_path, "w", encoding="utf-8") as f:
                            f.write(rewritten)

                        with self._lock:
                            chapters_data[out_fname] = {
                                "status": "rewritten",
                                "rewritten_at": datetime.now().strftime("%Y-%m-%d %H:%M"),
                                "lang": lang,
                                "rewrite_mode": "review",
                                "framework": selected_fw,
                                "target_country": target_country,
                                "output_file": out_fname,
                            }
                        self._save_status_safe(group_path)
                        log(f"✓ Ch.{i+1}/{total}: {raw_name}")
                        # Update input chapters progress
                        self._update_input_chapters_status(
                            checked, "writing", chapters_data,
                            f"Ch {i+1}/{total} done"
                        )

                    except Exception as e:
                        rewritten_texts.append("")
                        out_filenames[-1] = ""
                        log(f"✗ Ch.{i+1}/{total}: {e}")
                if _stopped():
                    log("Stopped")
                    return

                # ── Post-write validation: duplicate/missing check ──
                written_ok = [i for i, t in enumerate(rewritten_texts) if t]
                written_fail = [i for i, t in enumerate(rewritten_texts) if not t]
                if written_fail:
                    log(
                        f"⚠️ Missing chapters: "                        f"{', '.join(str(i+1) for i in written_fail)}"
                    )
                # Check for duplicate chapter content
                seen_texts = {}
                for i, txt in enumerate(rewritten_texts):
                    if not txt:
                        continue
                    short = txt[:200].strip()
                    for prev_i, prev_short in seen_texts.items():
                        if short == prev_short:
                            log(
                                f"⚠️ DUPLICATE: Ch.{i+1} appears identical to Ch.{prev_i+1}"                            )
                            break
                    seen_texts[i] = short

                # ── Step 11: Cross-chapter review + Patch ──
                log("Step 11/12: Cross-chapter review...")
                _update_job_progress("Step 11/12")

                if not _log_callback:
                    self._log.set_status("Review: reviewing flow & consistency...", False)
                rw_chapters = []
                rw_index_map = []
                for i in range(min(total, len(rewritten_texts))):
                    if rewritten_texts[i]:
                        rw_chapters.append({
                            "filename": out_filenames[i],
                            "text": rewritten_texts[i],
                            "title": chapter_titles[i] if i < len(chapter_titles) else "",
                        })
                        rw_index_map.append(i)

                api_rev = APIClient(
                    endpoints, log_api=log_api, tier=tier,
                    stop_check=_stopped
                )
                # Label chapters with file position to avoid ambiguity
                # (AI may confuse ranking #2 with file position 2)
                labeled_text = "\n\n".join(
                    f"[CHAPTER_FILE {j+1}] {c['filename']}\n{c['text']}"
                    for j, c in enumerate(rw_chapters)
                )
                review_result = review_cross_chapter(
                    labeled_text,
                    api_rev, lang=lang,
                    log_callback=lambda m: log(m),
                    niche=_niche,
                )

                issues = review_result.get("issues", [])
                # When transitions are OFF, filter out transition-related issues
                if not _use_transitions:
                    _before = len(issues)
                    issues = [
                        iss for iss in issues
                        if "transition" not in (iss.get("type", iss.get("issue_type", "")) or "").lower()
                    ]
                    _skipped = _before - len(issues)
                    if _skipped:
                        log(f"  ℹ Skipped {_skipped} transition issue(s) (transitions OFF)")
                _do_patch = job.get("_cached_auto_patch", False) if job else self._chk_auto_patch.isChecked()
                auto_patched = 0
                if _do_patch and issues:
                    for issue in issues:
                        if issue.get("severity") in ("critical", "major"):
                            fc = issue.get("fix_chapter")
                            if not fc:
                                involved = issue.get("chapters_involved", [])
                                if involved:
                                    fc = involved[0]
                            if not fc:
                                continue
                            # Handle case where fc is a list
                            if isinstance(fc, list):
                                fc = fc[0] if fc else None
                            if fc is None:
                                continue
                            try:
                                fix_ch_num = int(fc)
                            except (ValueError, TypeError):
                                continue
                            # Map fix_ch_num (original chapter number) to rw_chapters index
                            original_idx = fix_ch_num - 1  # 0-based in rewritten_texts
                            rw_idx = None
                            for ri, mapped_idx in enumerate(rw_index_map):
                                if mapped_idx == original_idx:
                                    rw_idx = ri
                                    break
                            if rw_idx is not None:
                                full_ctx = "\n\n".join(
                                    f"[CHAPTER_FILE {j+1}] {c['filename']}\n{c['text']}"
                                    for j, c in enumerate(rw_chapters)
                                )
                                api_p = APIClient(
                                    endpoints, log_api=log_api, tier="flash",
                                    stop_check=_stopped
                                )
                                patched = patch_chapter_overlap(
                                    rw_chapters[rw_idx]["text"], issue, full_ctx, api_p,
                                    log_callback=lambda m: log(m)
                                )
                                rw_chapters[rw_idx]["text"] = patched
                                rewritten_texts[rw_index_map[rw_idx]] = patched
                                # Save patched file
                                patched_fname = out_filenames[rw_index_map[rw_idx]]
                                patched_path = os.path.join(output_dir, patched_fname)
                                with open(patched_path, "w", encoding="utf-8") as f:
                                    f.write(patched)
                                auto_patched += 1
                elif issues:
                    _crit = len([i for i in issues if i.get('severity') in ('critical','major')])
                    if _crit:
                        log(f"⚠ {_crit} critical/major issues found — auto-patch OFF, skipping fixes")

                if auto_patched:
                    log(f"✓ Auto-patched {auto_patched} issues")
                flow_score = review_result.get("overall_flow_score", 0)
                issues_remaining = len(issues) - auto_patched
                log(
                    f"✓ Review done! flow={flow_score}, issues_total={len(issues)}, patched={auto_patched}, remaining={issues_remaining}"                )

                # Save review result
                rev_path = os.path.join(pipeline_dir, "_review.json")
                with open(rev_path, "w", encoding="utf-8") as f:
                    json.dump(review_result, f, indent=2, ensure_ascii=False)
                log("📄 Saved: _review.json")

                # ── Step 12: Merge ──
                log("Step 12/12: Merging...")
                _update_job_progress("Step 12/12")

                if rw_chapters:
                    full_path = os.path.join(output_dir, "FULL_SCRIPT.txt")
                    with open(full_path, "w", encoding="utf-8") as f:
                        for j, c in enumerate(rw_chapters):
                            if j > 0:
                                f.write("\n\n" + "=" * 60 + "\n\n")
                            ch_title = c.get("title", "").strip()
                            if not ch_title:
                                ch_title = c['filename'].replace('.txt', '').replace('_', ' ')
                            f.write(f"Chapter {j+1}: {ch_title}\n\n")
                            f.write(c["text"])
                    log(
                        f"✓ Merged → FULL_SCRIPT.txt ({len(rw_chapters)} chapters)"                    )



                if not _log_callback:
                    self._log.set_status("Done", False)
                log(
                    f"✓ Complete! Framework: '{selected_fw}', "                    f"Country: {target_country}, Chapters: {len(rw_chapters)}"
                )
                self._update_input_chapters_status(
                    checked, "verified", chapters_data, "✓ Done"
                )
                try:
                    import winsound
                    winsound.MessageBeep(winsound.MB_ICONASTERISK)
                except Exception:
                    pass

                # ── Excel update: Rewrite = Done ──
                self._update_excel_rewrite(group_path)

                # ── Copy unused chapters + save source mapping ──
                if selected_products and unused_product_names:
                    source_mapping = {"used": [], "unused": []}
                    for pname in sorted(selected_products):
                        pd = _unused_bp_product_lookup.get(pname, {})
                        ch = _find_source_chapter(pd, pname)
                        if ch:
                            gpc = os.path.dirname(ch["filepath"])
                            source_mapping["used"].append({
                                "product": pname,
                                "chapter_file": ch["filename"],
                                "source_video": ch.get("group", ""),
                                "source_path": ch["filepath"],
                                "video_id": self._extract_video_id_from_path(gpc),
                            })

                    unused_dir = (job.get("_cached_unused_dir", "") if job else self._txt_unused_dir.text().strip())
                    copied_count = 0
                    copied_files = set()
                    for pname in sorted(unused_product_names):
                        pd = _unused_bp_product_lookup.get(pname, {})
                        ch = _find_source_chapter(pd, pname)
                        if ch:
                            gpc = os.path.dirname(ch["filepath"])
                            entry = {
                                "product": pname,
                                "chapter_file": ch["filename"],
                                "source_video": ch.get("group", ""),
                                "source_path": ch["filepath"],
                                "video_id": self._extract_video_id_from_path(gpc),
                            }
                            if unused_dir and ch["filepath"] not in copied_files:
                                os.makedirs(unused_dir, exist_ok=True)
                                dest = os.path.join(unused_dir, ch["filename"])
                                if os.path.exists(dest):
                                    base, ext = os.path.splitext(ch["filename"])
                                    n = 2
                                    while os.path.exists(os.path.join(unused_dir, f"{base}_{n}{ext}")):
                                        n += 1
                                    dest = os.path.join(unused_dir, f"{base}_{n}{ext}")
                                try:
                                    import shutil
                                    shutil.copy2(ch["filepath"], dest)
                                    entry["copied_to"] = dest
                                    copied_count += 1
                                    copied_files.add(ch["filepath"])
                                except Exception as e:
                                    log(f"⚠ Failed to copy {ch['filename']}: {e}")
                            source_mapping["unused"].append(entry)

                    mapping_path = os.path.join(pipeline_dir, "_source_mapping.json")
                    with open(mapping_path, "w", encoding="utf-8") as f:
                        json.dump(source_mapping, f, indent=2, ensure_ascii=False)
                    log(f"📄 _source_mapping.json ({len(source_mapping['used'])} used, {len(source_mapping['unused'])} unused)")
                    if copied_count > 0:
                        log(f"✓ Copied {copied_count} unused chapter(s) → {unused_dir}")

                # Wait for v2 to finish (if dual-mode was started)
                if '_v2_thread' in dir() and _v2_thread is not None and _v2_thread.is_alive():
                    log("⏳ v1 done — waiting for v2 to finish...")
                    _v2_thread.join()
                    log("✓ v2 also finished")

            except Exception as e:
                log(f"Error: {e}")
                if not _log_callback:
                    self._log.set_status("Error", True)
                self._update_input_chapters_status(
                    checked, "error", chapters_data, str(e)[:50]
                )
                try:
                    import winsound
                    winsound.MessageBeep(winsound.MB_ICONHAND)
                except Exception:
                    pass
            finally:
                if not job:
                    self._running = False

        if job:
            _run()  # ThreadPoolExecutor handles threading
        else:
            threading.Thread(target=_run, daemon=True).start()
===
"""
script_creation_tab.py — UI tab for Script Creation pipeline.
Two modes: Top/List Review (review pipeline) and Narrative (narrative pipeline),
each using a style guide JSON with pipeline-specific frameworks.
"""
import os
import json
import csv
import re
import threading
from concurrent.futures import ThreadPoolExecutor, as_completed
from datetime import datetime

from PyQt6.QtWidgets import (
    QWidget, QVBoxLayout, QHBoxLayout, QLabel, QComboBox,
    QPushButton, QLineEdit, QSpinBox, QCheckBox,
    QTreeWidget, QTreeWidgetItem, QHeaderView, QFileDialog,
    QSizePolicy, QRadioButton, QButtonGroup, QDialog, QDialogButtonBox,
    QScrollArea, QMessageBox, QMenu, QInputDialog,
)
from PyQt6.QtCore import pyqtSignal, Qt


from ui.log_section import LogSection
from core.api_client import APIClient
# (config manager imported below after rewriter imports)
from core.yt_downloader import (
    find_excel_for_video_id, update_excel_rewrite_status,
)
from core.rewriter import (
    rewrite_chapter, verify_chapter, save_rewritten_file,
    generate_narrative_outline, generate_renew_outline,
    review_narrative_full, patch_chapter_overlap,
    build_word_count_rule,
    detect_framework, extract_blueprint,
    generate_narrative_outline, write_from_blueprint, generate_narrative_phase_plan,
    validate_phase_plan_sub_keys, apply_chapter_splits,
    audit_outline,
    recommend_framework, recommend_framework_new_content, check_blueprint, convert_units,
    verify_facts, create_review_outline, write_review_chapter,
    reality_check_blueprint, enrich_prices_google, enrich_blueprint_google,
    extract_blueprint_review, audit_outline_review, review_cross_chapter,
    verify_specs_google, research_blueprint_multicall, transform_rhetoric,
)
from core.config_manager import save_config, load_config, load_api_keys, load_gemini_keys, save_niche_config, load_niche_config


class ScriptCreationTab(QWidget):
    """Tab for rewriting chapters using a style guide JSON."""

    CONFIG_NAME = "rewrite_style_config"
    progress_text = pyqtSignal(str, str)
    tree_refresh = pyqtSignal()
    job_update = pyqtSignal()  # refresh job table from worker thread
    _fw_ranking_request = pyqtSignal(list, str)  # rankings, original_fw

    def __init__(self, parent=None):
        super().__init__(parent)
        self._fw_ranking_result = None   # stores user selection from dialog
        self._fw_ranking_event = threading.Event()  # sync worker ↔ UI
        self._fw_ranking_request.connect(self._show_fw_ranking_dialog)
        self._running = False
        self._stop_flag = False  # legacy compat, will be per-job
        self._lock = threading.Lock()
        self._status = {}  # {chapters: {fname: {...}}}
        self._chapters = []  # [{filename, filepath, text, group}...]
        self._narrative_outline = {}
        self._group_path = ""  # primary scan folder
        self._config_loaded = False  # flag to prevent mode defaults overwriting saved config
        # ── Job management ──
        self._jobs = {}  # job_id -> {id, folder_name, group_path, mode, stop_event, status, progress, future}
        self._job_counter = 0
        self._task_counter = 0  # user-facing task number for logs
        from concurrent.futures import ThreadPoolExecutor
        self._job_pool = ThreadPoolExecutor(max_workers=3, thread_name_prefix="rewrite")
        self._build_ui()
        self._connect_signals()
        self._load_saved_config()
        # Trigger mode-based UI setup (style filter, framework combo, country visibility)
        self._on_mode_changed(self._combo_mode.currentText())

    # ── UI ─────────────────────────────────────────────────────────

    def _build_ui(self):
        main_layout = QVBoxLayout(self)
        main_layout.setContentsMargins(8, 4, 8, 4)
        main_layout.setSpacing(4)

        # ── Row 1a: Output folder ──
        io_row = QHBoxLayout()
        io_row.setSpacing(6)
        io_row.addWidget(QLabel("Output:"))
        self._txt_output = QLineEdit()
        self._txt_output.setPlaceholderText("Để trống = lưu vào style_rewrite/ trong thư mục gốc")
        io_row.addWidget(self._txt_output, 1)
        btn_browse_out = QPushButton("Browse")
        btn_browse_out.setToolTip("Select output folder")
        btn_browse_out.clicked.connect(lambda: self._browse("output"))
        io_row.addWidget(btn_browse_out)
        main_layout.addLayout(io_row)

        # ── Row 1b: Unused chapters folder ──
        unused_row = QHBoxLayout()
        unused_row.setSpacing(6)
        unused_row.addWidget(QLabel("Unused:"))
        self._txt_unused_dir = QLineEdit()
        self._txt_unused_dir.setPlaceholderText("Chọn thư mục lưu chapters không được sử dụng")
        unused_row.addWidget(self._txt_unused_dir, 1)
        btn_browse_unused = QPushButton("Browse")
        btn_browse_unused.setToolTip("Select unused chapters folder")
        btn_browse_unused.clicked.connect(lambda: self._browse("unused"))
        unused_row.addWidget(btn_browse_unused)
        self._btn_delete_unused = QPushButton("🗑 Delete")
        self._btn_delete_unused.setToolTip("Delete files in unused chapters folder")
        self._btn_delete_unused.setStyleSheet(
            "QPushButton { background: #e74c3c; color: white; font-weight: bold; "
            "border-radius: 3px; padding: 3px 10px; } "
            "QPushButton:hover { background: #c0392b; }"
        )
        self._btn_delete_unused.clicked.connect(self._delete_unused_chapters)
        unused_row.addWidget(self._btn_delete_unused)
        main_layout.addLayout(unused_row)

        # ── Row 2: Mode, Style, Lang, Tier, Threads ──
        rw_row1 = QHBoxLayout()
        rw_row1.setSpacing(6)

        rw_row1.addWidget(QLabel("Mode:"))
        self._combo_mode = QComboBox()
        self._combo_mode.addItem("Top/List Review")
        self._combo_mode.addItem("Narrative")
        self._combo_mode.setSizePolicy(QSizePolicy.Policy.Fixed, QSizePolicy.Policy.Fixed)
        self._combo_mode.currentTextChanged.connect(self._on_mode_changed)
        rw_row1.addWidget(self._combo_mode)
        rw_row1.addSpacing(4)

        rw_row1.addWidget(QLabel("Style:"))
        self._combo_style = QComboBox()
        self._combo_style.setSizePolicy(QSizePolicy.Policy.Preferred, QSizePolicy.Policy.Fixed)
        self._combo_style.setMinimumWidth(180)
        self._refresh_style_dropdown()
        self._combo_style.showPopup = self._show_style_popup
        rw_row1.addWidget(self._combo_style)
        self._combo_style.currentTextChanged.connect(
            lambda _: self._on_mode_changed(self._combo_mode.currentText())
        )
        rw_row1.addSpacing(4)

        # Framework selector (visible for both modes)
        self._lbl_framework = QLabel("Framework:")
        rw_row1.addWidget(self._lbl_framework)
        self._combo_framework = QComboBox()
        self._combo_framework.addItem("Auto (detect & switch)")
        self._combo_framework.setSizePolicy(QSizePolicy.Policy.Preferred, QSizePolicy.Policy.Fixed)
        self._combo_framework.setMinimumWidth(160)
        rw_row1.addWidget(self._combo_framework)
        self._lbl_framework.setVisible(False)
        self._combo_framework.setVisible(False)
        rw_row1.addSpacing(4)

        rw_row1.addWidget(QLabel("Lang:"))
        self._combo_lang = QComboBox()
        self._combo_lang.addItems(["Tiếng Anh", "Tiếng Tây Ban Nha", "Tiếng Việt", "Tiếng Nga"])
        self._combo_lang.setSizePolicy(QSizePolicy.Policy.Fixed, QSizePolicy.Policy.Fixed)
        rw_row1.addWidget(self._combo_lang)
        rw_row1.addSpacing(4)

        rw_row1.addWidget(QLabel("Tier:"))
        self._combo_tier = QComboBox()
        self._combo_tier.addItems(["Pro", "Flash"])
        self._combo_tier.setSizePolicy(QSizePolicy.Policy.Fixed, QSizePolicy.Policy.Fixed)
        rw_row1.addWidget(self._combo_tier)
        rw_row1.addSpacing(4)

        self._lbl_threads = QLabel("Threads:")
        rw_row1.addWidget(self._lbl_threads)
        self._spin_threads = QSpinBox()
        self._spin_threads.setRange(1, 8)
        self._spin_threads.setValue(3)
        self._spin_threads.setSizePolicy(QSizePolicy.Policy.Fixed, QSizePolicy.Policy.Fixed)
        rw_row1.addWidget(self._spin_threads)
        rw_row1.addSpacing(4)

        self._lbl_country = QLabel("Country:")
        rw_row1.addWidget(self._lbl_country)
        self._combo_country = QComboBox()
        self._combo_country.addItems(["US", "EU"])
        self._combo_country.setSizePolicy(QSizePolicy.Policy.Fixed, QSizePolicy.Policy.Fixed)
        rw_row1.addWidget(self._combo_country)
        self._lbl_country.setVisible(False)
        self._combo_country.setVisible(False)
        rw_row1.addStretch()
        main_layout.addLayout(rw_row1)

        # ── Row 3: Word count ──
        wc_row = QHBoxLayout()
        wc_row.setSpacing(4)

        def _make_wc_pair(label, default_min, default_max):
            wc_row.addWidget(QLabel(label))
            sp_min = QSpinBox()
            sp_min.setRange(0, 5000)
            sp_min.setValue(default_min)
            sp_min.setSingleStep(100)
            sp_min.setSpecialValueText("—")
            sp_min.setSizePolicy(QSizePolicy.Policy.Fixed, QSizePolicy.Policy.Fixed)
            wc_row.addWidget(sp_min)
            wc_row.addWidget(QLabel("~"))
            sp_max = QSpinBox()
            sp_max.setRange(0, 5000)
            sp_max.setValue(default_max)
            sp_max.setSingleStep(100)
            sp_max.setSpecialValueText("—")
            sp_max.setSizePolicy(QSizePolicy.Policy.Fixed, QSizePolicy.Policy.Fixed)
            wc_row.addWidget(sp_max)
            return sp_min, sp_max

        # ── Chapters range ──
        wc_row.addWidget(QLabel("Ch:"))
        self._ch_min = QSpinBox()
        self._ch_min.setRange(0, 50)
        self._ch_min.setValue(0)
        self._ch_min.setSpecialValueText("—")
        self._ch_min.setSizePolicy(QSizePolicy.Policy.Fixed, QSizePolicy.Policy.Fixed)
        wc_row.addWidget(self._ch_min)
        wc_row.addWidget(QLabel("~"))
        self._ch_max = QSpinBox()
        self._ch_max.setRange(0, 50)
        self._ch_max.setValue(0)
        self._ch_max.setSpecialValueText("—")
        self._ch_max.setSizePolicy(QSizePolicy.Policy.Fixed, QSizePolicy.Policy.Fixed)
        wc_row.addWidget(self._ch_max)
        wc_row.addSpacing(10)

        self._wc_open_min, self._wc_open_max = _make_wc_pair("Open:", 0, 0)
        wc_row.addSpacing(10)
        self._wc_body_min, self._wc_body_max = _make_wc_pair("Body:", 0, 0)
        wc_row.addSpacing(10)
        self._wc_end_min, self._wc_end_max = _make_wc_pair("End:", 0, 0)
        wc_row.addStretch()
        main_layout.addLayout(wc_row)

        # ── Row 4: Actions ──
        btn_row = QHBoxLayout()
        btn_row.setSpacing(4)

        btn_scan = QPushButton("📂 Scan Folder")
        btn_scan.setToolTip("Scan a folder for .txt chapter files")
        btn_scan.clicked.connect(self._scan_folder)
        btn_row.addWidget(btn_scan)

        btn_add = QPushButton("+ Add")
        btn_add.setToolTip("Add individual .txt file(s)")
        btn_add.clicked.connect(self._add_single_file)
        btn_row.addWidget(btn_add)

        self._btn_rewrite = QPushButton("▶ Rewrite")
        self._btn_rewrite.setProperty("class", "btn-accent")
        self._btn_rewrite.clicked.connect(self._do_rewrite)
        btn_row.addWidget(self._btn_rewrite)

        self._btn_new_content = QPushButton("✦ New Content")
        self._btn_new_content.setProperty("class", "btn-success")
        self._btn_new_content.setToolTip(
            "Research a topic from scratch → Generate blueprint → Write new script\n"
            "No source files needed — just enter a topic name."
        )
        self._btn_new_content.clicked.connect(self._do_new_content)
        btn_row.addWidget(self._btn_new_content)

        self._btn_rech = QPushButton("🔄 Re-ch")
        self._btn_rech.setToolTip("Rewrite checked chapter(s) using existing pipeline data")
        self._btn_rech.clicked.connect(self._do_rewrite_chapter)
        btn_row.addWidget(self._btn_rech)

        self._btn_stop = QPushButton("■ Stop")
        self._btn_stop.clicked.connect(self._do_stop)
        btn_row.addWidget(self._btn_stop)

        self._btn_retry = QPushButton("🔄 Retry")
        self._btn_retry.setToolTip("Retry failed/error/stopped folders")
        self._btn_retry.clicked.connect(self._do_retry)
        btn_row.addWidget(self._btn_retry)

        self._btn_save = QPushButton("Save Config")
        self._btn_save.clicked.connect(self._save_config)
        btn_row.addWidget(self._btn_save)

        self._chk_excel_update = QCheckBox("📊 Excel")
        self._chk_excel_update.setChecked(True)
        self._chk_excel_update.setToolTip("Update Rewrite status in Excel after completion")
        btn_row.addWidget(self._chk_excel_update)

        self._chk_transitions = QCheckBox("↔ Transitions")
        self._chk_transitions.setChecked(True)
        self._chk_transitions.setToolTip(
            "Add bridge sentences between chapters.\n"
            "OFF = open each chapter directly with topic name (Top/List only)"
        )
        btn_row.addWidget(self._chk_transitions)

        self._chk_cut_video = QCheckBox("🎬 Cut Video")
        self._chk_cut_video.setChecked(True)
        self._chk_cut_video.setToolTip(
            "After rewrite, download YouTube video and cut into chapter clips.\n"
            "Requires YouTube URL in merge file. Skips if already cut."
        )
        btn_row.addWidget(self._chk_cut_video)

        self._chk_google_check = QCheckBox("🔍 Google Check")
        self._chk_google_check.setChecked(True)
        self._chk_google_check.setToolTip(
            "Use Google Search to verify facts and enrich data.\n"
            "Firearms: also looks up prices. Mystery: verifies sources & dates.\n"
            "Requires Gemini API key(s) in header bar."
        )
        btn_row.addWidget(self._chk_google_check)

        self._chk_auto_patch = QCheckBox("🩹 Auto-Patch")
        self._chk_auto_patch.setChecked(False)
        self._chk_auto_patch.setToolTip(
            "Auto-fix critical/major cross-chapter issues after review.\n"
            "OFF = review only (log issues, no changes).\n"
            "ON = automatically patch chapters (may alter tone)."
        )
        btn_row.addWidget(self._chk_auto_patch)

        btn_row.addStretch()

        self._lbl_stats = QLabel("")
        btn_row.addWidget(self._lbl_stats)
        main_layout.addLayout(btn_row)

        # ── Split: Folder list (left) + Chapter tree (right) ──
        from PyQt6.QtWidgets import QSplitter
        self._splitter = QSplitter(Qt.Orientation.Horizontal)

        # Folder list (left)
        self._folder_tree = QTreeWidget()
        self._folder_tree.setHeaderLabels(["#", "Folder", "Status", "Progress"])
        self._folder_tree.setColumnCount(4)
        jh = self._folder_tree.header()
        jh.setStretchLastSection(False)
        jh.setSectionResizeMode(0, QHeaderView.ResizeMode.Fixed)
        jh.resizeSection(0, 30)
        jh.setSectionResizeMode(1, QHeaderView.ResizeMode.Stretch)
        for c in (2, 3):
            jh.setSectionResizeMode(c, QHeaderView.ResizeMode.ResizeToContents)
        self._folder_tree.setRootIsDecorated(False)
        self._folder_tree.setAlternatingRowColors(True)
        self._folder_tree.currentItemChanged.connect(self._on_folder_selected)
        self._folder_tree.clicked.connect(lambda: setattr(self, '_last_active_panel', self._folder_tree))
        self._folder_tree.setSelectionMode(QTreeWidget.SelectionMode.ExtendedSelection)
        self._folder_tree.setContextMenuPolicy(Qt.ContextMenuPolicy.CustomContextMenu)
        self._folder_tree.customContextMenuRequested.connect(self._on_folder_tree_context_menu)
        self._splitter.addWidget(self._folder_tree)

        # Chapter tree (right)
        self._tree = QTreeWidget()
        self._tree.setHeaderLabels(["Chapter", "Status", "Progress"])
        self._tree.setColumnCount(3)
        header = self._tree.header()
        header.setStretchLastSection(False)
        header.setSectionResizeMode(0, QHeaderView.ResizeMode.Stretch)
        for c in (1, 2):
            header.setSectionResizeMode(c, QHeaderView.ResizeMode.ResizeToContents)
        self._tree.setRootIsDecorated(False)
        self._tree.setAlternatingRowColors(True)
        self._tree.itemChanged.connect(self._on_item_changed)
        self._tree.clicked.connect(lambda: setattr(self, '_last_active_panel', self._tree))
        self._tree.setSelectionMode(QTreeWidget.SelectionMode.ExtendedSelection)
        self._tree.setContextMenuPolicy(Qt.ContextMenuPolicy.CustomContextMenu)
        self._tree.customContextMenuRequested.connect(self._on_chapter_tree_context_menu)
        self._propagating = False
        self._last_active_panel = self._tree  # default
        self._splitter.addWidget(self._tree)

        self._splitter.setSizes([350, 650])  # 35/65
        main_layout.addWidget(self._splitter, 1)

        # ── Row 5: Tree management buttons (below splitter) ──
        tree_btn_row = QHBoxLayout()
        tree_btn_row.setSpacing(4)

        self._btn_open = QPushButton("📂 Open")
        self._btn_open.clicked.connect(self._open_output_folder)
        tree_btn_row.addWidget(self._btn_open)

        self._btn_clear = QPushButton("Clear")
        self._btn_clear.clicked.connect(self._clear_tree)
        tree_btn_row.addWidget(self._btn_clear)

        btn_remove = QPushButton("Remove")
        btn_remove.setToolTip("Remove checked chapters from list")
        btn_remove.clicked.connect(self._remove_checked)
        tree_btn_row.addWidget(btn_remove)

        self._btn_all = QPushButton("All")
        self._btn_all.clicked.connect(self._select_all)
        tree_btn_row.addWidget(self._btn_all)

        self._btn_none = QPushButton("None")
        self._btn_none.clicked.connect(self._deselect_all)
        tree_btn_row.addWidget(self._btn_none)

        self._btn_resume = QPushButton("▶ Resume")
        self._btn_resume.setToolTip(
            "Resume an interrupted pipeline from its last checkpoint.\n"
            "Set Output path to the existing output folder first."
        )
        self._btn_resume.clicked.connect(self._do_resume)
        tree_btn_row.addWidget(self._btn_resume)

        tree_btn_row.addStretch()
        main_layout.addLayout(tree_btn_row)

        # ── Log ──
        self._log = LogSection()
        main_layout.addWidget(self._log, 0)

    # ── Signals ────────────────────────────────────────────────────

    def _connect_signals(self):
        self.progress_text.connect(self._on_progress_text)
        self.tree_refresh.connect(self._refresh_tree)
        self.job_update.connect(self._refresh_folder_tree)

    # ── Style dropdown ─────────────────────────────────────────────

    def _refresh_style_dropdown(self):
        """Scan styles/ folder and populate dropdown, filtered by current mode."""
        current = self._combo_style.currentText() if self._combo_style.count() else ""
        self._combo_style.blockSignals(True)
        self._combo_style.clear()

        mode = self._combo_mode.currentText()
        if mode == "Top/List Review":
            target_pipeline = "review"
        else:
            target_pipeline = "narrative"

        styles_dir = os.path.join(
            os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
            "styles"
        )
        if os.path.isdir(styles_dir):
            for fname in sorted(os.listdir(styles_dir)):
                if fname.endswith(".json"):
                    # Read pipeline field to filter
                    fpath = os.path.join(styles_dir, fname)
                    try:
                        with open(fpath, "r", encoding="utf-8") as f:
                            sd = json.load(f)
                        file_pipeline = sd.get("pipeline", "narrative")
                    except Exception:
                        file_pipeline = "narrative"

                    if file_pipeline == target_pipeline:
                        style_name = fname.replace(".json", "").replace("_", " ").title()
                        self._combo_style.addItem(f"✦ {style_name}", fname)

        if self._combo_style.count() == 0:
            self._combo_style.addItem("(no styles found)")

        if current:
            idx = self._combo_style.findText(current)
            if idx >= 0:
                self._combo_style.setCurrentIndex(idx)
        self._combo_style.blockSignals(False)

    def _show_style_popup(self):
        self._refresh_style_dropdown()
        QComboBox.showPopup(self._combo_style)

    def _get_style_filename(self):
        """Return the selected style JSON filename, e.g. 'my_style.json'."""
        idx = self._combo_style.currentIndex()
        if idx >= 0:
            data = self._combo_style.itemData(idx)
            if data:
                return data
        # Fallback for items without data
        text = self._combo_style.currentText()
        if text.startswith("✦ "):
            return text[2:].strip().lower().replace(" ", "_") + ".json"
        return None

    # ── Lang ───────────────────────────────────────────────────────

    _LANG_MAP = {"Tiếng Anh": "english", "Tiếng Tây Ban Nha": "español", "Tiếng Việt": "tiếng việt", "Tiếng Nga": "русский"}
    _LANG_NAMES = {"en": "English", "es": "Spanish", "vi": "Vietnamese", "ru": "Russian"}

    def _get_lang_code(self):
        return self._LANG_MAP.get(self._combo_lang.currentText(), "english")

    # ── Word Count ─────────────────────────────────────────────────

    def _get_word_count_rule(self, section="body"):
        pairs = {
            "open": (self._wc_open_min, self._wc_open_max),
            "body": (self._wc_body_min, self._wc_body_max),
            "end": (self._wc_end_min, self._wc_end_max),
        }
        sp_min, sp_max = pairs.get(section, pairs["body"])
        return build_word_count_rule(sp_min.value(), sp_max.value())

    def _get_chapter_range_rule(self):
        """Build chapter count instruction string from Ch min/max."""
        v_min = self._ch_min.value()
        v_max = self._ch_max.value()
        if v_min > 0 and v_max > 0:
            return f"between {v_min} and {v_max} chapters"
        elif v_min > 0:
            return f"at least {v_min} chapters"
        elif v_max > 0:
            return f"at most {v_max} chapters"
        return ""

    # ── File / Folder Browsing ─────────────────────────────────────

    def _browse(self, target):
        start_dir = ""
        if target == "output":
            start_dir = self._txt_output.text()
        elif target == "unused":
            start_dir = self._txt_unused_dir.text()
        d = QFileDialog.getExistingDirectory(self, f"Select {target} folder", start_dir)
        if d:
            if target == "output":
                self._txt_output.setText(d)
            elif target == "unused":
                self._txt_unused_dir.setText(d)

    def _delete_unused_chapters(self):
        """Delete files in unused chapters folder with state-dependent warnings."""
        # Check pipeline state
        if self._running:
            QMessageBox.warning(
                self, "Unused Chapters",
                "Pipeline đang chạy.\n"
                "Vui lòng đợi hoàn thành trước khi xoá."
            )
            return
        unused_dir = self._txt_unused_dir.text().strip()
        if not unused_dir:
            QMessageBox.information(
                self, "Unused Chapters",
                "Chưa chọn thư mục unused chapters."
            )
            return
        if not os.path.isdir(unused_dir):
            QMessageBox.information(
                self, "Unused Chapters",
                f"Thư mục không tồn tại:\n{unused_dir}"
            )
            return
        # Count txt files
        txt_files = [f for f in os.listdir(unused_dir)
                     if f.lower().endswith(".txt")]
        if not txt_files:
            QMessageBox.information(
                self, "Unused Chapters",
                "Thư mục rỗng \u2014 không có file .txt nào để xoá."
            )
            return
        # Confirm deletion
        reply = QMessageBox.warning(
            self, "Xác nhận xoá",
            f"Xoá {len(txt_files)} file .txt trong:\n{unused_dir}\n\n"
            "Không thể hoàn tác!",
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No,
            QMessageBox.StandardButton.No
        )
        if reply == QMessageBox.StandardButton.Yes:
            deleted = 0
            for f in txt_files:
                try:
                    os.remove(os.path.join(unused_dir, f))
                    deleted += 1
                except Exception:
                    pass
            self._log.log(f"[Style] Deleted {deleted} file(s) from unused folder")

    def _open_output_folder(self):
        out = self._txt_output.text().strip()
        if not out:
            out = os.path.join(self._group_path, "style_rewrite") if self._group_path else ""
        if out and os.path.isdir(out):
            os.startfile(out)

    def _resolve_output_dir(self, ref_filepath=None):
        """Resolve output directory. If empty, auto-create 'style_rewrite/' in source file dir."""
        output_dir = self._txt_output.text().strip()
        if output_dir:
            return output_dir
        # Use the source file's directory
        if ref_filepath:
            src_dir = os.path.dirname(ref_filepath)
        elif self._chapters:
            src_dir = os.path.dirname(self._chapters[0]["filepath"])
        elif self._group_path and os.path.isdir(self._group_path):
            src_dir = self._group_path
        else:
            self._log.log("[Style] Input folder not set")
            return ""
        output_dir = os.path.join(src_dir, "style_rewrite")
        os.makedirs(output_dir, exist_ok=True)
        self._log.log(f"[Style] Output → {output_dir}")
        return output_dir

    def _active_panel(self):
        """Return whichever panel was last clicked."""
        return getattr(self, '_last_active_panel', self._tree)

    def _clear_tree(self):
        self._tree.clear()
        self._folder_tree.clear()
        self._chapters = []
        self._status = {}
        self._group_path = ""
        self._lbl_stats.setText("")
        self._log.log("[Style] Cleared")

    def _remove_checked(self):
        """Remove checked items from the focused panel."""
        panel = self._active_panel()
        if panel is self._folder_tree:
            # Remove checked folders and their chapters
            removed_groups = []
            for i in range(panel.topLevelItemCount()):
                item = panel.topLevelItem(i)
                if item and item.checkState(1) == Qt.CheckState.Checked:
                    g = item.data(1, Qt.ItemDataRole.UserRole)
                    if g:
                        removed_groups.append(g)
            if not removed_groups:
                self._log.log("[Style] No folders selected to remove")
                return
            before = len(self._chapters)
            self._chapters = [c for c in self._chapters if c.get("group") not in removed_groups]
            removed = before - len(self._chapters)
            self._log.log(f"[Style] Removed {len(removed_groups)} folder(s), {removed} chapter(s)")
            self._refresh_tree()
        else:
            # Remove checked chapters from current folder
            checked = self._get_checked_chapters()
            if not checked:
                self._log.log("[Style] No chapters selected to remove")
                return
            checked_paths = {c["filepath"] for c in checked}
            before = len(self._chapters)
            self._chapters = [c for c in self._chapters if c["filepath"] not in checked_paths]
            removed = before - len(self._chapters)
            self._log.log(f"[Style] Removed {removed} chapter(s)")
            self._refresh_tree()

    def _on_folder_tree_context_menu(self, pos):
        """Right-click context menu for folder tree."""
        selected = self._folder_tree.selectedItems()
        if not selected:
            return
        menu = QMenu(self)
        action_remove = menu.addAction(f"🗑 Remove {len(selected)} folder(s)")
        action_retry = menu.addAction(f"🔄 Retry {len(selected)} folder(s)")
        action = menu.exec(self._folder_tree.viewport().mapToGlobal(pos))
        if action == action_remove:
            groups_to_remove = set()
            for item in selected:
                g = item.data(1, Qt.ItemDataRole.UserRole)
                if g:
                    groups_to_remove.add(g)
            if groups_to_remove:
                before = len(self._chapters)
                self._chapters = [c for c in self._chapters if c.get("group") not in groups_to_remove]
                removed = before - len(self._chapters)
                self._log.log(f"[Style] Removed {len(groups_to_remove)} folder(s), {removed} chapter(s)")
                self._refresh_tree()
        elif action == action_retry:
            groups_to_retry = []
            for item in selected:
                g = item.data(1, Qt.ItemDataRole.UserRole)
                if g:
                    groups_to_retry.append(g)
            if groups_to_retry:
                self._do_retry(specific_folders=groups_to_retry)

    def _on_chapter_tree_context_menu(self, pos):
        """Right-click context menu for chapter tree."""
        selected = self._tree.selectedItems()
        if not selected:
            return
        menu = QMenu(self)
        action_remove = menu.addAction(f"🗑 Remove {len(selected)} chapter(s)")
        action = menu.exec(self._tree.viewport().mapToGlobal(pos))
        if action == action_remove:
            paths_to_remove = set()
            for item in selected:
                ch = item.data(0, Qt.ItemDataRole.UserRole)
                if ch and isinstance(ch, dict) and "filepath" in ch:
                    paths_to_remove.add(ch["filepath"])
            if paths_to_remove:
                self._chapters = [c for c in self._chapters if c["filepath"] not in paths_to_remove]
                self._log.log(f"[Style] Removed {len(paths_to_remove)} chapter(s)")
                self._refresh_tree()

    # ── Config Save/Load ───────────────────────────────────────────

    def _save_config(self):
        cfg = {
            "output": self._txt_output.text(),
            "unused_dir": self._txt_unused_dir.text(),
            "mode": self._combo_mode.currentText(),
            "style": self._combo_style.currentText(),
            "framework": self._combo_framework.currentText(),
            "lang": self._combo_lang.currentText(),
            "tier": self._combo_tier.currentText(),
            "threads": self._spin_threads.value(),
            "country": self._combo_country.currentText(),
            "ch_min": self._ch_min.value(),
            "ch_max": self._ch_max.value(),
            "wc_open_min": self._wc_open_min.value(),
            "wc_open_max": self._wc_open_max.value(),
            "wc_body_min": self._wc_body_min.value(),
            "wc_body_max": self._wc_body_max.value(),
            "wc_end_min": self._wc_end_min.value(),
            "wc_end_max": self._wc_end_max.value(),
            "excel_update": self._chk_excel_update.isChecked(),
            "transitions": self._chk_transitions.isChecked(),
            "cut_video": self._chk_cut_video.isChecked(),
            "google_check": self._chk_google_check.isChecked(),
            "auto_patch": self._chk_auto_patch.isChecked(),
        }
        save_config(self.CONFIG_NAME, cfg)

        # Also save per-niche settings (style-specific)
        style_file = self._get_style_filename()
        if style_file:
            niche_cfg = {
                "lang": self._combo_lang.currentText(),
                "framework": self._combo_framework.currentText(),
                "tier": self._combo_tier.currentText(),
                "threads": self._spin_threads.value(),
                "country": self._combo_country.currentText(),
                "ch_min": self._ch_min.value(),
                "ch_max": self._ch_max.value(),
                "wc_open_min": self._wc_open_min.value(),
                "wc_open_max": self._wc_open_max.value(),
                "wc_body_min": self._wc_body_min.value(),
                "wc_body_max": self._wc_body_max.value(),
                "wc_end_min": self._wc_end_min.value(),
                "wc_end_max": self._wc_end_max.value(),
                "excel_update": self._chk_excel_update.isChecked(),
                "transitions": self._chk_transitions.isChecked(),
                "cut_video": self._chk_cut_video.isChecked(),
                "google_check": self._chk_google_check.isChecked(),
                "auto_patch": self._chk_auto_patch.isChecked(),
            }
            save_niche_config(style_file, niche_cfg)
        self._log.log("[Style] Config saved")

    def _apply_niche_config(self):
        """Load and apply per-niche config for the currently selected style."""
        # Skip during initial config load to avoid signal cascade
        if not getattr(self, '_config_loaded', False):
            return  # Skip silently during init
        style_file = self._get_style_filename()
        if not style_file:
            self._log.log("[Style] Niche skip: no style file")
            return
        niche = load_niche_config(style_file)
        if not niche:
            self._log.log(f"[Style] Niche skip: no config for {style_file}")
            return
        self._log.log(f"[Style] Niche loaded: {style_file} → lang={niche.get('lang')}, wc_body_min={niche.get('wc_body_min')}")
        # Apply niche-specific settings
        if niche.get("lang"):
            idx = self._combo_lang.findText(niche["lang"])
            if idx >= 0:
                self._combo_lang.setCurrentIndex(idx)
        if niche.get("framework"):
            idx = self._combo_framework.findText(niche["framework"])
            if idx >= 0:
                self._combo_framework.setCurrentIndex(idx)
        if niche.get("tier"):
            idx = self._combo_tier.findText(niche["tier"])
            if idx >= 0:
                self._combo_tier.setCurrentIndex(idx)
        if niche.get("threads"):
            self._spin_threads.setValue(niche["threads"])
        if niche.get("country"):
            idx = self._combo_country.findText(niche["country"])
            if idx >= 0:
                self._combo_country.setCurrentIndex(idx)
        if "ch_min" in niche:
            self._ch_min.setValue(niche["ch_min"])
        if "ch_max" in niche:
            self._ch_max.setValue(niche["ch_max"])
        for key in ("wc_open_min", "wc_open_max", "wc_body_min",
                     "wc_body_max", "wc_end_min", "wc_end_max"):
            w = getattr(self, f"_{key}", None)
            if w and key in niche:
                w.setValue(niche[key])
        # Restore checkbox states per-niche
        for key, chk in (("excel_update", self._chk_excel_update),
                         ("transitions", self._chk_transitions),
                         ("cut_video", self._chk_cut_video),
                         ("google_check", self._chk_google_check),
                         ("auto_patch", self._chk_auto_patch)):
            if key in niche:
                chk.setChecked(niche[key])
        # Legacy migration: old price_check/enrich_data → google_check
        if "google_check" not in niche:
            if "enrich_data" in niche or "price_check" in niche:
                _legacy = niche.get("enrich_data", niche.get("price_check", True))
                self._chk_google_check.setChecked(_legacy)

    def _load_saved_config(self):
        cfg = load_config(self.CONFIG_NAME)
        if not cfg:
            return
        # Restore text fields
        if cfg.get("output"):
            self._txt_output.setText(cfg["output"])
        if cfg.get("unused_dir"):
            self._txt_unused_dir.setText(cfg["unused_dir"])
        if cfg.get("mode"):
            idx = self._combo_mode.findText(cfg["mode"])
            if idx >= 0:
                self._combo_mode.setCurrentIndex(idx)
        if cfg.get("style"):
            idx = self._combo_style.findText(cfg["style"])
            if idx >= 0:
                self._combo_style.setCurrentIndex(idx)
        if cfg.get("framework"):
            idx = self._combo_framework.findText(cfg["framework"])
            if idx >= 0:
                self._combo_framework.setCurrentIndex(idx)
        if cfg.get("lang"):
            idx = self._combo_lang.findText(cfg["lang"])
            if idx >= 0:
                self._combo_lang.setCurrentIndex(idx)
        if cfg.get("tier"):
            idx = self._combo_tier.findText(cfg["tier"])
            if idx >= 0:
                self._combo_tier.setCurrentIndex(idx)
        if cfg.get("threads"):
            self._spin_threads.setValue(cfg["threads"])
        if cfg.get("country"):
            idx = self._combo_country.findText(cfg["country"])
            if idx >= 0:
                self._combo_country.setCurrentIndex(idx)
        if "ch_min" in cfg:
            self._ch_min.setValue(cfg["ch_min"])
        if "ch_max" in cfg:
            self._ch_max.setValue(cfg["ch_max"])
        for key in ("wc_open_min", "wc_open_max", "wc_body_min",
                     "wc_body_max", "wc_end_min", "wc_end_max"):
            w = getattr(self, f"_{key}", None)
            if w and key in cfg:
                w.setValue(cfg[key])
        self._chk_excel_update.setChecked(cfg.get("excel_update", True))
        self._chk_transitions.setChecked(cfg.get("transitions", True))
        self._chk_cut_video.setChecked(cfg.get("cut_video", True))
        self._chk_google_check.setChecked(cfg.get("google_check", True))
        self._chk_auto_patch.setChecked(cfg.get("auto_patch", False))
        self._config_loaded = True

    # ── Natural sort helper ────────────────────────────────────────

    @staticmethod
    def _natural_sort_key(name):
        import re
        return [int(c) if c.isdigit() else c.lower()
                for c in re.split(r'(\d+)', name)]

    # ── Scan Folder ────────────────────────────────────────────────

    def _scan_folder(self):
        from ui.multi_folder_dialog import select_multiple_folders
        selected_dirs = select_multiple_folders(
            self, "Select folder(s)",
            self._group_path if hasattr(self, '_group_path') and self._group_path else ""
        )
        if not selected_dirs:
            return

        SKIP_PATTERNS = [
            "_SUMMARY", "_VERIFY", "_STATUS", "_MERGE", "_REORDER",
            "FULL_SCRIPT", "_PREVIEW", "_STYLE_", "_REWRITE_STATUS",
        ]

        for d in selected_dirs:
            if not os.path.isdir(d):
                continue
            self._group_path = d

            chapters = []
            for dirpath, dirnames, filenames in os.walk(d):
                dirnames[:] = [dn for dn in dirnames if not dn.startswith(".")]
                rel = os.path.relpath(dirpath, d)
                if rel == ".":
                    label = os.path.basename(d)
                else:
                    label = rel.replace("\\", "/")

                txt_files = sorted(
                    (f for f in filenames
                     if f.lower().endswith(".txt")
                     and not f.lower().startswith("tts_")
                     and not any(skip in f.upper() for skip in SKIP_PATTERNS)),
                    key=self._natural_sort_key
                )

                for fname in txt_files:
                    fpath = os.path.join(dirpath, fname)
                    try:
                        with open(fpath, "r", encoding="utf-8") as f:
                            text = f.read()
                    except Exception:
                        continue
                    chapters.append({
                        "filename": fname,
                        "filepath": fpath,
                        "text": text,
                        "group": label,
                    })

            if not chapters:
                self._log.log(f"[Style] No .txt files in {os.path.basename(d)}")
                continue

            root_name = os.path.basename(d)
            self._chapters = [c for c in self._chapters if c.get("group") != root_name]
            self._chapters.extend(chapters)

            folders = set(c["group"] for c in chapters)
            self._log.log(
                f"[Style] Loaded {len(chapters)} files in {len(folders)} folder(s) from {root_name}"
            )

        self._refresh_tree()

    # ── Add single files ───────────────────────────────────────────

    def _add_single_file(self):
        files, _ = QFileDialog.getOpenFileNames(
            self, "Select script files", "", "Text files (*.txt);;All (*)"
        )
        if not files:
            return
        for fpath in files:
            fname = os.path.basename(fpath)
            if any(c["filepath"] == fpath for c in self._chapters):
                continue
            with open(fpath, "r", encoding="utf-8") as f:
                text = f.read()
            self._chapters.append({
                "filename": fname,
                "filepath": fpath,
                "text": text,
                "group": "(Added)",
            })
        self._log.log(f"[Style] Added {len(files)} file(s)")
        self._refresh_tree()

    # ── Tree helpers ───────────────────────────────────────────────

    def _refresh_tree(self):
        """Populate folder list (left) and chapter list (right) for selected folder."""
        from collections import OrderedDict
        groups = OrderedDict()
        for ch in self._chapters:
            g = ch.get("group", "")
            if g not in groups:
                groups[g] = []
            groups[g].append(ch)

        # Update folder list (left panel)
        self._folder_tree.blockSignals(True)
        prev_selected = getattr(self, "_selected_group", None)
        self._folder_tree.clear()

        first_item = None
        select_item = None
        for group_name, group_chapters in groups.items():
            # Get job status for this folder if it exists
            job = self._get_job_for_group(group_name)
            if job:
                status = self._JOB_STATUS_MAP.get(job["status"], job["status"])
                progress = job.get("progress", "")
            else:
                status = ""
                progress = f"{len(group_chapters)} ch"

            task_num = str(job.get("task_num", "")) if job else ""
            item = QTreeWidgetItem([task_num, group_name, status, progress])
            item.setFlags(item.flags() | Qt.ItemFlag.ItemIsUserCheckable)
            item.setCheckState(1, Qt.CheckState.Checked)
            item.setData(1, Qt.ItemDataRole.UserRole, group_name)
            self._folder_tree.addTopLevelItem(item)
            if first_item is None:
                first_item = item
            if group_name == prev_selected:
                select_item = item

        self._folder_tree.blockSignals(False)

        # Restore or select first folder
        if select_item:
            self._folder_tree.setCurrentItem(select_item)
        elif first_item:
            self._folder_tree.setCurrentItem(first_item)

        # Stats
        total = len(self._chapters)
        g_count = len(groups)
        if g_count > 1:
            self._lbl_stats.setText(f"{g_count} folders, {total} ch")
        else:
            self._lbl_stats.setText(f"{total} ch")

    def _get_job_for_group(self, group_name):
        """Find the most recent job matching this folder group."""
        for jid in reversed(list(self._jobs)):
            job = self._jobs[jid]
            if job["folder_name"] == group_name:
                return job
            # Check merged groups
            if group_name in job.get("merged_groups", []):
                return job
        return None

    _STATUS_MAP = {
        "pending": "⏳ Pending",
        "processing": "⚙ Processing",
        "writing": "✍ Writing",
        "rewritten": "✍ Rewritten",
        "verified": "✓ Done",
        "error": "✗ Error",
    }

    _JOB_STATUS_MAP = {
        "running": "⚙ Running",
        "queued": "⏳ Queued",
        "done": "✅ Done",
        "error": "❌ Error",
        "stopped": "⏹ Stopped",
    }

    def _refresh_folder_tree(self):
        """Update folder statuses in-place (called via job_update signal)."""
        for i in range(self._folder_tree.topLevelItemCount()):
            item = self._folder_tree.topLevelItem(i)
            if not item:
                continue
            group_name = item.data(1, Qt.ItemDataRole.UserRole)
            if not group_name:
                continue
            job = self._get_job_for_group(group_name)
            if job:
                item.setText(0, str(job.get("task_num", "")))
                item.setText(2, self._JOB_STATUS_MAP.get(
                    job["status"], job["status"]))
                item.setText(3, job.get("progress", ""))
            else:
                item.setText(0, "")
                item.setText(2, "")
                # keep chapter count as-is

    def _on_folder_selected(self, current, previous):
        """When user clicks a folder on the left, show its chapters on the right."""
        if not current:
            return
        group_name = current.data(1, Qt.ItemDataRole.UserRole)
        if not group_name:
            return
        self._selected_group = group_name

        # Find chapters for this group
        chapters_data = self._status.get("chapters", {})
        self._tree.blockSignals(True)
        self._tree.clear()
        for ch in self._chapters:
            if ch.get("group") != group_name:
                continue
            fname = ch["filename"]
            ch_st = chapters_data.get(fname, {})
            status_text = ch_st.get("status", "pending")
            display = self._STATUS_MAP.get(status_text, status_text)
            progress_text = ch_st.get("progress", "")
            item = QTreeWidgetItem([fname, display, progress_text])
            item.setFlags(item.flags() | Qt.ItemFlag.ItemIsUserCheckable)
            item.setCheckState(0, Qt.CheckState.Checked)
            item.setData(0, Qt.ItemDataRole.UserRole, ch)
            self._tree.addTopLevelItem(item)
        self._tree.blockSignals(False)

    def _on_item_changed(self, item, column):
        if column != 0 or self._propagating:
            return
        # Propagate check state to children
        if item.childCount() > 0:
            self._propagating = True
            state = item.checkState(0)
            for i in range(item.childCount()):
                item.child(i).setCheckState(0, state)
            self._propagating = False

    def _on_progress_text(self, filename, text):
        def _find(parent):
            for i in range(parent.topLevelItemCount() if hasattr(parent, 'topLevelItemCount') else parent.childCount()):
                item = parent.topLevelItem(i) if hasattr(parent, 'topLevelItem') else parent.child(i)
                if item.text(0) == filename:
                    item.setText(2, text)
                    return True
                if item.childCount() > 0:
                    for j in range(item.childCount()):
                        child = item.child(j)
                        if child.text(0) == filename:
                            child.setText(2, text)
                            return True
            return False
        _find(self._tree)



    def _select_all(self):
        panel = self._active_panel()
        col = 1 if panel is self._folder_tree else 0
        for i in range(panel.topLevelItemCount()):
            item = panel.topLevelItem(i)
            if item.flags() & Qt.ItemFlag.ItemIsUserCheckable:
                item.setCheckState(col, Qt.CheckState.Checked)

    def _deselect_all(self):
        panel = self._active_panel()
        col = 1 if panel is self._folder_tree else 0
        for i in range(panel.topLevelItemCount()):
            item = panel.topLevelItem(i)
            if item.flags() & Qt.ItemFlag.ItemIsUserCheckable:
                item.setCheckState(col, Qt.CheckState.Unchecked)

    def _get_checked_chapters(self):
        result = []
        def _collect(parent):
            count = parent.topLevelItemCount() if hasattr(parent, 'topLevelItemCount') else parent.childCount()
            for i in range(count):
                item = parent.topLevelItem(i) if hasattr(parent, 'topLevelItem') else parent.child(i)
                ch = item.data(0, Qt.ItemDataRole.UserRole)
                if ch and item.checkState(0) == Qt.CheckState.Checked:
                    result.append(ch)
                if item.childCount() > 0:
                    _collect(item)
        _collect(self._tree)
        return result

    # ── Status ─────────────────────────────────────────────────────

    def _save_status_safe(self, group_path):
        if not group_path:
            return
        try:
            status_path = os.path.join(group_path, "_status.json")
            with self._lock:
                with open(status_path, "w", encoding="utf-8") as f:
                    json.dump(self._status, f, indent=2, ensure_ascii=False)
        except Exception:
            pass

    def _do_cut_video_for_group(self, job):
        """Post-rewrite: Cut downloaded video into chapter clips.
        
        Simple flow:
          1. Find video .mp4 in project dir (parent of group_path/01_chapters)
          2. Parse timecodes from merge file
          3. ffmpeg cut into chapter clips
        """
        from core.video_cutter import (
            find_merge_file, parse_merge_timecodes, download_video, cut_video,
            extract_youtube_url_from_merge,
        )
        log_prefix = job.get("log_prefix", "[Cut]")
        stop_event = job.get("stop_event")
        _log_cb = job.get("_log_callback")

        def log(msg):
            if _log_cb:
                _log_cb(f"{log_prefix} {msg}")
            else:
                self._log.log(f"{log_prefix} {msg}")

        def stop_check():
            return stop_event and stop_event.is_set()

        # Determine the chapters directory (contains merge file + chapter text files)
        chapters_dir = job.get("group_path", "")
        if not chapters_dir or not os.path.isdir(chapters_dir):
            log("🎬 Skip video cut: no group_path")
            return

        # Project dir = parent of 01_chapters
        project_dir = os.path.dirname(chapters_dir)

        # 1. Find merge file  
        merge_path = find_merge_file(chapters_dir)
        if not merge_path:
            log(f"🎬 ⚠ No merge file found, skip video cut")
            return

        # 2. Check if already cut
        video_out_dir = os.path.join(project_dir, "02_video_chapters")
        if os.path.isdir(video_out_dir):
            existing_mp4 = [f for f in os.listdir(video_out_dir) if f.endswith(".mp4")]
            if existing_mp4:
                log(f"🎬 ⏭ Already cut ({len(existing_mp4)} clips)")
                return

        # 3. Parse timecodes
        chapters_tc = parse_merge_timecodes(merge_path)
        if not chapters_tc:
            log(f"🎬 ⚠ No timecodes in merge file")
            return

        # 4. Find video file (look in project dir, then chapters dir)
        video_path = ""
        for search_dir in [project_dir, chapters_dir]:
            if not os.path.isdir(search_dir):
                continue
            for vf in os.listdir(search_dir):
                if vf.endswith((".mp4", ".mkv", ".webm")) and not vf.startswith("Ch_"):
                    candidate = os.path.join(search_dir, vf)
                    if os.path.getsize(candidate) > 1_000_000:  # >1MB
                        video_path = candidate
                        log(f"🎬 Found video: {vf}")
                        break
            if video_path:
                break

        # 5. No local video → try download via YouTube URL in merge file
        if not video_path:
            yt_url = extract_youtube_url_from_merge(merge_path)
            if not yt_url:
                log(f"🎬 ⚠ No video file found and no YouTube URL in merge file")
                return
            log(f"🎬 Downloading video: {yt_url}")
            import tempfile
            _tmp_dir = tempfile.mkdtemp(prefix="cutter_")
            video_path = download_video(
                yt_url, _tmp_dir, log_callback=log, stop_check=stop_check
            )
            if not video_path or not os.path.isfile(video_path):
                log(f"🎬 ❌ Download failed")
                return

        if stop_check():
            return

        # 6. Cut!
        log(f"🎬 Cutting {len(chapters_tc)} chapters...")
        saved = cut_video(
            video_path, chapters_tc, video_out_dir,
            log_callback=log, stop_check=stop_check,
        )
        log(f"🎬 ✅ Done: {len(saved)}/{len(chapters_tc)} clips → 02_video_chapters/")

    def _update_input_chapters_status(self, checked, status_text, chapters_data, progress=""):
        """Update all input chapters to a given status and refresh UI."""
        for ch in checked:
            fname = ch["filename"]
            ch_st = chapters_data.setdefault(fname, {})
            ch_st["status"] = status_text
            if progress:
                ch_st["progress"] = progress
        self.tree_refresh.emit()

    def _do_retry(self, specific_folders=None):
        """Retry failed/error/stopped folders."""
        if specific_folders:
            retry_groups = specific_folders
        else:
            # Find folders with failed/error/stopped status
            retry_groups = []
            for i in range(self._folder_tree.topLevelItemCount()):
                item = self._folder_tree.topLevelItem(i)
                if not item:
                    continue
                group_name = item.data(1, Qt.ItemDataRole.UserRole)
                if not group_name:
                    continue
                job = self._get_job_for_group(group_name)
                if job and job["status"] in ("error", "stopped"):
                    retry_groups.append(group_name)

        if not retry_groups:
            self._log.log("[Style] No failed/stopped folders to retry")
            return

        # Reset status for these folders
        for gn in retry_groups:
            job = self._get_job_for_group(gn)
            if job:
                # Remove old job so _do_rewrite can create new one
                jid = job.get("id")
                if jid and jid in self._jobs:
                    del self._jobs[jid]
            # Reset chapter statuses for this group
            for ch in self._chapters:
                if ch.get("group") == gn:
                    fname = ch["filename"]
                    if fname in self._status:
                        # Reset error/failed chapters
                        ch_st = self._status[fname]
                        if ch_st.get("status") in ("error", "pending"):
                            self._status.pop(fname, None)

        self._log.log(f"[Style] Retrying {len(retry_groups)} folder(s): {', '.join(g.split(']_', 1)[-1][:30] if ']_' in g else g[:30] for g in retry_groups)}")

        # Check the retry folders in the folder tree
        retry_set = set(retry_groups)
        for i in range(self._folder_tree.topLevelItemCount()):
            item = self._folder_tree.topLevelItem(i)
            if not item:
                continue
            gn = item.data(1, Qt.ItemDataRole.UserRole)
            if gn in retry_set:
                item.setCheckState(1, Qt.CheckState.Checked)
            else:
                item.setCheckState(1, Qt.CheckState.Unchecked)

        self.job_update.emit()
        # Trigger rewrite for checked folders
        self._do_rewrite()

    def _do_stop(self):
        running_jobs = {jid: j for jid, j in self._jobs.items() if j["status"] == "running"}
        if not running_jobs:
            self._stop_flag = True  # legacy fallback
            self._log.log("[Style] Stopping...")
            return

        if len(running_jobs) == 1:
            # Only 1 job — stop it directly
            jid, job = next(iter(running_jobs.items()))
            job["stop_event"].set()
            job["status"] = "stopped"
            job["progress"] = "Stopped"
            self._log.log(f"[Job] Stopping: {job['folder_name']}")
            self.job_update.emit()
        else:
            # Multiple jobs — show menu
            from PyQt6.QtWidgets import QMenu
            menu = QMenu(self)
            for jid, job in running_jobs.items():
                action = menu.addAction(f"Stop: {job['folder_name']}")
                action.setData(jid)
            menu.addSeparator()
            stop_all = menu.addAction("■ Stop All")
            stop_all.setData("__all__")

            action = menu.exec(self._btn_stop.mapToGlobal(self._btn_stop.rect().bottomLeft()))
            if action:
                chosen = action.data()
                if chosen == "__all__":
                    for jid, job in running_jobs.items():
                        job["stop_event"].set()
                        job["status"] = "stopped"
                        job["progress"] = "Stopped"
                    self._log.log("[Job] Stopping ALL jobs")
                else:
                    job = self._jobs.get(chosen)
                    if job:
                        job["stop_event"].set()
                        job["status"] = "stopped"
                        job["progress"] = "Stopped"
                        self._log.log(f"[Job] Stopping: {job['folder_name']}")
                self.job_update.emit()

    # ── Build Style Prompt ─────────────────────────────────────────

    def _build_style_prompt(self, wc_rule, lang, chapter_idx=None,
                            total=None, prev_context=""):
        """Build the system prompt from the selected style JSON."""
        style_file = self._get_style_filename()
        if not style_file:
            return None, "No style selected"

        styles_dir = os.path.join(
            os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
            "styles"
        )
        style_path = os.path.join(styles_dir, style_file)
        if not os.path.isfile(style_path):
            return None, f"Style file not found: {style_file}"

        with open(style_path, "r", encoding="utf-8") as f:
            style_json = f.read()

        lang_name = self._LANG_NAMES.get(lang, lang)

        parts = [
            "You are a professional script writer. "
            "Follow these writing rules EXACTLY:\n\n",
            style_json, "\n\n",
            f"WORD COUNT RULE: {wc_rule}\n\n",
            f"IMPORTANT: Write ALL output in {lang_name}.\n",
        ]
        if chapter_idx is not None and total is not None:
            parts.append(f"This is chapter {chapter_idx + 1} of {total}.\n")
        parts.append(
            "Rewrite the chapter below following the rules above. "
            "Output ONLY the rewritten chapter text, nothing else."
        )
        if prev_context:
            parts.append(
                f"\n\nPREVIOUS CHAPTERS CONTEXT (maintain continuity):\n{prev_context}"
            )

        return "".join(parts), style_file

    # ── Main Dispatch ──────────────────────────────────────────────

    def _on_mode_changed(self, mode_text):
        is_review = (mode_text == "Top/List Review")

        # Always show framework combo
        self._lbl_framework.setVisible(True)
        self._combo_framework.setVisible(True)
        self._lbl_threads.setVisible(False)
        self._spin_threads.setVisible(False)

        # Country only for review
        self._lbl_country.setVisible(is_review)
        self._combo_country.setVisible(is_review)
        self._chk_transitions.setVisible(is_review)

        # Defaults per mode — always update when switching
        self._chk_cut_video.setChecked(is_review)
        self._chk_cut_video.setVisible(is_review)
        self._chk_excel_update.setChecked(is_review)
        self._chk_excel_update.setVisible(is_review)
        self._chk_google_check.setChecked(True)
        self._chk_google_check.setVisible(True)

        # Filter styles by mode
        self._refresh_style_dropdown()

        # Populate framework combo from first available style
        style_json_raw, _ = self._load_style_json_raw()
        if style_json_raw:
            try:
                sd = json.loads(style_json_raw)
                fw_names = [fw.get("name", "") for fw in sd.get("frameworks", []) if fw.get("enabled", True)]
                if fw_names:
                    self._combo_framework.blockSignals(True)
                    current = self._combo_framework.currentText()
                    self._combo_framework.clear()
                    self._combo_framework.addItem("Auto (detect & switch)")
                    for name in fw_names:
                        self._combo_framework.addItem(name)
                    idx = self._combo_framework.findText(current)
                    if idx >= 0:
                        self._combo_framework.setCurrentIndex(idx)
                    self._combo_framework.blockSignals(False)
            except (json.JSONDecodeError, AttributeError):
                pass

        # Update button + default word counts per mode
        if is_review:
            self._btn_rewrite.setText("▶ Rewrite")
            self._btn_rewrite.setToolTip(
                "Extract blueprint → Recommend framework → Check → Convert → Outline → Write → Verify"
            )
            # Review defaults: shorter chapters, more of them
            if not self._config_loaded:
                self._ch_min.setValue(7)
                self._ch_max.setValue(10)
                self._wc_open_min.setValue(0)    # —
                self._wc_open_max.setValue(200)
                self._wc_body_min.setValue(0)    # —
                self._wc_body_max.setValue(400)
                self._wc_end_min.setValue(0)     # —
                self._wc_end_max.setValue(200)
        else:
            self._btn_rewrite.setText("▶ Rewrite")
            self._btn_rewrite.setToolTip(
                "Detect framework → Extract blueprint → New framework → Write new"
            )
            # Narrative defaults: longer chapters, fewer
            if not self._config_loaded:
                self._ch_min.setValue(5)
                self._ch_max.setValue(20)
                self._wc_open_min.setValue(1300)
                self._wc_open_max.setValue(1800)
                self._wc_body_min.setValue(1300)
                self._wc_body_max.setValue(1800)
                self._wc_end_min.setValue(1200)
                self._wc_end_max.setValue(1500)

        # Load per-niche config (overrides mode defaults if saved)
        self._apply_niche_config()

    def _show_fw_ranking_dialog(self, rankings, original_fw):
        """Show framework ranking popup on the main thread.
        rankings: list of dicts with 'name', 'score', 'reason'.
        original_fw: the detected original framework (may be greyed out).
        """
        try:
            import winsound
            winsound.MessageBeep(winsound.MB_ICONEXCLAMATION)
        except Exception:
            pass
        dlg = QDialog(self)
        dlg.setWindowTitle("Xếp hạng Framework — Phân tích AI")
        dlg.setMinimumWidth(520)
        layout = QVBoxLayout(dlg)

        # Parse original framework info
        try:
            fw_info = json.loads(original_fw)
            fw_name = fw_info.get("name", "Unknown")
            fw_conf = fw_info.get("confidence", "?")
            fw_reason = fw_info.get("reasoning", "")
        except (json.JSONDecodeError, TypeError):
            fw_name = str(original_fw)
            fw_conf = "?"
            fw_reason = ""

        header_text = (
            f"<b>AI đã phân tích nội dung và xếp hạng các framework.</b><br><br>"
            f"<b>Framework kịch bản gốc:</b> {fw_name} "
            f"(độ tin cậy: {fw_conf})"
        )
        if fw_reason:
            header_text += f"<br><i>{fw_reason}</i>"

        header = QLabel(header_text)
        header.setWordWrap(True)
        layout.addWidget(header)
        layout.addSpacing(8)

        # Scrollable area for framework list
        scroll = QScrollArea()
        scroll.setWidgetResizable(True)
        scroll.setMaximumHeight(450)
        scroll.setStyleSheet("QScrollArea { border: none; }")
        scroll_widget = QWidget()
        scroll_layout = QVBoxLayout(scroll_widget)
        scroll_layout.setContentsMargins(0, 0, 0, 0)

        btn_group = QButtonGroup(dlg)
        radios = []
        for i, r in enumerate(rankings):
            name = r.get("name", "")
            score = r.get("score", 0)
            reason = r.get("reason", "")
            is_original = (name == fw_name)

            label_text = f"{name}  —  {score}/10"
            if is_original:
                label_text += "  (gốc)"

            radio = QRadioButton(label_text)
            radio.setStyleSheet("font-weight: bold; font-size: 13px;")
            if i == 0:
                radio.setChecked(True)

            reason_lbl = QLabel(f"    {reason}")
            reason_lbl.setWordWrap(True)
            reason_lbl.setStyleSheet("color: #888; margin-left: 24px; margin-bottom: 8px;")

            btn_group.addButton(radio, i)
            radios.append((radio, name))
            scroll_layout.addWidget(radio)
            scroll_layout.addWidget(reason_lbl)

        scroll_layout.addStretch()
        scroll.setWidget(scroll_widget)
        layout.addWidget(scroll)

        layout.addSpacing(12)
        buttons = QDialogButtonBox()
        btn_ok = buttons.addButton("Chọn", QDialogButtonBox.ButtonRole.AcceptRole)
        btn_cancel = buttons.addButton("Hủy", QDialogButtonBox.ButtonRole.RejectRole)
        buttons.accepted.connect(dlg.accept)
        buttons.rejected.connect(dlg.reject)
        layout.addWidget(buttons)

        if dlg.exec() == QDialog.DialogCode.Accepted:
            checked_id = btn_group.checkedId()
            if 0 <= checked_id < len(radios):
                self._fw_ranking_result = radios[checked_id][1]
            else:
                self._fw_ranking_result = rankings[0]["name"]
        else:
            self._fw_ranking_result = None  # user cancelled

        self._fw_ranking_event.set()

    # ═══════════════════════════════════════════════════════════════
    # SHARED: Outline → Audit → Write → Review → Patch → Merge
    # Called by BOTH _do_new_content and _do_rewrite / _run_fw_pipeline
    # ═══════════════════════════════════════════════════════════════
    def _run_shared_fw_pipeline(
        self, *,
        fw_name, fw_output_dir, fw_pipeline_dir, fw_log,
        blueprint, style_json_raw, endpoints, tier, lang, niche,
        stop_check, get_wc_rule, get_ch_range,
        log_api=None,
        on_chapter_saved=None,   # callback(out_fname, fw_name) for Rewrite UI tracking
        auto_patch=True,
        resume=False,
    ):
        """Shared pipeline: outline → audit → write → review → patch → merge.
        Used by both New Content and Rewrite pipelines to avoid code duplication.
        """
        _log_api = log_api or (lambda *a: None)
        os.makedirs(fw_output_dir, exist_ok=True)
        os.makedirs(fw_pipeline_dir, exist_ok=True)

        # ── Step A: Phase Planning (driven by pipeline_features in style JSON) ──
        _has_phase_plan = False
        try:
            _style_data = json.loads(style_json_raw) if isinstance(style_json_raw, str) else style_json_raw
            _pf = _style_data.get("pipeline_features", {})
            _has_phase_plan = _pf.get("phase_plan", False)
        except (json.JSONDecodeError, TypeError, AttributeError):
            pass

        phase_plan = None
        ch_range = get_ch_range()
        if _has_phase_plan:
            split_path = os.path.join(fw_pipeline_dir, "_phase_plan_final.json")
            validated_path = os.path.join(fw_pipeline_dir, "_phase_plan_validated.json")
            phase_plan_path = os.path.join(fw_pipeline_dir, "_phase_plan.json")

            if resume and os.path.isfile(split_path):
                # Resume: load final split plan (all A steps done)
                with open(split_path, "r", encoding="utf-8") as f:
                    phase_plan = json.load(f)
                fw_log("✓ [Resume] Phase plan loaded from _phase_plan_final.json")
            elif resume and os.path.isfile(validated_path):
                # Resume: validated exists but not split → run A3 only
                with open(validated_path, "r", encoding="utf-8") as f:
                    phase_plan = json.load(f)
                fw_log("✓ [Resume] Validated plan loaded — running split only")
                phase_plan.pop("_validation_log", None)
                phase_plan = apply_chapter_splits(phase_plan, log_callback=lambda m: fw_log(m))
                with open(split_path, "w", encoding="utf-8") as f:
                    json.dump(phase_plan, f, indent=2, ensure_ascii=False)
            elif resume and os.path.isfile(phase_plan_path):
                # Resume: phase plan exists but not validated → run A2+A3
                with open(phase_plan_path, "r", encoding="utf-8") as f:
                    phase_plan = json.load(f)
                fw_log("✓ [Resume] Phase plan loaded — running validate + split")
                phase_plan = validate_phase_plan_sub_keys(
                    phase_plan, blueprint, endpoints,
                    log_callback=lambda m: fw_log(m), stop_check=stop_check,
                    niche=niche,
                )
                with open(validated_path, "w", encoding="utf-8") as f:
                    json.dump(phase_plan, f, indent=2, ensure_ascii=False)
                val_log = phase_plan.pop("_validation_log", None)
                if val_log:
                    val_log_path = os.path.join(fw_pipeline_dir, "_validation_reasoning.json")
                    with open(val_log_path, "w", encoding="utf-8") as f:
                        json.dump(val_log, f, indent=2, ensure_ascii=False)
                if stop_check():
                    return
                phase_plan = apply_chapter_splits(phase_plan, log_callback=lambda m: fw_log(m))
                with open(split_path, "w", encoding="utf-8") as f:
                    json.dump(phase_plan, f, indent=2, ensure_ascii=False)
            else:
                # Normal flow: run A1+A2+A3
                fw_log(f"Planning phases for '{fw_name}'...")
                api_phase = APIClient(endpoints, log_api=_log_api, tier=tier, stop_check=stop_check)
                ch_range = get_ch_range()
                phase_plan = generate_narrative_phase_plan(
                    blueprint, style_json_raw, fw_name, api_phase,
                    chapter_range=ch_range, lang=lang,
                    log_callback=lambda m: fw_log(m), niche=niche,
                )
                phase_plan_path = os.path.join(fw_pipeline_dir, "_phase_plan.json")
                with open(phase_plan_path, "w", encoding="utf-8") as f:
                    json.dump(phase_plan, f, indent=2, ensure_ascii=False)

                if stop_check():
                    return

                # Step A2: Validate
                fw_log("Validating sub_key_data classifications...")
                phase_plan = validate_phase_plan_sub_keys(
                    phase_plan, blueprint, endpoints,
                    log_callback=lambda m: fw_log(m), stop_check=stop_check,
                    niche=niche,
                )
                validated_path = os.path.join(fw_pipeline_dir, "_phase_plan_validated.json")
                with open(validated_path, "w", encoding="utf-8") as f:
                    json.dump(phase_plan, f, indent=2, ensure_ascii=False)
                val_log = phase_plan.pop("_validation_log", None)
                if val_log:
                    val_log_path = os.path.join(fw_pipeline_dir, "_validation_reasoning.json")
                    with open(val_log_path, "w", encoding="utf-8") as f:
                        json.dump(val_log, f, indent=2, ensure_ascii=False)
                    fw_log(f"  📄 Saved validation reasoning → _validation_reasoning.json")

                if stop_check():
                    return

                # Step A3: Split
                fw_log("Splitting phases into chapters...")
                phase_plan = apply_chapter_splits(phase_plan, log_callback=lambda m: fw_log(m))
                split_path = os.path.join(fw_pipeline_dir, "_phase_plan_final.json")
                with open(split_path, "w", encoding="utf-8") as f:
                    json.dump(phase_plan, f, indent=2, ensure_ascii=False)

            if stop_check():
                return
        else:
            pass  # non-biography: no phase planning needed

        # ── Step B+C: Outline + Audit ──
        outline_path = os.path.join(fw_pipeline_dir, "_renew_outline.json")
        audited_path = os.path.join(fw_pipeline_dir, "_renew_outline_audited.json")

        _skip_audit = False
        if resume and os.path.isfile(audited_path):
            # Resume: audited outline exists → load it
            with open(audited_path, "r", encoding="utf-8") as f:
                outline = json.load(f)
            out_chapters = outline.get("chapters", [])
            _skip_audit = True
            total = len(out_chapters)
            fw_log(f"✓ [Resume] Audited outline loaded ({total} chapters)")
        elif resume and os.path.isfile(outline_path):
            # Resume: outline exists but not audited → run audit only
            with open(outline_path, "r", encoding="utf-8") as f:
                outline = json.load(f)
            fw_log("✓ [Resume] Outline loaded — running audit only")
            out_chapters = outline.get("chapters", [])
            total = len(out_chapters)
            # Falls through to audit below
        else:
            # Normal flow: generate outline
            fw_log(f"Generating outline with '{fw_name}'...")
            api_out = APIClient(endpoints, log_api=_log_api, tier=tier, stop_check=stop_check)
            outline = generate_narrative_outline(
                blueprint, style_json_raw, fw_name, api_out,
                chapter_range=ch_range, lang=lang,
                log_callback=lambda m: fw_log(m), niche=niche,
                phase_plan=phase_plan,
            )
            out_chapters = outline.get("chapters", [])
            total = len(out_chapters)
            arc = outline.get("narrative_arc", "")[:100]
            fw_log(f"✓ Outline: {total} chapters")
            if arc:
                fw_log(f"  Arc: {arc}...")
            outline_path = os.path.join(fw_pipeline_dir, "_renew_outline.json")
            with open(outline_path, "w", encoding="utf-8") as f:
                json.dump(outline, f, indent=2, ensure_ascii=False)

        if stop_check() or total == 0:
            return

        # ── Audit (skip if already loaded audited outline via resume) ──
        if not _skip_audit:
            fw_log("Auditing outline structure...")
            api_audit = APIClient(endpoints, log_api=_log_api, tier="flash", stop_check=stop_check)
            audited_outline, audit_issues = audit_outline(
                outline, blueprint, style_json_raw, fw_name, api_audit,
                log_callback=lambda m: fw_log(m), niche=niche,
                chapter_range=ch_range,
            )
            audit_path = os.path.join(fw_pipeline_dir, "_audit.json")
            with open(audit_path, "w", encoding="utf-8") as f:
                json.dump({"issues": audit_issues}, f, indent=2, ensure_ascii=False)
            if audit_issues:
                outline = audited_outline
                out_chapters = outline.get("chapters", [])
                total = len(out_chapters)
            audited_path = os.path.join(fw_pipeline_dir, "_renew_outline_audited.json")
            with open(audited_path, "w", encoding="utf-8") as f:
                json.dump(outline, f, indent=2, ensure_ascii=False)
            fw_log(f"📄 Saved audited outline ({total} chapters)")
        if stop_check() or total == 0:
            return
        # ── Save phase_data for inspection ──
        phase_plan = outline.get("phase_chapter_plan", [])

        # Fallback: auto-generate phase_chapter_plan from chapters if AI omitted it
        if not phase_plan and out_chapters:
            from collections import OrderedDict
            step_map = OrderedDict()
            for ch in out_chapters:
                step = ch.get("framework_step", "Unknown")
                ch_num = ch.get("chapter_number", 0)
                if step not in step_map:
                    step_map[step] = []
                step_map[step].append(ch_num)
            phase_plan = []
            for step_name, ch_nums in step_map.items():
                phase_plan.append({
                    "phase": step_name,
                    "chapters": ch_nums,
                    "reason_for_split": f"Auto-grouped {len(ch_nums)} chapters" if len(ch_nums) > 1 else None,
                })
            outline["phase_chapter_plan"] = phase_plan
            # Re-save the outline with phase_chapter_plan
            audited_path = os.path.join(fw_pipeline_dir, "_renew_outline_audited.json")
            with open(audited_path, "w", encoding="utf-8") as f:
                json.dump(outline, f, indent=2, ensure_ascii=False)
            fw_log(f"⚠️ phase_chapter_plan was missing — auto-generated from framework_step ({len(phase_plan)} phases)")

        if phase_plan:
            phase_data_dir = os.path.join(fw_pipeline_dir, "_phase_data")
            os.makedirs(phase_data_dir, exist_ok=True)

            summary_lines = []
            for idx, phase in enumerate(phase_plan):
                phase_name = phase.get("phase", f"phase_{idx}")
                safe_name = "".join(c if c.isalnum() or c in " _-" else "_" for c in phase_name).strip().replace(" ", "_")
                phase_file = os.path.join(phase_data_dir, f"phase_{idx+1:02d}_{safe_name}.json")
                with open(phase_file, "w", encoding="utf-8") as f:
                    json.dump(phase, f, indent=2, ensure_ascii=False)

                # Build summary line
                node_count = phase.get("node_count", phase.get("pacing_evaluation", {}).get("node_count", "?"))
                cap_check = phase.get("capacity_check", phase.get("pacing_evaluation", {}).get("capacity_check", ""))
                chs = phase.get("chapters", [])
                split_reason = phase.get("reason_for_split", "null")
                action = "SPLIT" if len(chs) > 1 else "KEEP"
                summary_lines.append(
                    f"[{action}] Phase {idx+1}: {phase_name}\n"
                    f"       Chapters: {chs} | Main beats: {node_count}\n"
                    f"       Capacity: {cap_check}\n"
                    f"       Reason: {split_reason}"
                )

            # Save readable summary
            summary_path = os.path.join(phase_data_dir, "_summary.txt")
            with open(summary_path, "w", encoding="utf-8") as f:
                f.write(f"Phase Chapter Plan Summary\n")
                f.write(f"Framework: {outline.get('framework_used', '?')}\n")
                f.write(f"Total chapters: {total}\n")
                f.write(f"Total phases: {len(phase_plan)}\n")
                f.write(f"{'='*60}\n\n")
                f.write("\n\n".join(summary_lines))

            fw_log(f"📂 Saved {len(phase_plan)} phase plans to _phase_data/")

        # ── Write chapters ──
        fw_log(f"Writing {total} chapters...")
        rewritten_texts = []
        out_filenames = []
        chapter_titles = []
        renew_outline_str = json.dumps(outline, indent=2, ensure_ascii=False)

        for i, ch_outline in enumerate(out_chapters):
            if stop_check():
                break

            ch_type = ch_outline.get("chapter_type", "body")
            if ch_type == "hook":
                raw_name = "Intro"
            elif ch_type == "end":
                raw_name = "Outro_CTA"
            else:
                prods = ch_outline.get("products_covered", [])
                if prods and len(prods) <= 2:
                    raw_name = " vs ".join(prods) if len(prods) == 2 else prods[0]
                else:
                    raw_name = ch_outline.get("title", f"chapter_{i+1}")
            safe_title = "".join(
                c if c.isalnum() or c in " _-" else "_"
                for c in raw_name
            ).strip().replace(" ", "_")[:60]
            out_fname = f"ch_{i+1:02d}_{safe_title}.txt"

            if i == 0:
                wc_section = "open"
            elif i == total - 1:
                wc_section = "end"
            else:
                wc_section = "body"
            wc_rule = get_wc_rule(wc_section)

            if wc_rule == "SKIP":
                fw_log(f"⏭ Ch.{i+1}/{total}: skipped ({wc_section} = SKIP)")
                continue

            out_filenames.append(out_fname)
            chapter_titles.append(raw_name)

            # Resume: check if this chapter already exists
            out_path = os.path.join(fw_output_dir, out_fname)
            if resume and os.path.isfile(out_path):
                with open(out_path, "r", encoding="utf-8") as f:
                    existing_text = f.read()
                rewritten_texts.append(existing_text)
                fw_log(f"✓ [Resume] Ch.{i+1}/{total}: {raw_name} — loaded from disk")
                continue

            prev_context = ""
            if rewritten_texts:
                prev_context = "\n---\n".join(rewritten_texts[-2:])

            try:
                api_w = APIClient(endpoints, log_api=_log_api, tier=tier, stop_check=stop_check)
                rewritten = write_from_blueprint(
                    blueprint=blueprint,
                    style_json=style_json_raw,
                    framework_name=fw_name,
                    chapter_outline=ch_outline,
                    chapter_number=i + 1,
                    total_chapters=total,
                    api_client=api_w,
                    word_count_rule=wc_rule,
                    lang=lang,
                    previous_context=prev_context,
                    full_outline=renew_outline_str,
                    log_callback=lambda m: fw_log(m),
                    niche=niche,
                    save_dir=fw_pipeline_dir,
                )
                rewritten_texts.append(rewritten)

                lines = rewritten.split("\n", 1)
                body_only = lines[1].lstrip("\n") if len(lines) > 1 else rewritten
                out_path = os.path.join(fw_output_dir, out_fname)
                with open(out_path, "w", encoding="utf-8") as f:
                    f.write(body_only)

                if on_chapter_saved:
                    on_chapter_saved(out_fname, fw_name)
                fw_log(f"✓ Ch.{i+1}/{total}: {raw_name}")

            except Exception as e:
                rewritten_texts.append("")
                out_filenames[-1] = ""
                fw_log(f"✗ Ch.{i+1}/{total}: {e}")

        if stop_check():
            fw_log("Stopped")
            return

        # ── Cross-chapter Review + Patch ──
        fw_log("Cross-chapter review...")
        rw_chapters = []
        rw_index_map = []
        for i in range(len(rewritten_texts)):
            if rewritten_texts[i]:
                rw_chapters.append({
                    "filename": out_filenames[i] if i < len(out_filenames) else f"ch_{i+1:02d}.txt",
                    "text": rewritten_texts[i],
                    "title": chapter_titles[i] if i < len(chapter_titles) else "",
                })
                rw_index_map.append(i)

        if len(rw_chapters) >= 2:
            try:
                api_rev = APIClient(endpoints, log_api=_log_api, tier=tier, stop_check=stop_check)
                review_result = review_narrative_full(
                    rw_chapters, api_rev,
                    log_callback=lambda m: fw_log(m),
                    niche=niche, lang=lang,
                )

                issues = review_result.get("issues", [])
                auto_patched_count = 0
                if auto_patch and issues:
                    for issue in issues:
                        if issue.get("severity") in ("critical", "major"):
                            fc = issue.get("fix_chapter")
                            if not fc:
                                involved = issue.get("chapters_involved", [])
                                if involved:
                                    fc = involved[0]
                            if not fc:
                                continue
                            try:
                                fix_ch_num = int(fc)
                            except (ValueError, TypeError):
                                continue
                            if 1 <= fix_ch_num <= len(rw_chapters):
                                rw_idx = fix_ch_num - 1
                                full_ctx = "\n\n".join(
                                    f"=== Ch.{j+1} ===\n{c['text']}"
                                    for j, c in enumerate(rw_chapters)
                                )
                                api_p = APIClient(endpoints, log_api=_log_api, tier="flash", stop_check=stop_check)
                                patched = patch_chapter_overlap(
                                    rw_chapters[rw_idx]["text"], issue, full_ctx, api_p,
                                    log_callback=lambda m: fw_log(m),
                                )
                                rw_chapters[rw_idx]["text"] = patched
                                rewritten_texts[rw_index_map[rw_idx]] = patched
                                patched_fname = out_filenames[rw_index_map[rw_idx]]
                                if patched_fname:
                                    patched_path = os.path.join(fw_output_dir, patched_fname)
                                    with open(patched_path, "w", encoding="utf-8") as f:
                                        _lines = patched.split("\n", 1)
                                        _body = _lines[1].lstrip("\n") if len(_lines) > 1 else patched
                                        f.write(_body)
                                auto_patched_count += 1
                elif issues and not auto_patch:
                    n_crit = len([i for i in issues if i.get('severity') in ('critical','major')])
                    fw_log(f"⚠ {n_crit} critical/major issues found — auto-patch OFF")

                if auto_patched_count:
                    fw_log(f"✓ Auto-patched {auto_patched_count} issues")
                flow_score = review_result.get("overall_flow_score", 0)
                fw_log(f"✓ Review done! flow={flow_score}, issues={len(issues)}")

                rev_path = os.path.join(fw_pipeline_dir, "_review.json")
                with open(rev_path, "w", encoding="utf-8") as f:
                    json.dump(review_result, f, indent=2, ensure_ascii=False)
            except Exception as e:
                fw_log(f"⚠ Review failed (non-fatal): {e}")
        else:
            fw_log("Skipped review (< 2 chapters)")

        # ── Merge FULL_SCRIPT.txt ──
        if rw_chapters:
            full_path = os.path.join(fw_output_dir, "FULL_SCRIPT.txt")
            with open(full_path, "w", encoding="utf-8") as f:
                for j, c in enumerate(rw_chapters):
                    if j > 0:
                        f.write("\n\n" + "=" * 60 + "\n\n")
                    ch_title = c.get("title", "").strip()
                    if not ch_title:
                        ch_lines = c["text"].split("\n", 1)
                        ch_title = ch_lines[0].strip() if ch_lines else f"Chapter {j+1}"
                    ch_lines = c["text"].split("\n", 1)
                    ch_body = ch_lines[1].lstrip("\n") if len(ch_lines) > 1 else c["text"]
                    f.write(f"Chapter {j+1}: {ch_title}\n\n{ch_body}")
            fw_log(f"✓ Merged → FULL_SCRIPT.txt ({len(rw_chapters)} chapters)")

        fw_log(f"✓ Complete! '{fw_name}'")

    def _do_resume(self):
        """Resume an interrupted pipeline from its last checkpoint."""
        output_dir = self._txt_output.text().strip()
        if not output_dir or not os.path.isdir(output_dir):
            self._log.log("[Resume] ✗ No valid Output path — set Output folder first")
            return

        # Find _resume.json (could be in root _pipeline/ or one level up)
        pipeline_dir = os.path.join(output_dir, "_pipeline")
        resume_path = os.path.join(pipeline_dir, "_resume.json")
        if not os.path.isfile(resume_path):
            self._log.log("[Resume] ✗ No _resume.json found — this folder has no resume data")
            return

        with open(resume_path, "r", encoding="utf-8") as f:
            resume_meta = json.load(f)

        r_mode = resume_meta.get("mode", "")
        r_type = resume_meta.get("type", "")
        r_niche = resume_meta.get("niche", "")
        r_style = resume_meta.get("style", "")
        r_lang = resume_meta.get("lang", "")

        if r_mode != "Narrative":
            self._log.log(f"[Resume] ✗ Resume only supports Narrative mode (found: {r_mode})")
            return
        if r_type != "new_content":
            self._log.log(f"[Resume] ✗ Resume only supports New Content type (found: {r_type})")
            return

        self._log.log(f"[Resume] ▶ Resuming: mode={r_mode}, niche={r_niche}, style={r_style}")

        # Load style JSON
        style_path = os.path.join("styles", r_style)
        if not os.path.isfile(style_path):
            self._log.log(f"[Resume] ✗ Style file not found: {style_path}")
            return
        with open(style_path, "r", encoding="utf-8") as f:
            style_data = json.load(f)
        style_json_raw = json.dumps(style_data, ensure_ascii=False, indent=2)

        # Load blueprint (must exist for resume)
        bp_path = os.path.join(pipeline_dir, "_blueprint.json")
        if not os.path.isfile(bp_path):
            self._log.log("[Resume] ✗ No blueprint found — research not complete, cannot resume")
            return
        with open(bp_path, "r", encoding="utf-8") as f:
            blueprint = json.load(f)
        self._log.log(f"[Resume] ✓ Blueprint loaded ({len(json.dumps(blueprint)):,} chars)")

        # Detect version directories
        version_dirs = sorted([
            d for d in os.listdir(output_dir)
            if os.path.isdir(os.path.join(output_dir, d)) and re.match(r'^v\d+_', d)
        ])
        if not version_dirs:
            self._log.log("[Resume] ✗ No version folders (v1_*, v2_*) found")
            return

        # Check which versions need resume
        versions_to_resume = []
        for vdir in version_dirs:
            full_script = os.path.join(output_dir, vdir, "FULL_SCRIPT.txt")
            if os.path.exists(full_script):
                self._log.log(f"[Resume] ✓ {vdir} already complete — skip")
            else:
                # Extract framework name from dir: v1_Sử_Thi → Sử Thi
                fw_name = re.sub(r'^v\d+_', '', vdir).replace('_', ' ')
                versions_to_resume.append((vdir, fw_name))
                self._log.log(f"[Resume] ⟳ {vdir} needs resume (framework: {fw_name})")

        if not versions_to_resume:
            self._log.log("[Resume] ✓ All versions already complete — nothing to resume")
            return

        # Get settings from UI
        lang = r_lang or self._get_lang_code()
        tier = self._combo_tier.currentText().lower()
        endpoints = load_api_keys()
        if not endpoints:
            self._log.log("[Resume] ✗ No API keys configured")
            return

        _wc_cache = {
            "open": (self._wc_open_min.value(), self._wc_open_max.value()),
            "body": (self._wc_body_min.value(), self._wc_body_max.value()),
            "end": (self._wc_end_min.value(), self._wc_end_max.value()),
        }
        _ch_min = self._ch_min.value()
        _ch_max = self._ch_max.value()
        _do_patch = self._chk_auto_patch.isChecked()

        def _get_wc_rule(section="body"):
            wc_min, wc_max = _wc_cache.get(section, _wc_cache["body"])
            return build_word_count_rule(wc_min, wc_max)

        def _get_ch_range():
            if _ch_min > 0 and _ch_max > 0:
                return f"between {_ch_min} and {_ch_max} chapters"
            elif _ch_min > 0:
                return f"at least {_ch_min} chapters"
            elif _ch_max > 0:
                return f"at most {_ch_max} chapters"
            return "a suitable number of chapters"

        self._stop_flag = False
        log = lambda m: self._log.log(f"[Resume] {m}")

        def _resume_worker():
            try:
                _stopped = lambda: self._stop_flag
                self._log.set_status(f"Resuming {len(versions_to_resume)} version(s)...", False)

                if len(versions_to_resume) == 1:
                    vdir, fw_name = versions_to_resume[0]
                    fw_output_dir = os.path.join(output_dir, vdir)
                    fw_pipeline_dir = os.path.join(fw_output_dir, "_pipeline")
                    fw_log = lambda m, _pfx=f"[{vdir}]": log(f"{_pfx} {m}")
                    self._run_shared_fw_pipeline(
                        fw_name=fw_name,
                        fw_output_dir=fw_output_dir,
                        fw_pipeline_dir=fw_pipeline_dir,
                        fw_log=fw_log,
                        blueprint=blueprint,
                        style_json_raw=style_json_raw,
                        endpoints=endpoints,
                        tier=tier,
                        lang=lang,
                        niche=r_niche,
                        stop_check=_stopped,
                        get_wc_rule=_get_wc_rule,
                        get_ch_range=_get_ch_range,
                        auto_patch=_do_patch,
                        resume=True,
                    )
                else:
                    from concurrent.futures import ThreadPoolExecutor, as_completed
                    log(f"🔀 Resuming {len(versions_to_resume)} versions in PARALLEL...")
                    with ThreadPoolExecutor(max_workers=len(versions_to_resume)) as executor:
                        futures = {}
                        for vdir, fw_name in versions_to_resume:
                            fw_output_dir = os.path.join(output_dir, vdir)
                            fw_pipeline_dir = os.path.join(fw_output_dir, "_pipeline")
                            fw_log = lambda m, _pfx=f"[{vdir}]": log(f"{_pfx} {m}")
                            futures[executor.submit(
                                self._run_shared_fw_pipeline,
                                fw_name=fw_name,
                                fw_output_dir=fw_output_dir,
                                fw_pipeline_dir=fw_pipeline_dir,
                                fw_log=fw_log,
                                blueprint=blueprint,
                                style_json_raw=style_json_raw,
                                endpoints=endpoints,
                                tier=tier,
                                lang=lang,
                                niche=r_niche,
                                stop_check=_stopped,
                                get_wc_rule=_get_wc_rule,
                                get_ch_range=_get_ch_range,
                                auto_patch=_do_patch,
                                resume=True,
                            )] = vdir
                        for future in as_completed(futures):
                            vdir = futures[future]
                            try:
                                future.result()
                            except Exception as e:
                                log(f"❌ {vdir} failed: {e}")

                log("✦ Resume complete!")
                self._log.set_status("✓ Resume complete", True)
            except Exception as e:
                import traceback
                log(f"❌ Error: {e}")
                log(traceback.format_exc())
                self._log.set_status(f"❌ Resume error: {e}", True)

        threading.Thread(target=_resume_worker, daemon=True).start()

    def _do_new_content(self):
        """Launch new content creation from scratch — research topic → write script."""
        # ── 1. Popup: ask for topic ──
        topic, ok = QInputDialog.getText(
            self, "✦ New Content — Research & Write",
            "Nhập đề tài / tên nhân vật:\n(VD: Albert Einstein, Napoleon Bonaparte, Van Gogh)",
        )
        if not ok or not topic.strip():
            return
        topic = topic.strip()

        # ── 2. Validate style selection ──
        style_info = self._combo_style.currentData()  # actual filename stored as itemData
        if not style_info:
            style_info = self._combo_style.currentText()  # fallback
        if not style_info or style_info == "(no styles found)":
            QMessageBox.warning(self, "No Style", "Please select a style JSON first.")
            return

        style_path = os.path.join("styles", style_info)
        if not os.path.isfile(style_path):
            QMessageBox.warning(self, "Style not found", f"{style_path} not found")
            return

        with open(style_path, "r", encoding="utf-8") as f:
            style_data = json.load(f)
        style_json_raw = json.dumps(style_data, ensure_ascii=False, indent=2)

        # ── 3. Build output directory ──
        user_output = self._txt_output.text().strip()

        if user_output and os.path.isdir(user_output):
            # User specified an existing folder → use it directly
            output_dir = user_output
        else:
            # Auto-generate: Documents/{niche}_{topic}_{timestamp}
            _DEFAULT_BASE = os.path.join(os.path.expanduser("~"), "OneDrive", "Documents")
            if not os.path.isdir(_DEFAULT_BASE):
                _DEFAULT_BASE = os.path.join(os.path.expanduser("~"), "Documents")

            niche_raw = (style_data.get("niche", "") or "").strip().lower()
            _NICHE_LABELS = {
                "biography": "Biography", "tiểu sử": "Biography", "nhân vật": "Biography",
                "chân dung": "Biography", "cuộc đời": "Biography",
                "mystery": "Mystery", "bí ẩn": "Mystery", "enigma": "Mystery",
                "battle": "Battle", "military": "Military", "trận": "Battle", "chiến": "Battle",
                "firearms": "Firearms",
            }
            niche_label = "Content"
            for keyword, label in _NICHE_LABELS.items():
                if keyword in niche_raw:
                    niche_label = label
                    break
            topic_safe = re.sub(r'[<>:"/\\|?*]', '_', topic).replace(' ', '_')[:50]
            timestamp = datetime.now().strftime("%Y%m%d_%H%M")
            folder_name = f"{niche_label}_{topic_safe}_{timestamp}"
            output_dir = os.path.join(_DEFAULT_BASE, folder_name)

        pipeline_dir = os.path.join(output_dir, "_pipeline")
        research_dir = os.path.join(pipeline_dir, "_research_sections")

        # ── 4. Check if blueprint already exists (skip research) ──
        bp_path = os.path.join(pipeline_dir, "_blueprint.json")
        skip_research = os.path.isfile(bp_path)

        # ── 5. Collect settings & launch worker ──
        mode = self._combo_mode.currentText()
        is_review = (mode == "Top/List Review")
        lang_full = self._combo_lang.currentText() if hasattr(self, '_combo_lang') else "Tiếng Anh"
        lang = self._LANG_MAP.get(lang_full, "english")

        user_framework = self._combo_framework.currentText()
        framework_names = [
            self._combo_framework.itemText(i)
            for i in range(self._combo_framework.count())
            if self._combo_framework.itemText(i) != "Auto (detect & switch)"
        ]
        tier = self._combo_tier.currentText().lower() if hasattr(self, '_combo_tier') else "pro"
        _niche = (style_data.get("niche", "") or "").lower()

        endpoints = load_api_keys()
        if not endpoints:
            QMessageBox.warning(self, "No API Keys", "No API keys configured.")
            return

        # Cache word count settings
        _wc_cache = {
            "open": (self._wc_open_min.value(), self._wc_open_max.value()),
            "body": (self._wc_body_min.value(), self._wc_body_max.value()),
            "end": (self._wc_end_min.value(), self._wc_end_max.value()),
        }
        _ch_min = self._ch_min.value()
        _ch_max = self._ch_max.value()
        _do_patch = self._chk_auto_patch.isChecked()

        def _get_wc_rule(section="body"):
            wc_min, wc_max = _wc_cache.get(section, _wc_cache["body"])
            return build_word_count_rule(wc_min, wc_max)

        def _get_ch_range():
            if _ch_min > 0 and _ch_max > 0:
                return f"between {_ch_min} and {_ch_max} chapters"
            elif _ch_min > 0:
                return f"at least {_ch_min} chapters"
            elif _ch_max > 0:
                return f"at most {_ch_max} chapters"
            return "a suitable number of chapters"

        self._stop_flag = False
        log_prefix = f"[New] {topic[:30]}"
        log = lambda m: self._log.log(f"{log_prefix} {m}")

        log(f"✦ New Content: '{topic}'")
        log(f"  Style: {style_info} | Mode: {mode} | Lang: {lang}")
        log(f"  Output: {output_dir}")
        self._log.set_status(f"New Content: {topic[:40]}...", False)

        def _new_content_worker():
            try:
                _stopped = lambda: self._stop_flag
                os.makedirs(pipeline_dir, exist_ok=True)
                os.makedirs(research_dir, exist_ok=True)

                # Save resume metadata (step 0)
                _resume_meta = {
                    "mode": mode,
                    "type": "new_content",
                    "niche": _niche,
                    "style": style_info,
                    "lang": lang,
                    "started_at": datetime.now().isoformat(timespec="seconds"),
                }
                _resume_path = os.path.join(pipeline_dir, "_resume.json")
                with open(_resume_path, "w", encoding="utf-8") as f:
                    json.dump(_resume_meta, f, indent=2, ensure_ascii=False)

                # ═══════════════════════════════════════
                # Step 1: Research blueprint (Plan A)
                # ═══════════════════════════════════════
                if skip_research:
                    log("Step 1/6: Loading existing blueprint (skip research)...")
                    with open(bp_path, "r", encoding="utf-8") as f:
                        blueprint = json.load(f)
                    chars = len(json.dumps(blueprint, ensure_ascii=False))
                    log(f"✓ Blueprint loaded: {chars:,} chars")
                else:
                    log("Step 1/6: Researching topic (Plan A: multi-section)...")
                    blueprint = research_blueprint_multicall(
                        topic=topic,
                        api_endpoints=endpoints,
                        lang="english",  # Always research in English for max AI knowledge recall
                        save_dir=research_dir,
                        log_callback=log,
                        stop_check=_stopped,
                        niche=_niche,
                    )
                    # Save blueprint
                    with open(bp_path, "w", encoding="utf-8") as f:
                        json.dump(blueprint, f, indent=2, ensure_ascii=False)
                    log(f"📄 Saved: _pipeline/_blueprint.json")

                if _stopped():
                    log("⛔ Stopped by user")
                    return

                # ═══════════════════════════════════════
                # Step 2: Select frameworks (AI ranking)
                # ═══════════════════════════════════════
                log("Step 2/6: Selecting framework...")

                if user_framework != "Auto (detect & switch)":
                    selected_fws = [user_framework]
                    log(f"✓ User selected: '{user_framework}'")
                else:
                    api_sel = APIClient(endpoints, log_api=lambda *a: None, tier="pro", stop_check=_stopped)
                    rec_result = recommend_framework_new_content(
                        blueprint, style_data, api_sel, lang=lang,
                        log_callback=log, niche=_niche,
                    )
                    rankings = rec_result.get("rankings", [])
                    for r in rankings:
                        if "framework" in r and "name" not in r:
                            r["name"] = r.pop("framework")
                    if rankings:
                        rankings = [r for r in rankings if r.get("name") in framework_names]
                    if not rankings:
                        rankings = [{"name": fw, "score": 5, "reason": "N/A"} for fw in framework_names]
                    rankings.sort(key=lambda x: x.get("score", 0), reverse=True)

                    rank_path = os.path.join(pipeline_dir, "_rankings.json")
                    with open(rank_path, "w", encoding="utf-8") as f:
                        json.dump({"rankings": rankings}, f, indent=2, ensure_ascii=False)
                    log(f"AI ranking: " + ", ".join(f"{r['name']}={r.get('score', '?')}" for r in rankings))

                    _SCORE_THRESHOLD = 8.5
                    _niche_str = style_data.get("niche", "").lower()
                    _BIO_KEYWORDS = ("biography", "tiểu sử", "nhân vật", "chân dung", "cuộc đời")
                    _is_bio = any(kw in _niche_str for kw in _BIO_KEYWORDS)

                    if _is_bio:
                        # Biography: v1 = best of General, v2 = best of Specialized
                        _GENERAL_FWS = {"Sử Thi", "Sự Lụi Tàn"}
                        generals = [r for r in rankings if r.get("name") in _GENERAL_FWS]
                        specials = [r for r in rankings if r.get("name") not in _GENERAL_FWS]
                        generals.sort(key=lambda x: x.get("score", 0), reverse=True)
                        specials.sort(key=lambda x: x.get("score", 0), reverse=True)

                        if generals:
                            selected_fws = [generals[0]["name"]]
                            log(f"  ✓ Auto-selected v1: '{generals[0]['name']}' (score={generals[0].get('score', '?')}) [bio: general]")
                        else:
                            selected_fws = [rankings[0]["name"]]
                            log(f"  ✓ Auto-selected v1: '{rankings[0]['name']}' (score={rankings[0].get('score', '?')}) [fallback]")

                        if specials and specials[0].get("score", 0) >= _SCORE_THRESHOLD:
                            selected_fws.append(specials[0]["name"])
                            log(f"  ✓ Auto-selected v2: '{specials[0]['name']}' (score={specials[0].get('score', '?')}) [bio: specialized]")
                        elif specials:
                            log(f"  ⊘ Skipped v2: '{specials[0]['name']}' (score={specials[0].get('score', '?')} < {_SCORE_THRESHOLD})")
                    else:
                        # Non-biography: top framework always, #2 only if score >= threshold
                        selected_fws = [rankings[0]["name"]]
                        log(f"  ✓ Auto-selected v1: '{rankings[0]['name']}' (score={rankings[0].get('score', '?')})")
                        if len(rankings) >= 2 and rankings[1].get("score", 0) >= _SCORE_THRESHOLD:
                            selected_fws.append(rankings[1]["name"])
                            log(f"  ✓ Auto-selected v2: '{rankings[1]['name']}' (score={rankings[1].get('score', '?')})")

                if _stopped():
                    return

                # ═══════════════════════════════════════
                # Steps 3-6: Outline → Audit → Write → Review (per framework)
                # Uses shared pipeline — same code as Rewrite
                # Run in PARALLEL when multiple frameworks selected
                # ═══════════════════════════════════════
                def _run_single_fw(fw_idx, fw_name):
                    """Run one framework pipeline (called from thread)."""
                    safe_fw = "".join(c if c.isalnum() or c in " _-" else "_" for c in fw_name).strip().replace(" ", "_")
                    fw_output_dir = os.path.join(output_dir, f"v{fw_idx}_{safe_fw}")
                    fw_pipeline_dir = os.path.join(fw_output_dir, "_pipeline")

                    fw_log = lambda m, _pfx=f"[v{fw_idx} {fw_name[:20]}]": log(f"{_pfx} {m}")

                    self._run_shared_fw_pipeline(
                        fw_name=fw_name,
                        fw_output_dir=fw_output_dir,
                        fw_pipeline_dir=fw_pipeline_dir,
                        fw_log=fw_log,
                        blueprint=blueprint,
                        style_json_raw=style_json_raw,
                        endpoints=endpoints,
                        tier=tier,
                        lang=lang,
                        niche=_niche,
                        stop_check=_stopped,
                        get_wc_rule=_get_wc_rule,
                        get_ch_range=_get_ch_range,
                        auto_patch=_do_patch,
                    )

                if len(selected_fws) == 1:
                    _run_single_fw(1, selected_fws[0])
                else:
                    # Parallel execution for 2+ frameworks
                    from concurrent.futures import ThreadPoolExecutor, as_completed
                    log(f"🔀 Running {len(selected_fws)} frameworks in PARALLEL...")
                    with ThreadPoolExecutor(max_workers=len(selected_fws)) as executor:
                        futures = {
                            executor.submit(_run_single_fw, idx, name): name
                            for idx, name in enumerate(selected_fws, 1)
                        }
                        for future in as_completed(futures):
                            fw = futures[future]
                            try:
                                future.result()
                            except Exception as e:
                                log(f"❌ Framework '{fw}' failed: {e}")

                log(f"\n✦ New Content complete!")
                log(f"📁 Output: {output_dir}")
                self._log.set_status(f"✓ New Content: {topic[:40]}", True)

            except Exception as e:
                import traceback
                log(f"❌ Error: {e}")
                log(traceback.format_exc())
                self._log.set_status(f"❌ Error: {e}", True)

        threading.Thread(target=_new_content_worker, daemon=True).start()

    def _do_rewrite(self):
        """Create rewrite jobs for checked folders (with merge option)."""
        mode = self._combo_mode.currentText()

        # Get checked folders from left panel (checkbox on column 1)
        checked_folders = []
        for i in range(self._folder_tree.topLevelItemCount()):
            item = self._folder_tree.topLevelItem(i)
            if item and item.checkState(1) == Qt.CheckState.Checked:
                group_name = item.data(1, Qt.ItemDataRole.UserRole)
                if group_name:
                    checked_folders.append(group_name)

        if not checked_folders:
            self._log.log("[Style] No folders checked")
            return

        # If multiple folders → ask Rewrite Each or Merge
        merge = False
        if len(checked_folders) > 1:
            from PyQt6.QtWidgets import QMessageBox
            msg = QMessageBox(self)
            msg.setWindowTitle("Chọn chế độ Rewrite")
            msg.setText(
                f"Đã chọn {len(checked_folders)} thư mục.\n"
                "Bạn muốn rewrite kiểu nào?"
            )
            btn_each = msg.addButton(
                "⚡ Rewrite riêng", QMessageBox.ButtonRole.ActionRole)
            btn_merge = msg.addButton(
                "🔗 Gộp && Rewrite", QMessageBox.ButtonRole.ActionRole)
            btn_cancel = msg.addButton("Hủy", QMessageBox.ButtonRole.RejectRole)
            msg.exec()
            clicked = msg.clickedButton()
            if clicked == btn_merge:
                merge = True
            elif clicked != btn_each:
                return  # cancelled

        # ── Style-content niche check via Flash AI (per folder) ──
        try:
            import json as _json, threading
            from PyQt6.QtWidgets import QMessageBox
            from PyQt6.QtWidgets import QApplication

            style_file = self._get_style_filename() or ""
            styles_dir = os.path.join(
                os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
                "styles"
            )
            style_path = os.path.join(styles_dir, style_file)

            # Read style niche from JSON
            style_niche = ""
            if os.path.isfile(style_path):
                try:
                    with open(style_path, "r", encoding="utf-8") as _f:
                        _sdata = _json.load(_f)
                        style_niche = _sdata.get("niche", "")
                        self._style_topic_keywords = _sdata.get("topic_keywords", [])
                except Exception:
                    pass

            if style_niche and checked_folders:
                self._log.log(f"[Niche] Checking {len(checked_folders)} folder(s) against style: {style_niche}")
                style_niche_lower = style_niche.lower()
                style_words = set(style_niche_lower.split())
                if hasattr(self, '_style_topic_keywords'):
                    style_words |= set(k.lower() for k in self._style_topic_keywords)

                matched_folders = []
                mismatched_folders = []  # [(folder_name, detected_niche)]

                endpoints = load_api_keys()

                for folder_idx, gn in enumerate(checked_folders):
                    # Collect sample from this folder
                    ch_titles = []
                    ch_sample = ""
                    for ch in self._chapters:
                        if ch.get("group") == gn:
                            ch_titles.append(ch.get("filename", ""))
                            if not ch_sample and ch.get("text"):
                                words = ch["text"].split()[:200]
                                ch_sample = " ".join(words)

                    if not ch_titles:
                        matched_folders.append(gn)
                        continue

                    folder_display = gn.split("]_", 1)[-1] if "]_" in gn else gn
                    folder_display = folder_display[:50]
                    self._log.log(f"[Niche] ({folder_idx+1}/{len(checked_folders)}) Detecting: {folder_display}...")

                    titles_str = "\n".join(ch_titles[:10])
                    prompt = (
                        "Based on these chapter titles and sample text, "
                        "what is the CONTENT GENRE / NICHE TYPE? "
                        "Return the GENRE (e.g. 'biography', 'mystery history'), "
                        "NOT the specific topic (e.g. NOT 'albert einstein'). "
                        "Reply with ONLY a short phrase (2-5 words). Examples:\n"
                        "- 'biography' (for any person's life story)\n"
                        "- 'mystery history' (for historical mysteries)\n"
                        "- 'battle analysis' (for military battles)\n"
                        "- 'firearms review' (for gun reviews)\n"
                        "- 'tech gadgets' (for technology reviews)\n\n"
                        f"Chapter titles:\n{titles_str}\n\n"
                        f"Sample text (first 200 words):\n{ch_sample[:800]}"
                    )

                    api = APIClient(endpoints, log_api=False, tier="flash")
                    result = [None]

                    def _detect(api_ref=api, prompt_ref=prompt):
                        result[0] = api_ref.call_api(
                            [{"role": "user", "content": prompt_ref}],
                            temperature=0.1, max_tokens=30, timeout=15
                        )

                    t = threading.Thread(target=_detect, daemon=True)
                    t.start()
                    import time as _time
                    _deadline = _time.time() + 15
                    while t.is_alive() and _time.time() < _deadline:
                        QApplication.processEvents()
                        _time.sleep(0.1)

                    if result[0] and result[0].get("success"):
                        detected_niche = result[0]["content"].strip().strip("\"'").lower()
                        detected_words = set(detected_niche.split())
                        overlap = detected_words & style_words

                        if overlap:
                            self._log.log(f"[Niche]   ✓ '{detected_niche}' — matches style")
                            matched_folders.append(gn)
                        else:
                            self._log.log(f"[Niche]   ✗ '{detected_niche}' — does NOT match style")
                            mismatched_folders.append((gn, detected_niche))
                    else:
                        self._log.log(f"[Niche]   ⚠ Detection failed — treating as matched")
                        matched_folders.append(gn)

                # Show summary if any mismatches
                if mismatched_folders:
                    self._log.log(f"[Niche] Result: {len(matched_folders)} matched, {len(mismatched_folders)} mismatched")

                    mismatch_lines = []
                    for gn, det in mismatched_folders:
                        short = gn.split("]_", 1)[-1] if "]_" in gn else gn
                        mismatch_lines.append(f"  ✗ {short[:60]}\n     → detected: {det}")

                    match_lines = []
                    for gn in matched_folders:
                        short = gn.split("]_", 1)[-1] if "]_" in gn else gn
                        match_lines.append(f"  ✓ {short[:60]}")

                    warn_msg = (
                        f"Style niche: {style_niche}\n\n"
                        f"✗ Không khớp ({len(mismatched_folders)}):\n"
                        + "\n".join(mismatch_lines)
                    )
                    if match_lines:
                        warn_msg += (
                            f"\n\n✓ Khớp ({len(matched_folders)}):\n"
                            + "\n".join(match_lines)
                        )

                    msg = QMessageBox(self)
                    msg.setWindowTitle("⚠ Niche Check Results")
                    msg.setIcon(QMessageBox.Icon.Warning)
                    msg.setText(warn_msg)

                    btn_all = msg.addButton("▶ Chạy tất cả", QMessageBox.ButtonRole.AcceptRole)
                    if matched_folders:
                        btn_matched = msg.addButton(
                            f"▶ Chỉ chạy {len(matched_folders)} folder khớp",
                            QMessageBox.ButtonRole.ActionRole
                        )
                    else:
                        btn_matched = None
                    btn_cancel = msg.addButton("Hủy", QMessageBox.ButtonRole.RejectRole)
                    msg.exec()

                    clicked = msg.clickedButton()
                    if clicked == btn_cancel:
                        self._log.log("[Niche] ⛔ Cancelled by user")
                        return
                    elif clicked == btn_matched and btn_matched:
                        checked_folders = matched_folders
                        self._log.log(f"[Niche] Running {len(matched_folders)} matched folder(s) only")
                    else:
                        self._log.log(f"[Niche] Running all {len(checked_folders)} folder(s)")
                else:
                    self._log.log(f"[Niche] ✓ All {len(checked_folders)} folder(s) match style")
        except Exception as e:
            self._log.log(f"[Niche] ⚠ Check error: {e}")

        if merge:
            self._do_rewrite_merge(checked_folders, mode)
        else:
            self._do_rewrite_each(checked_folders, mode)

    def _do_rewrite_merge(self, checked_folders, mode):
        """Merge all checked folders into a single job."""
        # Merge requires explicit output path
        if not self._txt_output.text().strip():
            QMessageBox.warning(
                self, "Merge",
                "Chế độ Merge bắt buộc phải chọn thư mục Output.\n"
                "Vui lòng chọn đường dẫn output trước khi merge."
            )
            return
        all_chapters = []
        for gn in checked_folders:
            chs = [c for c in self._chapters if c.get("group") == gn]
            all_chapters.extend(chs)
        if not all_chapters:
            self._log.log("[Style] No chapters in checked folders")
            return

        # Use first folder's path for output
        group_path = os.path.dirname(all_chapters[0]["filepath"])
        merged_name = " + ".join(gn[:20] for gn in checked_folders[:3])
        if len(checked_folders) > 3:
            merged_name += f" +{len(checked_folders)-3} more"

        self._task_counter += 1
        task_num = self._task_counter
        self._create_and_submit_job(
            folder_name=merged_name, group_path=group_path,
            mode=mode, chapters=all_chapters, task_num=task_num,
            merged_groups=list(checked_folders),
        )
        self.job_update.emit()
        self._log.log(
            f"[Task {task_num}] Merged {len(checked_folders)} folders "
            f"({len(all_chapters)} chapters) → 1 job"
        )

    def _do_rewrite_each(self, checked_folders, mode):
        """Create 1 job per checked folder."""
        jobs_created = 0
        for group_name in checked_folders:
            folder_chapters = [
                ch for ch in self._chapters
                if ch.get("group") == group_name
            ]
            if not folder_chapters:
                continue
            group_path = os.path.dirname(folder_chapters[0]["filepath"])
            self._task_counter += 1
            self._create_and_submit_job(
                folder_name=group_name, group_path=group_path,
                mode=mode, chapters=folder_chapters,
                task_num=self._task_counter,
            )
            jobs_created += 1

        if jobs_created > 0:
            self.job_update.emit()
            self._log.log(f"[Job] {jobs_created} job(s) submitted")
        else:
            self._log.log("[Style] No chapters found in checked folders")

    def _do_rewrite_chapter(self):
        """Rewrite selected chapters using existing pipeline data."""
        checked = self._get_checked_chapters()
        if not checked:
            self._log.log("[Re-ch] No chapters checked")
            return

        # Find the output directory (style_rewrite/) from checked files
        first_path = checked[0]["filepath"]
        output_dir = os.path.dirname(first_path)
        pipeline_dir = os.path.join(output_dir, "_pipeline")

        # If _pipeline/ not found here, the checked file may be an INPUT file
        # → look in style_rewrite/ under the input file's directory instead
        if not os.path.isdir(pipeline_dir):
            alt_output = os.path.join(output_dir, "style_rewrite")
            alt_pipeline = os.path.join(alt_output, "_pipeline")
            if os.path.isdir(alt_pipeline):
                output_dir = alt_output
                pipeline_dir = alt_pipeline
                self._log.log("[Re-ch] Found pipeline in style_rewrite/")

        if not os.path.isdir(pipeline_dir):
            self._log.log("[Re-ch] ✗ No _pipeline/ folder found — run full pipeline first")
            return

        # Detect mode: review has _review_outline*.json, narrative has _renew_outline*.json
        is_review = os.path.isfile(os.path.join(pipeline_dir, "_review_outline.json"))
        is_narrative = os.path.isfile(os.path.join(pipeline_dir, "_renew_outline.json"))

        if not is_review and not is_narrative:
            self._log.log("[Re-ch] ✗ No outline found in _pipeline/")
            return

        mode_label = "review" if is_review else "narrative"
        self._log.log(f"[Re-ch] Mode: {mode_label}, {len(checked)} chapter(s) selected")

        # Load pipeline data
        try:
            # Blueprint
            bp_path = os.path.join(pipeline_dir, "_blueprint.json")
            if not os.path.isfile(bp_path):
                bp_path = os.path.join(pipeline_dir, "_blueprint_converted.json")
            with open(bp_path, "r", encoding="utf-8") as f:
                blueprint = json.load(f)
            self._log.log(f"[Re-ch] ✓ Loaded blueprint")

            # Outline (prefer audited version)
            if is_review:
                outline_path = os.path.join(pipeline_dir, "_review_outline_audited.json")
                if not os.path.isfile(outline_path):
                    outline_path = os.path.join(pipeline_dir, "_review_outline.json")
            else:
                outline_path = os.path.join(pipeline_dir, "_renew_outline_audited.json")
                if not os.path.isfile(outline_path):
                    outline_path = os.path.join(pipeline_dir, "_renew_outline.json")
            with open(outline_path, "r", encoding="utf-8") as f:
                outline = json.load(f)
            out_chapters = outline.get("chapters", [])
            self._log.log(f"[Re-ch] ✓ Loaded outline ({len(out_chapters)} chapters)")

            # Style JSON
            style_json_raw, style_info = self._load_style_json_raw()
            if style_json_raw is None:
                self._log.log(f"[Re-ch] ✗ {style_info}")
                return

            # Extract niche from style filename (same as _do_renew_style)
            _niche = style_info.replace(".json", "").split("_", 1)[-1].replace("_", " ") if "_" in style_info else ""
            if _niche:
                self._log.log(f"[Re-ch] Niche: {_niche}")

            # Framework name from outline
            selected_fw = outline.get("framework", outline.get("target_framework", ""))
            if not selected_fw:
                # Try detection file
                det_path = os.path.join(pipeline_dir, "_detection.json")
                if os.path.isfile(det_path):
                    with open(det_path, "r", encoding="utf-8") as f:
                        det = json.load(f)
                    selected_fw = det.get("detected_framework", "Unknown")
            self._log.log(f"[Re-ch] Framework: {selected_fw}")

        except Exception as e:
            self._log.log(f"[Re-ch] ✗ Failed to load pipeline data: {e}")
            return

        # Settings
        lang = self._get_lang_code()
        tier = self._combo_tier.currentText().lower()
        target_country = self._combo_country.currentText()
        outline_json_str = json.dumps(outline, indent=2, ensure_ascii=False)

        # Build list of all output chapter files in order
        all_ch_files = sorted(
            [f for f in os.listdir(output_dir)
             if f.startswith("ch_") and f.endswith(".txt")],
            key=lambda x: x
        )

        # Submit as background job
        self._task_counter += 1
        task_num = self._task_counter
        log_prefix = f"[Task {task_num}]"
        stop_event = threading.Event()

        def _run():
            log = lambda m: self._log.log(f"{log_prefix} {m}")
            endpoints = load_api_keys()
            log_api = False
            _use_transitions = self._chk_transitions.isChecked()

            for ch_data in checked:
                if stop_event.is_set():
                    log("Stopped")
                    return

                fname = ch_data["filename"]
                # Parse index from filename: ch_05_xxx.txt → 4 (0-indexed)
                try:
                    ch_idx = int(fname.split("_")[1]) - 1
                except (IndexError, ValueError):
                    log(f"✗ Cannot parse chapter index from '{fname}'")
                    continue

                if ch_idx < 0 or ch_idx >= len(out_chapters):
                    log(f"✗ Chapter index {ch_idx+1} out of range (outline has {len(out_chapters)} chapters)")
                    continue

                ch_outline = out_chapters[ch_idx]
                ch_type = ch_outline.get("chapter_type", "body")
                total = len(out_chapters)

                # Word count
                if ch_type == "hook":
                    wc_section = "open"
                elif ch_type == "end":
                    wc_section = "end"
                elif ch_idx == 0:
                    wc_section = "open"
                elif ch_idx == total - 1:
                    wc_section = "end"
                else:
                    wc_section = "body"
                wc_rule = _get_wc_rule_s(wc_section)

                # SKIP: if both min/max = 0, skip this chapter
                if wc_rule == "SKIP":
                    fw_log(f"⏭ Ch.{ch_idx+1}/{total}: skipped ({wc_section} = SKIP)")
                    continue

                # Build previous context (hook = none, body/end = adjacent chapters)
                prev_context = ""
                if ch_type != "hook" and ch_idx > 0:
                    context_parts = []
                    # Read ch[i-1]
                    if ch_idx - 1 >= 0 and ch_idx - 1 < len(all_ch_files):
                        prev_file = os.path.join(output_dir, all_ch_files[ch_idx - 1])
                        if os.path.isfile(prev_file):
                            with open(prev_file, "r", encoding="utf-8") as f:
                                context_parts.append(f.read())
                    # Read ch[i+1] for context
                    if ch_idx + 1 < len(all_ch_files):
                        next_file = os.path.join(output_dir, all_ch_files[ch_idx + 1])
                        if os.path.isfile(next_file):
                            with open(next_file, "r", encoding="utf-8") as f2:
                                context_parts.append(f2.read())
                    prev_context = "\n---\n".join(context_parts)

                log(f"Rewriting ch.{ch_idx+1}/{total}: {fname} (type={ch_type})")

                try:
                    api_w = APIClient(
                        endpoints, log_api=log_api, tier=tier,
                        stop_check=lambda: stop_event.is_set()
                    )

                    if is_review:
                        rewritten = write_review_chapter(
                            blueprint=blueprint,
                            style_json=style_json_raw,
                            framework_name=selected_fw,
                            chapter_outline=ch_outline,
                            chapter_number=ch_idx + 1,
                            total_chapters=total,
                            api_client=api_w,
                            word_count_rule=wc_rule,
                            lang=lang,
                            previous_context=prev_context,
                            target_country=target_country,
                            full_outline=outline_json_str,
                            log_callback=lambda m: log(m),
                            use_transitions=_use_transitions,
                        )
                    else:
                        rewritten = write_from_blueprint(
                            blueprint=blueprint,
                            style_json=style_json_raw,
                            framework_name=selected_fw,
                            chapter_outline=ch_outline,
                            chapter_number=ch_idx + 1,
                            total_chapters=total,
                            api_client=api_w,
                            word_count_rule=wc_rule,
                            lang=lang,
                            previous_context=prev_context,
                            full_outline=outline_json_str,
                            log_callback=lambda m: log(m),
                            niche=_niche,
                            save_dir=pipeline_dir,
                        )

                    # Write output (overwrite)
                    out_path = os.path.join(output_dir, fname)
                    with open(out_path, "w", encoding="utf-8") as f:
                        f.write(rewritten)
                    log(f"✓ Rewrote: {fname}")

                except Exception as e:
                    log(f"✗ Failed: {fname} — {e}")

            log("✓ Re-ch complete")

        # Submit to thread pool
        self._job_counter += 1
        jid = f"job_{self._job_counter}"
        job = {
            "id": jid,
            "task_num": task_num,
            "folder_name": f"Re-ch ({len(checked)} ch)",
            "group_path": output_dir,
            "mode": "Re-ch",
            "stop_event": stop_event,
            "status": "running",
            "progress": "Starting...",
            "checked": checked,
            "future": None,
            "log_prefix": log_prefix,
        }
        self._jobs[jid] = job

        def _wrapper():
            try:
                _run()
                if not stop_event.is_set():
                    job["status"] = "done"
                    job["progress"] = "✓ Complete"
                else:
                    job["status"] = "stopped"
                    job["progress"] = "Stopped"
            except Exception as e:
                job["status"] = "error"
                job["progress"] = str(e)[:50]
            self.job_update.emit()

        future = self._job_pool.submit(_wrapper)
        job["future"] = future
        self._log.log(f"[Task {task_num}] Re-ch started: {len(checked)} chapter(s)")
        self.job_update.emit()


    def _create_and_submit_job(self, folder_name, group_path, mode,
                               chapters, task_num, merged_groups=None):
        """Create a job dict and submit to the thread pool."""
        self._job_counter += 1
        jid = f"job_{self._job_counter}"
        stop_event = threading.Event()
        job = {
            "id": jid,
            "task_num": task_num,
            "folder_name": folder_name,
            "group_path": group_path,
            "mode": mode,
            "stop_event": stop_event,
            "status": "running",
            "progress": "Starting...",
            "checked": list(chapters),
            "future": None,
            "log_prefix": f"[Task {task_num}]",
            # Cache UI values for thread-safe access in worker
            "_cached_wc_open": (self._wc_open_min.value(), self._wc_open_max.value()),
            "_cached_wc_body": (self._wc_body_min.value(), self._wc_body_max.value()),
            "_cached_wc_end": (self._wc_end_min.value(), self._wc_end_max.value()),
            "_cached_ch_min": self._ch_min.value(),
            "_cached_ch_max": self._ch_max.value(),
            "_cached_transitions": self._chk_transitions.isChecked(),
            "_cached_google_check": self._chk_google_check.isChecked(),
            "_cached_auto_patch": self._chk_auto_patch.isChecked(),
        }
        if merged_groups:
            job["merged_groups"] = merged_groups
        self._jobs[jid] = job

        def _job_wrapper(j=job, m=mode, se=stop_event):
            try:
                if m == "Top/List Review":
                    self._do_renew_review(job=j)
                else:
                    self._do_renew_style(job=j)
                if not se.is_set():
                    # Post-rewrite: Video cutting
                    if self._chk_cut_video.isChecked():
                        self._do_cut_video_for_group(j)
                    j["status"] = "done"
                    j["progress"] = "✓ Complete"
                else:
                    j["status"] = "stopped"
                    j["progress"] = "Stopped"
            except Exception as e:
                j["status"] = "error"
                j["progress"] = str(e)[:50]
            self.job_update.emit()

        future = self._job_pool.submit(_job_wrapper)
        job["future"] = future
        self._log.log(f"[Task {task_num}] Started: {folder_name} ({mode})")

    @staticmethod
    def _strip_source_tags(obj):
        """Recursively strip source tags: {'value': X, 'source': ...} → X."""
        if isinstance(obj, dict):
            if "value" in obj and "source" in obj and len(obj) == 2:
                return obj["value"]
            return {k: ScriptCreationTab._strip_source_tags(v) for k, v in obj.items()}
        if isinstance(obj, list):
            return [ScriptCreationTab._strip_source_tags(item) for item in obj]
        return obj

    def _load_style_json_raw(self):
        """Load the raw style JSON string for the selected style."""
        style_file = self._get_style_filename()
        if not style_file:
            return None, "No style selected"
        styles_dir = os.path.join(
            os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
            "styles"
        )
        style_path = os.path.join(styles_dir, style_file)
        if not os.path.isfile(style_path):
            return None, f"Style file not found: {style_file}"
        with open(style_path, "r", encoding="utf-8") as f:
            return f.read(), style_file

    def _do_renew_style(self, job=None):
        checked = job["checked"] if job else self._get_checked_chapters()
        if not checked:
            self._log.log(f"{job.get('log_prefix', '[Renew]') if job else '[Renew]'} No chapters selected")
            return
        output_dir = (job.get("_cached_output_dir") if job else None) or self._resolve_output_dir(checked[0]["filepath"])
        if not output_dir:
            return

        # Use cached style JSON from job (Auto Pipeline) or load from widget
        if job and job.get("_cached_style_raw"):
            style_json_raw = job["_cached_style_raw"]
            style_info = job.get("_cached_style_info", "auto")
        else:
            style_json_raw, style_info = self._load_style_json_raw()
        if style_json_raw is None:
            self._log.log(f"[Renew] ✗ {style_info}")
            return

        # Parse style JSON to get framework names
        try:
            style_data = json.loads(style_json_raw)
            framework_names = [
                fw.get("name", "") for fw in style_data.get("frameworks", [])
                if fw.get("enabled", True)
            ]
        except (json.JSONDecodeError, AttributeError):
            framework_names = []

        if not framework_names:
            self._log.log(f"{job.get('log_prefix', '[Renew]') if job else '[Renew]'} ✗ No frameworks found in style guide")
            return

        group_path = job["group_path"] if job else self._group_path
        stop_event = job["stop_event"] if job else None
        log_prefix = job["log_prefix"] if job else "[Renew]"
        if not job:
            self._running = True
        tier = job.get("_cached_tier", self._combo_tier.currentText().lower()) if job else self._combo_tier.currentText().lower()
        log_api = False
        lang = job.get("_cached_lang", self._get_lang_code()) if job else self._get_lang_code()
        user_framework = job.get("_cached_framework", self._combo_framework.currentText()) if job else self._combo_framework.currentText()

        # Cached word count / chapter count / transitions (thread-safe)
        if job:
            _wc_cache = {
                "open": job.get("_cached_wc_open", (0, 0)),
                "body": job.get("_cached_wc_body", (0, 0)),
                "end": job.get("_cached_wc_end", (0, 0)),
            }
            _ch_min = job.get("_cached_ch_min", 0)
            _ch_max = job.get("_cached_ch_max", 0)
            _use_transitions = job.get("_cached_transitions", True)
        else:
            _wc_cache = {
                "open": (self._wc_open_min.value(), self._wc_open_max.value()),
                "body": (self._wc_body_min.value(), self._wc_body_max.value()),
                "end": (self._wc_end_min.value(), self._wc_end_max.value()),
            }
            _ch_min = self._ch_min.value()
            _ch_max = self._ch_max.value()
            _use_transitions = self._chk_transitions.isChecked()

        def _get_wc_rule_s(section="body"):
            wc_min, wc_max = _wc_cache.get(section, _wc_cache["body"])
            return build_word_count_rule(wc_min, wc_max)

        def _get_ch_range_s():
            if _ch_min > 0 and _ch_max > 0:
                return f"between {_ch_min} and {_ch_max} chapters"
            elif _ch_min > 0:
                return f"at least {_ch_min} chapters"
            elif _ch_max > 0:
                return f"at most {_ch_max} chapters"
            return "a suitable number of chapters"

        self._log.log(
            f"{log_prefix} Starting pipeline: {len(checked)} input(s), "
            f"style={style_info}, {len(framework_names)} frameworks"
        )
        self._log.set_status(f"{log_prefix} detecting framework...", False)

        def _run():
            # Per-job stop check
            def _stopped():
                if stop_event and stop_event.is_set():
                    return True
                return self._stop_flag
            # Patch self._stop_flag for backward compat with API clients
            # that use lambda: self._stop_flag
            if not job:
                self._stop_flag = False

            def _update_job_progress(text):
                if job:
                    job["progress"] = text
                    self.job_update.emit()

            # Log wrapper: auto-prefix all messages with [Task N]
            log = lambda m: self._log.log(f"{log_prefix} {m}")

            try:
                endpoints = load_api_keys()
                chapters_data = self._status.setdefault("chapters", {})

                # Mark all input chapters as processing
                self._update_input_chapters_status(
                    checked, "processing", chapters_data, "Step 1/8"
                )
                _update_job_progress("Step 1/8")

                # ── Step 1: Concatenate all text ──
                full_text = ""
                for i, ch in enumerate(checked, 1):
                    full_text += f"\n\n=== PART {i}: {ch['filename']} ===\n{ch['text']}"

                log(f"Step 1/8: Full text {len(full_text):,} chars")
                _update_job_progress("Step 1/8")

                if _stopped():
                    return

                # Get niche from style JSON (consistent with Review mode)
                _niche = (style_data.get("niche", "") or "").lower()
                if not _niche:
                    # Fallback: extract from style filename
                    _niche = style_info.replace(".json", "").split("_", 1)[-1].replace("_", " ") if "_" in style_info else ""

                # ── Step 2: Detect original framework ──
                log("Step 2/8: Detecting original framework...")
                _update_job_progress("Step 2/8")

                api_det = APIClient(endpoints, log_api=log_api, tier="flash", stop_check=_stopped)
                detection = detect_framework(
                    full_text, api_det,
                    log_callback=lambda m: log(m),
                    frameworks_list=style_data.get("frameworks", []),
                )
                original_fw = detection.get("detected_framework", "")
                confidence = detection.get("confidence", "?")
                log(
                    f"✓ Original framework: '{original_fw}' (confidence: {confidence})"                )

                # Save detection result
                os.makedirs(output_dir, exist_ok=True)
                pipeline_dir = os.path.join(output_dir, "_pipeline")
                os.makedirs(pipeline_dir, exist_ok=True)
                det_path = os.path.join(pipeline_dir, "_detection.json")
                with open(det_path, "w", encoding="utf-8") as f:
                    json.dump(detection, f, indent=2, ensure_ascii=False)
                log(f"📄 Saved: _pipeline/_detection.json")
                if _stopped():
                    return

                # ── Step 3: Extract blueprint ──
                log("Step 3/8: Extracting content blueprint...")
                _update_job_progress("Step 3/8")

                self._log.set_status("Renew: extracting blueprint...", False)
                api_bp = APIClient(endpoints, log_api=log_api, tier=tier, stop_check=_stopped)
                blueprint = extract_blueprint(
                    full_text, api_bp, lang=lang,
                    log_callback=lambda m: log(m),
                    niche=_niche,
                )
                # Log niche-appropriate blueprint summary
                bp_parts = []
                for field, label in [
                    ("life_phases", "life phases"), ("battle_phases", "battle phases"),
                    ("key_facts", "facts"), ("key_events", "events"),
                    ("achievements", "achievements"), ("conflicts", "conflicts"),
                    ("turning_points", "turning points"), ("systemic_opposition", "systemic opposition"),
                    ("key_relationships", "relationships"),
                ]:
                    n = len(blueprint.get(field, []))
                    if n > 0:
                        bp_parts.append(f"{n} {label}")
                log(f"✓ Blueprint: {', '.join(bp_parts) if bp_parts else 'extracted'}")

                # Save blueprint for reference
                bp_path = os.path.join(pipeline_dir, "_blueprint.json")
                with open(bp_path, "w", encoding="utf-8") as f:
                    json.dump(blueprint, f, indent=2, ensure_ascii=False)

                if _stopped():
                    return

                # ── Step 3.5: Enrich empty blueprint fields ──
                # Always runs: Google Check ON → Google Search, OFF → AI knowledge
                _google_check_on = job.get("_cached_google_check", self._chk_google_check.isChecked()) if job else self._chk_google_check.isChecked()
                _gemini_keys = load_gemini_keys()
                if _gemini_keys:
                    _src = "Google Search fallback" if _google_check_on else "AI knowledge only"
                    log(f"Step 3.5: Enriching blueprint ({_src})...")
                    self._log.set_status("Enriching blueprint data...", False)
                    try:
                        enrich_result = enrich_blueprint_google(
                            blueprint, _gemini_keys,
                            niche=_niche,
                            lang=lang,
                            log_callback=lambda m: log(m),
                            stop_check=_stopped,
                            use_google_search=_google_check_on,
                            api_endpoints=endpoints,
                        )
                        # Save enrichment result
                        er_path = os.path.join(pipeline_dir, "_enrichment.json")
                        with open(er_path, "w", encoding="utf-8") as f:
                            json.dump(enrich_result, f, indent=2, ensure_ascii=False)
                        log(f"📄 Saved: _enrichment.json")

                        # Re-save enriched blueprint
                        if enrich_result.get("fields_filled", 0) > 0:
                            with open(bp_path, "w", encoding="utf-8") as f:
                                json.dump(blueprint, f, indent=2, ensure_ascii=False)
                            log(f"✓ Blueprint updated with {enrich_result['fields_filled']} enriched field(s)")
                    except Exception as e:
                        log(f"⚠️ Enrichment failed (non-fatal): {e}")
                else:
                    log("⚠ No Gemini API keys — skipping enrichment")

                if _stopped():
                    return

                # ── Step 4: Select frameworks ──
                if user_framework != "Auto (detect & switch)":
                    # User explicitly chose a framework
                    selected_fws = [user_framework]
                    log(
                        f"✓ User selected framework: '{user_framework}'"                    )
                else:
                    # Auto mode: AI ranks all frameworks
                    available = framework_names

                    # Rewrite mode: always use generic AI-only framework recommendation
                    api_sel = APIClient(
                        endpoints, log_api=log_api, tier="pro",
                        stop_check=_stopped
                    )
                    rec_result = recommend_framework(
                        blueprint, style_data, api_sel, lang=lang,
                        log_callback=lambda m: log(m)
                    )

                    rankings = rec_result.get("rankings", [])

                    # Normalize keys: API may return "framework" or "name"
                    for r in rankings:
                        if "framework" in r and "name" not in r:
                            r["name"] = r.pop("framework")
                        if "reasoning" in r and "reason" not in r:
                            r["reason"] = r.pop("reasoning")

                    if rankings:
                        # Filter to only valid framework names
                        rankings = [r for r in rankings if r.get("name") in available]
                        if not rankings:
                            rankings = [{"name": fw, "score": 5, "reason": "Không có đánh giá"} for fw in available]
                    else:
                        # Fallback: equal scores
                        rankings = [{"name": fw, "score": 5, "reason": "AI không thể đánh giá"} for fw in available]
                        log("⚠ AI ranking failed, showing equal scores")

                    # Sort by score descending
                    rankings.sort(key=lambda x: x.get("score", 0), reverse=True)

                    # Save rankings
                    rank_path = os.path.join(pipeline_dir, "_rankings.json")
                    with open(rank_path, "w", encoding="utf-8") as f:
                        json.dump({
                            "original_framework": original_fw,
                            "original_confidence": confidence,
                            "rankings": rankings
                        }, f, indent=2, ensure_ascii=False)
                    log(f"📄 Saved: _pipeline/_rankings.json")
                    log(
                        f"AI ranking: "                        + ", ".join(f"{r['name']}={r.get('score', '?')}" for r in rankings)
                    )

                    # ── Auto-select frameworks ──
                    _niche_str = style_data.get("niche", "").lower()
                    _BATTLE_KEYWORDS = ("battle", "war", "military", "combat")
                    _is_battle = any(kw in _niche_str for kw in _BATTLE_KEYWORDS)

                    if _is_battle:
                        # Battle niche: ALWAYS include "The Investigative Deep-Dive"
                        # + add best of REMAINING frameworks only if score >= 8.5
                        _MUST_HAVE = "The Investigative Deep-Dive"
                        _SCORE_THRESHOLD = 8.5
                        selected_fws = [_MUST_HAVE]
                        inv_score = next((r.get("score", "?") for r in rankings if r["name"] == _MUST_HAVE), "?")
                        log(f"  ✓ Auto-selected v1: '{_MUST_HAVE}' (score={inv_score}) [battle: must-have]")

                        # Best from remaining (excluding Investigative)
                        remaining = [r for r in rankings if r["name"] != _MUST_HAVE]
                        if remaining:
                            best = remaining[0]
                            if best.get("score", 0) >= _SCORE_THRESHOLD:
                                selected_fws.append(best["name"])
                                log(f"  ✓ Auto-selected v2: '{best['name']}' (score={best.get('score', '?')}) [battle: top remaining]")
                            else:
                                log(f"  ⊘ Skipped v2: '{best['name']}' (score={best.get('score', '?')} < {_SCORE_THRESHOLD})")
                    else:
                        _SCORE_THRESHOLD = 8.5
                        _BIO_KEYWORDS = ("biography", "tiểu sử", "nhân vật", "chân dung", "cuộc đời")
                        _is_bio = any(kw in _niche_str for kw in _BIO_KEYWORDS)

                        if _is_bio:
                            # Biography: v1 = best of General, v2 = best of Specialized
                            _GENERAL_FWS = {"Sử Thi", "Sự Lụi Tàn"}
                            generals = [r for r in rankings if r.get("name") in _GENERAL_FWS]
                            specials = [r for r in rankings if r.get("name") not in _GENERAL_FWS]
                            generals.sort(key=lambda x: x.get("score", 0), reverse=True)
                            specials.sort(key=lambda x: x.get("score", 0), reverse=True)

                            if generals:
                                selected_fws = [generals[0]["name"]]
                                log(f"  ✓ Auto-selected v1: '{generals[0]['name']}' (score={generals[0].get('score', '?')}) [bio: general]")
                            else:
                                selected_fws = [rankings[0]["name"]]
                                log(f"  ✓ Auto-selected v1: '{rankings[0]['name']}' (score={rankings[0].get('score', '?')}) [fallback]")

                            if specials and specials[0].get("score", 0) >= _SCORE_THRESHOLD:
                                selected_fws.append(specials[0]["name"])
                                log(f"  ✓ Auto-selected v2: '{specials[0]['name']}' (score={specials[0].get('score', '?')}) [bio: specialized]")
                            elif specials:
                                log(f"  ⊘ Skipped v2: '{specials[0]['name']}' (score={specials[0].get('score', '?')} < {_SCORE_THRESHOLD})")
                        else:
                            # Non-biography/non-battle: top framework always, #2 only if score >= threshold
                            selected_fws = [rankings[0]["name"]]
                            log(f"  ✓ Auto-selected v1: '{rankings[0]['name']}' (score={rankings[0].get('score', '?')})")

                            if len(rankings) >= 2:
                                v2_score = rankings[1].get("score", 0)
                                if v2_score >= _SCORE_THRESHOLD:
                                    selected_fws.append(rankings[1]["name"])
                                    log(f"  ✓ Auto-selected v2: '{rankings[1]['name']}' (score={v2_score})")
                                else:
                                    log(f"  ⊘ Skipped v2: '{rankings[1]['name']}' (score={v2_score} < {_SCORE_THRESHOLD})")

                if _stopped():
                    return

                # ── Helper: build version directory name ──
                def _fw_dir_name(idx, fw_name):
                    safe = "".join(
                        c if c.isalnum() or c in " _-" else "_"
                        for c in fw_name
                    ).strip().replace(" ", "_")
                    # Add score from rankings if available
                    _score_map = {r["name"]: r.get("score", 0) for r in rankings} if 'rankings' in dir() else {}
                    _s = _score_map.get(fw_name, 0)
                    score_suffix = f"_{_s}" if _s else ""
                    return f"v{idx}_{safe}{score_suffix}"

                # ── Helper: run Steps 5-8 for one framework ──
                def _run_fw_pipeline(fw_name, fw_output_dir, fw_pipeline_dir, fw_log):
                    """Steps 5-8 for a single framework — delegates to shared pipeline."""
                    _do_patch = job.get("_cached_auto_patch", False) if job else self._chk_auto_patch.isChecked()

                    def _on_ch_saved(out_fname, _fw_name):
                        with self._lock:
                            chapters_data[out_fname] = {
                                "status": "rewritten",
                                "rewritten_at": datetime.now().strftime("%Y-%m-%d %H:%M"),
                                "lang": lang,
                                "rewrite_mode": "renew",
                                "framework": _fw_name,
                                "original_framework": original_fw,
                                "output_file": out_fname,
                            }
                        self._save_status_safe(group_path)

                    self._run_shared_fw_pipeline(
                        fw_name=fw_name,
                        fw_output_dir=fw_output_dir,
                        fw_pipeline_dir=fw_pipeline_dir,
                        fw_log=fw_log,
                        blueprint=blueprint,
                        style_json_raw=style_json_raw,
                        endpoints=endpoints,
                        tier=tier,
                        lang=lang,
                        niche=_niche,
                        stop_check=_stopped,
                        get_wc_rule=_get_wc_rule_s,
                        get_ch_range=_get_ch_range_s,
                        log_api=log_api,
                        on_chapter_saved=_on_ch_saved,
                        auto_patch=_do_patch,
                    )

                # ── Execute framework pipeline(s) ──
                if len(selected_fws) == 1:
                    # Single framework → flat output (backward compatible)
                    _update_job_progress("Steps 5-8")
                    _run_fw_pipeline(
                        selected_fws[0], output_dir, pipeline_dir,
                        fw_log=log
                    )
                else:
                    # Dual framework → parallel execution in versioned dirs
                    from concurrent.futures import ThreadPoolExecutor as _FwTPE, as_completed as _fw_ac

                    fw_tasks = []
                    for idx, fw_name in enumerate(selected_fws, 1):
                        dir_name = _fw_dir_name(idx, fw_name)
                        fw_out = os.path.join(output_dir, dir_name)
                        fw_pipe = os.path.join(fw_out, "_pipeline")
                        tag = f"[v{idx}]"
                        fw_log_fn = lambda m, _tag=tag: log(f"{_tag} {m}")
                        fw_tasks.append((fw_name, fw_out, fw_pipe, fw_log_fn))

                    log(f"🔀 Running {len(fw_tasks)} frameworks in parallel:")
                    for fw_name, fw_out, _, _ in fw_tasks:
                        log(f"  → {fw_name} → {os.path.basename(fw_out)}/")

                    _update_job_progress("Steps 5-8 (dual)")

                    with _FwTPE(max_workers=len(fw_tasks), thread_name_prefix="fw") as fw_pool:
                        futs = []
                        for fw_name, fw_out, fw_pipe, fw_log_fn in fw_tasks:
                            futs.append(
                                fw_pool.submit(
                                    _run_fw_pipeline,
                                    fw_name, fw_out, fw_pipe, fw_log_fn
                                )
                            )
                        for fut in _fw_ac(futs):
                            try:
                                fut.result()
                            except Exception as e:
                                log(f"⚠️ Framework pipeline error: {e}")

                self._log.set_status("Done", False)
                log(
                    f"✓ All done! {len(selected_fws)} version(s): "
                    + ", ".join(selected_fws)
                )
                self._update_input_chapters_status(
                    checked, "verified", chapters_data, "✓ Done"
                )
                try:
                    import winsound
                    winsound.MessageBeep(winsound.MB_ICONASTERISK)
                except Exception:
                    pass

                # ── Excel update: Rewrite = Done ──
                self._update_excel_rewrite(group_path)

            except Exception as e:
                log(f"Error: {e}")
                self._log.set_status("Error", True)
                self._update_input_chapters_status(
                    checked, "error", chapters_data, str(e)[:50]
                )
                try:
                    import winsound
                    winsound.MessageBeep(winsound.MB_ICONHAND)
                except Exception:
                    pass
            finally:
                if not job:
                    self._running = False

        if job:
            _run()  # ThreadPoolExecutor handles threading
        else:
            threading.Thread(target=_run, daemon=True).start()

    def _extract_video_id_from_path(self, folder_path):
        """Extract video ID from folder name. Supports [videoID] bracket format."""
        import re
        folder_name = os.path.basename(folder_path)
        # Try bracket format: [videoID]
        m = re.search(r'\[([A-Za-z0-9_-]+)\]', folder_name)
        if m:
            return m.group(1)
        # Fallback: 11 chars after STT_
        m = re.match(r'^\d{3,}_', folder_name)
        if m:
            rest = folder_name[m.end():]
            if len(rest) >= 11:
                candidate = rest[:11]
                after = rest[11:12] if len(rest) > 11 else ""
                if after in ('_', '') and re.match(r'^[A-Za-z0-9_-]+$', candidate):
                    return candidate
        return ""

    def _update_excel_rewrite(self, group_path):
        """Update Excel Rewrite column after successful rewrite."""
        if not self._chk_excel_update.isChecked():
            return
        video_id = self._extract_video_id_from_path(group_path)
        log_fn = lambda m: self._log.log(f"[Excel] {m}")
        if not video_id:
            log_fn("Could not extract video ID from folder name")
            return
        yt_cfg = load_config("youtube_config")
        excel_folder = yt_cfg.get("excel_folder", "") if yt_cfg else ""
        if not excel_folder:
            log_fn("Excel folder not set in YouTube config")
            return
        excel_path = find_excel_for_video_id(excel_folder, video_id)
        if not excel_path:
            log_fn(f"No Excel entry found for {video_id}")
            return
        try:
            update_excel_rewrite_status(excel_path, video_id, log_cb=log_fn)
            log_fn(f"✅ Rewrite = Done ({os.path.basename(excel_path)})")
        except PermissionError:
            log_fn(f"⚠ Excel is locked — Rewrite status not updated")

    # ── Review Pipeline (separate from narrative) ──────────────────

    def _do_renew_review(self, job=None):
        """Review pipeline: extract → recommend → check → convert → outline → write → verify."""
        checked = job["checked"] if job else self._get_checked_chapters()
        if not checked:
            log("No chapters selected")
            return
        output_dir = (job.get("_cached_output_dir") if job else None) or self._resolve_output_dir(checked[0]["filepath"])
        if not output_dir:
            return

        # Use cached style JSON from job (Auto Pipeline) or load from widget
        if job and job.get("_cached_style_raw"):
            style_json_raw = job["_cached_style_raw"]
            style_info = job.get("_cached_style_info", "auto")
        else:
            style_json_raw, style_info = self._load_style_json_raw()
        if style_json_raw is None:
            if _log_callback:
                _log_callback(f"[Review] ✗ {style_info}")
            else:
                self._log.log(f"[Review] ✗ {style_info}")
            return

        try:
            style_data = json.loads(style_json_raw)
            _niche = (style_data.get("niche", "") or "").lower()
            framework_names = [
                fw.get("name", "") for fw in style_data.get("frameworks", [])
                if fw.get("enabled", True)
            ]
        except (json.JSONDecodeError, AttributeError):
            _niche = ""
            framework_names = []

        if not framework_names:
            log("✗ No frameworks found in style guide")
            return

        group_path = job["group_path"] if job else self._group_path
        stop_event = job["stop_event"] if job else None
        log_prefix = job["log_prefix"] if job else "[Review]"
        if not job:
            self._running = True
        # Use cached values from job dict (thread-safe) or read from widgets
        tier = job.get("_cached_tier", self._combo_tier.currentText().lower()) if job else self._combo_tier.currentText().lower()
        log_api = False
        lang = job.get("_cached_lang", self._get_lang_code()) if job else self._get_lang_code()
        target_country = job.get("_cached_country", self._combo_country.currentText()) if job else self._combo_country.currentText()
        user_framework = job.get("_cached_framework", self._combo_framework.currentText()) if job else self._combo_framework.currentText()
        _log_callback = job.get("_log_callback") if job else None
        # Auto-dual: enabled when called from Auto Pipeline OR when user selects "Auto" in Style Rewrite
        _auto_dual = (job.get("_auto_dual", False) if job else False) or user_framework == "Auto (detect & switch)"

        # Cached word count / chapter count / transitions (thread-safe)
        if job:
            _wc_cache = {
                "open": job.get("_cached_wc_open", (0, 0)),
                "body": job.get("_cached_wc_body", (0, 0)),
                "end": job.get("_cached_wc_end", (0, 0)),
            }
            _ch_min = job.get("_cached_ch_min", 0)
            _ch_max = job.get("_cached_ch_max", 0)
            _use_transitions = job.get("_cached_transitions", True)
        else:
            _wc_cache = {
                "open": (self._wc_open_min.value(), self._wc_open_max.value()),
                "body": (self._wc_body_min.value(), self._wc_body_max.value()),
                "end": (self._wc_end_min.value(), self._wc_end_max.value()),
            }
            _ch_min = self._ch_min.value()
            _ch_max = self._ch_max.value()
            _use_transitions = self._chk_transitions.isChecked()

        def _get_wc_rule(section="body"):
            wc_min, wc_max = _wc_cache.get(section, _wc_cache["body"])
            return build_word_count_rule(wc_min, wc_max)

        def _get_ch_range():
            if _ch_min > 0 and _ch_max > 0:
                return f"between {_ch_min} and {_ch_max} chapters"
            elif _ch_min > 0:
                return f"at least {_ch_min} chapters"
            elif _ch_max > 0:
                return f"at most {_ch_max} chapters"
            return "a suitable number of chapters"

        if _log_callback:
            _log_callback(
                f"{log_prefix} Starting review: {len(checked)} input(s), "
                f"style={style_info}, country={target_country}"
            )
        else:
            self._log.log(
                f"{log_prefix} Starting review: {len(checked)} input(s), "
                f"style={style_info}, country={target_country}"
            )
            self._log.set_status(f"{log_prefix} starting...", False)

        def _run():
            nonlocal output_dir  # May be reassigned in dual-framework mode
            # Per-job stop check
            def _stopped():
                if stop_event and stop_event.is_set():
                    return True
                return self._stop_flag
            if not job:
                self._stop_flag = False

            def _update_job_progress(text):
                if job:
                    job["progress"] = text
                    self.job_update.emit()

            # Log wrapper: forward to Auto tab if available, else Style Rewrite tab
            def log(m):
                if _log_callback:
                    _log_callback(f"{log_prefix} {m}")
                else:
                    self._log.log(f"{log_prefix} {m}")

            try:
                endpoints = load_api_keys()
                chapters_data = self._status.setdefault("chapters", {})

                # Validate unused chapters folder (required in manual mode only)
                if not job:
                    unused_dir_check = self._txt_unused_dir.text().strip()
                    if not unused_dir_check:
                        log("⛔ Chưa chọn thư mục Unused chapters. Vui lòng chọn trước khi chạy.")
                        return

                # Mark all input chapters as processing
                self._update_input_chapters_status(
                    checked, "processing", chapters_data, "Step 1/12"
                )
                _update_job_progress("Step 1/12")

                # ── Step 1: Concatenate all text ──
                _cached_full_text = job.get("_cached_full_text") if job else None
                if _cached_full_text:
                    full_text = _cached_full_text
                    log(f"Step 1/12: Using cached text ({len(full_text):,} chars)")
                else:
                    full_text = ""
                    for i, ch in enumerate(checked, 1):
                        full_text += f"\n\n=== PART {i}: {ch['filename']} ===\n{ch['text']}"

                log(f"Step 1/12: Full text {len(full_text):,} chars")
                _update_job_progress("Step 1/12")

                if _stopped():
                    return

                # ── Step 2 & 3: Detect framework + Extract blueprint ──
                _cached_blueprint = job.get("_cached_blueprint") if job else None
                if _cached_blueprint:
                    # v2 path: skip Steps 2-3, reuse shared data from v1
                    blueprint = _cached_blueprint
                    n_products = len(blueprint.get("product_evaluation", []))
                    log(f"Step 2/12: Skipped (using v1 detection)")
                    log(f"Step 3/12: Using cached blueprint ({n_products} products)")
                    os.makedirs(output_dir, exist_ok=True)
                    pipeline_dir = os.path.join(output_dir, "_pipeline")
                    os.makedirs(pipeline_dir, exist_ok=True)
                else:
                    # v1 / standalone path: run Steps 2-3 normally
                    log("Step 2/12: Detecting original framework...")
                    _update_job_progress("Step 2/12")

                    if not _log_callback:
                        self._log.set_status("Review: detecting framework...", False)
                    api_det = APIClient(
                        endpoints, log_api=log_api, tier="flash",
                        stop_check=_stopped
                    )
                    detection = detect_framework(
                        full_text, api_det,
                        log_callback=lambda m: log(m),
                        frameworks_list=style_data.get("frameworks", []),
                    )
                    original_fw = detection.get("detected_framework", "Unknown")
                    fw_confidence = detection.get("confidence", "?")
                    fw_reasoning = detection.get("reasoning", "")
                    log(
                        f"✓ Original framework: '{original_fw}' (confidence: {fw_confidence})"
                    )

                    # Save detection
                    os.makedirs(output_dir, exist_ok=True)
                    pipeline_dir = os.path.join(output_dir, "_pipeline")
                    os.makedirs(pipeline_dir, exist_ok=True)
                    det_path = os.path.join(pipeline_dir, "_detection.json")
                    with open(det_path, "w", encoding="utf-8") as f:
                        json.dump(detection, f, indent=2, ensure_ascii=False)
                    log("📄 Saved: _detection.json")

                    if _stopped():
                        return

                    # ── Step 3: Extract blueprint ──
                    log("Step 3/12: Extracting blueprint...")
                    _update_job_progress("Step 3/12")

                    if not _log_callback:
                        self._log.set_status("Review: extracting blueprint...", False)
                    api_bp = APIClient(
                        endpoints, log_api=log_api, tier=tier,
                        stop_check=_stopped
                    )
                    blueprint = extract_blueprint_review(
                        full_text, api_bp, lang=lang,
                        log_callback=lambda m: log(m),
                        niche=_niche,
                    )

                    n_products = len(blueprint.get("product_evaluation", []))
                    log(
                        f"✓ Blueprint: {n_products} product(s) extracted"
                    )

                    # Save raw blueprint (with source tags)
                    bp_raw_path = os.path.join(pipeline_dir, "_blueprint_raw.json")
                    with open(bp_raw_path, "w", encoding="utf-8") as f:
                        json.dump(blueprint, f, indent=2, ensure_ascii=False)
                    log("📄 Saved: _blueprint_raw.json")

                    if _stopped():
                        return

                # ── Step 4: Recommend framework ──
                if user_framework != "Auto (detect & switch)":
                    selected_fw = user_framework
                    log(f"✓ User selected framework: '{selected_fw}'")
                elif len(framework_names) == 1:
                    # Only 1 framework — auto-select, no popup needed
                    selected_fw = framework_names[0]
                    log(f"✓ Auto-selected (single framework): '{selected_fw}'")
                else:

                    log("Step 4/12: Ranking frameworks...")
                    _update_job_progress("Step 4/12")

                    if not _log_callback:
                        self._log.set_status("Review: ranking frameworks...", False)
                    api_rec = APIClient(
                        endpoints, log_api=log_api, tier="pro",
                        stop_check=_stopped
                    )
                    rec_result = recommend_framework(
                        blueprint, style_data, api_rec, lang=lang,
                        log_callback=lambda m: log(m)
                    )

                    # Build rankings for popup
                    rankings = rec_result.get("rankings", [])

                    # Normalize keys: API may return "framework" or "name", "reasoning" or "reason"
                    for r in rankings:
                        if "framework" in r and "name" not in r:
                            r["name"] = r.pop("framework")
                        if "reasoning" in r and "reason" not in r:
                            r["reason"] = r.pop("reasoning")

                    if not rankings:
                        rankings = [{"name": fw, "score": 5, "reason": "Không có đánh giá"}
                                    for fw in framework_names]

                    # Filter to valid names
                    rankings = [r for r in rankings if r.get("name") in framework_names]
                    if not rankings:
                        rankings = [{"name": fw, "score": 5, "reason": "Không có đánh giá"}
                                    for fw in framework_names]

                    rankings.sort(key=lambda x: x.get("score", 0), reverse=True)

                    # Save rankings
                    rank_path = os.path.join(pipeline_dir, "_rankings.json")
                    with open(rank_path, "w", encoding="utf-8") as f:
                        json.dump(rec_result, f, indent=2, ensure_ascii=False)
                    log("📄 Saved: _rankings.json")

                    log(
                        "[Review] Ranking: "
                        + ", ".join(f"{r['name']}={r.get('score', '?')}" for r in rankings[:5])
                    )

                    # ── Auto-dual mode: auto-select top 2, #2 only if score >= 8.5 ──
                    _SCORE_THRESHOLD = 8.5
                    if _auto_dual and len(rankings) >= 2:
                        selected_fw = rankings[0]["name"]
                        v2_score = rankings[1].get("score", 0)
                        if v2_score >= _SCORE_THRESHOLD:
                            top2 = [rankings[0]["name"], rankings[1]["name"]]
                            log(f"✓ Auto-dual: selected top 2 → {top2[0]} & {top2[1]}")
                        else:
                            top2 = [selected_fw]
                            log(f"✓ Auto: selected → {selected_fw}")
                            log(f"  ⊘ Skipped v2: '{rankings[1]['name']}' (score={v2_score} < {_SCORE_THRESHOLD})")
                    elif _auto_dual:
                        selected_fw = rankings[0]["name"]
                        log(f"✓ Auto: selected → {selected_fw}")
                    else:
                        # Show popup for user selection
                        self._fw_ranking_event.clear()
                        self._fw_ranking_result = None
                        fw_info_json = json.dumps({
                            "name": original_fw,
                            "confidence": fw_confidence,
                            "reasoning": fw_reasoning
                        }, ensure_ascii=False)
                        self._fw_ranking_request.emit(rankings, fw_info_json)
                        self._fw_ranking_event.wait()

                        if self._fw_ranking_result is None:
                            log("✗ User cancelled framework selection")
                            if not _log_callback:
                                self._log.set_status("Cancelled", True)
                            return

                        selected_fw = self._fw_ranking_result
                        log(f"✓ User selected: '{selected_fw}'")
                if _stopped():
                    return

                # Store top2 for dual-framework second pass
                _dual_second_fw = None
                if _auto_dual and 'top2' in dir() and len(top2) >= 2:
                    _dual_second_fw = top2[1]

                # ── Start v2 in parallel thread (before Step 5) ──
                if _dual_second_fw and not _stopped():
                    import re as _re_mod
                    import threading as _th
                    log(f"\n{'='*50}")
                    log(f"🔄 Dual-framework: v1={selected_fw}, v2={_dual_second_fw}")
                    log(f"{'='*50}")

                    # Create v1 subfolder and redirect output_dir
                    safe_fw1 = _re_mod.sub(r'[<>:"/\\|?*]', '', selected_fw)[:40]
                    # Look up ranking scores for directory suffix
                    _score_map = {r["name"]: r.get("score", 0) for r in rankings} if 'rankings' in dir() else {}
                    _s1 = _score_map.get(selected_fw, 0)
                    _s1_suffix = f"_{_s1}" if _s1 else ""
                    v1_dir = os.path.join(output_dir, f"v1_{safe_fw1}{_s1_suffix}")
                    os.makedirs(v1_dir, exist_ok=True)

                    # Create v2 subfolder
                    safe_fw2 = _re_mod.sub(r'[<>:"/\\|?*]', '', _dual_second_fw)[:40]
                    _s2 = _score_map.get(_dual_second_fw, 0)
                    _s2_suffix = f"_{_s2}" if _s2 else ""
                    v2_dir = os.path.join(output_dir, f"v2_{safe_fw2}{_s2_suffix}")
                    os.makedirs(v2_dir, exist_ok=True)

                    # Redirect v1 output and metadata to its subfolder
                    output_dir = v1_dir
                    pipeline_dir = os.path.join(v1_dir, "_pipeline")
                    os.makedirs(pipeline_dir, exist_ok=True)

                    # Build v2 job — use existing job or create minimal one for manual mode
                    if job:
                        v2_job = dict(job)
                    else:
                        v2_job = {
                            "id": f"manual_v2_{id(self)}",
                            "checked": checked,
                            "group_path": group_path,
                            "mode": "Top/List Review",
                            "status": "running",
                            "progress": "v2...",
                            "log_prefix": "[Review-v2]",
                            "_cached_tier": tier,
                            "_cached_lang": lang,
                            "_cached_country": target_country,
                            "_cached_style_raw": style_json_raw,
                            "_cached_style_info": style_info,
                            "_cached_google_check": self._chk_google_check.isChecked(),
                            "_cached_transitions": _use_transitions,
                            "_cached_ch_min": _ch_min,
                            "_cached_ch_max": _ch_max,
                            "_cached_wc_open": _wc_cache["open"],
                            "_cached_wc_body": _wc_cache["body"],
                            "_cached_wc_end": _wc_cache["end"],
                        }
                    v2_job["_auto_dual"] = False  # Prevent recursion
                    v2_job["_cached_framework"] = _dual_second_fw
                    v2_job["_cached_output_dir"] = v2_dir
                    v2_job["log_prefix"] = f"[Review-v2]"
                    # v2 gets its own stop_event (independent of v1 completion)
                    v2_stop = _th.Event()
                    v2_job["stop_event"] = v2_stop
                    # Pass shared data so v2 skips Steps 1-3
                    import copy as _copy
                    v2_job["_cached_full_text"] = full_text
                    v2_job["_cached_blueprint"] = _copy.deepcopy(blueprint)
                    v2_job["_cached_niche"] = _niche

                    _v2_thread = _th.Thread(
                        target=self._do_renew_review,
                        kwargs={"job": v2_job},
                        daemon=True,
                    )
                    _v2_thread.start()
                    log(f"✓ v2 thread started — both pipelines running in parallel")

                # Get the selected framework dict
                selected_fw_dict = None
                for fw in style_data.get("frameworks", []):
                    if fw.get("name") == selected_fw:
                        selected_fw_dict = fw
                        break

                # ── Step 5: Reality check blueprint ──
                log(
                    f"Step 5/12: Reality-checking blueprint "
                    f"(framework: {selected_fw})..."
                )
                _update_job_progress("Step 5/12")
                if not _log_callback:
                    self._log.set_status("Review: verifying & enriching data...", False)
                api_rc = APIClient(
                    endpoints, log_api=log_api, tier="flash",
                    stop_check=_stopped
                )
                try:
                    rc_result = reality_check_blueprint(
                        blueprint, api_rc, lang=lang,
                        log_callback=lambda m: log(m),
                        niche=_niche,
                    )

                    # Save full verification result
                    rc_path = os.path.join(pipeline_dir, "_reality_check.json")
                    verification = rc_result.get("verification", rc_result)
                    with open(rc_path, "w", encoding="utf-8") as f:
                        json.dump(verification, f, indent=2, ensure_ascii=False)
                    log("📄 Saved: _reality_check.json")

                    # ── Apply verification results to blueprint programmatically ──
                    # Step A: Strip source tags
                    blueprint = self._strip_source_tags(blueprint)

                    # Step B: Apply corrections from ai_knowledge_checks
                    products = blueprint.get("product_evaluation", [])
                    n_corrections = 0
                    n_enriched = 0
                    for vp in verification.get("products", []):
                        vp_name = vp.get("product_name", "")
                        # Find matching product in blueprint
                        bp_prod = None
                        for p in products:
                            pn = p.get("product_name", p.get("name", ""))
                            if pn and vp_name and pn.lower() == vp_name.lower():
                                bp_prod = p
                                break
                        if not bp_prod:
                            continue

                        # Apply corrections
                        for chk in vp.get("ai_knowledge_checks", []):
                            if chk.get("verified") is False and chk.get("correct_value"):
                                field = chk.get("field", "")
                                correct = chk["correct_value"]
                                if field and field in bp_prod:
                                    bp_prod[field] = correct
                                    n_corrections += 1
                                else:
                                    # Try nested: field could be dot-notation
                                    parts = field.split(".")
                                    target = bp_prod
                                    for part in parts[:-1]:
                                        if isinstance(target, dict) and part in target:
                                            target = target[part]
                                        else:
                                            target = None
                                            break
                                    if target and isinstance(target, dict) and parts[-1] in target:
                                        target[parts[-1]] = correct
                                        n_corrections += 1

                        # Apply enrichments
                        for enr in vp.get("enriched_data", []):
                            field = enr.get("field", "")
                            value = enr.get("value", "")
                            if field and value:
                                if field not in bp_prod or not bp_prod[field]:
                                    bp_prod[field] = value
                                    n_enriched += 1
                                else:
                                    # Try nested
                                    parts = field.split(".")
                                    target = bp_prod
                                    for part in parts[:-1]:
                                        if isinstance(target, dict) and part in target:
                                            target = target[part]
                                        elif isinstance(target, dict):
                                            target[part] = {}
                                            target = target[part]
                                        else:
                                            target = None
                                            break
                                    if target and isinstance(target, dict):
                                        if parts[-1] not in target or not target[parts[-1]]:
                                            target[parts[-1]] = value
                                            n_enriched += 1

                    # Save cleaned + corrected blueprint
                    bp_path = os.path.join(pipeline_dir, "_blueprint.json")
                    with open(bp_path, "w", encoding="utf-8") as f:
                        json.dump(blueprint, f, indent=2, ensure_ascii=False)
                    log(f"📄 Saved: _blueprint.json (stripped, {n_corrections} corrections, {n_enriched} enrichments)")

                    # Export to CSV
                    csv_path = os.path.join(pipeline_dir, "_reality_check.csv")
                    with open(csv_path, "w", encoding="utf-8-sig", newline="") as cf:
                        writer = csv.writer(cf)
                        writer.writerow([
                            "Product", "Type", "Field",
                            "AI Value", "Verified", "Correct Value", "Issue Type"
                        ])
                        for prod in verification.get("products", []):
                            pname = prod.get("product_name", "?")
                            for chk in prod.get("ai_knowledge_checks", []):
                                writer.writerow([
                                    pname, "AI_CHECK",
                                    chk.get("field", ""),
                                    chk.get("ai_value", ""),
                                    chk.get("verified", ""),
                                    chk.get("correct_value", ""),
                                    chk.get("issue_type", "")
                                ])
                            for fa in prod.get("enriched_data", []):
                                writer.writerow([
                                    pname, "ENRICHED",
                                    fa.get("field", ""),
                                    fa.get("value", ""),
                                    fa.get("confidence", ""),
                                    "", ""
                                ])
                    log("📄 Saved: _reality_check.csv")

                    # Log summary
                    assessment = verification.get("overall_assessment", {})
                    n_fudd = assessment.get("fudd_lore_found", assessment.get("myths_found", 0))
                    n_anac = assessment.get("anachronisms_found", 0)
                    log(
                        f"✓ Reality check: "
                        f"{n_fudd} myths/Fudd-lore, {n_anac} anachronisms, "
                        f"{n_corrections} corrected, {n_enriched} enriched"
                    )

                except Exception as e:
                    log(f"⚠️ Reality check failed (non-fatal): {e}")
                    log("Stripping source tags and continuing...")
                    blueprint = self._strip_source_tags(blueprint)
                    bp_path = os.path.join(pipeline_dir, "_blueprint.json")
                    with open(bp_path, "w", encoding="utf-8") as f:
                        json.dump(blueprint, f, indent=2, ensure_ascii=False)

                if _stopped():
                    return

                # Niche detection for spec/price steps
                _SPEC_NICHES = {"gun", "firearm", "ammo", "ammunition",
                                 "weapon", "rifle", "pistol", "shotgun",
                                 "súng", "đạn", "vũ khí",
                                 "military", "quân sự", "thiết bị"}
                _PRICE_NICHES = {"gun", "firearm", "ammo", "ammunition",
                                 "weapon", "rifle", "pistol", "shotgun",
                                 "súng", "đạn", "vũ khí"}
                _niche_words = set(_niche.lower().split())
                _is_spec_niche = bool(_niche_words & _SPEC_NICHES)
                _is_price_niche = bool(_niche_words & _PRICE_NICHES)

                # ── Step 5a+5b+5c: Google Check + Enrich ──
                _google_check_enabled = job.get("_cached_google_check", self._chk_google_check.isChecked()) if job else self._chk_google_check.isChecked()

                from concurrent.futures import ThreadPoolExecutor as _TPE, as_completed
                import threading as _threading

                _google_tasks = []
                _bp_write_lock = _threading.Lock()

                # Step 5a: Spec verify — only when Google Check ON + spec niche
                if _google_check_enabled and _is_spec_niche:
                    def _run_spec_verify():
                        """Step 5a: Spec verification via Google Search."""
                        gemini_keys_5a = load_gemini_keys()
                        if not gemini_keys_5a:
                            return
                        log("Step 5a: Verifying specs via Google Search...")
                        try:
                            spec_result = verify_specs_google(
                                blueprint, gemini_keys_5a,
                                lang=lang,
                                log_callback=lambda m: log(m),
                                stop_check=_stopped,
                            )
                            if spec_result:
                                spec_path = os.path.join(pipeline_dir, "_spec_verification.json")
                                with open(spec_path, "w", encoding="utf-8") as f:
                                    json.dump(spec_result, f, indent=2, ensure_ascii=False)
                                log("📄 Saved: _spec_verification.json")
                        except Exception as e:
                            log(f"⚠️ Spec verification failed (non-fatal): {e}")
                    _google_tasks.append(_run_spec_verify)

                # Step 5b: Price enrich — only when Google Check ON + price niche
                if _google_check_enabled and _is_price_niche:
                    def _run_price_enrich():
                        """Step 5b: Price enrichment via Google Search."""
                        gemini_keys_5b = load_gemini_keys()
                        if not gemini_keys_5b:
                            log("⚠ Google Check enabled but no Gemini API keys — skipping prices")
                            return
                        log("Step 5b: Enriching prices via Google Search...")
                        try:
                            price_result = enrich_prices_google(
                                blueprint, gemini_keys_5b,
                                lang=lang,
                                log_callback=lambda m: log(m),
                                stop_check=_stopped,
                            )
                            pe_path = os.path.join(pipeline_dir, "_price_enrichment.json")
                            with open(pe_path, "w", encoding="utf-8") as f:
                                json.dump(price_result, f, indent=2, ensure_ascii=False)
                            log("📄 Saved: _price_enrichment.json")

                            with _bp_write_lock:
                                bp_path = os.path.join(pipeline_dir, "_blueprint.json")
                                with open(bp_path, "w", encoding="utf-8") as f:
                                    json.dump(blueprint, f, indent=2, ensure_ascii=False)
                            log(f"✓ Price enrichment: {price_result.get('price_summary', '?')}")
                        except Exception as e:
                            log(f"⚠️ Price enrichment failed (non-fatal): {e}")
                    _google_tasks.append(_run_price_enrich)

                # Step 5c: Blueprint enrich — ALWAYS runs
                # Google Check ON → Google Search, OFF → AI knowledge
                def _run_blueprint_enrich():
                    """Step 5c: Blueprint enrichment (always runs)."""
                    gemini_keys_5c = load_gemini_keys()
                    if not gemini_keys_5c:
                        log("⚠ No Gemini API keys — skipping enrichment")
                        return
                    _src = "Google Search" if _google_check_enabled else "AI knowledge"
                    log(f"Step 5c: Enriching blueprint via {_src}...")
                    try:
                        enrich_result = enrich_blueprint_google(
                            blueprint, gemini_keys_5c,
                            niche=_niche,
                            lang=lang,
                            log_callback=lambda m: log(m),
                            stop_check=_stopped,
                            use_google_search=_google_check_enabled,
                            api_endpoints=endpoints,
                        )
                        er_path = os.path.join(pipeline_dir, "_enrichment.json")
                        with open(er_path, "w", encoding="utf-8") as f:
                            json.dump(enrich_result, f, indent=2, ensure_ascii=False)
                        log("📄 Saved: _enrichment.json")

                        if enrich_result.get("fields_filled", 0) > 0:
                            with _bp_write_lock:
                                bp_path = os.path.join(pipeline_dir, "_blueprint.json")
                                with open(bp_path, "w", encoding="utf-8") as f:
                                    json.dump(blueprint, f, indent=2, ensure_ascii=False)
                            log(f"✓ Blueprint enriched: {enrich_result['fields_filled']} field(s) filled")
                    except Exception as e:
                        log(f"⚠️ Blueprint enrichment failed (non-fatal): {e}")
                _google_tasks.append(_run_blueprint_enrich)

                # Step 5d: Rhetoric transform — generate alternative rhetoric
                def _run_rhetoric_transform():
                    """Step 5d: Transform original rhetoric into culturally-adapted alternatives."""
                    gemini_keys_5d = load_gemini_keys()
                    log(f"Step 5d: Transforming rhetoric for {target_country}...")
                    try:
                        rt_result = transform_rhetoric(
                            blueprint,
                            niche=_niche,
                            lang=lang,
                            target_country=target_country,
                            log_callback=lambda m: log(m),
                            stop_check=_stopped,
                            api_endpoints=endpoints,
                            gemini_keys=gemini_keys_5d,
                        )
                        rt_path = os.path.join(pipeline_dir, "_rhetoric_transform.json")
                        with open(rt_path, "w", encoding="utf-8") as f:
                            json.dump(rt_result, f, indent=2, ensure_ascii=False)
                        log("📄 Saved: _rhetoric_transform.json")

                        if rt_result.get("products_transformed", 0) > 0:
                            with _bp_write_lock:
                                bp_path = os.path.join(pipeline_dir, "_blueprint.json")
                                with open(bp_path, "w", encoding="utf-8") as f:
                                    json.dump(blueprint, f, indent=2, ensure_ascii=False)
                            log(f"✓ Rhetoric: {rt_result['products_transformed']} product(s) transformed")
                    except Exception as e:
                        log(f"⚠️ Rhetoric transform failed (non-fatal): {e}")
                _google_tasks.append(_run_rhetoric_transform)

                _update_job_progress("Step 5: Enrich data")
                if not _log_callback:
                    self._log.set_status("Review: enriching data...", False)

                with _TPE(max_workers=min(3, len(_google_tasks)),
                          thread_name_prefix="gcheck") as vpool:
                    futs = [vpool.submit(fn) for fn in _google_tasks]
                    for fut in as_completed(futs):
                        try:
                            fut.result()
                        except Exception:
                            pass

                log("✓ Step 5 complete")

                if _stopped():
                    return


                # ── Step 6: Check blueprint completeness ──
                if selected_fw_dict:
                    log("Step 6/12: Checking blueprint completeness...")
                    _update_job_progress("Step 6/12")

                    if not _log_callback:
                        self._log.set_status("Review: checking data...", False)
                    api_chk = APIClient(
                        endpoints, log_api=log_api, tier="flash",
                        stop_check=_stopped
                    )
                    check_result = check_blueprint(
                        blueprint, selected_fw_dict, api_chk, lang=lang,
                        log_callback=lambda m: log(m),
                        niche=_niche,
                    )

                    status_str = check_result.get("overall_status", "UNKNOWN")
                    log(f"✓ Data completeness: {status_str}")
                    # Save check result
                    chk_path = os.path.join(pipeline_dir, "_completeness_check.json")
                    with open(chk_path, "w", encoding="utf-8") as f:
                        json.dump(check_result, f, indent=2, ensure_ascii=False)
                    log("📄 Saved: _completeness_check.json")

                    if status_str == "INSUFFICIENT":
                        self._log.log(
                            "[Review] ⚠ Blueprint data is insufficient for this framework. "
                            "Continuing anyway — results may have gaps."
                        )
                else:
                    log("Step 6/12: Skipped (framework dict not found)")
                    _update_job_progress("Step 6/12")


                if _stopped():
                    return

                # ── Step 7: Convert units ──
                log(f"Step 7/12: Converting units for {target_country}...")
                _update_job_progress("Step 7/12")

                blueprint = convert_units(blueprint, target_country, style_data=style_data)
                if style_data and style_data.get("units"):
                    log(f"✓ Units: using style-defined system (skipped auto-conversion)")
                else:
                    log(f"✓ Units converted to {target_country}")
                # Save converted blueprint
                bp_conv_path = os.path.join(pipeline_dir, "_blueprint_converted.json")
                with open(bp_conv_path, "w", encoding="utf-8") as f:
                    json.dump(blueprint, f, indent=2, ensure_ascii=False)

                if _stopped():
                    return

                # ── Step 8-9: Create review outline + Audit ──
                _resume_mode = job.get("_resume_mode", False) if job else False
                _cached_audited_outline = None
                if _resume_mode:
                    _audited_path = os.path.join(pipeline_dir, "_review_outline_audited.json")
                    if os.path.isfile(_audited_path):
                        try:
                            with open(_audited_path, "r", encoding="utf-8") as _f:
                                _cached_audited_outline = json.load(_f)
                        except Exception:
                            _cached_audited_outline = None

                if _cached_audited_outline:
                    # Resume: load cached audited outline, skip steps 8-9
                    outline = _cached_audited_outline
                    out_chapters = outline.get("chapters", [])
                    total = len(out_chapters)
                    log(f"Step 8/12: ⏭ Cached outline ({total} chapters)")
                    log(f"Step 9/12: ⏭ Cached audit")
                    _update_job_progress("Step 9/12")
                else:
                    # Normal: run steps 8-9
                    log(f"Step 8/12: Creating outline with '{selected_fw}'...")
                    _update_job_progress("Step 8/12")

                    if not _log_callback:
                        self._log.set_status(f"Review: outline ({selected_fw})...", False)
                    api_out = APIClient(
                        endpoints, log_api=log_api, tier=tier,
                        stop_check=_stopped
                    )

                    # Detect niche to choose outline function
                    _is_mystery = "mystery" in _niche or "bí ẩn" in _niche

                    if _is_mystery:
                        # Mystery history: no product shuffling needed
                        log(f"[Mystery] Using mystery outline for niche '{_niche}'")
                        outline = create_review_outline(
                            blueprint, style_data, selected_fw, api_out,
                            lang=lang,
                            chapter_range=_get_ch_range(),
                            log_callback=lambda m: log(m),
                            niche=_niche,
                        )
                    else:
                        # Product review: shuffle products & strip ordering clues
                        import random
                        outline_blueprint = json.loads(json.dumps(blueprint))  # deep copy
                        products_for_outline = outline_blueprint.get("product_evaluation", [])
                        random.shuffle(products_for_outline)
                        # Strip per-product fields that create ordering chains
                        for prod in products_for_outline:
                            prod.pop("comparisons", None)
                            prod.pop("narrative_moments", None)
                            prod.pop("source_parts", None)
                            vp = prod.get("value_proposition", {})
                            if isinstance(vp, dict):
                                vp.pop("comparison_value", None)
                        outline_blueprint["product_evaluation"] = products_for_outline
                        # Strip top-level ordering hints
                        outline_blueprint.pop("original_order", None)
                        outline_blueprint.pop("ranking_criteria", None)
                        outline_blueprint.pop("key_claims", None)
                        log(f"✓ Shuffled {len(products_for_outline)} products, stripped ordering clues")
                        outline = create_review_outline(
                            outline_blueprint, style_data, selected_fw, api_out,
                            lang=lang,
                            chapter_range=_get_ch_range(),
                            log_callback=lambda m: log(m),
                            niche=_niche,
                        )

                    out_chapters = outline.get("chapters", [])
                    total = len(out_chapters)
                    log(f"✓ Outline: {total} chapters")
                    # Save outline
                    outline_path = os.path.join(pipeline_dir, "_review_outline.json")
                    with open(outline_path, "w", encoding="utf-8") as f:
                        json.dump(outline, f, indent=2, ensure_ascii=False)
                    log("📄 Saved: _review_outline.json")

                    # Post-process: remove hook/end chapters when their wc = SKIP
                    _skip_open = _get_wc_rule("open") == "SKIP"
                    _skip_end = _get_wc_rule("end") == "SKIP"
                    if _skip_open or _skip_end:
                        filtered = []
                        removed = []
                        for ch in out_chapters:
                            ct = ch.get("chapter_type", "body")
                            if _skip_open and ct == "hook":
                                removed.append("hook")
                                continue
                            if _skip_end and ct == "end":
                                removed.append("end")
                                continue
                            filtered.append(ch)
                        if removed:
                            out_chapters = filtered
                            outline["chapters"] = out_chapters
                            total = len(out_chapters)
                            log(f"✂ Removed {', '.join(removed)} chapter(s) (wc=SKIP) → {total} chapters")

                    if _stopped() or total == 0:
                        return

                    # ── Step 9: Audit outline ──
                    log("Step 9/12: Auditing outline...")
                    _update_job_progress("Step 9/12")

                    if not _log_callback:
                        self._log.set_status("Review: auditing outline...", False)
                    api_audit = APIClient(
                        endpoints, log_api=log_api, tier="flash",
                        stop_check=_stopped
                    )
                    audit_result = audit_outline_review(
                        blueprint, outline, selected_fw_dict or {}, style_json_raw, api_audit,
                        chapter_range=_get_ch_range(),
                        log_callback=lambda m: log(m),
                        niche=_niche,
                    )
                    # audit_outline_review now returns the outline directly
                    # (falls back to original outline on JSON parse error)
                    audited_outline = audit_result

                    # Always update to audited version (may be same as original if no issues)
                    outline = audited_outline
                    out_chapters = outline.get("chapters", [])
                    total = len(out_chapters)
                    audited_path = os.path.join(pipeline_dir, "_review_outline_audited.json")
                    with open(audited_path, "w", encoding="utf-8") as f:
                        json.dump(outline, f, indent=2, ensure_ascii=False)
                    log(f"📄 Saved audited outline ({total} chapters)")

                if _stopped() or total == 0:
                    return

                # Filter blueprint to only include products selected in outline
                selected_products = set()
                for ch in out_chapters:
                    for p in ch.get("products_covered", []):
                        selected_products.add(p)
                if selected_products:
                    writer_blueprint = json.loads(json.dumps(blueprint))
                    writer_blueprint["product_evaluation"] = [
                        p for p in writer_blueprint.get("product_evaluation", [])
                        if p.get("product_name") in selected_products
                    ]
                    writer_blueprint.pop("original_order", None)
                    writer_blueprint.pop("ranking_criteria", None)
                    writer_blueprint.pop("key_claims", None)
                    # Strip source_parts from writer blueprint
                    for wp in writer_blueprint.get("product_evaluation", []):
                        wp.pop("source_parts", None)
                    log(
                        f"✓ Filtered blueprint: {len(selected_products)} products for writer"                    )
                else:
                    writer_blueprint = blueprint

                # ── Unused chapters detection (copy deferred to end) ──
                unused_product_names = set()
                _unused_bp_product_lookup = {}
                if selected_products:
                    all_bp_products = blueprint.get("product_evaluation", [])
                    all_product_names = {p.get("product_name") for p in all_bp_products}
                    unused_product_names = all_product_names - selected_products

                    if unused_product_names:
                        log(f"⚠ {len(unused_product_names)} unused product(s): {', '.join(sorted(unused_product_names))}")

                    # Helper: map product → source chapter (source_parts first, text fallback)
                    def _find_source_chapter(product_dict, product_name):
                        """Find source chapter for a product using source_parts or text match."""
                        source_parts = product_dict.get("source_parts", [])
                        if source_parts:
                            import re
                            for sp in source_parts:
                                m = re.search(r'(\d+)', sp)
                                if m:
                                    idx = int(m.group(1)) - 1
                                    if 0 <= idx < len(checked):
                                        return checked[idx]
                        # Fallback: text matching
                        for ch in checked:
                            if product_name.lower() in ch.get("text", "").lower():
                                return ch
                        return None

                    # Build lookup for later use
                    _unused_bp_product_lookup = {
                        p.get("product_name"): p for p in all_bp_products
                    }

                    # Multi-folder check for merge mode (early exit)
                    is_merge = job and job.get("merged_groups")
                    if is_merge:
                        used_folders = set()
                        for pname in sorted(selected_products):
                            pd = _unused_bp_product_lookup.get(pname, {})
                            ch = _find_source_chapter(pd, pname)
                            if ch:
                                used_folders.add(ch.get("group", ""))
                        if len(used_folders) < 2:
                            log("⚠ Merge cảnh báo: Tất cả items được chọn đều từ 1 nguồn. "
                                "Merge không có ý nghĩa — hãy chạy riêng folder đó.")
                            log("⛔ Dừng pipeline.")
                            return

                if _stopped():
                    return

                # ── Step 10: Write each chapter ──
                log(f"Step 10/12: Writing {total} chapters...")
                _update_job_progress("Step 10/12")

                if not _log_callback:
                    self._log.set_status("Review: writing chapters...", False)
                rewritten_texts = []
                out_filenames = []
                chapter_titles = []
                outline_json_str = json.dumps(
                    outline, indent=2, ensure_ascii=False
                )

                for i, ch_outline in enumerate(out_chapters):
                    if _stopped():
                        break

                    # Filename: hook→Intro, end→Outro_CTA, body→product name
                    ch_type = ch_outline.get("chapter_type", "body")
                    if ch_type == "hook":
                        raw_name = "Intro"
                    elif ch_type == "end":
                        raw_name = "Outro_CTA"
                    else:
                        # Use product name for body; fall back to title
                        prods = ch_outline.get("products_covered", [])
                        if prods and len(prods) <= 2:
                            raw_name = " vs ".join(prods) if len(prods) == 2 else prods[0]
                        else:
                            raw_name = ch_outline.get("title", f"chapter_{i+1}")
                    safe_title = "".join(
                        c if c.isalnum() or c in " _-" else "_"
                        for c in raw_name
                    ).strip().replace(" ", "_")[:60]
                    out_fname = f"ch_{i+1:02d}_{safe_title}.txt"

                    # Word count by position — prioritize chapter_type over position
                    ch_type = ch_outline.get("chapter_type", "body")
                    if ch_type == "hook":
                        wc_section = "open"
                    elif ch_type == "end":
                        wc_section = "end"
                    elif i == 0 and _get_wc_rule("open") != "SKIP":
                        wc_section = "open"
                    elif i == total - 1 and _get_wc_rule("end") != "SKIP":
                        wc_section = "end"
                    else:
                        wc_section = "body"
                    wc_rule = _get_wc_rule(wc_section)

                    # SKIP: if both min/max = 0, skip this chapter
                    if wc_rule == "SKIP":
                        log(f"⏭ Ch.{i+1}/{total}: skipped ({wc_section} = SKIP)")
                        continue

                    # Append filename AFTER skip check to keep indices aligned
                    # with rewritten_texts (which also skips these chapters)
                    out_filenames.append(out_fname)
                    chapter_titles.append(raw_name)

                    # Previous context — end chapter gets ALL chapters for accurate summary
                    prev_context = ""
                    if rewritten_texts:
                        if ch_type == "end":
                            prev_context = "\n---\n".join(rewritten_texts)
                        else:

                            prev_context = "\n---\n".join(rewritten_texts[-2:])

                    try:
                        api_w = APIClient(
                            endpoints, log_api=log_api, tier=tier,
                            stop_check=_stopped
                        )
                        rewritten = write_review_chapter(
                            blueprint=writer_blueprint,
                            style_json=style_json_raw,
                            framework_name=selected_fw,
                            chapter_outline=ch_outline,
                            chapter_number=i + 1,
                            total_chapters=total,
                            api_client=api_w,
                            word_count_rule=wc_rule,
                            lang=lang,
                            previous_context=prev_context,
                            target_country=target_country,
                            full_outline=outline_json_str,
                            log_callback=lambda m: log(m),
                            use_transitions=_use_transitions,
                        )
                        rewritten_texts.append(rewritten)

                        out_path = os.path.join(output_dir, out_fname)
                        with open(out_path, "w", encoding="utf-8") as f:
                            f.write(rewritten)

                        with self._lock:
                            chapters_data[out_fname] = {
                                "status": "rewritten",
                                "rewritten_at": datetime.now().strftime("%Y-%m-%d %H:%M"),
                                "lang": lang,
                                "rewrite_mode": "review",
                                "framework": selected_fw,
                                "target_country": target_country,
                                "output_file": out_fname,
                            }
                        self._save_status_safe(group_path)
                        log(f"✓ Ch.{i+1}/{total}: {raw_name}")
                        # Update input chapters progress
                        self._update_input_chapters_status(
                            checked, "writing", chapters_data,
                            f"Ch {i+1}/{total} done"
                        )

                    except Exception as e:
                        rewritten_texts.append("")
                        out_filenames[-1] = ""
                        log(f"✗ Ch.{i+1}/{total}: {e}")
                if _stopped():
                    log("Stopped")
                    return

                # ── Post-write validation: duplicate/missing check ──
                written_ok = [i for i, t in enumerate(rewritten_texts) if t]
                written_fail = [i for i, t in enumerate(rewritten_texts) if not t]
                if written_fail:
                    log(
                        f"⚠️ Missing chapters: "                        f"{', '.join(str(i+1) for i in written_fail)}"
                    )
                # Check for duplicate chapter content
                seen_texts = {}
                for i, txt in enumerate(rewritten_texts):
                    if not txt:
                        continue
                    short = txt[:200].strip()
                    for prev_i, prev_short in seen_texts.items():
                        if short == prev_short:
                            log(
                                f"⚠️ DUPLICATE: Ch.{i+1} appears identical to Ch.{prev_i+1}"                            )
                            break
                    seen_texts[i] = short

                # ── Step 11: Cross-chapter review + Patch ──
                log("Step 11/12: Cross-chapter review...")
                _update_job_progress("Step 11/12")

                if not _log_callback:
                    self._log.set_status("Review: reviewing flow & consistency...", False)
                rw_chapters = []
                rw_index_map = []
                for i in range(min(total, len(rewritten_texts))):
                    if rewritten_texts[i]:
                        rw_chapters.append({
                            "filename": out_filenames[i],
                            "text": rewritten_texts[i],
                            "title": chapter_titles[i] if i < len(chapter_titles) else "",
                        })
                        rw_index_map.append(i)

                api_rev = APIClient(
                    endpoints, log_api=log_api, tier=tier,
                    stop_check=_stopped
                )
                # Label chapters with file position to avoid ambiguity
                # (AI may confuse ranking #2 with file position 2)
                labeled_text = "\n\n".join(
                    f"[CHAPTER_FILE {j+1}] {c['filename']}\n{c['text']}"
                    for j, c in enumerate(rw_chapters)
                )
                review_result = review_cross_chapter(
                    labeled_text,
                    api_rev, lang=lang,
                    log_callback=lambda m: log(m),
                    niche=_niche,
                )

                issues = review_result.get("issues", [])
                # When transitions are OFF, filter out transition-related issues
                if not _use_transitions:
                    _before = len(issues)
                    issues = [
                        iss for iss in issues
                        if "transition" not in (iss.get("type", iss.get("issue_type", "")) or "").lower()
                    ]
                    _skipped = _before - len(issues)
                    if _skipped:
                        log(f"  ℹ Skipped {_skipped} transition issue(s) (transitions OFF)")
                _do_patch = job.get("_cached_auto_patch", False) if job else self._chk_auto_patch.isChecked()
                auto_patched = 0
                if _do_patch and issues:
                    for issue in issues:
                        if issue.get("severity") in ("critical", "major"):
                            fc = issue.get("fix_chapter")
                            if not fc:
                                involved = issue.get("chapters_involved", [])
                                if involved:
                                    fc = involved[0]
                            if not fc:
                                continue
                            # Handle case where fc is a list
                            if isinstance(fc, list):
                                fc = fc[0] if fc else None
                            if fc is None:
                                continue
                            try:
                                fix_ch_num = int(fc)
                            except (ValueError, TypeError):
                                continue
                            # Map fix_ch_num (original chapter number) to rw_chapters index
                            original_idx = fix_ch_num - 1  # 0-based in rewritten_texts
                            rw_idx = None
                            for ri, mapped_idx in enumerate(rw_index_map):
                                if mapped_idx == original_idx:
                                    rw_idx = ri
                                    break
                            if rw_idx is not None:
                                full_ctx = "\n\n".join(
                                    f"[CHAPTER_FILE {j+1}] {c['filename']}\n{c['text']}"
                                    for j, c in enumerate(rw_chapters)
                                )
                                api_p = APIClient(
                                    endpoints, log_api=log_api, tier="flash",
                                    stop_check=_stopped
                                )
                                patched = patch_chapter_overlap(
                                    rw_chapters[rw_idx]["text"], issue, full_ctx, api_p,
                                    log_callback=lambda m: log(m)
                                )
                                rw_chapters[rw_idx]["text"] = patched
                                rewritten_texts[rw_index_map[rw_idx]] = patched
                                # Save patched file
                                patched_fname = out_filenames[rw_index_map[rw_idx]]
                                patched_path = os.path.join(output_dir, patched_fname)
                                with open(patched_path, "w", encoding="utf-8") as f:
                                    f.write(patched)
                                auto_patched += 1
                elif issues:
                    _crit = len([i for i in issues if i.get('severity') in ('critical','major')])
                    if _crit:
                        log(f"⚠ {_crit} critical/major issues found — auto-patch OFF, skipping fixes")

                if auto_patched:
                    log(f"✓ Auto-patched {auto_patched} issues")
                flow_score = review_result.get("overall_flow_score", 0)
                issues_remaining = len(issues) - auto_patched
                log(
                    f"✓ Review done! flow={flow_score}, issues_total={len(issues)}, patched={auto_patched}, remaining={issues_remaining}"                )

                # Save review result
                rev_path = os.path.join(pipeline_dir, "_review.json")
                with open(rev_path, "w", encoding="utf-8") as f:
                    json.dump(review_result, f, indent=2, ensure_ascii=False)
                log("📄 Saved: _review.json")

                # ── Step 12: Merge ──
                log("Step 12/12: Merging...")
                _update_job_progress("Step 12/12")

                if rw_chapters:
                    full_path = os.path.join(output_dir, "FULL_SCRIPT.txt")
                    with open(full_path, "w", encoding="utf-8") as f:
                        for j, c in enumerate(rw_chapters):
                            if j > 0:
                                f.write("\n\n" + "=" * 60 + "\n\n")
                            ch_title = c.get("title", "").strip()
                            if not ch_title:
                                ch_title = c['filename'].replace('.txt', '').replace('_', ' ')
                            f.write(f"Chapter {j+1}: {ch_title}\n\n")
                            f.write(c["text"])
                    log(
                        f"✓ Merged → FULL_SCRIPT.txt ({len(rw_chapters)} chapters)"                    )



                if not _log_callback:
                    self._log.set_status("Done", False)
                log(
                    f"✓ Complete! Framework: '{selected_fw}', "                    f"Country: {target_country}, Chapters: {len(rw_chapters)}"
                )
                self._update_input_chapters_status(
                    checked, "verified", chapters_data, "✓ Done"
                )
                try:
                    import winsound
                    winsound.MessageBeep(winsound.MB_ICONASTERISK)
                except Exception:
                    pass

                # ── Excel update: Rewrite = Done ──
                self._update_excel_rewrite(group_path)

                # ── Copy unused chapters + save source mapping ──
                if selected_products and unused_product_names:
                    source_mapping = {"used": [], "unused": []}
                    for pname in sorted(selected_products):
                        pd = _unused_bp_product_lookup.get(pname, {})
                        ch = _find_source_chapter(pd, pname)
                        if ch:
                            gpc = os.path.dirname(ch["filepath"])
                            source_mapping["used"].append({
                                "product": pname,
                                "chapter_file": ch["filename"],
                                "source_video": ch.get("group", ""),
                                "source_path": ch["filepath"],
                                "video_id": self._extract_video_id_from_path(gpc),
                            })

                    unused_dir = (job.get("_cached_unused_dir", "") if job else self._txt_unused_dir.text().strip())
                    copied_count = 0
                    copied_files = set()
                    for pname in sorted(unused_product_names):
                        pd = _unused_bp_product_lookup.get(pname, {})
                        ch = _find_source_chapter(pd, pname)
                        if ch:
                            gpc = os.path.dirname(ch["filepath"])
                            entry = {
                                "product": pname,
                                "chapter_file": ch["filename"],
                                "source_video": ch.get("group", ""),
                                "source_path": ch["filepath"],
                                "video_id": self._extract_video_id_from_path(gpc),
                            }
                            if unused_dir and ch["filepath"] not in copied_files:
                                os.makedirs(unused_dir, exist_ok=True)
                                dest = os.path.join(unused_dir, ch["filename"])
                                if os.path.exists(dest):
                                    base, ext = os.path.splitext(ch["filename"])
                                    n = 2
                                    while os.path.exists(os.path.join(unused_dir, f"{base}_{n}{ext}")):
                                        n += 1
                                    dest = os.path.join(unused_dir, f"{base}_{n}{ext}")
                                try:
                                    import shutil
                                    shutil.copy2(ch["filepath"], dest)
                                    entry["copied_to"] = dest
                                    copied_count += 1
                                    copied_files.add(ch["filepath"])
                                except Exception as e:
                                    log(f"⚠ Failed to copy {ch['filename']}: {e}")
                            source_mapping["unused"].append(entry)

                    mapping_path = os.path.join(pipeline_dir, "_source_mapping.json")
                    with open(mapping_path, "w", encoding="utf-8") as f:
                        json.dump(source_mapping, f, indent=2, ensure_ascii=False)
                    log(f"📄 _source_mapping.json ({len(source_mapping['used'])} used, {len(source_mapping['unused'])} unused)")
                    if copied_count > 0:
                        log(f"✓ Copied {copied_count} unused chapter(s) → {unused_dir}")

                # Wait for v2 to finish (if dual-mode was started)
                if '_v2_thread' in dir() and _v2_thread is not None and _v2_thread.is_alive():
                    log("⏳ v1 done — waiting for v2 to finish...")
                    _v2_thread.join()
                    log("✓ v2 also finished")

            except Exception as e:
                log(f"Error: {e}")
                if not _log_callback:
                    self._log.set_status("Error", True)
                self._update_input_chapters_status(
                    checked, "error", chapters_data, str(e)[:50]
                )
                try:
                    import winsound
                    winsound.MessageBeep(winsound.MB_ICONHAND)
                except Exception:
                    pass
            finally:
                if not job:
                    self._running = False

        if job:
            _run()  # ThreadPoolExecutor handles threading
        else:
            threading.Thread(target=_run, daemon=True).start()
```

**Key change:** Replaced `_is_biography` hardcode with `pipeline_features.phase_plan` check from style JSON. Any niche with `"phase_plan": true` in its style JSON now runs the full pipeline.

