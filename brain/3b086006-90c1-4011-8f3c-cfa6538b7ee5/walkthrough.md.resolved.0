    return json.loads(content)


def convert_units(blueprint: dict, target_country: str = "US", style_data: dict = None) -> dict:
    """Convert all measurement units in blueprint's product_evaluation
    to the target country's system. Pure Python, no API call.

    If style_data has a "units" field, skip conversion entirely — the style
    defines its own measurement system (e.g., military = metric worldwide).

    target_country: 'US' or 'EU'
    style_data: optional style JSON dict
    Returns: modified blueprint with converted units.
    """
    import copy

    # If style declares its own unit system, skip automatic conversion
    if style_data and style_data.get("units"):
        return copy.deepcopy(blueprint)

    bp = copy.deepcopy(blueprint)
    products = bp.get("product_evaluation", [])
    if not products:
        return bp

    # Conversion helpers
    def _kg_to_lbs(val):
        try:
            return round(float(val) * 2.20462, 1)
        except (ValueError, TypeError):
            return val

    def _lbs_to_kg(val):
        try:
            return round(float(val) / 2.20462, 2)
        except (ValueError, TypeError):
            return val

    def _mm_to_inches(val):
        try:
            return round(float(val) / 25.4, 2)
        except (ValueError, TypeError):
            return val

    def _inches_to_mm(val):
        try:
            return round(float(val) * 25.4, 1)
        except (ValueError, TypeError):
            return val

    def _m_to_yards(val):
        try:
            return round(float(val) * 1.09361, 1)
        except (ValueError, TypeError):
            return val

    def _yards_to_m(val):
        try:
            return round(float(val) / 1.09361, 1)
        except (ValueError, TypeError):
            return val

    def _convert_str(text, target):
        """Attempt to convert detected units in a string."""
        if not isinstance(text, str) or not text.strip():
            return text
        import re as _re

        if target == "US":
            # kg → lbs
            text = _re.sub(
                r'(\d+\.?\d*)\s*kg\b',
                lambda m: f"{_kg_to_lbs(m.group(1))} lbs",
                text, flags=_re.IGNORECASE
            )
            # mm → inches
            text = _re.sub(
                r'(\d+\.?\d*)\s*mm\b',
                lambda m: f"{_mm_to_inches(m.group(1))} inches",
                text, flags=_re.IGNORECASE
            )
            # cm → inches
            text = _re.sub(
                r'(\d+\.?\d*)\s*cm\b',
                lambda m: f"{_mm_to_inches(float(m.group(1)) * 10)} inches",
                text, flags=_re.IGNORECASE
            )
            # meters → yards
            text = _re.sub(
                r'(\d+\.?\d*)\s*(?:meters?|m)\b',
                lambda m: f"{_m_to_yards(m.group(1))} yards",
                text, flags=_re.IGNORECASE
            )
            # EUR → USD (approx 1.1)
            text = _re.sub(
                r'€\s*(\d+\.?\d*)',
                lambda m: f"${round(float(m.group(1)) * 1.1, 0):.0f}",
                text
            )
        elif target == "EU":
            # lbs → kg
            text = _re.sub(
                r'(\d+\.?\d*)\s*lbs?\b',
                lambda m: f"{_lbs_to_kg(m.group(1))} kg",
                text, flags=_re.IGNORECASE
            )
            # inches → mm
            text = _re.sub(
                r'(\d+\.?\d*)\s*inch(?:es)?\b',
                lambda m: f"{_inches_to_mm(m.group(1))} mm",
                text, flags=_re.IGNORECASE
            )
            # yards → meters
            text = _re.sub(
                r'(\d+\.?\d*)\s*yards?\b',
                lambda m: f"{_yards_to_m(m.group(1))} m",
                text, flags=_re.IGNORECASE
            )
            # USD → EUR (approx /1.1)
            text = _re.sub(
                r'\$\s*(\d+\.?\d*)',
                lambda m: f"€{round(float(m.group(1)) / 1.1, 0):.0f}",
                text
            )
        return text

    # Walk through all product evaluation data and convert string values
    def _walk_and_convert(obj, target):
        if isinstance(obj, dict):
            return {k: _walk_and_convert(v, target) for k, v in obj.items()}
        elif isinstance(obj, list):
            return [_walk_and_convert(item, target) for item in obj]
        elif isinstance(obj, str):
            return _convert_str(obj, target)
        return obj

    bp["product_evaluation"] = _walk_and_convert(products, target_country)
    return bp


def reality_check_blueprint(
    blueprint: dict,
    api_client,
    lang: str = "en",
    log_callback=None,
    niche: str = "",
) -> dict:
    """Verify and enrich blueprint data against AI's training knowledge.

    Cross-references specs, pricing, and product status.
    Returns: {verification_date_note, products: [...], overall_assessment}
    """
    prompt_file = _get_niche_prompt("reality_check", niche)
    system_template = _load_prompt(prompt_file)
    system_prompt = system_template.replace("{lang}", lang)

    blueprint_json = json.dumps(blueprint, ensure_ascii=False, indent=2)

    user_content = (
        "BLUEPRINT DATA TO VERIFY AND ENRICH:\n"
        f"{blueprint_json}"
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_content},
    ]

    if log_callback:
        log_callback("Reality-checking blueprint data...")

    result = api_client.call_api(
        messages, temperature=0.1, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"❌ Reality check failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"✓ Reality check completed via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        return json.loads(json_match.group())
    return json.loads(content)


def enrich_prices_google(
    blueprint: dict,
    gemini_keys: list,
    api_client=None,
    lang: str = "en",
    log_callback=None,
    stop_check=None,
    price_date: str = "",
) -> dict:
    """Look up current US street prices via Google Search and update blueprint.

    Uses Gemini native API with google_search=True to get real-time prices.
    Supports key rotation across multiple Gemini API keys.

    Args:
        blueprint: blueprint dict with 'product_evaluation' list
        gemini_keys: list of Gemini API keys (AIza...)
        price_date: e.g. "March 2026" — auto-detected if empty

    Returns: dict with 'updated_products', 'price_data', 'price_summary'
    """
    from core.api_client import APIClient
    from datetime import datetime

    if not gemini_keys:
        if log_callback:
            log_callback("⚠ No Gemini API keys — skipping price check")
        return {"updated_products": [], "price_summary": "No API keys"}

    products = blueprint.get("product_evaluation", [])
    if not products:
        if log_callback:
            log_callback("⚠ No products in blueprint — skipping price check")
        return {"updated_products": [], "price_summary": "No products"}

    if not price_date:
        now = datetime.now()
        month_names = [
            "", "January", "February", "March", "April", "May", "June",
            "July", "August", "September", "October", "November", "December"
        ]
        price_date = f"{month_names[now.month]} {now.year}"

    # Build product list for query
    product_names = []
    for p in products:
        name = p.get("product_name", p.get("name", "Unknown"))
        product_names.append(name)

    if log_callback:
        log_callback(
            f"🔍 Looking up prices for {len(product_names)} product(s) "
            f"({price_date})..."
        )

    # Build prompt
    names_list = "\n".join(f"  {i+1}. {n}" for i, n in enumerate(product_names))
    prompt = (
        f"I need the current estimated US street price "
        f"(retail/market price in {price_date}) "
        f"for each of these firearms/ammunition products:\n\n"
        f"{names_list}\n\n"
        f"For each product, provide:\n"
        f"- product_name: exact name as listed\n"
        f"- street_price_usd: estimated price in USD (single number, e.g. 500)\n"
        f"- price_range: e.g. \"$450-$550\"\n"
        f"- price_note: brief note about price context\n\n"
        f"OUTPUT: JSON only, no markdown. Format:\n"
        f'{{"products": [{{"product_name": "...", "street_price_usd": 500, '
        f'"price_range": "$450-$550", "price_note": "..."}}]}}'
    )

    messages = [{"role": "user", "content": prompt}]

    # Create a temporary API client if not provided
    if api_client is None:
        api_client = APIClient([], stop_check=stop_check)

    # Key rotation: try each key
    last_error = ""
    key_count = len(gemini_keys)

    for key_idx, api_key in enumerate(gemini_keys):
        if stop_check and stop_check():
            return {"updated_products": [], "price_summary": "Stopped by user"}

        if log_callback and key_count > 1:
            log_callback(f"  Using key {key_idx + 1}/{key_count}...")

        try:
            result = api_client.call_gemini_native(
                messages,
                gemini_api_key=api_key,
                model="gemini-2.5-flash",
                google_search=True,
                timeout=120,
                stop_check=stop_check,
            )

            if result["success"]:
                content = result["content"]
                jm = re.search(r'\{[\s\S]*\}', content)
                if jm:
                    price_data = json.loads(jm.group())
                else:
                    price_data = json.loads(content)

                # Merge prices into blueprint
                price_map = {}
                for pp in price_data.get("products", []):
                    pname = pp.get("product_name", "")
                    price_map[pname.lower()] = pp

                updated = []
                for p in products:
                    name = p.get("product_name", p.get("name", ""))
                    matched = price_map.get(name.lower(), {})
                    if matched:
                        p["street_price_usd"] = matched.get("street_price_usd")
                        p["price_range"] = matched.get("price_range", "")
                        p["price_note"] = matched.get("price_note", "")
                        p["price_date"] = price_date
                        p["price_source"] = "Google Search"
                        updated.append(name)

                if log_callback:
                    log_callback(
                        f"✓ Updated prices for {len(updated)}/"
                        f"{len(products)} product(s)"
                    )

                return {
                    "updated_products": updated,
                    "price_data": price_data,
                    "price_summary": (
                        f"{len(updated)} prices updated ({price_date})"
                    ),
                }
            else:
                last_error = result.get("error", "Unknown error")
                if log_callback:
                    log_callback(f"  ⚠ Key {key_idx + 1} failed: {last_error}")
                continue

        except Exception as e:
            last_error = str(e)
            if log_callback:
                log_callback(f"  ⚠ Key {key_idx + 1} exception: {e}")
            continue

    if log_callback:
        log_callback(f"❌ All {key_count} key(s) failed. Last error: {last_error}")
    return {
        "updated_products": [],
        "price_summary": f"Failed: {last_error}",
    }


def verify_specs_google(
    blueprint: dict,
    gemini_keys: list,
    lang: str = "en",
    log_callback=None,
    stop_check=None,
) -> dict:
    """Verify product specs via Google Search Grounding.

    Checks key specs (caliber, capacity, weight, barrel length, action type,
    manufacturer, production status) against real-time Google Search data.
    Corrects any outdated or wrong values in the blueprint.

    Returns: dict with 'corrections', 'verified_count', 'corrected_count'
    """
    from core.api_client import APIClient

    if not gemini_keys:
        if log_callback:
            log_callback("⚠ No Gemini API keys — skipping spec verification")
        return {"corrections": [], "verified_count": 0, "corrected_count": 0}

    products = blueprint.get("product_evaluation", [])
    if not products:
        return {"corrections": [], "verified_count": 0, "corrected_count": 0}

    # Build spec summary for each product
    spec_lines = []
    for i, p in enumerate(products, 1):
        name = p.get("product_name", p.get("name", "Unknown"))
        specs = []
        for key in ("caliber", "capacity", "weight", "barrel_length",
                     "action_type", "manufacturer", "overall_length",
                     "production_status", "country_of_origin", "msrp"):
            val = p.get(key)
            if val:
                specs.append(f"{key}: {val}")
        spec_str = ", ".join(specs) if specs else "no specs listed"
        spec_lines.append(f"  {i}. {name} — {spec_str}")

    product_list = "\n".join(spec_lines)

    if log_callback:
        log_callback(
            f"🔎 Verifying specs for {len(products)} product(s) via Google Search..."
        )

    prompt = (
        "I need you to VERIFY the following firearm/ammunition product specs "
        "using Google Search. For EACH product, search for the official specs "
        "and compare with the values listed below.\n\n"
        f"PRODUCTS AND CURRENT SPECS:\n{product_list}\n\n"
        "For each product, check:\n"
        "- caliber/chambering\n"
        "- magazine capacity\n"
        "- barrel length\n"
        "- overall length\n"
        "- weight\n"
        "- action type\n"
        "- manufacturer (current, after any acquisitions)\n"
        "- production status (current production / discontinued / limited)\n"
        "- MSRP or street price\n\n"
        "OUTPUT: JSON only, no markdown. Format:\n"
        '{"products": [\n'
        '  {"product_name": "...", "status": "CORRECT" or "CORRECTED",\n'
        '   "corrections": [\n'
        '     {"field": "caliber", "old_value": "...", "new_value": "...", '
        '"source": "manufacturer website"}\n'
        '   ],\n'
        '   "verified_specs": {"caliber": "...", "capacity": "...", ...}\n'
        '  }\n'
        ']}'
    )

    messages = [{"role": "user", "content": prompt}]
    api_client = APIClient([], stop_check=stop_check)

    last_error = ""
    key_count = len(gemini_keys)

    for key_idx, api_key in enumerate(gemini_keys):
        if stop_check and stop_check():
            return {"corrections": [], "verified_count": 0, "corrected_count": 0}

        if log_callback and key_count > 1:
            log_callback(f"  Using key {key_idx + 1}/{key_count}...")

        try:
            result = api_client.call_gemini_native(
                messages,
                gemini_api_key=api_key,
                model="gemini-2.5-flash",
                google_search=True,
                timeout=180,
                stop_check=stop_check,
            )

            if result["success"]:
                content = result["content"]
                jm = re.search(r'\{[\s\S]*\}', content)
                if jm:
                    verify_data = json.loads(jm.group())
                else:
                    verify_data = json.loads(content)

                # Apply corrections to blueprint
                verify_map = {}
                for vp in verify_data.get("products", []):
                    vname = vp.get("product_name", "")
                    verify_map[vname.lower()] = vp

                corrections_total = 0
                verified_total = 0
                all_corrections = []

                for p in products:
                    name = p.get("product_name", p.get("name", ""))
                    matched = verify_map.get(name.lower(), {})
                    if not matched:
                        continue

                    verified_total += 1
                    corrections = matched.get("corrections", [])
                    verified_specs = matched.get("verified_specs", {})

                    # Apply verified specs
                    for spec_key, spec_val in verified_specs.items():
                        if spec_val and spec_key not in ("product_name",):
                            p[spec_key] = spec_val

                    # Log corrections
                    for c in corrections:
                        corrections_total += 1
                        field = c.get("field", "?")
                        old = c.get("old_value", "?")
                        new = c.get("new_value", "?")
                        if log_callback:
                            log_callback(
                                f"  ⚡ {name}: {field} "
                                f"'{old}' → '{new}'"
                            )
                        all_corrections.append({
                            "product": name, **c
                        })

                if log_callback:
                    log_callback(
                        f"✓ Specs verified: {verified_total} product(s), "
                        f"{corrections_total} correction(s)"
                    )

                return {
                    "corrections": all_corrections,
                    "verified_count": verified_total,
                    "corrected_count": corrections_total,
                    "raw_data": verify_data,
                }
            else:
                last_error = result.get("error", "Unknown error")
                if log_callback:
                    log_callback(f"  ⚠ Key {key_idx + 1} failed: {last_error}")
                continue

        except Exception as e:
            last_error = str(e)
            if log_callback:
                log_callback(f"  ⚠ Key {key_idx + 1} exception: {e}")
            continue

    if log_callback:
        log_callback(f"❌ Spec verification: all {key_count} key(s) failed")
    return {"corrections": [], "verified_count": 0, "corrected_count": 0}



def verify_facts(
    written_text: str,
    blueprint: dict,
    api_client,
    target_country: str = "US",
    lang: str = "en",
    log_callback=None,
) -> dict:
    """Verify facts in written script against blueprint, check unit conversions.

    Returns: {fact_check, unit_conversions, product_coverage, overall_score}
    """
    system_template = _load_prompt("system_verify_facts.txt")
    system_prompt = system_template.replace(
        "{lang}", lang
    ).replace(
        "{target_country}", target_country
    )

    blueprint_json = json.dumps(blueprint, ensure_ascii=False, indent=2)

    user_content = (
        f"WRITTEN SCRIPT:\n{written_text}\n\n"
        f"SOURCE BLUEPRINT:\n{blueprint_json}"
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_content},
    ]

    if log_callback:
        log_callback("Verifying facts and units...")

    result = api_client.call_api(
        messages, temperature=0.1, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"❌ Fact verification failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"✓ Facts verified via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        return json.loads(json_match.group())
    return json.loads(content)


def create_review_outline(
    blueprint: dict,
    style_guide: dict,
    framework_name: str,
    api_client,
    lang: str = "en",
    chapter_range: str = "a suitable number of chapters",
    log_callback=None,
    niche: str = "",
) -> dict:
    """Create a chapter outline for a review script using framework-specific
    Hook/Body/End structure and evaluation_focus.

    Returns: {framework_used, total_chapters, thesis, chapters: [...],
              cta, products_coverage_map}
    """
    prompt_file = _get_niche_prompt("outline", niche)
    system_template = _load_prompt(prompt_file)
    system_prompt = system_template.replace("{lang}", lang)

    # ── Strip author_rhetoric from blueprint before outline sees it ──
    # Same logic as writer: outline must choose angles from alternative_rhetoric,
    # not replicate the original author's editorial framing.
    import copy
    _bp_for_outline = copy.deepcopy(blueprint)
    for product in _bp_for_outline.get("product_evaluation", []):
        product.pop("author_rhetoric", None)
        for alt in product.get("alternative_rhetoric", []):
            if isinstance(alt, dict):
                alt.pop("original", None)
                alt.pop("data_source", None)
    blueprint_json = json.dumps(_bp_for_outline, ensure_ascii=False, indent=2)

    # Extract the specific framework
    framework = None
    for fw in style_guide.get("frameworks", []):
        if fw.get("name", "") == framework_name:
            framework = fw
            break

    if not framework:
        raise RuntimeError(f"Framework '{framework_name}' not found in style guide")

    framework_json = json.dumps(framework, ensure_ascii=False, indent=2)

    # Extract openings, closings, techniques
    meta = {
        "openings": [o.get("name", "") for o in style_guide.get("openings", [])],
        "closings": [c.get("name", "") for c in style_guide.get("closings", [])],
        "techniques": [t.get("name", "") for t in style_guide.get("techniques", [])],
    }
    meta_json = json.dumps(meta, ensure_ascii=False, indent=2)
    # Pre-calculate subject/product constraints from chapter range
    _niche_lower = (niche or "").lower()
    _is_mystery_niche = "mystery" in _niche_lower

    if _is_mystery_niche:
        # Mystery: count subjects from key_events/key_facts/product_evaluation
        n_events = len(blueprint.get("key_events", []))
        n_facts = len(blueprint.get("key_facts", []))
        n_pe = len(blueprint.get("product_evaluation", []))
        n_subjects = max(n_events, n_facts, n_pe, 1)
        _label = "MYSTERY CONSTRAINT"
        _item = "mysteries"
        _item_singular = "mystery"
        _order = "Order by ESCALATING impossibility/significance."
        _dropped_key = "mysteries_dropped"
    else:
        # Product review: count products
        n_subjects = len(blueprint.get("product_evaluation", []))
        _label = "PRODUCT CONSTRAINT"
        _item = "products"
        _item_singular = "product"
        _order = ""
        _dropped_key = "products_dropped"

    product_names = [
        p.get("product_name", f"Item {i+1}")
        for i, p in enumerate(blueprint.get("product_evaluation", []))
    ]

    # Parse chapter range to extract min/max
    import re as _re
    ch_match = _re.search(r'between\s+(\d+)\s+and\s+(\d+)', chapter_range)
    ch_min_match = _re.search(r'at least\s+(\d+)', chapter_range)
    ch_max_match = _re.search(r'at most\s+(\d+)', chapter_range)

    if ch_match:
        ch_min, ch_max = int(ch_match.group(1)), int(ch_match.group(2))
    elif ch_min_match:
        ch_min, ch_max = int(ch_min_match.group(1)), 0
    elif ch_max_match:
        ch_min, ch_max = 0, int(ch_max_match.group(1))
    else:
        ch_min, ch_max = 0, 0

    # Body chapters = total - hook(1) - end(1)
    if ch_min and ch_max:
        body_min = max(1, ch_min - 2)
        body_max = max(1, ch_max - 2)
        subject_instruction = (
            f"{_label} (pre-calculated):\n"
            f"- Blueprint has {n_subjects} {_item}.\n"
            f"- Body chapters: {body_min}-{body_max} (1 {_item_singular} per chapter).\n"
            f"- Select {min(n_subjects, body_min)}-{min(n_subjects, body_max)} {_item}.\n"
            + (f"- {_order}\n" if _order else "")
            + f"- List dropped {_item} in `{_dropped_key}`."
        )
        chapter_instruction = f"**CHAPTER COUNT (HARD LIMIT):** {ch_min}-{ch_max} chapters total."
    elif ch_max:
        body_max = max(1, ch_max - 2)
        subject_instruction = (
            f"{_label} (pre-calculated):\n"
            f"- Blueprint has {n_subjects} {_item}.\n"
            f"- Maximum {min(n_subjects, body_max)} {_item} (1 per body chapter).\n"
            + (f"- {_order}\n" if _order else "")
            + f"- List dropped {_item} in `{_dropped_key}`."
        )
        chapter_instruction = f"**CHAPTER COUNT (HARD LIMIT):** at most {ch_max} chapters total."
    elif ch_min:
        body_min = max(1, ch_min - 2)
        subject_instruction = (
            f"{_label} (pre-calculated):\n"
            f"- Blueprint has {n_subjects} {_item}.\n"
            f"- Minimum {min(n_subjects, body_min)} {_item} (1 per body chapter)."
            + (f"\n- {_order}" if _order else "")
        )
        chapter_instruction = f"**CHAPTER COUNT (HARD LIMIT):** at least {ch_min} chapters total."
    else:
        subject_instruction = (
            f"{_label}:\n"
            f"- Blueprint has {n_subjects} {_item}. Include as appropriate."
            + (f"\n- {_order}" if _order else "")
        )
        chapter_instruction = "**CHAPTER COUNT:** use a suitable number of chapters."

    user_content = (
        f"BLUEPRINT:\n{blueprint_json}\n\n"
        f"FRAMEWORK:\n{framework_json}\n\n"
        f"AVAILABLE OPENINGS/CLOSINGS/TECHNIQUES:\n{meta_json}\n\n"
        f"{subject_instruction}\n\n"
        f"{chapter_instruction}"
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_content},
    ]

    if log_callback:
        log_callback(f"Creating review outline with '{framework_name}'...")

    result = api_client.call_api(
        messages, temperature=0.3, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"❌ Outline creation failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"✓ Review outline created via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        return json.loads(json_match.group())
    return json.loads(content)


def write_review_chapter(
    blueprint: dict,
    style_json: str,
    framework_name: str,
    chapter_outline: dict,
    chapter_number: int,
    total_chapters: int,
    api_client,
    word_count_rule: str = "1300 to 1800 words",
    lang: str = "en",
    previous_context: str = "",
    target_country: str = "US",
    full_outline: str = "",
    log_callback=None,
    use_transitions: bool = True,
) -> str:
    """Write a NEW review chapter from a content blueprint + style guide.
    Uses the review-specific prompt with chapter_type, target_country,
    products_covered, evaluation_criteria, etc.

    Returns: the written chapter text.
    """
    # Load style-specific writer prompt — no fallback, niche must match
    _niche_prompt_map = {
        "firearms": "system_write_review_firearms.txt",
        "military": "system_write_review_military.txt",
        "mystery": "system_write_review_mystery.txt",
    }
    prompt_file = None
    try:
        _style_data = json.loads(style_json) if isinstance(style_json, str) else style_json
        _niche = _style_data.get("niche", "").lower()
        for key, fname in _niche_prompt_map.items():
            if key in _niche:
                prompt_file = fname
                break
    except Exception:
        pass
    if not prompt_file:
        raise ValueError(
            f"No writer prompt found for niche '{_style_data.get('niche', '?')}'. "
            f"Create a prompt file and add it to _niche_prompt_map in rewriter.py."
        )

    # ── Mystery niche: modular base + structure architecture ──
    _prompts_dir = os.path.join(os.path.dirname(__file__), "..", "prompts")
    _base_path = os.path.join(_prompts_dir, "base_mystery_writer.txt")
    _ch_structure = chapter_outline.get("chapter_structure", "mythbuster")

    if "mystery" in (_niche or "") and os.path.exists(_base_path):
        system_template = _load_prompt("base_mystery_writer.txt")

        # Load structure-specific prompt
        _struct_file = f"mystery_structures/structure_{_ch_structure}.txt"
        _struct_path = os.path.join(_prompts_dir, _struct_file)
        if os.path.exists(_struct_path):
            _struct_content = _load_prompt(_struct_file)
        else:
            _struct_content = (
                f"Follow the '{_ch_structure}' storytelling structure. "
                "Use the outline's chapter_structure field as your guide."
            )
        system_template = system_template.replace(
            "{structure_prompt}", _struct_content
        )

        # Inject conditional MAINSTREAM/COUNTER based on structure
        _dialectic_structures = {
            "mythbuster", "detective_trail", "conflicting_accounts"
        }
        if _ch_structure in _dialectic_structures:
            _cond = (
                "CONDITIONAL — this structure REQUIRES [MAINSTREAM] + [COUNTER]:\n\n"
                "  [MAINSTREAM] Official/conventional explanation — present FAIRLY\n"
                "    - From `mainstream_theory` in outline\n"
                "    - Give genuine intellectual weight — this is NOT a strawman\n"
                "    - BAD: \"Mainstream historians are wrong\"\n"
                "    - GOOD: \"Historians classify them as a hereditary criminal cult. "
                "The consistency is explained as oral tradition. These are not foolish arguments.\"\n\n"
                "  [COUNTER] Pivot + counter-evidence — expose the gaps\n"
                "    - From `core_impossibility` in outline\n"
                "    - SHARP PIVOT required — the most important sentence in the chapter\n"
                "    - PIVOT BLACKLIST (HARD BAN — may NOT appear more than ONCE in the entire video):\n"
                "      × \"This/That explanation, however, [verb]s...\"\n"
                "      × \"The mainstream/conventional explanation holds that...\"\n"
                "      × \"The mainstream historical view classifies/dismisses...\"\n"
                "    - USE INSTEAD (one per chapter, no repeats):\n"
                "      * Data contradiction: \"That accounts for X. It does not account for Y.\"\n"
                "      * Scale impossibility: \"Hereditary gangs do not produce 600 years of identical methodology.\"\n"
                "      * Direct challenge: \"To accept this requires believing that...\"\n"
                "      * Temporal paradox: \"This compound was not identified until 1840. They were deploying it in 672.\"\n"
                "      * Methodological gap: \"The technique targets structures not mapped until...\"\n"
                "      * Absence as evidence: \"Every record survives — except this one.\""
            )
        else:
            _cond = (
                f"NOTE: Structure '{_ch_structure}' does NOT require [MAINSTREAM] or [COUNTER].\n"
                "Focus on [EVIDENCE] and the structure's own storytelling flow.\n"
                "Do NOT force a mainstream→counter dialectic into this chapter."
            )
        system_template = system_template.replace(
            "{required_elements_conditional}", _cond
        )
        if log_callback:
            log_callback(f"  [Prompt] base + structure_{_ch_structure}.txt")
    else:
        # Fallback to monolithic prompt for non-mystery niches
        system_template = _load_prompt(prompt_file)

    # ── Strip author_rhetoric from blueprint before writer sees it ──
    # Writer must use alternative_rhetoric (creative fuel) only.
    # Keeping author_rhetoric would let writer copy original rhetoric.
    # Also strip `original` and `data_source` from alternative_rhetoric items —
    # writer only needs `type` + `alternative` text. data_source leaks original
    # phrases (e.g., "manos perezosas") that the writer copies verbatim.
    import copy
    _bp_sanitized = copy.deepcopy(blueprint)
    for product in _bp_sanitized.get("product_evaluation", []):
        product.pop("author_rhetoric", None)
        for alt in product.get("alternative_rhetoric", []):
            if isinstance(alt, dict):
                alt.pop("original", None)
                alt.pop("data_source", None)
    blueprint_json = json.dumps(_bp_sanitized, ensure_ascii=False, indent=2)

    # Extract review-specific outline fields
    products = chapter_outline.get("products_covered", [])
    products_str = ", ".join(products) if products else "N/A"
    eval_criteria = chapter_outline.get("evaluation_criteria", [])
    eval_str = ", ".join(eval_criteria) if eval_criteria else "N/A"
    primary = chapter_outline.get("primary_criterion", "")
    techniques = chapter_outline.get("techniques_to_use", [])
    techniques_str = ", ".join(techniques) if techniques else "N/A"
    chapter_type = chapter_outline.get("chapter_type", "body")

    compact_style = _extract_style_for_framework(style_json, framework_name)

    system_prompt = system_template.replace(
        "{style_json}", compact_style
    ).replace(
        "{framework_name}", framework_name
    ).replace(
        "{chapter_type}", chapter_type or "body"
    ).replace(
        "{target_country}", target_country
    ).replace(
        "{blueprint}", blueprint_json
    ).replace(
        "{full_outline}", full_outline or "(not provided)"
    ).replace(
        "{chapter_number}", str(chapter_number)
    ).replace(
        "{total_chapters}", str(total_chapters)
    ).replace(
        "{chapter_title}", chapter_outline.get("title") or f"Chapter {chapter_number}"
    ).replace(
        "{chapter_summary}", chapter_outline.get("summary") or ""
    ).replace(
        "{products_covered}", products_str
    ).replace(
        "{evaluation_criteria}", eval_str
    ).replace(
        "{primary_criterion}", primary or "N/A"
    ).replace(
        "{depth_focus}", chapter_outline.get("depth_focus") or "N/A"
    ).replace(
        "{techniques_to_use}", techniques_str
    ).replace(
        "{emotional_beat}", chapter_outline.get("emotional_beat") or ""
    ).replace(
        "{ends_with}", chapter_outline.get("ends_with") or ""
    ).replace(
        "{tone_category}", chapter_outline.get("tone_category") or "N/A"
    ).replace(
        "{ranking_reason}", chapter_outline.get("ranking_reason") or "N/A"
    ).replace(
        "{unique_selling_point}", chapter_outline.get("unique_selling_point") or "N/A"
    ).replace(
        "{target_user}", chapter_outline.get("target_user") or "N/A"
    ).replace(
        "{cons_to_mention}", chapter_outline.get("cons_to_mention") or "N/A"
    ).replace(
        "{countdown_position}", str(chapter_outline.get("countdown_position") or "N/A")
    ).replace(
        "{products_count}", str(max(total_chapters - 2, 1))
    ).replace(
        "{word_count_rule}", word_count_rule
    ).replace(
        "{previous_context}", previous_context if previous_context else "(This is the first chapter)"
    ).replace(
        "{lang}", lang
    ).replace(
        "{tone_slot}", chapter_outline.get("tone_slot") or "N/A"
    ).replace(
        "{chapter_structure}", chapter_outline.get("chapter_structure") or "N/A"
    ).replace(
        "{closing_type}", chapter_outline.get("closing_type") or "N/A"
    ).replace(
        "{debate_seed}", chapter_outline.get("debate_seed") or "N/A"
    )

    # ── Conditional transition stripping ──
    if not use_transitions:
        import re
        # Mystery prompt: has a dedicated ═══ TRANSITIONS ═══ section
        transition_block = re.search(
            r'═+\s*TRANSITIONS BETWEEN CHAPTERS\s*═+.*?(?=═+|$)',
            system_prompt, re.DOTALL
        )
        if transition_block:
            no_transition_rule = (
                "═══════════════════════════════════════\n"
                "CHAPTER OPENING RULE (NO TRANSITIONS)\n"
                "═══════════════════════════════════════\n\n"
                "Do NOT write bridge sentences between chapters.\n"
                "Do NOT execute `ends_with` from the outline.\n"
                "Open each body chapter DIRECTLY with its assigned structure.\n"
                "End each chapter with its closing type — do NOT add any transition to the next chapter.\n"
            )
            system_prompt = (
                system_prompt[:transition_block.start()]
                + no_transition_rule
                + system_prompt[transition_block.end():]
            )
        else:
            # Firearms/Military: inject override rule before messages
            system_prompt += (
                "\n\n═══════════════════════════════════════\n"
                "CHAPTER OPENING RULE (NO TRANSITIONS)\n"
                "═══════════════════════════════════════\n\n"
                "Do NOT write bridge sentences connecting to the previous chapter.\n"
                "Open each body chapter DIRECTLY with its rank number + product/system name,\n"
                "then proceed immediately with the assigned structure.\n"
            )

        # Strip ALL remaining transition/ends_with instructions from prompt
        # These exist outside the TRANSITIONS block and cause AI to still write transitions
        system_prompt = re.sub(
            r'^.*?[Ee]xecute\s+`?ends_with`?.*?$', '', system_prompt, flags=re.MULTILINE
        )
        system_prompt = re.sub(
            r'^.*?GEOGRAPHIC/TEMPORAL TRANSITIONS.*?$', '', system_prompt, flags=re.MULTILINE
        )
        system_prompt = re.sub(
            r'Ends with:.*$', 'Ends with: (transitions OFF — end with closing type only)',
            system_prompt, count=1, flags=re.MULTILINE
        )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": (
            f"Write chapter {chapter_number} of {total_chapters}: "
            f"{chapter_outline.get('title', '')}\n\n"
            f"Use the blueprint and style guide in the system prompt. "
            f"Write in {lang}.\n\n"
            f"MANDATORY WORD COUNT: {word_count_rule}. "
            f"Count your output — do NOT submit if below minimum."
        )},
    ]

    if log_callback:
        log_callback(f"  Writing Ch.{chapter_number} [{chapter_type}] from blueprint ({framework_name})...")

    result = api_client.call_api(
        messages, temperature=0.7, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"  ❌ API failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"  ✓ Ch.{chapter_number} written via {model}")

    return result["content"].strip()
```

**Key changes:**
1. `_NICHE_PROMPT_MAP`: Battle entries added for `narrative_phase_plan` and new `narrative_validate_sub_key`. V2 routing via `"phân tích trận đánh"` key.
2. `_get_niche_prompt`: **Longest-match-first** logic — prevents "trận" matching before "phân tích trận đánh".
3. `validate_phase_plan_sub_keys`: Added `niche` param. Niche-aware prompt loading + niche-aware blueprint excerpt builder (battle uses `battle_phases`, `commanders`, `technology_and_weapons`; biography uses `life_phases`, `conflicts`).

