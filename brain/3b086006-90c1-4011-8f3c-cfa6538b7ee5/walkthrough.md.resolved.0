def _get_niche_prompt(step: str, niche: str) -> str:
    """Get the prompt filename for a pipeline step + niche combination.
    Raises ValueError if the niche has no prompt for this step.
    """
    step_map = _NICHE_PROMPT_MAP.get(step, {})
    niche_lower = (niche or "").lower()
    # Sort by key length descending → longest match wins
    # This ensures "phân tích trận đánh" matches before "trận"
    for key, fname in sorted(step_map.items(), key=lambda x: len(x[0]), reverse=True):
        if key in niche_lower:
            return fname
    # No matching niche — tell user to create prompts
    known = ", ".join(step_map.keys())
    raise ValueError(
        f"No '{step}' prompt found for niche '{niche}'. "
        f"Known niches: [{known}]. "
        f"Please create a prompt file for this niche and add it to "
        f"_NICHE_PROMPT_MAP in rewriter.py."
    )


def _require_niche_prompt(step: str, niche: str, log_callback=None) -> str:
    """Get niche-specific prompt or raise RuntimeError with clear guidance.
    `step` should be WITHOUT the 'narrative_' prefix (e.g. 'outline', 'audit').
    """
    if not niche:
        raise RuntimeError(
            f"Narrative {step} requires a niche. Please set niche in style_data."
        )
    map_key = f"narrative_{step}"
    try:
        prompt_file = _get_niche_prompt(map_key, niche)
    except ValueError:
        raise RuntimeError(
            f"No narrative {step} prompt for niche '{niche}'. "
            f"Create prompts/system_narrative_{step}_<niche>.txt and add to "
            f"_NICHE_PROMPT_MAP['{map_key}']"
        )
    if log_callback:
        log_callback(f"[niche={niche}] {step} → {prompt_file}")
    return prompt_file


def _extract_style_for_framework(style_json: str, framework_name: str) -> str:
    """Extract only the relevant framework + shared rules from the full style JSON.

    Instead of sending the entire style JSON (939 lines, 4 frameworks),
    send only:
    - core_rules (shared voice/tone/vocabulary)
    - The ONE framework being used (with all its rules)
    - chapter_structures (body chapter templates)
    - closing_types (chapter ending types)

    Returns: a compact JSON string with only relevant data.
    """
    try:
        style = json.loads(style_json) if isinstance(style_json, str) else style_json
    except (json.JSONDecodeError, TypeError):
        return style_json  # fallback: return as-is

    frameworks = style.get("frameworks", [])
    target_fw = None
    for fw in frameworks:
        if fw.get("name", "") == framework_name:
            target_fw = fw
            break

    if not target_fw:
        return style_json  # fallback if framework not found

    # Build compact style with only what the AI needs
    compact = {
        "core_rules": style.get("core_rules", {}),
        "framework": target_fw,  # ONLY the one being used
        "chapter_structures": style.get("chapter_structures", []),
        "closing_types": style.get("closing_types", []),
    }

    # Generate explicit data priority from evaluation_focus
    eval_focus = target_fw.get("evaluation_focus", {})
    primary_field = eval_focus.get("primary_data_field", "")
    secondary_fields = eval_focus.get("secondary_fields", [])
    best_when = eval_focus.get("best_when", "")

    # Determine myth level from technique_emphasis
    tech = target_fw.get("technique_emphasis", {})
    myth_level = "sparingly"
    for level in ["use_heavily", "use_moderately", "use_sparingly"]:
        if "Myth vs Reality" in tech.get(level, []):
            myth_level = level.replace("use_", "")
            break

    if primary_field:
        priority_parts = [f"PRIMARY blueprint data: `{primary_field}`"]
        if secondary_fields:
            priority_parts.append(
                f"SECONDARY data: {', '.join(f'`{f}`' for f in secondary_fields)}"
            )
        priority_parts.append(f"Myth vs Reality: use {myth_level}")
        if best_when:
            priority_parts.append(f"This framework works best when: {best_when}")

        compact["data_priority"] = " | ".join(priority_parts)

    return json.dumps(compact, ensure_ascii=False, indent=2)


def _extract_chapter_blueprint(blueprint: dict, chapter_outline: dict) -> dict:
    """Extract only blueprint sections relevant to this chapter.

    Uses TWO strategies:
    1. EXACT SECTION matching for life_phase_covered, relationships_featured,
       myths_debunked (these map to known blueprint sections)
    2. FUZZY SEARCH for key_data items — these are plain-text descriptions
       that need substring matching across all blueprint list/dict sections.

    Falls back to full blueprint if extraction yields nothing useful.
    """
    result = {}

    # Always include core_identity (name, dates — minimal context)
    if "core_identity" in blueprint:
        result["core_identity"] = blueprint["core_identity"]

    # Always include personal_profile (humanizing details — every chapter needs this)
    if "personal_profile" in blueprint:
        result["personal_profile"] = blueprint["personal_profile"]

    # ── 1. life_phase_covered → match to blueprint.life_phases ──
    # AI may comma-join multiple phases: "Phase A, Phase B"
    # Split and match each individually
    life_phase_raw = chapter_outline.get("life_phase_covered", "")
    if life_phase_raw and life_phase_raw != "null" and isinstance(life_phase_raw, str):
        # Split on comma (AI often does "The Struggling Academic, The Patent Office and Annus Mirabilis")
        phase_queries = [p.strip().lower() for p in life_phase_raw.split(",") if p.strip()]

        if "life_phases" in blueprint and isinstance(blueprint["life_phases"], list):
            for item in blueprint["life_phases"]:
                if not isinstance(item, dict):
                    continue
                item_text = json.dumps(item, ensure_ascii=False).lower()
                for pq in phase_queries:
                    if pq in item_text:
                        result.setdefault("life_phases", []).append(item)
                        break  # don't add same item twice

    # ── 2. relationships_featured → match to blueprint.key_relationships ──
    rels = chapter_outline.get("relationships_featured", [])
    if rels and "key_relationships" in blueprint and isinstance(blueprint["key_relationships"], list):
        for rel_name in rels:
            if not isinstance(rel_name, str):
                continue
            rel_lower = rel_name.lower()
            for item in blueprint["key_relationships"]:
                if isinstance(item, dict) and rel_lower in json.dumps(item, ensure_ascii=False).lower():
                    result.setdefault("key_relationships", []).append(item)

    # ── 3. myths_debunked → match to blueprint.myths_vs_reality ──
    myths = chapter_outline.get("myths_debunked", [])
    if myths and "myths_vs_reality" in blueprint and isinstance(blueprint["myths_vs_reality"], list):
        for myth in myths:
            if not isinstance(myth, str) or myth == "null":
                continue
            myth_lower = myth.lower()
            for item in blueprint["myths_vs_reality"]:
                if isinstance(item, dict) and myth_lower in json.dumps(item, ensure_ascii=False).lower():
                    result.setdefault("myths_vs_reality", []).append(item)

    # ── 4. key_data → FUZZY search across ALL blueprint sections ──
    # key_data items are plain English like "Job at the Swiss Patent Office"
    # They are NOT dotted paths — they need substring matching against blueprint content
    key_data = chapter_outline.get("main_key_data", chapter_outline.get("key_data", []))
    sub_key_data = chapter_outline.get("sub_key_data", [])
    all_search_items = (key_data if isinstance(key_data, list) else []) + (sub_key_data if isinstance(sub_key_data, list) else [])
    if all_search_items:
        # Sections to search (skip those already handled above)
        _skip = {"core_identity", "personal_profile", "core_topic",
                 "life_phases", "key_relationships", "myths_vs_reality"}

        for kd_item in all_search_items:
            if not isinstance(kd_item, str):
                continue

            # Try as dotted path first (backward compat: "achievements.Nobel Prize")
            parts = kd_item.split(".", 1)
            if len(parts) == 2 and parts[0].strip() in blueprint:
                top_key = parts[0].strip()
                sub_query = parts[1].strip().lower()
                section = blueprint[top_key]
                if isinstance(section, list):
                    for item in section:
                        if isinstance(item, dict):
                            if sub_query in json.dumps(item, ensure_ascii=False).lower():
                                result.setdefault(top_key, []).append(item)
                        elif isinstance(item, str) and sub_query in item.lower():
                            result.setdefault(top_key, []).append(item)
                elif isinstance(section, dict):
                    for k, v in section.items():
                        if sub_query in k.lower() or sub_query in json.dumps(v, ensure_ascii=False).lower():
                            result.setdefault(top_key, {})[k] = v
                continue  # dotted path handled, skip fuzzy

            # Fuzzy search: scan all blueprint sections for matching content
            kd_lower = kd_item.lower()
            for bp_key, bp_section in blueprint.items():
                if bp_key in _skip:
                    continue
                if isinstance(bp_section, list):
                    for item in bp_section:
                        if isinstance(item, dict):
                            if kd_lower in json.dumps(item, ensure_ascii=False).lower():
                                existing = result.get(bp_key, [])
                                if item not in existing:
                                    result.setdefault(bp_key, []).append(item)
                        elif isinstance(item, str) and kd_lower in item.lower():
                            result.setdefault(bp_key, []).append(item)
                elif isinstance(bp_section, dict):
                    for k, v in bp_section.items():
                        if kd_lower in k.lower() or kd_lower in json.dumps(v, ensure_ascii=False).lower():
                            result.setdefault(bp_key, {})[k] = v

    # Fallback: if extraction yielded only always-included keys, send full
    _always_keys = {"core_identity", "personal_profile"}
    if set(result.keys()) <= _always_keys:
        return blueprint

    return result

# Niche-specific outline fields injected in write_from_blueprint (all niches)
_NICHE_OUTLINE_FIELDS = {
    # ── Battle ──
    "{battle_phase}": "battle_phase",
    "{timeline_position}": "timeline_position",
