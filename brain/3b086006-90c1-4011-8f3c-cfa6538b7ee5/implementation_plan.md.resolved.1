# NEW — niche-aware từ pipeline_features.excerpt_fields:
def _build_excerpt(blueprint, excerpt_fields):
    """Build relevant blueprint excerpt using configured fields."""
    if not excerpt_fields:
        raise RuntimeError(
            "pipeline_features.excerpt_fields not configured. "
            "Cannot build validation excerpt without knowing which "
            "blueprint sections are relevant for this niche."
        )
    excerpt = {}
    for field in excerpt_fields:
        val = blueprint.get(field)
        if val:
            excerpt[field] = val
    if not excerpt:
        raise RuntimeError(
            f"Blueprint has NONE of the configured excerpt_fields: {excerpt_fields}. "
            f"Blueprint keys: {list(blueprint.keys())}. "
            f"Check that extract/research prompt output matches excerpt_fields."
        )
    return excerpt
```

`excerpt_fields` đọc từ `pipeline_features` — truyền vào khi gọi validate.

