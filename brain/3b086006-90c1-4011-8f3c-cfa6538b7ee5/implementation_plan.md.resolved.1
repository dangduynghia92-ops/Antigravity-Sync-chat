# NEW — đọc từ pipeline_features.always_include_keys:
def _extract_chapter_blueprint(blueprint, chapter_outline, always_include_keys=None):
    result = {}
    
    _aik = always_include_keys or ["core_identity", "personal_profile"]  # backward compat
    for key in _aik:
        if key in blueprint:
            result[key] = blueprint[key]
    
    # Nếu KHÔNG tìm được bất kỳ always_key nào → báo lỗi schema mismatch
    if not result:
        raise RuntimeError(
            f"Blueprint has NONE of the always_include_keys: {_aik}. "
            f"Blueprint keys: {list(blueprint.keys())}. "
            f"Check pipeline_features.always_include_keys in style JSON "
            f"matches your extract/research blueprint prompt output."
        )
    
    # ... rest of extraction logic (key_data fuzzy search — UNCHANGED)
    
    # Fallback check — nếu chỉ có always-keys → KHÔNG gửi full blueprint
    # Thay vào đó: báo lỗi rõ ràng
    if set(result.keys()) <= set(_aik):
        raise RuntimeError(
            f"Chapter blueprint extraction found ONLY always-include keys. "
            f"No key_data/sub_key_data matched any blueprint section. "
            f"Outline chapter: {chapter_outline.get('title', '?')}. "
            f"key_data: {chapter_outline.get('main_key_data', chapter_outline.get('key_data', []))}. "
            f"This usually means the outline prompt generates key_data text that "
            f"doesn't match blueprint content. Check outline prompt rules."
        )
```

> [!CAUTION]
> **OLD behavior**: fallback trả FULL blueprint → chạy tiếp, tốn token, output sai.
> **NEW behavior**: `RuntimeError` + log rõ nguyên nhân → pipeline STOP ngay, user biết fix gì.

