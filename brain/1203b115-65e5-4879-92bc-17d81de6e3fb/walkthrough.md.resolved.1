                        self._safe_log(log_callback, f"[T] {endpoint.name} timeout. Switching...")
                        continue
                    except requests.exceptions.ConnectionError:
                        endpoint.fail_count += 1
                        self._safe_log(log_callback, f"[C] {endpoint.name} connection failed. Switching...")
                        continue
                    except Exception as e:
                        endpoint.fail_count += 1
                        self._safe_log(log_callback, f"[X] {endpoint.name} error: {str(e)}")
