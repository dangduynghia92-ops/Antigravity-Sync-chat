        self.keys_file = keys_file or API_KEYS_FILE
        self.primary: Optional[Endpoint] = None
        self.endpoints: List[Endpoint] = []
        self._current_idx = 0
        self.log_api: bool = False  # Toggle: save request/response history
        self.load_config()

    def load_config(self):
        """Load API configuration from api_keys.json."""
        if not os.path.exists(self.keys_file):
            return

        try:
            with open(self.keys_file, 'r', encoding='utf-8') as f:
                data = json.load(f)
        except (json.JSONDecodeError, IOError):
            return

        # Load primary endpoint
        if "primary" in data:
            p = data["primary"]
            self.primary = Endpoint(
                name=p.get("name", "Primary API"),
                base_url=p.get("base_url", ""),
                api_key=p.get("api_key", ""),
                flash_model=p.get("model", ""),
                pro_model=p.get("model", ""),
                is_primary=True
            )

        # Load fallback endpoints
        self.endpoints = []
        for ep in data.get("endpoints", []):
            self.endpoints.append(Endpoint(
                name=ep.get("name", ""),
                base_url=ep.get("base_url", ""),
                api_key=ep.get("api_key", ""),
                flash_model=ep.get("flash_model", ""),
                pro_model=ep.get("pro_model", ""),
                enabled=ep.get("enabled", True),
            ))

    def save_config(self):
        """Save current API configuration to api_keys.json."""
        data = {}

        if self.primary:
            data["primary"] = {
                "name": self.primary.name,
                "base_url": self.primary.base_url,
                "api_key": self.primary.api_key,
                "model": self.primary.flash_model
            }

        data["endpoints"] = []
        for ep in self.endpoints:
            data["endpoints"].append({
                "name": ep.name,
                "base_url": ep.base_url,
                "api_key": ep.api_key,
                "flash_model": ep.flash_model,
                "pro_model": ep.pro_model,
                "enabled": ep.enabled,
            })

        with open(self.keys_file, 'w', encoding='utf-8') as f:
            json.dump(data, f, indent=4, ensure_ascii=False)

    def get_all_endpoints(self) -> List[Endpoint]:
        """Get list of all enabled, configured endpoints (primary first)."""
        result = []
        if self.primary and self.primary.api_key:
            result.append(self.primary)
        result.extend([ep for ep in self.endpoints if ep.api_key and ep.enabled])
        return result

    def _build_url(self, base_url: str) -> str:
