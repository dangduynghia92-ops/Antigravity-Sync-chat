    def _interruptible_sleep(seconds: float, stop_check: Optional[Callable] = None) -> bool:
        """Sleep in 0.5s chunks, checking stop_check. Returns False if stopped."""
        if not stop_check:
            time.sleep(seconds)
            return True
        end_t = time.time() + seconds
        while time.time() < end_t:
            if stop_check():
                return False
            time.sleep(min(0.5, max(0, end_t - time.time())))
        return True

