                return True, f"✅ Connected! Model: {model}"
            else:
                return False, f"❌ Status {response.status_code}: {response.text[:100]}"
        except requests.exceptions.Timeout:
            return False, "❌ Connection timeout (15s)"
        except requests.exceptions.ConnectionError:
            return False, "❌ Cannot connect to server"
        except Exception as e:
            return False, f"❌ Error: {str(e)}"

    def send_vision_request(
        self,
        image_path: str,
        prompt: str,
        log_callback: Optional[Callable] = None,
    ) -> Optional[str]:
        """Send an image + text prompt to the API for vision analysis.

        Args:
            image_path: Path to the image file.
            prompt: Text prompt to send alongside the image.
            log_callback: Optional function to log messages.

        Returns:
            Generated text response, or None if all endpoints fail.
        """
        import base64

        # Read and encode image
        try:
            with open(image_path, "rb") as f:
                image_data = base64.b64encode(f.read()).decode("utf-8")
        except Exception as e:
            self._safe_log(log_callback, f"[X] Cannot read image: {e}")
            return None

        # Detect mime type
        ext = os.path.splitext(image_path)[1].lower()
        mime_map = {".png": "image/png", ".jpg": "image/jpeg", ".jpeg": "image/jpeg",
                    ".webp": "image/webp", ".gif": "image/gif"}
        mime_type = mime_map.get(ext, "image/png")

        # Build multimodal message (OpenAI-compatible format)
        messages = [
            {"role": "user", "content": [
                {"type": "image_url", "image_url": {"url": f"data:{mime_type};base64,{image_data}"}},
                {"type": "text", "text": prompt},
            ]}
        ]

        available = self.get_all_endpoints()
        if not available:
            self._safe_log(log_callback, "[X] No API endpoints configured!")
            return None

        for endpoint in available:
            model = endpoint.flash_model or endpoint.pro_model
            if not model:
                continue

            url = self._build_url(endpoint.base_url)
            headers = {
                "Content-Type": "application/json",
                "Authorization": f"Bearer {endpoint.api_key}"
            }
            payload = {
                "model": model,
                "messages": messages,
                "max_tokens": 256,
                "temperature": 0.1,
            }

            try:
                response = requests.post(url, headers=headers, json=payload, timeout=30)
                if response.status_code == 200:
                    result = response.json()
                    content = result.get("choices", [{}])[0].get("message", {}).get("content", "")
                    if content:
                        return content.strip()
                else:
                    self._safe_log(log_callback,
                                   f"[X] Vision {endpoint.name}: {response.status_code}")
                    continue
            except Exception as e:
                self._safe_log(log_callback, f"[X] Vision error: {str(e)}")
                continue

        return None

    def call_gemini_native(
        self,
        messages: list,
        gemini_api_key: str,
        model: str = "gemini-2.5-flash",
        temperature: float = 0.7,
        max_tokens: int = 65536,
        timeout: int = 120,
        google_search: bool = True,
        stop_check: Optional[Callable] = None,
    ) -> dict:
        """Call Gemini API directly (native format) with Google Search Grounding.

        Args:
            messages: OpenAI-style messages [{"role": "...", "content": "..."}]
            gemini_api_key: Direct Gemini API key (AIza...)
            model: Model name (e.g. "gemini-2.5-flash")
            google_search: Enable Google Search Grounding for fact-checking
            stop_check: Optional callable returning True to abort

        Returns:
            dict with keys: success, content, model, error, grounding_metadata, status_code
        """
        _FAIL = lambda err, sc=0: {
            "success": False, "content": "", "model": model,
            "error": err, "grounding_metadata": None, "status_code": sc,
        }

        if stop_check and stop_check():
            return _FAIL("Stopped by user")

        # Rate limiting — min 2s between Gemini native calls
        _min_delay = 2.0
        elapsed = time.time() - self._gemini_last_call
        if elapsed < _min_delay:
            wait = _min_delay - elapsed
            if not self._interruptible_sleep(wait, stop_check):
                return _FAIL("Stopped by user")

        # Build Gemini native URL
        url = f"https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent"

        # Convert OpenAI messages → Gemini native format
        system_text = ""
        contents = []
        for msg in messages:
            role = msg.get("role", "user")
            text = msg.get("content", "")
            if role == "system":
                system_text += text + "\n"
            else:
                gemini_role = "user" if role == "user" else "model"
                contents.append({
                    "role": gemini_role,
                    "parts": [{"text": text}]
                })

        payload = {
            "contents": contents,
            "generationConfig": {
                "temperature": temperature,
                "maxOutputTokens": max_tokens,
            },
        }
        if system_text.strip():
            payload["systemInstruction"] = {
                "parts": [{"text": system_text.strip()}]
            }
        if google_search:
            payload["tools"] = [{"google_search": {}}]

        headers = {
            "Content-Type": "application/json",
            "x-goog-api-key": gemini_api_key,
        }

        # Retry logic for 429 rate limiting
        max_retries = 2
        backoff = 5  # Initial backoff seconds

        for attempt in range(max_retries + 1):
            if stop_check and stop_check():
                return _FAIL("Stopped by user")

            try:
                resp = requests.post(url, json=payload, headers=headers, timeout=timeout)
                status = resp.status_code
                self._gemini_last_call = time.time()

                if status == 200:
                    data = resp.json()
                    content = ""
                    grounding_meta = None
                    if "candidates" in data and data["candidates"]:
                        candidate = data["candidates"][0]
                        parts = candidate.get("content", {}).get("parts", [])
                        content = "".join(p.get("text", "") for p in parts)
                        if "groundingMetadata" in candidate:
                            grounding_meta = candidate["groundingMetadata"]

                    return {
                        "success": True,
                        "content": content,
                        "model": model,
                        "error": "",
                        "grounding_metadata": grounding_meta,
                        "status_code": 200,
                    }

                elif status == 429:
                    if attempt < max_retries:
                        # Retry with exponential backoff
                        if not self._interruptible_sleep(backoff, stop_check):
                            return _FAIL("Stopped by user", 429)
                        backoff = min(backoff * 2, 30)
                        continue
                    return _FAIL(f"Rate limited (429) after {max_retries} retries", 429)

                elif status >= 500:
                    if attempt < max_retries:
                        if not self._interruptible_sleep(5, stop_check):
                            return _FAIL("Stopped by user", status)
                        continue
                    return _FAIL(f"Server error ({status}): {resp.text[:300]}", status)

                else:
                    return _FAIL(f"HTTP {status}: {resp.text[:500]}", status)

            except requests.exceptions.Timeout:
                if attempt < max_retries:
                    continue
                return _FAIL("Timeout", 0)
            except Exception as e:
                return _FAIL(str(e), 0)

        return _FAIL("Max retries exceeded", 0)


def load_gemini_keys(app_dir: str = None) -> list:
    """Load Gemini API keys from gemini_keys.json.

    Args:
        app_dir: Application directory. If None, uses the default app directory.

    Returns:
        List of API key strings, or empty list if file not found.
    """
    if app_dir is None:
        app_dir = _APP_DIR
    keys_path = os.path.join(app_dir, "gemini_keys.json")
    if not os.path.exists(keys_path):
        return []
    try:
        with open(keys_path, "r", encoding="utf-8") as f:
            data = json.load(f)
        return [k for k in data.get("keys", []) if k and k.strip()]
    except (json.JSONDecodeError, IOError):
        return []


def save_gemini_keys(keys: list, app_dir: str = None):
    """Save Gemini API keys list to gemini_keys.json.

    Args:
        keys: List of API key strings.
        app_dir: Application directory. If None, uses the default app directory.
    """
    if app_dir is None:
        app_dir = _APP_DIR
    keys_path = os.path.join(app_dir, "gemini_keys.json")
    with open(keys_path, "w", encoding="utf-8") as f:
        json.dump({"keys": keys}, f, indent=2, ensure_ascii=False)

