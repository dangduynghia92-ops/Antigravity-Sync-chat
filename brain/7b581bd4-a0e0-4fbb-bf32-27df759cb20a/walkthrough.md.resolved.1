"""
regroup.py — Core logic for the Regroup module.
Scan split chapters, classify by niche via AI, copy to grouped folders.
"""
import os
import re
import json
import shutil
import hashlib
from dataclasses import dataclass, field, asdict
from typing import Optional


def _natural_sort_key(name: str):
    """Sort key for natural ordering: Chapter 1, 2, ..., 10 instead of 1, 10, 2."""
    return [int(c) if c.isdigit() else c.lower()
            for c in re.split(r'(\d+)', name)]


@dataclass
class ChapterEntry:
    """Represents a single chapter found during scanning."""
    source_script: str       # Subfolder name (e.g. "Top 10 bí ẩn")
    chapter_title: str       # e.g. "Chapter 2 - Kim tự tháp"
    chapter_number: int
    file_path: str           # Absolute path to chapter file
    summary: str = ""        # From _SUMMARY.txt
    file_hash: str = ""      # MD5 hash for tracking

    @property
    def id(self):
        """Unique ID: 'source/chapter_title'."""
        return f"{self.source_script}/{self.chapter_title}"


# ── Niche Management ────────────────────────────────────────────────

def get_niches_dir():
    """Return the niches directory path."""
    return os.path.join(os.path.dirname(os.path.dirname(__file__)), "niches")


def list_broad_topics():
    """List available broad topic files in niches/ folder."""
    niches_dir = get_niches_dir()
    if not os.path.isdir(niches_dir):
        return []
    topics = []
    for f in os.listdir(niches_dir):
        if f.endswith(".txt"):
            name = os.path.splitext(f)[0]
            topics.append(name)
    return sorted(topics)


def load_niche_list(topic_name: str) -> list:
    """Load niche list from file. Returns list of niche strings."""
    path = os.path.join(get_niches_dir(), f"{topic_name}.txt")
    if not os.path.isfile(path):
        return []
    with open(path, "r", encoding="utf-8") as f:
        lines = [line.strip() for line in f if line.strip()]
    return lines


def save_niche_list(topic_name: str, niches: list):
    """Save niche list to file."""
    niches_dir = get_niches_dir()
    os.makedirs(niches_dir, exist_ok=True)
    path = os.path.join(niches_dir, f"{topic_name}.txt")
    with open(path, "w", encoding="utf-8") as f:
        for niche in niches:
            f.write(niche.strip() + "\n")


# ── Scanning ────────────────────────────────────────────────────────

def _compute_file_hash(path: str) -> str:
    """Compute MD5 hash of file content."""
    try:
        with open(path, "rb") as f:
            return hashlib.md5(f.read()).hexdigest()
    except Exception:
        return ""


def _parse_summary_file(summary_path: str) -> dict:
    """
    Parse a _SUMMARY.txt file.
    Returns dict: {chapter_number: {"title": ..., "summary": ...}}
    """
    result = {}
    try:
        with open(summary_path, "r", encoding="utf-8") as f:
            content = f.read()

        current_num = None
        current_title = ""
        current_summary = ""

        for line in content.split("\n"):
            # Match: "Chapter N: Title"
            m = re.match(r"Chapter\s+(\d+):\s*(.*)", line)
            if m:
                # Save previous
                if current_num is not None:
                    result[current_num] = {
                        "title": current_title,
                        "summary": current_summary.strip(),
                    }
                current_num = int(m.group(1))
                current_title = m.group(2).strip()
                current_summary = ""
                continue

            # Match: "  Summary: ..." or "  Preview: ..."
            sm = re.match(r"\s+(Summary|Preview):\s*(.*)", line)
            if sm and current_num is not None:
                current_summary = sm.group(2).strip()

        # Save last
        if current_num is not None:
            result[current_num] = {
                "title": current_title,
                "summary": current_summary.strip(),
            }
    except Exception:
        pass

    return result


def scan_output_folder(folder: str, log_callback=None, min_content_length: int = 0) -> tuple:
    """
    Scan output folder for chapter files and summaries.
    
    Args:
        folder: path to scan
        log_callback: logging function
        min_content_length: if > 0, skip chapters with fewer chars than this
    
    Returns:
        (chapters: list[ChapterEntry], missing_summary: list[str])
    """
    chapters = []
    missing_summary = []
    filtered_count = 0

    if not os.path.isdir(folder):
        return chapters, missing_summary

    for subdir in sorted(os.listdir(folder), key=_natural_sort_key):
        subdir_path = os.path.join(folder, subdir)
        if not os.path.isdir(subdir_path):
            continue

        # Skip regroup output folders (they contain _GROUP_INFO.json)
        if os.path.isfile(os.path.join(subdir_path, "_GROUP_INFO.json")):
            continue

        # Find summary file
        summary_data = {}
        summary_files = [f for f in os.listdir(subdir_path) if f.endswith("_SUMMARY.txt")]
        if summary_files:
            summary_data = _parse_summary_file(
                os.path.join(subdir_path, summary_files[0])
            )
        else:
            missing_summary.append(subdir)

        # Find chapter files
        for f in sorted(os.listdir(subdir_path), key=_natural_sort_key):
            # Match "Chapter N - ..." or "72_Chapter N - ..."
            ch_match = re.match(r"(?:\d+_)?Chapter\s+(\d+)", f)
            is_chapter = (
                ch_match
                and (f.endswith(".txt") or f.endswith(".md"))
                and "_MERGED" not in f
                and "_SUMMARY" not in f
                and "_VERIFY" not in f
            )
            if not is_chapter:
                continue

            ch_num = int(ch_match.group(1))

            file_path = os.path.join(subdir_path, f)

            # Filter by content length
            if min_content_length > 0:
                try:
                    content_len = os.path.getsize(file_path)
                    if content_len < min_content_length:
                        filtered_count += 1
                        continue
                except OSError:
                    pass

            # Get summary from parsed summary file
            ch_info = summary_data.get(ch_num, {})
            summary_text = ch_info.get("summary", "")

            entry = ChapterEntry(
                source_script=subdir,
                chapter_title=os.path.splitext(f)[0],
                chapter_number=ch_num,
                file_path=file_path,
                summary=summary_text,
                file_hash=_compute_file_hash(file_path),
            )
            chapters.append(entry)

    if log_callback:
        log_callback(
            f"Scanned: {len(chapters)} chapters from "
            f"{len(set(ch.source_script for ch in chapters))} scripts"
        )
        if filtered_count > 0:
            log_callback(
                f"Filtered: {filtered_count} chapters skipped (< {min_content_length:,} chars)"
            )
        if missing_summary:
            log_callback(
                f"Warning: {len(missing_summary)} folder(s) missing summary: "
                + ", ".join(missing_summary[:5])
            )

    return chapters, missing_summary


# ── Generate Missing Summaries ──────────────────────────────────────

def generate_missing_summary(
    subdir_path: str,
    subdir_name: str,
    api_client,
    log_callback=None,
) -> str:
    """
    Generate a _SUMMARY.txt for a subfolder that is missing one.
    Reads all chapter files, sends to AI for summarization.
    
    Returns: path to created summary file, or "" on failure.
    """
    # Find chapter files
    chapter_files = []
    for f in sorted(os.listdir(subdir_path), key=_natural_sort_key):
        is_chapter = (
            re.match(r"(?:\d+_)?Chapter\s+\d+", f)
            and (f.endswith(".txt") or f.endswith(".md"))
            and "_MERGED" not in f
            and "_SUMMARY" not in f
            and "_VERIFY" not in f
        )
        if is_chapter:
            chapter_files.append(f)

    if not chapter_files:
        if log_callback:
            log_callback(f"No chapter files in '{subdir_name}'")
        return ""

    if log_callback:
        log_callback(f"Generating summary for '{subdir_name}' ({len(chapter_files)} chapters)...")

    # Read all chapters
    chapters_text = []
    for f in chapter_files:
        ch_match = re.match(r"Chapter\s+(\d+)", f)
        ch_num = int(ch_match.group(1)) if ch_match else 0
        ch_title = os.path.splitext(f)[0]

        try:
            with open(os.path.join(subdir_path, f), "r", encoding="utf-8") as fh:
                content = fh.read()
        except Exception:
            content = "(could not read)"

        chapters_text.append(
            f"Chapter {ch_num}: {ch_title}\nContent:\n{content}"
        )

    # Send to AI
    summary_prompt = (
        "For each chapter below, write a concise 3-6 sentence summary of the main content. "
        "Focus on key events, arguments, or facts discussed.\n"
        "Output ONLY valid JSON in this format:\n"
        '{"summaries": [{"number": 1, "summary": "3-6 sentence summary..."}]}\n\n'
        + "\n---\n".join(chapters_text)
    )

    messages = [
        {"role": "system", "content": "You are a content summarizer. Output ONLY valid JSON."},
        {"role": "user", "content": summary_prompt},
    ]

    try:
        result = api_client.call_api(messages)
        if not result["success"]:
            if log_callback:
                log_callback(f"API error for '{subdir_name}': {result['error']}")
            return ""

        # Parse AI response
        content = result["content"]
        json_match = re.search(r'\{[\s\S]*\}', content)
        if json_match:
            parsed = json.loads(json_match.group())
        else:
            parsed = json.loads(content)

        summaries = {}
        for s in parsed.get("summaries", []):
            summaries[s.get("number", 0)] = s.get("summary", "")

    except Exception as e:
        if log_callback:
            log_callback(f"Summary generation failed for '{subdir_name}': {e}")
        return ""

    # Write summary file (same format as chapter_splitter.save_summary)
    safe_name = re.sub(r'[<>:"/\\|?*]', '', subdir_name)
    summary_path = os.path.join(subdir_path, f"{safe_name}_SUMMARY.txt")

    with open(summary_path, "w", encoding="utf-8") as f:
        f.write(f"Chapter Summary — {subdir_name}\n")
        f.write("=" * 60 + "\n\n")
        f.write(f"Total chapters: {len(chapter_files)}\n\n")

        for cf in chapter_files:
            ch_match = re.match(r"Chapter\s+(\d+)", cf)
            ch_num = int(ch_match.group(1)) if ch_match else 0
            ch_title = os.path.splitext(cf)[0]

            f.write(f"Chapter {ch_num}: {ch_title}\n")

            summary = (summaries.get(ch_num) or
                       summaries.get(ch_num - 1) or
                       summaries.get(ch_num + 1) or "")
            if summary:
                f.write(f"  Summary: {summary}\n\n")
            else:
                # Fallback: read first 200 chars
                try:
                    with open(os.path.join(subdir_path, cf), "r", encoding="utf-8") as fh:
                        preview = fh.read(200).replace("\n", " ")
                    f.write(f"  Preview: {preview}...\n\n")
                except Exception:
                    f.write("  Preview: (could not read)\n\n")

    if log_callback:
        log_callback(f"✓ Summary created for '{subdir_name}'")

    return summary_path


# ── AI Classification ───────────────────────────────────────────────

def _load_regroup_prompt():
    """Load the regroup system prompt."""
    prompt_path = os.path.join(
        os.path.dirname(os.path.dirname(__file__)),
        "prompts", "system_regroup.txt"
    )
    try:
        with open(prompt_path, "r", encoding="utf-8") as f:
            return f.read()
    except FileNotFoundError:
        return (
            "You are a content classifier. Classify each chapter into "
            "the most fitting niche. Output ONLY valid JSON."
        )


def classify_chapters(
    chapters: list,
    niche_list: list,
    api_client,
    batch_size: int = 50,
    log_callback=None,
) -> dict:
    """
    Use AI to classify chapters into niches.
    Uses sequential numbered IDs (#1, #2, ...) for reliable matching.
    
    Returns:
        dict with "groups" key, each group has "chapters" containing
        actual ChapterEntry objects (not string IDs).
    """
    system_prompt = _load_regroup_prompt()
    niche_text = "\n".join(f"- {n}" for n in niche_list)

    if log_callback:
        log_callback(f"Preparing {len(chapters)} chapters for classification...")
        log_callback(f"Niches: {', '.join(niche_list)}")

    all_groups = {}  # niche -> {"chapters": [], "suggested_titles": []}

    # Build numbered chapter list + index map
    index_map = {}  # number -> ChapterEntry
    chapter_lines = []
    for i, ch in enumerate(chapters, 1):
        index_map[i] = ch
        summary_part = f" — {ch.summary}" if ch.summary else ""
        chapter_lines.append(
            f"#{i}: [{ch.source_script}] {ch.chapter_title}{summary_part}"
        )
        if log_callback and i <= 5:
            log_callback(f"  #{i}: {ch.source_script}/{ch.chapter_title}")
    if log_callback and len(chapters) > 5:
        log_callback(f"  ... and {len(chapters) - 5} more")

    # Split into batches
    batches = []
    for i in range(0, len(chapter_lines), batch_size):
        batch_start = i
        batch_end = min(i + batch_size, len(chapter_lines))
        batches.append((batch_start, chapter_lines[batch_start:batch_end]))

    for batch_idx, (offset, batch) in enumerate(batches):
        if log_callback:
            log_callback(
                f"━━ Batch {batch_idx + 1}/{len(batches)} "
                f"({len(batch)} chapters) → Sending to AI..."
            )

        user_prompt = (
            f"Available niches:\n{niche_text}\n\n"
            f"Chapters to classify (use the # number as ID):\n"
            + "\n".join(batch)
        )

        messages = [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": user_prompt},
        ]

        if log_callback:
            log_callback(f"  Waiting for AI response...")

        result = api_client.call_api(messages)
        if not result["success"]:
            if log_callback:
                log_callback(f"  ❌ API error: {result['error']}")
            continue

        if log_callback:
            model_name = result.get("model", "?")
            endpoint = result.get("endpoint_url", "?")
            log_callback(f"  ✓ Response from model: {model_name}")
            log_callback(f"    Endpoint: {endpoint}")
            log_callback(f"  Parsing response...")

        # Parse AI response
        try:
            content = result["content"]
            # Extract JSON from response
            json_match = re.search(r'\{[\s\S]*\}', content)
            if json_match:
                parsed = json.loads(json_match.group())
            else:
                parsed = json.loads(content)

            for group in parsed.get("groups", []):
                niche = group.get("niche", "Không khớp")
                if niche not in all_groups:
                    all_groups[niche] = {
                        "chapters": [],
                        "suggested_titles": group.get("suggested_titles", []),
                    }

                for ch_ref in group.get("chapters", []):
                    # Extract the number from the ID
                    raw_id = ch_ref.get("id", "")
                    reason = ch_ref.get("reason", "")

                    # Parse number: could be "#3", "3", "#3:", etc.
                    num_match = re.search(r'#?(\d+)', str(raw_id))
                    if num_match:
                        num = int(num_match.group(1))
                        ch = index_map.get(num)
                        if ch:
                            all_groups[niche]["chapters"].append({
                                "chapter": ch,
                                "reason": reason,
                            })
                        elif log_callback:
                            log_callback(
                                f"  ⚠️ ID #{num} out of range (max: {len(chapters)})"
                            )
                    elif log_callback:
                        log_callback(f"  ⚠️ Cannot parse ID: '{raw_id}'")

                # Merge suggested titles
                for title in group.get("suggested_titles", []):
                    if title not in all_groups[niche]["suggested_titles"]:
                        all_groups[niche]["suggested_titles"].append(title)

            if log_callback:
                batch_total = sum(
                    len(g["chapters"]) for g in all_groups.values()
                )
                log_callback(
                    f"  ✓ Parsed: {len(parsed.get('groups', []))} groups, "
                    f"{batch_total} chapters total so far"
                )

        except (json.JSONDecodeError, KeyError) as e:
            if log_callback:
                log_callback(f"  ❌ Failed to parse AI response: {e}")
                # Log first 200 chars of response for debugging
                log_callback(f"  Response preview: {content[:200]}...")

    # Convert to final format
    groups_list = []
    for niche, data in all_groups.items():
        ch_count = len(data["chapters"])
        groups_list.append({
            "niche": niche,
            "suggested_titles": data["suggested_titles"],
            "chapters": data["chapters"],  # now contains {"chapter": ChapterEntry, "reason": str}
        })
        if log_callback:
            titles_str = " | ".join(data["suggested_titles"][:2])
            log_callback(f"  📁 {niche}: {ch_count} chapters → {titles_str}")

    if log_callback:
        total = sum(len(g["chapters"]) for g in groups_list)
        log_callback(
            f"━━ Classification done: {len(groups_list)} groups, "
            f"{total}/{len(chapters)} chapters classified"
        )

    return {"groups": groups_list}


# ── Used Tracker ────────────────────────────────────────────────────

def load_used_tracker(folder: str) -> dict:
    """Load used chapters tracker from folder."""
    path = os.path.join(folder, "_USED_TRACKER.json")
    if not os.path.isfile(path):
        return {"used_chapters": []}
    try:
        with open(path, "r", encoding="utf-8") as f:
            return json.load(f)
    except Exception:
        return {"used_chapters": []}


def save_used_tracker(folder: str, data: dict):
    """Save used chapters tracker to folder."""
    path = os.path.join(folder, "_USED_TRACKER.json")
    with open(path, "w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False, indent=2)


def is_chapter_used(tracker: dict, chapter: ChapterEntry) -> Optional[str]:
    """
    Check if chapter is already used.
    Returns assigned_to group name if used, None otherwise.
    """
    for entry in tracker.get("used_chapters", []):
        if entry.get("path") == chapter.file_path:
            return entry.get("assigned_to", "unknown")
        if entry.get("hash") and entry.get("hash") == chapter.file_hash:
            return entry.get("assigned_to", "unknown")
    return None


def mark_chapters_used(tracker: dict, chapters: list, group_name: str):
    """Mark chapters as used in tracker."""
    from datetime import datetime
    date_str = datetime.now().strftime("%Y-%m-%d")
    for ch in chapters:
        tracker["used_chapters"].append({
            "path": ch.file_path,
            "hash": ch.file_hash,
            "source": ch.source_script,
            "title": ch.chapter_title,
            "assigned_to": group_name,
            "date": date_str,
        })


# ── Copy to Group ──────────────────────────────────────────────────

def _sanitize_folder_name(name: str) -> str:
    """Convert Vietnamese text to safe folder name."""
    import unicodedata
    # Normalize unicode
    name = unicodedata.normalize("NFD", name)
    # Remove diacritics
    name = "".join(c for c in name if unicodedata.category(c) != "Mn")
    # Replace spaces and special chars
    name = re.sub(r'[<>:"/\\|?*]', '', name)
    name = re.sub(r'\s+', '_', name.strip())
    name = name.lower()
    return name


def _find_existing_group(regroup_dir: str, niche_name: str):
    """Find an existing folder matching the niche name (with or without numbering)."""
    sanitized = _sanitize_folder_name(niche_name)
    if not os.path.isdir(regroup_dir):
        return None
    for d in os.listdir(regroup_dir):
        if not os.path.isdir(os.path.join(regroup_dir, d)):
            continue
        d_lower = d.lower()
        # Match exact name or name with _NNN suffix
        if d_lower == sanitized or re.match(rf"{re.escape(sanitized)}_\d+$", d_lower):
            return d
    return None


def copy_to_group(
    chapters: list,
    niche_name: str,
    broad_topic: str,
    suggested_titles: list,
    regroup_dir: str,
    scan_folder: str,
    log_callback=None,
) -> str:
    """
    Copy selected chapter files to a group folder.
    Reuses existing folder if one matches the niche name,
    otherwise creates a new one.
    Updates the used tracker.

    Returns: path to group folder
    """
    os.makedirs(regroup_dir, exist_ok=True)

    # Look for existing folder matching this niche
    existing = _find_existing_group(regroup_dir, niche_name)
    if existing:
        folder_name = existing
        is_new = False
    else:
        folder_name = _sanitize_folder_name(niche_name)
        is_new = True

    group_path = os.path.join(regroup_dir, folder_name)
    os.makedirs(group_path, exist_ok=True)

    action = "Creating" if is_new else "Appending to"
    if log_callback:
        log_callback(f"━━ {action} group: {folder_name}")
        log_callback(f"   Output: {group_path}")
        log_callback(f"   Chapters to copy: {len(chapters)}")

    # Copy files (skip if file with same name already exists)
    copied = 0
    skipped = 0
    chapter_info = []
    for ch in chapters:
        if not os.path.isfile(ch.file_path):
            if log_callback:
                log_callback(f"   ⚠️ File not found: {ch.file_path}")
            continue

        dest = os.path.join(group_path, os.path.basename(ch.file_path))
        if os.path.isfile(dest):
            skipped += 1
            continue
        shutil.copy2(ch.file_path, dest)
        copied += 1
        if log_callback:
            log_callback(f"   ✓ Copied: {ch.source_script}/{os.path.basename(ch.file_path)}")
        chapter_info.append({
            "source": ch.source_script,
            "title": ch.chapter_title,
            "original_path": ch.file_path,
            "summary": ch.summary,
        })

    # Update group info (merge with existing if present)
    info_path = os.path.join(group_path, "_GROUP_INFO.json")
    if os.path.isfile(info_path) and not is_new:
        with open(info_path, "r", encoding="utf-8") as f:
            group_info = json.load(f)
        group_info["chapters"].extend(chapter_info)
        group_info["chapter_count"] = len(group_info["chapters"])
        group_info["updated"] = __import__("datetime").datetime.now().strftime("%Y-%m-%d %H:%M")
    else:
        group_info = {
            "niche": niche_name,
            "broad_topic": broad_topic,
            "suggested_titles": suggested_titles,
            "created": __import__("datetime").datetime.now().strftime("%Y-%m-%d %H:%M"),
            "chapter_count": len(chapter_info),
            "chapters": chapter_info,
        }

    with open(info_path, "w", encoding="utf-8") as f:
        json.dump(group_info, f, ensure_ascii=False, indent=2)

    # Update used tracker
    tracker = load_used_tracker(scan_folder)
    mark_chapters_used(tracker, chapters, folder_name)
    save_used_tracker(scan_folder, tracker)

    if log_callback:
        msg = f"   ✓ Done: {copied} copied"
        if skipped:
            msg += f", {skipped} skipped (already exists)"
        log_callback(msg)

    return group_path
