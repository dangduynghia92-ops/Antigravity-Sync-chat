from core.regroup import (
    list_broad_topics, load_niche_list, save_niche_list,
    scan_output_folder, classify_chapters, ChapterEntry,
    load_used_tracker, is_chapter_used, copy_to_group,
    generate_missing_summary,
    FolderEntry, scan_output_folder_as_folders,
    classify_folders, move_folder_to_group,
)


class RegroupTab(QWidget):
    """Tab for regrouping split chapters by niche topic."""

    CONFIG_NAME = "regroup_config"

    progress_text = pyqtSignal(str)  # Update progress column text

    def __init__(self, parent=None):
        super().__init__(parent)
        self._chapters = []        # All scanned ChapterEntry
        self._folders = []         # All scanned FolderEntry (folder mode)
        self._classification = {}  # AI classification result
        self._tracker = {}         # Used tracker
        self._build_ui()
        self._load_saved_config()
        self.progress_text.connect(self._on_progress_text)

    def _build_ui(self):
        outer = QVBoxLayout(self)
        outer.setContentsMargins(0, 0, 0, 0)
        outer.setSpacing(0)

        vsplitter = QSplitter(Qt.Orientation.Vertical)

        content = QWidget()
        main_layout = QVBoxLayout(content)
        main_layout.setContentsMargins(8, 8, 8, 4)
        main_layout.setSpacing(6)

        # ── Row 1: Scan folder + Output ──
        row1 = QHBoxLayout()
        row1.setSpacing(6)

        row1.addWidget(QLabel("Scan Folder:"))
        self._txt_scan = QLineEdit()
        self._txt_scan.setFixedHeight(28)
        self._txt_scan.setMinimumWidth(180)
        self._txt_scan.setPlaceholderText("Folder chứa chapters đã tách...")
        row1.addWidget(self._txt_scan)

        btn_browse_scan = QPushButton("...")
        btn_browse_scan.setToolTip("Chọn folder chứa các file chapter")
        btn_browse_scan.setFixedSize(28, 28)
        btn_browse_scan.clicked.connect(self._browse_scan)
        row1.addWidget(btn_browse_scan)

        row1.addWidget(QLabel("Output:"))
