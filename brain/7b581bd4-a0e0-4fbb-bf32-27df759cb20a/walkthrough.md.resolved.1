    def _refresh_topics(self):
        current = self._combo_topic.currentText()
        self._combo_topic.clear()
        topics = list_broad_topics()
        self._combo_topic.addItems(topics)
        if current:
            idx = self._combo_topic.findText(current)
            if idx >= 0:
                self._combo_topic.setCurrentIndex(idx)

    def _on_topic_changed(self, topic):
        self._niche_list.clear()
        if not topic:
            return
        niches = load_niche_list(topic)
        for niche in niches:
            item = QListWidgetItem(niche)
            item.setFlags(item.flags() | Qt.ItemFlag.ItemIsUserCheckable)
            item.setCheckState(Qt.CheckState.Checked)
            self._niche_list.addItem(item)

    def _add_niche(self):
        text, ok = QInputDialog.getText(self, "Thêm ngách", "Tên ngách mới:")
        if ok and text.strip():
            item = QListWidgetItem(text.strip())
            item.setFlags(item.flags() | Qt.ItemFlag.ItemIsUserCheckable)
            item.setCheckState(Qt.CheckState.Checked)
            self._niche_list.addItem(item)
            self._save_niches_to_file()

    def _remove_niche(self):
        items = self._niche_list.selectedItems()
        for item in items:
            self._niche_list.takeItem(self._niche_list.row(item))
        self._save_niches_to_file()

    def _select_all_niches(self):
        for i in range(self._niche_list.count()):
            self._niche_list.item(i).setCheckState(Qt.CheckState.Checked)

    def _deselect_all_niches(self):
        for i in range(self._niche_list.count()):
            self._niche_list.item(i).setCheckState(Qt.CheckState.Unchecked)

    def _save_niches_to_file(self):
        topic = self._combo_topic.currentText()
        if not topic:
            return
        niches = []
        for i in range(self._niche_list.count()):
            niches.append(self._niche_list.item(i).text())
        save_niche_list(topic, niches)

    def _get_selected_niches(self):
        niches = []
        for i in range(self._niche_list.count()):
            item = self._niche_list.item(i)
            if item.checkState() == Qt.CheckState.Checked:
                niches.append(item.text())
        return niches

    # ── Mode Helper ─────────────────────────────────────────────────

    def _is_folder_mode(self):
        return self._combo_mode.currentText() == "Folder"

    # ── Scan ────────────────────────────────────────────────────────

    def _do_scan(self):
        if self._is_folder_mode():
            return self._do_scan_folders()
        return self._do_scan_chapters()

    def _do_scan_chapters(self):
        folder = self._txt_scan.text().strip()
        if not folder or not os.path.isdir(folder):
            self._log.log("[Regroup] Scan folder not set or doesn't exist")
            return

        self._log.log("[Regroup] Scanning chapters...")
        self._log.set_status("Scanning...", False)

        # Read widget values on main thread before starting background work
        min_chars = self._spin_min_chars.value() if self._chk_min_chars.isChecked() else 0
        tier = self._combo_tier.currentText().lower()

        def _run():
            try:
                self.progress_text.emit("Scanning...")
                chapters, missing = scan_output_folder(
                    folder,
                    log_callback=lambda m: self._log.log(f"[Regroup] {m}"),
                    min_content_length=min_chars,
                )

                # Auto-generate missing summaries
                if missing:
                    total_missing = len(missing)
                    self._log.log(
                        f"[Regroup] ⚠️ {total_missing} folder(s) thiếu summary, đang tạo tự động..."
                    )
                    self._log.set_status("Generating summaries...", False)

                    endpoints = load_api_keys()
                    api_client = APIClient(endpoints, log_api=False, tier=tier)

                    for idx, subdir_name in enumerate(missing):
                        self.progress_text.emit(f"Summary {idx+1}/{total_missing}")
                        subdir_path = os.path.join(folder, subdir_name)
                        generate_missing_summary(
                            subdir_path, subdir_name, api_client,
                            log_callback=lambda m: self._log.log(f"[Regroup] {m}")
                        )

                    # Re-scan to pick up new summaries
                    self._log.log("[Regroup] Re-scanning with new summaries...")
                    chapters, still_missing = scan_output_folder(
                        folder,
                        log_callback=lambda m: self._log.log(f"[Regroup] {m}"),
                        min_content_length=min_chars,
                    )
                    if still_missing:
                        self._log.log(
                            f"[Regroup] ⚠️ {len(still_missing)} folder(s) vẫn thiếu summary: "
                            + ", ".join(still_missing[:5])
                        )

                self._chapters = chapters
                self._tracker = load_used_tracker(folder)

                self._log.log(
                    f"[Regroup] Found {len(chapters)} chapters "
                    f"from {len(set(ch.source_script for ch in chapters))} scripts"
                )
                self._log.set_status("Scan done", False)
                self.progress_text.emit("✓ Done")

                # Build scan results in tree (no classification yet)
                self._classification = {}
                self._refresh_tree()

            except Exception as e:
                self._log.log(f"[Regroup] Scan error: {e}")
                self._log.set_status("Error", True)
                self.progress_text.emit("✗ Error")

        threading.Thread(target=_run, daemon=True).start()

    # ── Scan Folders ────────────────────────────────────────────────

    def _do_scan_folders(self):
        folder = self._txt_scan.text().strip()
        if not folder or not os.path.isdir(folder):
            self._log.log("[Regroup] Scan folder not set or doesn't exist")
            return

        self._log.log("[Regroup-Folder] Scanning folders...")
        self._log.set_status("Scanning folders...", False)

        min_chars = self._spin_min_chars.value() if self._chk_min_chars.isChecked() else 0
        tier = self._combo_tier.currentText().lower()

        def _run():
            try:
                self.progress_text.emit("Scanning...")
                folder_entries = scan_output_folder_as_folders(
                    folder,
                    log_callback=lambda m: self._log.log(f"[Regroup-Folder] {m}"),
                    min_content_length=min_chars,
                )

                # Check for missing summaries
                missing = []
                for fe in folder_entries:
                    has_summary = any(ch.summary for ch in fe.chapters)
                    if not has_summary:
                        missing.append(fe.folder_name)

                if missing:
                    total_missing = len(missing)
                    self._log.log(
                        f"[Regroup-Folder] ⚠️ {total_missing} folder(s) thiếu summary, đang tạo tự động..."
                    )
                    self._log.set_status("Generating summaries...", False)

                    endpoints = load_api_keys()
                    api_client = APIClient(endpoints, log_api=False, tier=tier)

                    for idx, subdir_name in enumerate(missing):
                        self.progress_text.emit(f"Summary {idx+1}/{total_missing}")
                        subdir_path = os.path.join(folder, subdir_name)
                        generate_missing_summary(
                            subdir_path, subdir_name, api_client,
                            log_callback=lambda m: self._log.log(f"[Regroup-Folder] {m}")
                        )

                    # Re-scan
                    self._log.log("[Regroup-Folder] Re-scanning with new summaries...")
                    folder_entries = scan_output_folder_as_folders(
                        folder,
                        log_callback=lambda m: self._log.log(f"[Regroup-Folder] {m}"),
                        min_content_length=min_chars,
                    )

                self._folders = folder_entries
                self._chapters = []  # Clear chapter mode data

                self._log.log(
                    f"[Regroup-Folder] Found {len(folder_entries)} folders, "
                    f"{sum(fe.chapter_count for fe in folder_entries)} chapters total"
                )
                self._log.set_status("Scan done", False)
                self.progress_text.emit("✓ Done")

                self._classification = {}
                self._refresh_tree()

            except Exception as e:
                self._log.log(f"[Regroup-Folder] Scan error: {e}")
                self._log.set_status("Error", True)
                self.progress_text.emit("✗ Error")

        threading.Thread(target=_run, daemon=True).start()

    # ── Classify ────────────────────────────────────────────────────

    def _do_classify(self):
        if self._is_folder_mode():
            return self._do_classify_folders()
        return self._do_classify_chapters()

    def _do_classify_chapters(self):
        if not self._chapters:
            self._log.log("[Regroup] No chapters scanned. Run Scan first.")
            return

        niches = self._get_selected_niches()
        if not niches:
            self._log.log("[Regroup] No niches selected.")
            return

        self._log.log("[Regroup] Starting AI classification...")
        self._log.set_status("Classifying...", False)

        # Filter out used chapters if checkbox is on
        chapters_to_classify = self._chapters
        hide_used = self._chk_hide_used.isChecked()
        if hide_used:
            chapters_to_classify = [
                ch for ch in self._chapters
                if not is_chapter_used(self._tracker, ch)
            ]

        # Read widget values on main thread
        tier = self._combo_tier.currentText().lower()

        def _run():
            try:
                self.progress_text.emit("Classifying...")
                endpoints = load_api_keys()
                api_client = APIClient(endpoints, log_api=False, tier=tier)

                result = classify_chapters(
                    chapters_to_classify, niches, api_client,
                    log_callback=lambda m: self._log.log(f"[Regroup] {m}")
                )
                self._classification = result
                self._refresh_tree()
                self._log.set_status("Classification done", False)
                self.progress_text.emit("✓ Done")

                # Auto-export unmatched chapters to CSV
                try:
                    self._export_unmatched()
                except Exception as ex:
                    self._log.log(f"[Regroup] Export warning: {ex}")

            except Exception as e:
                self._log.log(f"[Regroup] Classification error: {e}")
                self._log.set_status("Error", True)
                self.progress_text.emit("✗ Error")

        threading.Thread(target=_run, daemon=True).start()

    # ── Classify Folders ────────────────────────────────────────────

    def _do_classify_folders(self):
        if not self._folders:
            self._log.log("[Regroup-Folder] No folders scanned. Run Scan first.")
            return

        niches = self._get_selected_niches()
        if not niches:
            self._log.log("[Regroup-Folder] No niches selected.")
            return

        self._log.log("[Regroup-Folder] Starting AI folder classification...")
        self._log.set_status("Classifying folders...", False)

        tier = self._combo_tier.currentText().lower()

        def _run():
            try:
                self.progress_text.emit("Classifying...")
                endpoints = load_api_keys()
                api_client = APIClient(endpoints, log_api=False, tier=tier)

                result = classify_folders(
                    self._folders, niches, api_client,
                    log_callback=lambda m: self._log.log(f"[Regroup-Folder] {m}")
                )
                self._classification = result
                self._refresh_tree()
                self._log.set_status("Classification done", False)
                self.progress_text.emit("✓ Done")

            except Exception as e:
                self._log.log(f"[Regroup-Folder] Classification error: {e}")
                self._log.set_status("Error", True)
                self.progress_text.emit("✗ Error")

        threading.Thread(target=_run, daemon=True).start()

    # ── Tree Display ────────────────────────────────────────────────

    def _refresh_tree(self):
        self._tree.clear()

        if self._classification and "groups" in self._classification:
            self._show_classification_tree()
        elif self._chapters:
            self._show_scan_tree()

    def _show_scan_tree(self):
        """Show scan results grouped by source script."""
        by_source = {}
        for ch in self._chapters:
            by_source.setdefault(ch.source_script, []).append(ch)

        total = 0
        used = 0
        for source, chs in sorted(by_source.items()):
            parent = QTreeWidgetItem([f"📁 {source}", "", f"{len(chs)} chapters"])
            parent.setFlags(parent.flags() | Qt.ItemFlag.ItemIsAutoTristate)
            parent.setCheckState(0, Qt.CheckState.Unchecked)

            for ch in sorted(chs, key=lambda c: c.chapter_number):
                used_by = is_chapter_used(self._tracker, ch)
                total += 1

                if used_by and self._chk_hide_used.isChecked():
                    used += 1
                    continue

                status = f"⚠️ đã dùng ({used_by})" if used_by else "✅ chưa dùng"
                child = QTreeWidgetItem([ch.chapter_title, ch.source_script, status])
                child.setFlags(child.flags() | Qt.ItemFlag.ItemIsUserCheckable)
                child.setCheckState(0, Qt.CheckState.Unchecked if used_by else Qt.CheckState.Checked)
                child.setData(0, Qt.ItemDataRole.UserRole, ch)
                parent.addChild(child)

                if used_by:
                    used += 1

            if parent.childCount() > 0:
                self._tree.addTopLevelItem(parent)

        self._lbl_stats.setText(f"Tổng: {total} | Đã dùng: {used} | Còn lại: {total - used}")

    def _show_classification_tree(self):
        """Show AI classification results grouped by niche."""
        total_classified = 0
        for group in self._classification.get("groups", []):
            niche = group.get("niche", "?")
            chapters_refs = group.get("chapters", [])
            titles = group.get("suggested_titles", [])
            title_text = " | ".join(titles[:2]) if titles else ""

            parent = QTreeWidgetItem([
                f"📁 {niche} ({len(chapters_refs)})",
                title_text,
                ""
            ])
            parent.setFlags(parent.flags() | Qt.ItemFlag.ItemIsAutoTristate)
            parent.setCheckState(0, Qt.CheckState.Checked)

            for ch_ref in chapters_refs:
                # New format: ch_ref has "chapter" (ChapterEntry) and "reason"
                ch = ch_ref.get("chapter")
                reason = ch_ref.get("reason", "")

                if not ch:
                    continue

                used_by = is_chapter_used(self._tracker, ch)
                if used_by and self._chk_hide_used.isChecked():
                    continue

                status = f"⚠️ đã dùng ({used_by})" if used_by else "✅"
                child = QTreeWidgetItem([
                    ch.chapter_title,
                    ch.source_script,
                    status,
                ])
                child.setToolTip(0, reason)
                child.setFlags(child.flags() | Qt.ItemFlag.ItemIsUserCheckable)
                child.setCheckState(0, Qt.CheckState.Unchecked if used_by else Qt.CheckState.Checked)
                child.setData(0, Qt.ItemDataRole.UserRole, ch)
                parent.addChild(child)
                total_classified += 1

            if parent.childCount() > 0:
                self._tree.addTopLevelItem(parent)
                parent.setExpanded(True)

        self._lbl_stats.setText(f"Phân loại: {total_classified} chapters")

    # ── Folder Mode: Tree Display ───────────────────────────────────

    def _show_folder_scan_tree(self):
        """Show scan results: one row per folder."""
        total_ch = 0
        for fe in self._folders:
            total_ch += fe.chapter_count
            summary_short = (fe.combined_summary or "")[:120]
            if len(fe.combined_summary or "") > 120:
                summary_short += "..."

            item = QTreeWidgetItem([
                f"📁 {fe.folder_name}",
                f"{fe.chapter_count} chapters, {fe.total_chars:,} chars",
                "✅ sẵn sàng",
                ""
            ])
            item.setToolTip(0, summary_short)
            item.setFlags(item.flags() | Qt.ItemFlag.ItemIsUserCheckable)
            item.setCheckState(0, Qt.CheckState.Checked)
            item.setData(0, Qt.ItemDataRole.UserRole, fe)
            self._tree.addTopLevelItem(item)

        self._lbl_stats.setText(f"Tổng: {len(self._folders)} folders, {total_ch} chapters")

    def _show_folder_classification_tree(self):
        """Show AI classification results grouped by niche, with folders as items."""
        total_classified = 0
        for group in self._classification.get("groups", []):
            niche = group.get("niche", "?")
            folder_refs = group.get("folders", [])
            titles = group.get("suggested_titles", [])
            title_text = " | ".join(titles[:2]) if titles else ""

            parent = QTreeWidgetItem([
                f"📁 {niche} ({len(folder_refs)})",
                title_text,
                ""
            ])
            parent.setFlags(parent.flags() | Qt.ItemFlag.ItemIsAutoTristate)
            parent.setCheckState(0, Qt.CheckState.Checked)

            for f_ref in folder_refs:
                fe = f_ref.get("folder")
                reason = f_ref.get("reason", "")
                if not fe:
                    continue

                child = QTreeWidgetItem([
                    fe.folder_name,
                    f"{fe.chapter_count} ch, {fe.total_chars:,} chars",
                    "✅",
                ])
                child.setToolTip(0, reason)
                child.setFlags(child.flags() | Qt.ItemFlag.ItemIsUserCheckable)
                child.setCheckState(0, Qt.CheckState.Checked)
                child.setData(0, Qt.ItemDataRole.UserRole, fe)
                parent.addChild(child)
                total_classified += 1

            if parent.childCount() > 0:
                self._tree.addTopLevelItem(parent)
                parent.setExpanded(True)

        self._lbl_stats.setText(f"Phân loại: {total_classified} folders")

    # ── AI Suggest ──────────────────────────────────────────────────

    def _ai_suggest(self):
        """Auto-select best N chapters per group using range."""
        max_n = 999  # No limit — select all available

        for i in range(self._tree.topLevelItemCount()):
            parent = self._tree.topLevelItem(i)
            child_count = parent.childCount()

            # Uncheck all first
            for j in range(child_count):
                parent.child(j).setCheckState(0, Qt.CheckState.Unchecked)

            # Check up to max_n, skip used
            checked = 0
            for j in range(child_count):
                child = parent.child(j)
                ch = child.data(0, Qt.ItemDataRole.UserRole)
                if ch and not is_chapter_used(self._tracker, ch):
                    if checked < max_n:
                        child.setCheckState(0, Qt.CheckState.Checked)
                        checked += 1

        self._log.log(f"[Regroup] AI Suggest: selected up to {max_n} chapters per group")

    # ── Copy to Group ───────────────────────────────────────────────

    def _do_copy(self):
        if self._is_folder_mode():
            return self._do_move_folders()
        return self._do_copy_chapters()

    def _do_copy_chapters(self):
        regroup_dir = self._txt_output.text().strip()
        scan_dir = self._txt_scan.text().strip()
        if not regroup_dir:
            self._log.log("[Regroup] Output folder not set")
            return
        if not scan_dir:
            self._log.log("[Regroup] Scan folder not set")
            return

        broad_topic = self._combo_topic.currentText()

        # Collect checked chapters per group
        groups_to_copy = []
        for i in range(self._tree.topLevelItemCount()):
            parent = self._tree.topLevelItem(i)
            niche_label = parent.text(0)
            # Extract niche name (remove icon and count)
            niche_name = re.sub(r'^📁\s*', '', niche_label)
            niche_name = re.sub(r'\s*\(\d+\)\s*$', '', niche_name)
            titles_text = parent.text(1)
            suggested_titles = [t.strip() for t in titles_text.split("|") if t.strip()]

            checked_chapters = []
            for j in range(parent.childCount()):
                child = parent.child(j)
                if child.checkState(0) == Qt.CheckState.Checked:
                    ch = child.data(0, Qt.ItemDataRole.UserRole)
                    if ch:
                        checked_chapters.append(ch)

            if checked_chapters:
                groups_to_copy.append((niche_name, suggested_titles, checked_chapters))

        if not groups_to_copy:
            self._log.log("[Regroup] No chapters selected")
            return

        total_ch = sum(len(chs) for _, _, chs in groups_to_copy)
        self._log.log(
            f"[Regroup] Copying {len(groups_to_copy)} group(s), "
            f"{total_ch} chapters → {regroup_dir}"
        )
        self._log.set_status("Copying...", False)

        def _run():
            try:
                total = len(groups_to_copy)
                for idx, (niche_name, titles, chapters) in enumerate(groups_to_copy):
                    self.progress_text.emit(f"Copying {idx+1}/{total}...")
                    group_path = copy_to_group(
                        chapters, niche_name, broad_topic, titles,
                        regroup_dir, scan_dir,
                        log_callback=lambda m: self._log.log(f"[Regroup] {m}")
                    )
                    self._log.log(f"[Regroup] ✓ Created: {os.path.basename(group_path)}")

                # Reload tracker
                self._tracker = load_used_tracker(scan_dir)
                self._refresh_tree()

                self._log.log(
                    f"[Regroup] Done — {total} group(s) created ✓"
                )
                self._log.set_status("Done", False)
                self.progress_text.emit("✓ Done")

            except Exception as e:
                self._log.log(f"[Regroup] Copy error: {e}")
                self._log.set_status("Error", True)
                self.progress_text.emit("✗ Error")

        threading.Thread(target=_run, daemon=True).start()

    # ── Move Folders ────────────────────────────────────────────────

    def _do_move_folders(self):
        regroup_dir = self._txt_output.text().strip()
        scan_dir = self._txt_scan.text().strip()
        if not regroup_dir:
            self._log.log("[Regroup-Folder] Output folder not set")
            return
        if not scan_dir:
            self._log.log("[Regroup-Folder] Scan folder not set")
            return

        broad_topic = self._combo_topic.currentText()

        # Collect checked folders per niche group
        groups_to_move = []
        for i in range(self._tree.topLevelItemCount()):
            parent = self._tree.topLevelItem(i)
            niche_label = parent.text(0)
            niche_name = re.sub(r'^📁\s*', '', niche_label)
            niche_name = re.sub(r'\s*\(\d+\)\s*$', '', niche_name)
            titles_text = parent.text(1)
            suggested_titles = [t.strip() for t in titles_text.split("|") if t.strip()]

            checked_folders = []
            # Check if top-level item itself is a FolderEntry (scan mode, no children)
            fe_self = parent.data(0, Qt.ItemDataRole.UserRole)
            if fe_self and isinstance(fe_self, FolderEntry):
                if parent.checkState(0) == Qt.CheckState.Checked:
                    checked_folders.append(fe_self)
            else:
                # Classified mode: check children
                for j in range(parent.childCount()):
                    child = parent.child(j)
                    if child.checkState(0) == Qt.CheckState.Checked:
                        fe = child.data(0, Qt.ItemDataRole.UserRole)
                        if fe and isinstance(fe, FolderEntry):
                            checked_folders.append(fe)

            if checked_folders:
                groups_to_move.append((niche_name, suggested_titles, checked_folders))

        if not groups_to_move:
            self._log.log("[Regroup-Folder] No folders selected")
            return

        total_f = sum(len(fes) for _, _, fes in groups_to_move)
        self._log.log(
            f"[Regroup-Folder] Moving {total_f} folder(s) into "
            f"{len(groups_to_move)} group(s) → {regroup_dir}"
        )
        self._log.set_status("Moving...", False)

        def _run():
            try:
                total = len(groups_to_move)
                for idx, (niche_name, titles, folder_entries) in enumerate(groups_to_move):
                    self.progress_text.emit(f"Moving {idx+1}/{total}...")
                    group_path = move_folder_to_group(
                        folder_entries, niche_name, broad_topic, titles,
                        regroup_dir, scan_dir,
                        log_callback=lambda m: self._log.log(f"[Regroup-Folder] {m}")
                    )
                    self._log.log(
                        f"[Regroup-Folder] ✓ Created: {os.path.basename(group_path)}"
                    )

                # Re-scan to update tree (moved folders are gone)
                self._folders = scan_output_folder_as_folders(
                    scan_dir,
                    log_callback=lambda m: self._log.log(f"[Regroup-Folder] {m}"),
                )
                self._classification = {}
                self._refresh_tree()

                self._log.log(
                    f"[Regroup-Folder] Done — {total} group(s) created ✓"
                )
                self._log.set_status("Done", False)
                self.progress_text.emit("✓ Done")

            except Exception as e:
                self._log.log(f"[Regroup-Folder] Move error: {e}")
                self._log.set_status("Error", True)
                self.progress_text.emit("✗ Error")

        threading.Thread(target=_run, daemon=True).start()
