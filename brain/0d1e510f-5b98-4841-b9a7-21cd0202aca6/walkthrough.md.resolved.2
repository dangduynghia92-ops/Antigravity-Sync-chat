def build_word_count_rule(wc_min: int, wc_max: int) -> str:
    """Build a word count rule string from min/max values."""
    if wc_min > 0 and wc_max > 0:
        return f"{wc_min} to {wc_max} words"
    elif wc_min > 0:
        return f"at least {wc_min} words"
    elif wc_max > 0:
        return f"at most {wc_max} words"
    else:
        return "SKIP"


