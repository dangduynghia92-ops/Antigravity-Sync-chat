        preview = ch["text"][:3000]
        if len(ch["text"]) > 3000:
            preview += "\n[...truncated...]"
        all_text += f"\n\n=== CHAPTER {i}: {ch['filename']} ===\n{preview}"

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": f"Here are {len(chapters)} chapters to reorder:\n{all_text}"},
    ]

    if log_callback:
        log_callback(f"AI suggesting chapter order for {len(chapters)} chapters...")

    result = api_client.call_api(
        messages, temperature=0.3, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"❌ Reorder failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"✓ Reorder suggestion via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        suggestion = json.loads(json_match.group())
    else:
        suggestion = json.loads(content)

    return suggestion


def export_reorder_csv(output_dir: str, suggestion: dict) -> str:
    """Export reorder suggestion to CSV with Vietnamese headers."""
    os.makedirs(output_dir, exist_ok=True)
    csv_path = _safe_csv_path(os.path.join(output_dir, "_REORDER_SUGGESTION.csv"))

    headers = ["STT mới", "STT cũ", "Tên chapter", "Lý do"]

    rows = []
    for item in suggestion.get("suggested_order", []):
        rows.append([
            item.get("new_position", ""),
            item.get("original_position", ""),
            item.get("filename", ""),
            item.get("reason_vi", ""),
        ])

    # Sort by new_position
    rows.sort(key=lambda r: r[0] if isinstance(r[0], int) else 0)

    with open(csv_path, "w", newline="", encoding="utf-8-sig") as f:
        writer = csv.writer(f)
        writer.writerow(headers)
        writer.writerows(rows)

        # Write strategy at the bottom
        strategy = suggestion.get("strategy_vi", "")
        if strategy:
            writer.writerow([])
            writer.writerow(["Chiến lược:", strategy])

    return csv_path


