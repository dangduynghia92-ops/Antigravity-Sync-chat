def export_review_report(output_dir: str, status: dict) -> str:
    """Export a CSV review report with Vietnamese column headers."""
    os.makedirs(output_dir, exist_ok=True)
    report_path = _safe_csv_path(os.path.join(output_dir, "_REVIEW_REPORT.csv"))

    headers = [
        "STT", "Chapter", "Score", "Đạt", "Số từ",
        "Điểm mạnh", "Vấn đề", "Gợi ý cải thiện",
        "So sánh: Hook", "So sánh: Giữ chân", "So sánh: Điểm yếu", "So sánh: Tổng"
    ]

    rows = []
    idx = 0
    for fname in sorted(status.get("chapters", {}).keys()):
        ch_info = status["chapters"][fname]
        if ch_info.get("status") != "verified":
            continue
        idx += 1

        strengths = ch_info.get("verify_strengths", [])
        issues = ch_info.get("verify_issues", [])
        issue_texts = []
        for iss in issues:
            sev = iss.get("severity", "")
            det = iss.get("detail", "")
            issue_texts.append(f"[{sev}] {det}")

        comp = ch_info.get("verify_comparison", {})
        rows.append([
            idx,
            fname,
            ch_info.get("verify_score", ""),
            "✓" if ch_info.get("verify_passed") else "✗",
            ch_info.get("verify_word_count", ""),
            "; ".join(strengths) if strengths else "",
            "; ".join(issue_texts) if issue_texts else "",
            ch_info.get("verify_suggestion", ""),
            comp.get("hook", ""),
            comp.get("retention", ""),
            comp.get("weakness", ""),
            comp.get("overall", ""),
        ])

    with open(report_path, "w", newline="", encoding="utf-8-sig") as f:
        writer = csv.writer(f)
        writer.writerow(headers)
        writer.writerows(rows)

    return report_path


