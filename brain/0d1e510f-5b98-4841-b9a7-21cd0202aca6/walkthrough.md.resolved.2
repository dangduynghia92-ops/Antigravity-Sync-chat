def _build_research_section_prompt(topic, section, lang):
    """Build a focused research prompt for one section."""
    return (
        f"You are a biographical research specialist. Research '{topic}' and extract data.\n\n"
        f"OUTPUT LANGUAGE: {lang}\n\n"
        f"{section['prompt_focus']}\n"
        f"Output ONLY valid JSON containing these fields. No markdown, no code fences, no explanation.\n"
        f"All source tags = \"ai_knowledge\".\n"
        f"Prefer SPECIFIC facts: dates, names, places — not \"many people\"."
    )


def _build_research_expand_prompt(topic, section, draft_json, lang):
    """Build an expand prompt to review and add missing details."""
    return (
        f"You are a biographical research specialist. A draft blueprint section about '{topic}' "
        f"has been created. Your task is to REVIEW it and ADD ALL missing details.\n\n"
        f"OUTPUT LANGUAGE: {lang}\n\n"
        f"SECTION: {section['name']}\n"
        f"FIELDS: {', '.join(section['fields'])}\n\n"
        f"CURRENT DRAFT:\n{draft_json}\n\n"
        f"INSTRUCTIONS:\n"
        f"1. Keep ALL existing data (do NOT remove anything)\n"
        f"2. ADD missing events, facts, relationships, quotes that are NOT in the draft\n"
        f"3. EXPAND items that are too brief — add specific dates, names, details\n"
        f"4. If a list has few items, ADD more known items\n"
        f"5. Each key_events list should include ALL known events for that phase\n\n"
        f"Output the COMPLETE expanded section as valid JSON. No markdown, no code fences."
    )


def _merge_research_sections(sections_data):
    """Merge multiple section results into one blueprint with key normalization."""
    merged = {}
    for data in sections_data:
        if isinstance(data, dict):
            for k, v in data.items():
                norm_key = _KEY_NORMALIZE.get(k, k)
                merged[norm_key] = v
    return merged


def research_blueprint_multicall(
    topic,
    api_endpoints,
    lang="en",
    save_dir=None,
    log_callback=None,
    stop_check=None,
    niche="",
):
    """Research blueprint using Plan A: N Flash drafts + N Pro expands (parallel).

    Args:
        topic: subject to research (e.g. "Albert Einstein")
        api_endpoints: list of API endpoints
        lang: output language
        save_dir: directory to save intermediate files (optional)
        log_callback: function(str) for logging
        stop_check: function() -> bool for cancellation
        niche: niche string from style JSON (required)

    Returns:
        dict: merged blueprint

    Raises:
        RuntimeError: if niche has no research sections defined
    """
    import time
    from concurrent.futures import ThreadPoolExecutor, as_completed
    from core.api_client import APIClient

    log = log_callback or (lambda m: None)
    _stopped = stop_check or (lambda: False)

    # Get niche-specific research sections
    research_sections, section_names = _get_research_sections(niche)
    log(f"Research sections for niche '{niche}': {len(research_sections)} sections")
    MAX_RETRIES = 2
    RETRY_DELAY = 10

    def _save_json(filename, data):
        if not save_dir:
            return
        os.makedirs(save_dir, exist_ok=True)
        path = os.path.join(save_dir, filename)
        with open(path, "w", encoding="utf-8") as f:
            json.dump(data, f, indent=2, ensure_ascii=False)
        chars = len(json.dumps(data, ensure_ascii=False))
        log(f"💾 {filename} ({chars:,} chars)")

    def _draft_one(idx):
        section = research_sections[idx]
        t0 = time.time()
        api = APIClient(api_endpoints, tier="flash", stop_check=_stopped)
        prompt = _build_research_section_prompt(topic, section, lang)
        result = api.call_api(
            [{"role": "user", "content": prompt}],
            temperature=0.3, timeout=600
        )
        elapsed = time.time() - t0
        if not result["success"]:
            # Save API error info
            if save_dir:
                raw_name = f"{idx+1}_{section['name'][:30].replace(' ', '_').lower()}_draft_FAILED.txt"
                os.makedirs(save_dir, exist_ok=True)
                with open(os.path.join(save_dir, raw_name), "w", encoding="utf-8") as rf:
                    rf.write(f"API ERROR: {result.get('error', '?')}\n\nFull result: {json.dumps(result, ensure_ascii=False, indent=2)}")
            return idx, None, result.get("error", "?"), elapsed
        try:
            data = _clean_and_parse_json(result["content"])
            if data is None:
                raise ValueError("Failed to parse JSON")
        except Exception as e:
            # Save raw response for debugging
            if save_dir:
                raw_name = f"{idx+1}_{section['name'][:30].replace(' ', '_').lower()}_draft_FAILED_RAW.txt"
                os.makedirs(save_dir, exist_ok=True)
                with open(os.path.join(save_dir, raw_name), "w", encoding="utf-8") as rf:
                    rf.write(result["content"])
            return idx, None, f"JSON parse: {e}", elapsed
        model = result.get("model", "?")
        return idx, data, model, elapsed

    def _expand_one(idx, draft_data):
        section = research_sections[idx]
        t0 = time.time()
        api_pro = APIClient(api_endpoints, tier="pro", stop_check=_stopped)
        draft_json = json.dumps(draft_data, ensure_ascii=False, indent=2)
        prompt = _build_research_expand_prompt(topic, section, draft_json, lang)
        result = api_pro.call_api(
            [{"role": "user", "content": prompt}],
            temperature=0.3, timeout=600
        )
        elapsed = time.time() - t0
        if not result["success"]:
            # Save API error info
            if save_dir:
                raw_name = f"{idx+1}_{section['name'][:30].replace(' ', '_').lower()}_expand_FAILED.txt"
                os.makedirs(save_dir, exist_ok=True)
                with open(os.path.join(save_dir, raw_name), "w", encoding="utf-8") as rf:
                    rf.write(f"API ERROR: {result.get('error', '?')}\n\nFull result: {json.dumps(result, ensure_ascii=False, indent=2)}")
            return idx, None, result.get("error", "?"), elapsed
        try:
            data = _clean_and_parse_json(result["content"])
            if data is None:
                raise ValueError("Failed to parse JSON")
        except Exception as e:
            # Save raw response for debugging
            if save_dir:
                raw_name = f"{idx+1}_{section['name'][:30].replace(' ', '_').lower()}_FAILED_RAW.txt"
                raw_path = os.path.join(save_dir, raw_name)
                os.makedirs(save_dir, exist_ok=True)
                with open(raw_path, "w", encoding="utf-8") as rf:
                    rf.write(result["content"])
            return idx, None, f"JSON parse: {e}", elapsed
        model = result.get("model", "?")
        return idx, data, model, elapsed

    # ── Phase 1: 3 Flash drafts in parallel ──
    log("── Phase 1: 3 Flash drafts in parallel ──")
    t_phase1 = time.time()
    draft_results = [None, None, None]
    pending = [0, 1, 2]

    for attempt in range(1, MAX_RETRIES + 2):
        if not pending or _stopped():
            break
        if attempt > 1:
            log(f"  🔄 Retry {attempt-1}/{MAX_RETRIES} for draft(s) {[i+1 for i in pending]} (wait {RETRY_DELAY}s)")
            time.sleep(RETRY_DELAY)
        with ThreadPoolExecutor(max_workers=len(pending)) as pool:
            futures = {pool.submit(_draft_one, i): i for i in pending}
            failed = []
            for future in as_completed(futures):
                idx, data, info, elapsed = future.result()
                sec = research_sections[idx]
                if data is None:
                    log(f"  ❌ Draft {idx+1} ({sec['name']}): {info}")
                    failed.append(idx)
                else:
                    chars = len(json.dumps(data, ensure_ascii=False))
                    log(f"  ✓ Draft {idx+1} ({sec['name']}) via {info} ({elapsed:.1f}s, {chars:,} chars)")
                    draft_results[idx] = data
                    _save_json(f"{section_names[idx]}_draft.json", data)
        pending = failed

    if pending:
        failed_names = [research_sections[i]["name"] for i in pending]
        log(f"  ❌ Flash draft FAILED for section(s): {failed_names}")
        raise RuntimeError(
            f"Flash draft failed after {MAX_RETRIES} retries for section(s): "
            f"{', '.join(failed_names)}. Cannot proceed without draft data."
        )

    log(f"  ⏱ Phase 1: {time.time()-t_phase1:.1f}s")

    draft_merged = _merge_research_sections(draft_results)
    _save_json("blueprint_draft_merged.json", draft_merged)

    if _stopped():
        return draft_merged

    # ── Phase 2: 3 Pro expands in parallel ──
    log("── Phase 2: 3 Pro expands in parallel ──")
    t_phase2 = time.time()
    expanded_results = [None, None, None]
    pending = [i for i in range(3) if draft_results[i]]

    for i in range(3):
        if not draft_results[i]:
            log(f"  ❌ No draft for section {i+1} — cannot expand")
            raise RuntimeError(
                f"No draft data for section {i+1} ({research_sections[i]['name']}). "
                f"Cannot proceed to Pro expand."
            )

    for attempt in range(1, MAX_RETRIES + 2):
        if not pending or _stopped():
            break
        if attempt > 1:
            log(f"  🔄 Retry {attempt-1}/{MAX_RETRIES} for expand(s) {[i+1 for i in pending]} (wait {RETRY_DELAY}s)")
            time.sleep(RETRY_DELAY)
        with ThreadPoolExecutor(max_workers=len(pending)) as pool:
            futures = {pool.submit(_expand_one, i, draft_results[i]): i for i in pending}
            failed = []
            for future in as_completed(futures):
                idx, data, info, elapsed = future.result()
                sec = research_sections[idx]
                if data is None:
                    log(f"  ❌ Expand {idx+1} ({sec['name']}): {info}")
                    failed.append(idx)
                else:
                    chars = len(json.dumps(data, ensure_ascii=False))
                    log(f"  ✓ Expand {idx+1} ({sec['name']}) via {info} ({elapsed:.1f}s, {chars:,} chars)")
                    expanded_results[idx] = data
                    _save_json(f"{section_names[idx]}_expanded.json", data)
        pending = failed

    if pending:
        failed_names = [research_sections[i]["name"] for i in pending]
        log(f"  ❌ Pro expand FAILED for section(s): {failed_names}")
        log(f"  💾 Raw responses saved as *_FAILED_RAW.txt in research folder")
        raise RuntimeError(
            f"Pro expand failed after {MAX_RETRIES} retries for section(s): "
            f"{', '.join(failed_names)}. Check *_FAILED_RAW.txt for raw AI response."
        )

    log(f"  ⏱ Phase 2: {time.time()-t_phase2:.1f}s")

    # ── Merge final ──
    merged = _merge_research_sections(expanded_results)
    _save_json("blueprint_final.json", merged)

    d_chars = len(json.dumps(draft_merged, ensure_ascii=False))
    e_chars = len(json.dumps(merged, ensure_ascii=False))
    total_time = time.time() - t_phase1
    log(f"✓ Research complete: {e_chars:,} chars (draft: {d_chars:,}) in {total_time:.1f}s")

    return merged



