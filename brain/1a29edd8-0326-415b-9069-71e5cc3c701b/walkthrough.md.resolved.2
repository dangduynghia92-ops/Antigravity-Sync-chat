"""
rewriter.py — Core logic for the Rewrite pipeline.
Analyze → Rewrite → Verify → Order → Merge chapters.
"""
import csv
import json
import os
import re
from datetime import datetime


_BASE_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
_PROMPTS_DIR = os.path.join(_BASE_DIR, "prompts")

STATUS_FILE = "_REWRITE_STATUS.json"
MERGE_STATUS_FILE = "_MERGE_STATUS.json"


def _safe_csv_path(path: str) -> str:
    """Return a writable CSV path. If 'path' is locked (open in Excel etc.),
    append _2, _3, ... until a writable name is found."""
    if not os.path.exists(path):
        return path
    try:
        with open(path, "a"):
            return path  # writable
    except PermissionError:
        base, ext = os.path.splitext(path)
        for i in range(2, 100):
            alt = f"{base}_{i}{ext}"
            if not os.path.exists(alt):
                return alt
            try:
                with open(alt, "a"):
                    return alt
            except PermissionError:
                continue
        return path  # fallback


def _natural_sort_key(name: str):
    """Sort key for natural ordering: Chapter 1, 2, ..., 10 instead of 1, 10, 2."""
    return [int(c) if c.isdigit() else c.lower()
            for c in re.split(r'(\d+)', name)]


# ── Helpers ──────────────────────────────────────────────────────

def build_word_count_rule(wc_min: int, wc_max: int) -> str:
    """Build a word count rule string from min/max values."""
    if wc_min > 0 and wc_max > 0:
        return f"{wc_min} to {wc_max} words"
    elif wc_min > 0:
        return f"at least {wc_min} words"
    elif wc_max > 0:
        return f"at most {wc_max} words"
    else:
        return "around 1500 words"


# ── Load / Save ──────────────────────────────────────────────────

def load_group_chapters(group_path: str) -> list[dict]:
    """Load chapter .txt files from a group folder (recursive).

    If group_path contains .txt files directly, loads them.
    If group_path contains subfolders with .txt files, scans recursively.
    Each chapter dict has: filename, filepath, text, group (folder name).
    """
    chapters = []
    if not os.path.isdir(group_path):
        return chapters

    # Collect all (group_name, folder_path) pairs
    groups = []
    # Check for .txt files directly in group_path
    direct_txts = [f for f in os.listdir(group_path)
                   if f.endswith(".txt") and not f.startswith("_")
                   and os.path.isfile(os.path.join(group_path, f))]
    if direct_txts:
        groups.append((os.path.basename(group_path), group_path))

    # Check subfolders
    for sub in sorted(os.listdir(group_path), key=_natural_sort_key):
        sub_path = os.path.join(group_path, sub)
        if not os.path.isdir(sub_path) or sub.startswith("_") or sub.startswith("."):
            continue
        sub_txts = [f for f in os.listdir(sub_path)
                    if f.endswith(".txt") and not f.startswith("_")
                    and os.path.isfile(os.path.join(sub_path, f))]
        if sub_txts:
            groups.append((sub, sub_path))

    # Load chapters from each group
    for group_name, folder in groups:
        for fname in sorted(os.listdir(folder), key=_natural_sort_key):
            if not fname.endswith(".txt") or fname.startswith("_"):
                continue
            fpath = os.path.join(folder, fname)
            if not os.path.isfile(fpath):
                continue
            with open(fpath, "r", encoding="utf-8") as f:
                text = f.read()
            chapters.append({
                "filename": fname,
                "filepath": fpath,
                "text": text,
                "group": group_name,
            })
    return chapters


def load_rewrite_status(group_path: str) -> dict:
    """Load _REWRITE_STATUS.json or return empty structure."""
    status_path = os.path.join(group_path, STATUS_FILE)
    if os.path.exists(status_path):
        with open(status_path, "r", encoding="utf-8") as f:
            return json.load(f)
    return {"chapters": {}, "merged_file": ""}


def save_rewrite_status(group_path: str, status: dict):
    """Save rewrite status to JSON."""
    status_path = os.path.join(group_path, STATUS_FILE)
    with open(status_path, "w", encoding="utf-8") as f:
        json.dump(status, f, indent=2, ensure_ascii=False)


def load_merge_status(group_path: str) -> dict:
    """Load _MERGE_STATUS.json or return empty dict.
    Structure: {"chapter_filename": True, ...}
    """
    path = os.path.join(group_path, MERGE_STATUS_FILE)
    if os.path.exists(path):
        with open(path, "r", encoding="utf-8") as f:
            return json.load(f)
    return {}


def save_merge_status(group_path: str, merge_data: dict):
    """Save merge status to separate JSON file."""
    path = os.path.join(group_path, MERGE_STATUS_FILE)
    with open(path, "w", encoding="utf-8") as f:
        json.dump(merge_data, f, indent=2, ensure_ascii=False)


def clear_merge_status(group_path: str):
    """Delete merge status file to reset all merge flags."""
    path = os.path.join(group_path, MERGE_STATUS_FILE)
    if os.path.exists(path):
        os.remove(path)


def _load_prompt(name: str, lang: str = "english") -> str:
    """Load a prompt template from prompts/ directory.
    Tries prompts/{lang}/{name} first, falls back to prompts/{name}.
    """
    # Try language-specific prompt first
    lang_path = os.path.join(_PROMPTS_DIR, lang, name)
    if os.path.exists(lang_path):
        with open(lang_path, "r", encoding="utf-8") as f:
            return f.read()
    # Fallback to shared prompt
    path = os.path.join(_PROMPTS_DIR, name)
    with open(path, "r", encoding="utf-8") as f:
        return f.read()


def load_rewritten_files(output_dir: str) -> list[dict]:
    """Load all *_rewritten.txt files from an output directory.
    Returns: [{"filename": "...", "filepath": "...", "word_count": N}]
    """
    files = []
    if not os.path.isdir(output_dir):
        return files
    for fname in sorted(os.listdir(output_dir), key=_natural_sort_key):
        if fname.endswith("_rewritten.txt"):
            fpath = os.path.join(output_dir, fname)
            with open(fpath, "r", encoding="utf-8") as f:
                text = f.read()
            files.append({
                "filename": fname,
                "filepath": fpath,
                "word_count": len(text.split()),
            })
    return files


# ── Step 1: Analyze ──────────────────────────────────────────────

def analyze_chapter(
    chapter_text: str,
    api_client,
    lang: str = "english",
    log_callback=None,
) -> dict:
    """Analyze chapter and choose best storytelling method."""
    system_prompt = _load_prompt("system_analyze.txt", lang)

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": chapter_text},
    ]

    if log_callback:
        text_len = len(chapter_text)
        log_callback(f"  Sending to AI ({text_len} chars)...")

    result = api_client.call_api(
        messages, temperature=0.4, timeout=120
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"  ❌ API failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    endpoint = result.get("endpoint_url", "?")
    if log_callback:
        log_callback(f"  ✓ Response from {model}")
        log_callback(f"    Endpoint: {endpoint}")

    content = result["content"]
    if not content or not content.strip():
        if log_callback:
            log_callback("  ❌ Empty response from AI")
        raise RuntimeError("Empty response from AI")

    try:
        json_match = re.search(r'\{[\s\S]*\}', content)
        if json_match:
            analysis = json.loads(json_match.group())
        else:
            analysis = json.loads(content)
    except (json.JSONDecodeError, ValueError) as e:
        if log_callback:
            log_callback(f"  ❌ JSON parse error: {e}")
        raise RuntimeError(f"Invalid JSON from AI: {e}")

    return analysis


# ── Step 2: Rewrite ──────────────────────────────────────────────

def rewrite_chapter(
    chapter_text: str,
    analysis: dict,
    api_client,
    word_count_rule: str = "1300 to 1800 words",
    lang: str = "english",
    log_callback=None,
    system_prompt_override: str = None,
) -> str:
    """Rewrite chapter using the chosen storytelling method."""
    if system_prompt_override:
        system_prompt = system_prompt_override
    else:
        system_template = _load_prompt("system_rewrite.txt", lang)
        system_prompt = system_template.replace(
            "{method}", analysis.get("method", "inquiry_arc")
        ).replace(
            "{hook}", analysis.get("hook", "")
        ).replace(
            "{counter_argument}", analysis.get("counter_argument", "")
        ).replace(
            "{word_count_rule}", word_count_rule
        )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": f"ORIGINAL CHAPTER:\n\n{chapter_text}"},
    ]

    if log_callback:
        method = analysis.get("method", "?")
        log_callback(f"  Rewriting ({method}, {word_count_rule})...")

    result = api_client.call_api(
        messages, temperature=0.7, timeout=300
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"  ❌ API failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"  ✓ Rewritten via {model}")

    return result["content"].strip()


# ── Step 3: Verify ───────────────────────────────────────────────

def verify_chapter(
    original_text: str,
    rewritten_text: str,
    api_client,
    word_count_rule: str = "1300 to 1800 words",
    lang: str = "english",
    log_callback=None,
) -> dict:
    """Verify quality of rewritten chapter."""
    system_template = _load_prompt("system_review.txt", lang)
    system_prompt = system_template.replace("{word_count_rule}", word_count_rule)

    user_content = (
        f"ORIGINAL:\n{original_text}\n\n"
        f"---\n\n"
        f"REWRITTEN:\n{rewritten_text}"
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_content},
    ]

    if log_callback:
        log_callback("  Verifying quality...")

    result = api_client.call_api(
        messages, temperature=0.3, timeout=120
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"  ❌ API failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"  ✓ Verified via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        review = json.loads(json_match.group())
    else:
        review = json.loads(content)

    return review


# ── AI Merge: read content → select + order ─────────────────────

def _read_chapter_content(filepath: str, max_chars: int = 3000) -> str:
    """Read rewritten chapter file, truncate if too long."""
    try:
        with open(filepath, "r", encoding="utf-8") as f:
            text = f.read().strip()
        if len(text) > max_chars:
            return text[:max_chars] + "\n[...truncated...]"
        return text
    except Exception:
        return ""


def summarize_chapter(
    chapter_text: str,
    api_client,
    log_callback=None,
) -> str:
    """Generate a 3-5 sentence English summary of a chapter."""
    messages = [
        {"role": "system", "content": (
            "You are a content summarizer. Write a concise 3-5 sentence "
            "English summary of the chapter below. Focus on: main topic, "
            "key historical events/people, and the narrative angle. "
            "Output ONLY the summary text, nothing else."
        )},
        {"role": "user", "content": chapter_text},
    ]

    if log_callback:
        log_callback("  Summarizing...")

    result = api_client.call_api(
        messages, temperature=0.3, timeout=60
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"  ❌ Summary failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    return result["content"].strip()


def ai_order_chapters(
    chapter_files: list[dict],
    num_range: str,
    api_client,
    log_callback=None,
) -> dict:
    """AI reads actual content, groups chapters by theme.
    chapter_files: [{"filename", "filepath", "score", "word_count", "summary"(optional)}, ...]
    num_range: e.g. '5-10', '5-0' (min only), '0-10' (max only), '0-0' (no limit)
    Returns: {"groups": [...]}
    """
    system_template = _load_prompt("system_order.txt")

    # Build ch_rule from min-max
    parts = num_range.split("-")
    ch_min = int(parts[0]) if len(parts) > 0 else 0
    ch_max = int(parts[1]) if len(parts) > 1 else 0

    if ch_min > 0 and ch_max > 0:
        ch_rule = f"between {ch_min} and {ch_max} chapters"
    elif ch_min > 0:
        ch_rule = f"at least {ch_min} chapters"
    elif ch_max > 0:
        ch_rule = f"at most {ch_max} chapters"
    else:
        ch_rule = "enough chapters for a compelling video (around 5-10)"

    system_prompt = system_template.replace("{ch_rule}", ch_rule)

    blocks = []
    use_summary = len(chapter_files) > 30  # summary mode for large sets
    for ch in chapter_files:
        summary = ch.get("summary", "")
        if use_summary and summary:
            score = ch.get("score", "?")
            wc = ch.get("word_count", "?")
            blocks.append(
                f"=== {ch['filename']} (score: {score}, {wc} words) ===\n"
                f"{summary}"
            )
        else:
            content = _read_chapter_content(ch["filepath"])
            if not content:
                continue
            score = ch.get("score", "?")
            wc = ch.get("word_count", len(content.split()))
            blocks.append(
                f"=== {ch['filename']} (score: {score}, {wc} words) ===\n"
                f"{content}"
            )

    if not blocks:
        raise RuntimeError("No rewritten chapters found")

    mode_note = " (using summaries)" if use_summary else ""
    user_content = (
        f"Available chapters ({len(blocks)} total{mode_note}):\n\n"
        + "\n\n".join(blocks)
        + f"\n\nGroup these chapters into thematic clusters (each group: {ch_rule})."
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_content},
    ]

    if log_callback:
        log_callback(
            f"  AI reading {len(blocks)} chapters "
            f"({sum(len(b) for b in blocks)} chars){mode_note}..."
        )

    result = api_client.call_api(
        messages, temperature=0.4, timeout=180
    )

    if not result["success"]:
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"  ✓ AI grouped via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        return json.loads(json_match.group())
    return json.loads(content)


def export_merge_preview_csv(groups_data: dict, output_path: str,
                              highlight_group_id: int = 0) -> str:
    """Export merge preview analysis to CSV.
    groups_data: {"groups": [...]}
    highlight_group_id: if > 0, mark that group with ★★★ in the CSV
    Returns: path to CSV file.
    """
    groups = groups_data.get("groups", [])
    os.makedirs(os.path.dirname(output_path) or ".", exist_ok=True)
    output_path = _safe_csv_path(output_path)

    with open(output_path, "w", encoding="utf-8-sig", newline="") as f:
        writer = csv.writer(f)

        # Section 1: Group overview
        writer.writerow(["=== TỔNG QUAN CÁC NHÓM ==="])
        writer.writerow(["Nhóm", "Theme", "Mô tả", "Điểm hấp dẫn",
                         "Số chapters", "Lý do nhóm này hợp", "Tiêu đề gợi ý"])
        for g in groups:
            titles = " / ".join(g.get("suggested_titles_vi", []))
            chapters = g.get("chapters", [])
            gid = g.get("group_id", "")
            marker = " ★★★" if highlight_group_id and gid == highlight_group_id else ""
            writer.writerow([
                f"{gid}{marker}",
                g.get("theme", ""),
                g.get("description_vi", ""),
                g.get("appeal_score", ""),
                len(chapters),
                g.get("why_this_group_vi", ""),
                titles,
            ])

        writer.writerow([])
        writer.writerow([])

        # Section 2: Detail per group
        for g in groups:
            gid = g.get("group_id", "?")
            theme = g.get("theme", "")
            marker = " ★★★" if highlight_group_id and gid == highlight_group_id else ""
            writer.writerow([f"=== NHÓM {gid}: {theme}{marker} ==="])
            writer.writerow(["Vị trí", "Chapter", "Fit", "Vai trò", "Lý do xếp vị trí này"])
            for ch in g.get("chapters", []):
                writer.writerow([
                    ch.get("order", ""),
                    ch.get("filename", ""),
                    ch.get("fit_score", "?"),
                    ch.get("role_vi", ""),
                    ch.get("reason_vi", ""),
                ])
            writer.writerow([])

    return output_path


def ai_suggest_order(
    chapter_files: list[dict],
    api_client,
    log_callback=None,
) -> dict:
    """AI suggests order only (user already selected chapters).
    Returns: {selected_chapters: [{order, filename, reason_vi}], overall_strategy_vi}
    """
    system_prompt = (
        "You are a YouTube content strategist. "
        "The user already selected these chapters for their video. "
        "Suggest the BEST ORDER for maximum viewer retention.\n"
        "Reply JSON only:\n"
        '{"selected_chapters": [{"order": 1, "filename": "...", '
        '"reason_vi": "Lý do tiếng Việt"}], '
        '"overall_strategy_vi": "Chiến lược sắp xếp..."}'
    )

    blocks = []
    for ch in chapter_files:
        content = _read_chapter_content(ch["filepath"], max_chars=2000)
        if not content:
            continue
        blocks.append(f"=== {ch['filename']} ===\n{content}")

    if not blocks:
        raise RuntimeError("No chapters to order")

    user_content = (
        f"Order these {len(blocks)} chapters:\n\n"
        + "\n\n".join(blocks)
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_content},
    ]

    if log_callback:
        log_callback(f"  AI suggesting order for {len(blocks)} chapters...")

    result = api_client.call_api(
        messages, temperature=0.4, timeout=120
    )

    if not result["success"]:
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"  ✓ Order suggested via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        return json.loads(json_match.group())
    return json.loads(content)


# ── Save & Merge ─────────────────────────────────────────────────

def _split_title_body(text: str) -> tuple[str, str]:
    """Split rewritten text into (title, body).
    AI outputs title on first line. Returns (title, body_without_title).
    """
    lines = text.strip().split("\n", 1)
    title = lines[0].strip()
    body = lines[1].strip() if len(lines) > 1 else ""
    return title, body


def save_rewritten_file(output_dir: str, filename: str, text: str, lang: str = "english", index: int = None) -> str:
    """Save rewritten chapter to output directory (body only, no title)."""
    os.makedirs(output_dir, exist_ok=True)
    base = os.path.splitext(filename)[0]
    if index is not None:
        out_name = f"{lang}_{index:03d}_{base}_rewritten.txt"
    else:
        out_name = f"{lang}_{base}_rewritten.txt"
    out_path = os.path.join(output_dir, out_name)

    _, body = _split_title_body(text)
    with open(out_path, "w", encoding="utf-8") as f:
        f.write(body if body else text)

    return out_path


def merge_ordered_chapters(
    output_dir: str, status: dict, ordered_filenames: list[str]
) -> str:
    """Merge chapters in specified order into FINAL_SCRIPT.txt."""
    merged_lines = []
    separator = "\n\n" + "=" * 60 + "\n\n"

    for fname in ordered_filenames:
        ch_info = status.get("chapters", {}).get(fname, {})
        output_file = ch_info.get("output_file", "")
        if not output_file:
            continue

        out_path = os.path.join(output_dir, output_file)
        if not os.path.exists(out_path):
            continue

        with open(out_path, "r", encoding="utf-8") as f:
            content = f.read().strip()

        if merged_lines:
            merged_lines.append(separator)
        merged_lines.append(content)

    if not merged_lines:
        return ""

    merged_path = os.path.join(output_dir, "FINAL_SCRIPT.txt")
    with open(merged_path, "w", encoding="utf-8") as f:
        f.write("".join(merged_lines))

    return merged_path


def merge_from_paths(filepaths: list[str], output_path: str) -> str:
    """Merge chapter files from explicit file paths."""
    merged_lines = []

    for i, fp in enumerate(filepaths):
        if not os.path.exists(fp):
            continue
        with open(fp, "r", encoding="utf-8") as f:
            content = f.read().strip()
        if content:
            if merged_lines:
                merged_lines.append("\n\n" + "=" * 60 + "\n\n")
            # Add chapter header
            fname = os.path.splitext(os.path.basename(fp))[0]
            merged_lines.append(f"[{i+1:02d}]: {fname}\n")
            merged_lines.append("=" * 60 + "\n\n")
            merged_lines.append(content)

    if not merged_lines:
        return ""

    os.makedirs(os.path.dirname(output_path), exist_ok=True)
    with open(output_path, "w", encoding="utf-8") as f:
        f.write("".join(merged_lines))

    return output_path


# ── Review Report ────────────────────────────────────────────────

def export_review_report(output_dir: str, status: dict) -> str:
    """Export a CSV review report with Vietnamese column headers."""
    os.makedirs(output_dir, exist_ok=True)
    report_path = _safe_csv_path(os.path.join(output_dir, "_REVIEW_REPORT.csv"))

    headers = [
        "STT", "Chapter", "Score", "Đạt", "Số từ",
        "Điểm mạnh", "Vấn đề", "Gợi ý cải thiện",
        "So sánh: Hook", "So sánh: Giữ chân", "So sánh: Điểm yếu", "So sánh: Tổng"
    ]

    rows = []
    idx = 0
    for fname in sorted(status.get("chapters", {}).keys()):
        ch_info = status["chapters"][fname]
        if ch_info.get("status") != "verified":
            continue
        idx += 1

        strengths = ch_info.get("verify_strengths", [])
        issues = ch_info.get("verify_issues", [])
        issue_texts = []
        for iss in issues:
            sev = iss.get("severity", "")
            det = iss.get("detail", "")
            issue_texts.append(f"[{sev}] {det}")

        comp = ch_info.get("verify_comparison", {})
        rows.append([
            idx,
            fname,
            ch_info.get("verify_score", ""),
            "✓" if ch_info.get("verify_passed") else "✗",
            ch_info.get("verify_word_count", ""),
            "; ".join(strengths) if strengths else "",
            "; ".join(issue_texts) if issue_texts else "",
            ch_info.get("verify_suggestion", ""),
            comp.get("hook", ""),
            comp.get("retention", ""),
            comp.get("weakness", ""),
            comp.get("overall", ""),
        ])

    with open(report_path, "w", newline="", encoding="utf-8-sig") as f:
        writer = csv.writer(f)
        writer.writerow(headers)
        writer.writerows(rows)

    return report_path


# ── Chapter Reorder Suggestion ───────────────────────────────────

def suggest_chapter_order(
    chapters: list[dict],
    api_client,
    log_callback=None,
) -> dict:
    """Suggest optimal chapter order for narrative flow.
    chapters: [{filename, text, ...}, ...]
    Returns: {strategy_vi, suggested_order: [{new_position, original_position, filename, reason_vi}]}
    """
    system_prompt = _load_prompt("system_reorder.txt")

    # Build chapter summaries (truncate long texts)
    all_text = ""
    for i, ch in enumerate(chapters, 1):
        preview = ch["text"][:3000]
        if len(ch["text"]) > 3000:
            preview += "\n[...truncated...]"
        all_text += f"\n\n=== CHAPTER {i}: {ch['filename']} ===\n{preview}"

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": f"Here are {len(chapters)} chapters to reorder:\n{all_text}"},
    ]

    if log_callback:
        log_callback(f"AI suggesting chapter order for {len(chapters)} chapters...")

    result = api_client.call_api(
        messages, temperature=0.3, timeout=180
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"❌ Reorder failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"✓ Reorder suggestion via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        suggestion = json.loads(json_match.group())
    else:
        suggestion = json.loads(content)

    return suggestion


def export_reorder_csv(output_dir: str, suggestion: dict) -> str:
    """Export reorder suggestion to CSV with Vietnamese headers."""
    os.makedirs(output_dir, exist_ok=True)
    csv_path = _safe_csv_path(os.path.join(output_dir, "_REORDER_SUGGESTION.csv"))

    headers = ["STT mới", "STT cũ", "Tên chapter", "Lý do"]

    rows = []
    for item in suggestion.get("suggested_order", []):
        rows.append([
            item.get("new_position", ""),
            item.get("original_position", ""),
            item.get("filename", ""),
            item.get("reason_vi", ""),
        ])

    # Sort by new_position
    rows.sort(key=lambda r: r[0] if isinstance(r[0], int) else 0)

    with open(csv_path, "w", newline="", encoding="utf-8-sig") as f:
        writer = csv.writer(f)
        writer.writerow(headers)
        writer.writerows(rows)

        # Write strategy at the bottom
        strategy = suggestion.get("strategy_vi", "")
        if strategy:
            writer.writerow([])
            writer.writerow(["Chiến lược:", strategy])

    return csv_path


