    # ── Signals ────────────────────────────────────────────────────

    def _connect_signals(self):
        self.progress_text.connect(self._on_progress_text)
        self.tree_refresh.connect(self._refresh_tree)
        self.job_update.connect(self._refresh_folder_tree)

    # ── Style dropdown ─────────────────────────────────────────────

    def _refresh_style_dropdown(self):
        """Scan styles/ folder and populate dropdown, filtered by current mode."""
        current = self._combo_style.currentText() if self._combo_style.count() else ""
        self._combo_style.blockSignals(True)
        self._combo_style.clear()

        mode = self._combo_mode.currentText()
        if mode == "Top/List Review":
            target_pipeline = "review"
        else:
            target_pipeline = "narrative"

        styles_dir = os.path.join(
            os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
            "styles"
        )
        if os.path.isdir(styles_dir):
            for fname in sorted(os.listdir(styles_dir)):
                if fname.endswith(".json"):
                    # Read pipeline field to filter
                    fpath = os.path.join(styles_dir, fname)
                    try:
                        with open(fpath, "r", encoding="utf-8") as f:
                            sd = json.load(f)
                        file_pipeline = sd.get("pipeline", "narrative")
                    except Exception:
                        file_pipeline = "narrative"

                    if file_pipeline == target_pipeline:
                        style_name = fname.replace(".json", "").replace("_", " ").title()
                        self._combo_style.addItem(f"✦ {style_name}", fname)

        if self._combo_style.count() == 0:
            self._combo_style.addItem("(no styles found)")

        if current:
            idx = self._combo_style.findText(current)
            if idx >= 0:
                self._combo_style.setCurrentIndex(idx)
        self._combo_style.blockSignals(False)

    def _show_style_popup(self):
        self._refresh_style_dropdown()
        QComboBox.showPopup(self._combo_style)

    def _get_style_filename(self):
        """Return the selected style JSON filename, e.g. 'my_style.json'."""
        idx = self._combo_style.currentIndex()
        if idx >= 0:
            data = self._combo_style.itemData(idx)
            if data:
                return data
        # Fallback for items without data
        text = self._combo_style.currentText()
        if text.startswith("✦ "):
            return text[2:].strip().lower().replace(" ", "_") + ".json"
        return None

