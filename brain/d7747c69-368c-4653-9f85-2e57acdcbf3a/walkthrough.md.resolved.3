    No source script needed — AI researches the topic and creates the blueprint.

    Returns: blueprint dict (same schema as extract_blueprint)
    """
    _RESEARCH_PROMPT_MAP = {
        "biography": "system_research_blueprint_biography.txt",
        "tiểu sử": "system_research_blueprint_biography.txt",
        "nhân vật": "system_research_blueprint_biography.txt",
