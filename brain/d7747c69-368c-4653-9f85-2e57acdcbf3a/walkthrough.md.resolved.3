def transform_rhetoric(
    blueprint: dict,
    niche: str = "",
    lang: str = "en",
    target_country: str = "US",
    log_callback=None,
    stop_check=None,
    api_endpoints: list = None,
    gemini_keys: list = None,
) -> dict:
    """Transform original author rhetoric into original alternatives.

    Reads `author_rhetoric` from each product in the blueprint,
    sends it (with the product's `detailed_facts`) to the AI,
    and writes `alternative_rhetoric` back into the blueprint.

    Runs independently from data enrichment — no field overlap.

    Returns: dict with 'products_transformed', 'summary'
    """
    from core.api_client import APIClient

    def log(msg):
        if log_callback:
            log_callback(msg)

    # Check if any product has author_rhetoric
    products = blueprint.get("product_evaluation", [])
    has_rhetoric = any(
        p.get("author_rhetoric") for p in products if isinstance(p, dict)
    )
    if not has_rhetoric:
        log("⊘ No author_rhetoric in blueprint — skipping rhetoric transform")
        return {"products_transformed": 0, "summary": "No rhetoric to transform"}

    # Find niche-specific transform prompt
    niche_lower = (niche or "").lower()
    prompt_file = None
    for keyword, pfile in _NICHE_TRANSFORM_RHETORIC_MAP.items():
        if keyword in niche_lower:
            prompt_file = pfile
            break

    if not prompt_file:
        log(f"⊘ No rhetoric transform prompt for niche '{niche}' — skipping")
        return {"products_transformed": 0, "summary": f"No prompt for niche '{niche}'"}

    # Need at least one API source
    if not api_endpoints and not gemini_keys:
        log("⚠ No API keys or endpoints — skipping rhetoric transform")
        return {"products_transformed": 0, "summary": "No API keys"}

    # Build prompt
    system_template = _load_prompt(prompt_file)
    if not system_template:
        log(f"⚠ Could not load prompt: {prompt_file}")
        return {"products_transformed": 0, "summary": "Prompt file not found"}

    # Prepare slim blueprint: only product_name + detailed_facts + author_rhetoric
    slim_products = []
    for p in products:
        if not isinstance(p, dict):
            continue
        slim = {
            "product_name": p.get("product_name", "Unknown"),
            "detailed_facts": p.get("detailed_facts", []),
            "author_rhetoric": p.get("author_rhetoric", []),
        }
        slim_products.append(slim)

    slim_bp_json = json.dumps(slim_products, indent=2, ensure_ascii=False)

    system_prompt = (
        system_template
        .replace("{lang}", lang)
        .replace("{target_country}", target_country)
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": f"PRODUCT DATA:\n{slim_bp_json}"},
    ]

    # Call API
    log(f"🎨 Transforming rhetoric for {len(slim_products)} product(s) → {target_country}...")

    try:
        if api_endpoints:
            api_client = APIClient(api_endpoints, tier="flash", stop_check=stop_check)
        else:
            api_client = APIClient(
                [{"url": f"https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key={k}"}
                 for k in gemini_keys],
                tier="flash", stop_check=stop_check
            )
        result = api_client.call_api(messages, temperature=0.7, timeout=120)

        if not result.get("success"):
            log(f"⚠ Rhetoric transform failed: {result.get('error', 'unknown')}")
            return {"products_transformed": 0, "summary": f"API error: {result.get('error', '?')}"}

        content = (result.get("content") or "").strip()
        if not content:
            log("⚠ Rhetoric transform: empty response")
            return {"products_transformed": 0, "summary": "Empty response"}

        # Parse response
        transform_data = _clean_and_parse_json(content)
        if not transform_data:
            log("⚠ Rhetoric transform: could not parse JSON response")
            return {"products_transformed": 0, "summary": "Invalid JSON"}

        # Merge alternative_rhetoric back into blueprint
        transformed_products = transform_data.get("products", [])
        count = 0
        for tp in transformed_products:
            if not isinstance(tp, dict):
                continue
            tp_name = (tp.get("product_name") or "").lower()
            alt_rhetoric = tp.get("alternative_rhetoric", [])
            if not alt_rhetoric:
                continue

            # Find matching product in blueprint
            for bp_product in products:
                bp_name = (bp_product.get("product_name") or "").lower()
                if bp_name == tp_name or tp_name in bp_name or bp_name in tp_name:
                    bp_product["alternative_rhetoric"] = alt_rhetoric
                    count += 1
                    break

        model = result.get("model", "?")
        log(f"✓ Rhetoric transform: {count}/{len(slim_products)} product(s) via {model}")

        return {
            "products_transformed": count,
            "transform_data": transform_data,
            "summary": f"Transformed {count} products for {target_country}",
        }

    except Exception as e:
        log(f"⚠ Rhetoric transform error: {e}")
        return {"products_transformed": 0, "summary": str(e)}


def enrich_blueprint_google(
    blueprint: dict,
    gemini_keys: list,
    niche: str = "",
    lang: str = "en",
    log_callback=None,
    stop_check=None,
    use_google_search: bool = True,
    api_endpoints: list = None,
) -> dict:
    """Fill empty blueprint fields using 2-phase enrichment.

    Phase 1: AI internal knowledge via main endpoints (no search).
             Uses 9Router/proxy. Falls back to Gemini keys if no endpoints.
    Phase 2: Google Search grounding (Gemini keys direct) — only for
             fields STILL empty after Phase 1.

    If use_google_search=False, only Phase 1 runs.

    Args:
        blueprint: blueprint dict from extract_blueprint
        gemini_keys: list of Gemini API keys (for Phase 2 search)
        niche: niche keyword (e.g. "battle", "mystery")
        lang: language code
        log_callback: optional logging function
        stop_check: optional callable returning True to abort
        use_google_search: if True, runs Phase 2 with Google Search
        api_endpoints: main API endpoints for Phase 1 (via 9Router)

    Returns: dict with 'fields_filled', 'enrichment_data', 'summary'
    """
    from core.api_client import APIClient

    def log(msg):
        if log_callback:
            log_callback(msg)

    # Need at least one source
    if not gemini_keys and not api_endpoints:
        log("⚠ No API keys or endpoints — skipping enrichment")
        return {"fields_filled": 0, "summary": "No API keys"}

    # Find empty fields
    empties = _find_empty_fields(blueprint)
    if not empties:
        log("✓ Blueprint is complete — no empty fields to enrich")
        return {"fields_filled": 0, "summary": "Blueprint already complete"}

    log(f"📋 Found {len(empties)} empty field(s): {', '.join(empties[:10])}"
        + (f" (+{len(empties)-10} more)" if len(empties) > 10 else ""))

    # Find niche-specific enrichment prompt
    niche_lower = (niche or "").lower()
    prompt_file = None
    for keyword, pfile in _NICHE_ENRICH_PROMPT_MAP.items():
        if keyword in niche_lower:
            prompt_file = pfile
            break

    if not prompt_file:
        log(f"⚠ No enrichment prompt for niche '{niche}' — skipping")
        return {"fields_filled": 0, "summary": f"No prompt for niche '{niche}'"}

    total_filled = 0
    all_enrichment_data = {}

    # ══════════════════════════════════════════
    # PHASE 1: AI Internal Knowledge (via endpoints, no search)
    # ══════════════════════════════════════════
    log("── Phase 1: Enriching via AI knowledge...")
    if api_endpoints:
        # Use main endpoints (9Router/proxy)
        p1_result = _run_enrich_phase_endpoints(
            blueprint, api_endpoints, prompt_file, lang,
            phase_label="Phase 1 (AI knowledge)",
            log=log, stop_check=stop_check,
        )
    elif gemini_keys:
        # Fallback: use Gemini keys directly
        p1_result = _run_enrich_phase(
            blueprint, gemini_keys, prompt_file, lang,
            google_search=False,
            phase_label="Phase 1 (AI knowledge)",
            log=log, stop_check=stop_check,
        )
    else:
        p1_result = None
    if p1_result:
        total_filled += p1_result.get("fields_filled", 0)
        if p1_result.get("enrichment_data"):
            all_enrichment_data["phase1_ai"] = p1_result["enrichment_data"]

    if stop_check and stop_check():
        return {"fields_filled": total_filled, "summary": "Stopped by user"}

    # Check remaining empties
    remaining = _find_empty_fields(blueprint)

    # ══════════════════════════════════════════
    # PHASE 2: Google Search (only if enabled AND still empty fields)
    # ══════════════════════════════════════════
    if use_google_search and remaining:
        log(f"── Phase 2: {len(remaining)} field(s) still empty → Google Search...")
        p2_result = _run_enrich_phase(
            blueprint, gemini_keys, prompt_file, lang,
            google_search=True,
            phase_label="Phase 2 (Google Search)",
            log=log, stop_check=stop_check,
        )
        if p2_result:
            total_filled += p2_result.get("fields_filled", 0)
            if p2_result.get("enrichment_data"):
                all_enrichment_data["phase2_search"] = p2_result["enrichment_data"]
    elif use_google_search and not remaining:
        log("✓ All fields filled in Phase 1 — skipping Google Search")
    else:
        log("── Google Search disabled — Phase 1 only")

    # Final summary
    final_empties = _find_empty_fields(blueprint)
    if final_empties:
        log(f"  Still empty after enrichment: {', '.join(final_empties[:5])}"
            + (f" (+{len(final_empties)-5} more)"
               if len(final_empties) > 5 else ""))
    else:
        log("✓ Blueprint fully enriched — no empty fields remain")

    return {
        "fields_filled": total_filled,
        "enrichment_data": all_enrichment_data,
        "summary": f"Filled {total_filled} fields (2-phase)",
        "still_empty": final_empties,
    }


def _build_enrich_prompt(blueprint, prompt_file, lang):
    """Build enrichment prompt from template + blueprint data."""
    system_template = _load_prompt(prompt_file)
    core_topic = blueprint.get("core_topic", "Unknown")
    blueprint_json = json.dumps(blueprint, indent=2, ensure_ascii=False)
    return (
        system_template
        .replace("{lang}", lang)
        .replace("{core_topic}", core_topic if isinstance(core_topic, str)
                 else json.dumps(core_topic, ensure_ascii=False))
        .replace("{blueprint_json}", blueprint_json)
    )


def _merge_enrich_result(content, blueprint, phase_label, log):
    """Parse AI response and merge into blueprint. Returns result dict or None."""
    if not content:
        return None

    enrichment_data = _clean_and_parse_json(content)
    if enrichment_data is None:
        raise json.JSONDecodeError("Could not extract valid JSON after cleaning", content[:200], 0)

    pre_count = len(_find_empty_fields(blueprint))
    _deep_merge_empty(blueprint, enrichment_data)
    post_empties = _find_empty_fields(blueprint)
    fields_filled = pre_count - len(post_empties)

    return {
        "fields_filled": fields_filled,
        "enrichment_data": enrichment_data,
    }


def _clean_and_parse_json(text: str) -> dict | None:
    """Extract and parse JSON from AI response with aggressive cleaning.

    Handles: markdown fences, trailing commas, extra text after JSON,
    multiple JSON objects, comments.
    """
    if not text:
        return None

    text = text.strip()

    # 1. Strip markdown code fences
    text = re.sub(r'^```(?:json)?\s*\n?', '', text)
    text = re.sub(r'\n?\s*```\s*$', '', text)
    text = text.strip()

    # 2. Try direct parse first
    try:
        return json.loads(text)
    except json.JSONDecodeError:
        pass

    # 3. Find the FIRST complete top-level JSON object using brace matching
    json_str = _extract_matched_braces(text)
    if json_str:
        try:
            return json.loads(json_str)
        except json.JSONDecodeError:
            # 4. Try fixing trailing commas
            cleaned = _fix_trailing_commas(json_str)
            try:
                return json.loads(cleaned)
            except json.JSONDecodeError:
                pass

    # 5. Fallback: greedy regex (old behavior)
    jm = re.search(r'\{[\s\S]*\}', text)
    if jm:
        try:
            return json.loads(jm.group())
        except json.JSONDecodeError:
            cleaned = _fix_trailing_commas(jm.group())
            try:
                return json.loads(cleaned)
            except json.JSONDecodeError:
                pass

    return None


def _extract_matched_braces(text: str) -> str | None:
    """Find the first complete {...} with properly matched braces."""
    start = text.find('{')
    if start == -1:
        return None

    depth = 0
    in_string = False
    escape_next = False

    for i in range(start, len(text)):
        ch = text[i]

        if escape_next:
            escape_next = False
            continue

        if ch == '\\' and in_string:
            escape_next = True
            continue

        if ch == '"' and not escape_next:
            in_string = not in_string
            continue

        if in_string:
            continue

        if ch == '{':
            depth += 1
        elif ch == '}':
            depth -= 1
            if depth == 0:
                return text[start:i + 1]

    return None


def _fix_trailing_commas(text: str) -> str:
    """Remove trailing commas before } or ] (common AI mistake)."""
    # ,  } or ,  ]  (with optional whitespace/newlines)
    text = re.sub(r',\s*([}\]])', r'\1', text)
    return text


def _run_enrich_phase_endpoints(
    blueprint: dict,
    api_endpoints: list,
    prompt_file: str,
    lang: str,
    phase_label: str,
    log,
    stop_check=None,
) -> dict | None:
    """Run enrichment via main endpoints (9Router/proxy). No Google Search."""
    from core.api_client import APIClient

    system_prompt = _build_enrich_prompt(blueprint, prompt_file, lang)
    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": "Fill the empty fields in the blueprint above. Return the COMPLETE enriched blueprint JSON."},
    ]

    api_client = APIClient(api_endpoints, tier="flash", stop_check=stop_check)
    try:
        result = api_client.call_api(messages, temperature=0.2, timeout=120)
        if result["success"]:
            content = (result.get("content") or "").strip()
            if not content:
                log(f"  ⚠ {phase_label}: empty response")
                return None
            merge_result = _merge_enrich_result(content, blueprint, phase_label, log)
            model = result.get("model", "?")
            filled = merge_result["fields_filled"] if merge_result else 0
            log(f"  ✓ {phase_label}: filled {filled} field(s) via {model}")
            return merge_result
        else:
            log(f"  ⚠ {phase_label} failed: {result.get('error', 'unknown')}")
            return None
    except json.JSONDecodeError as e:
        log(f"  ⚠ {phase_label}: JSON parse error: {e}")
        return None
    except Exception as e:
        log(f"  ⚠ {phase_label} error: {e}")
        return None


def _run_enrich_phase(
    blueprint: dict,
    gemini_keys: list,
    prompt_file: str,
    lang: str,
    google_search: bool,
    phase_label: str,
    log,
    stop_check=None,
) -> dict | None:
    """Run enrichment via Gemini keys directly (supports Google Search).

    Uses round-robin key rotation to distribute load evenly.
    """
    from core.api_client import APIClient

    system_prompt = _build_enrich_prompt(blueprint, prompt_file, lang)
    messages = [{"role": "user", "content": system_prompt}]

    api_client = APIClient([], stop_check=stop_check)

    result = api_client.call_gemini_with_rotation(
        messages,
        gemini_keys=gemini_keys,
        model="gemini-2.5-flash",
        google_search=google_search,
        timeout=120,
        stop_check=stop_check,
        log_callback=log,
    )

    if result["success"]:
        content = (result.get("content") or "").strip()
        if not content:
            log(f"  ⚠ {phase_label}: API returned empty content")
            return None

        try:
            merge_result = _merge_enrich_result(content, blueprint, phase_label, log)
            model = result.get("model", "?")
            filled = merge_result["fields_filled"] if merge_result else 0
            log(f"  ✓ {phase_label}: filled {filled} field(s) via {model}")
            return merge_result
        except json.JSONDecodeError as e:
            log(f"  ⚠ {phase_label}: JSON parse error: {e}")
            return None
        except Exception as e:
            log(f"  ⚠ {phase_label}: error: {e}")
            return None

    log(f"  ⚠ {phase_label}: all keys failed")
    return None


def extract_blueprint_review(
    full_text: str,
    api_client,
    lang: str = "en",
    log_callback=None,
    niche: str = "",
) -> dict:
    """Extract a REVIEW-specific blueprint focused on product data only.
    No narrative fields (key_events, key_characters, narrative_moments).

    For mystery niche: includes key_figures, historical_context, geography,
    technology_and_artifacts, scholarly_debate (no ranking_criteria/original_order/thesis_angle).

    Returns: dict with core_topic, product_evaluation, key_claims, etc.
    """
    prompt_file = _get_niche_prompt("extract_blueprint", niche)
    system_template = _load_prompt(prompt_file)
    system_prompt = system_template.replace("{lang}", lang)

    # Extract first ~2000 chars (≈90s speech) and last ~2000 chars for thesis
    _THESIS_CHARS = 2000
    _first_segment = full_text[:_THESIS_CHARS].strip()
    _last_segment = full_text[-_THESIS_CHARS:].strip() if len(full_text) > _THESIS_CHARS else ""

    _thesis_hint = (
        f"\n\n=== THESIS CONTEXT (first ~90s + last ~90s of script) ===\n"
        f"--- OPENING (first ~90 seconds) ---\n{_first_segment}\n\n"
    )
    if _last_segment:
        _thesis_hint += f"--- CLOSING (last ~90 seconds) ---\n{_last_segment}\n"
    _thesis_hint += (
        "=== END THESIS CONTEXT ===\n"
        "IMPORTANT: Extract thesis_angle ONLY from the OPENING or CLOSING sections above. "
        "Use the author's near-verbatim words. Do NOT rephrase or generalize.\n"
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": f"REVIEW SCRIPT TO EXTRACT FROM:\n\n{full_text}{_thesis_hint}"},
    ]

    if log_callback:
        log_callback(f"Extracting review blueprint ({len(full_text):,} chars)...")

    result = api_client.call_api(
        messages, temperature=0.2, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"❌ Review blueprint extraction failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"✓ Review blueprint extracted via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        return json.loads(json_match.group())
    return json.loads(content)


def audit_outline_review(
    blueprint: dict,
    outline: dict,
    framework: dict,
    style_json: str,
    api_client,
    chapter_range: str = "",
    log_callback=None,
    niche: str = "",
) -> dict:
    """Audit a REVIEW outline using 2-pass approach for reliability.

    Pass 1: Detect issues only (small JSON output — reliable parsing).
    Pass 2: Fix outline only when issues are found (smaller context).

    Returns: the audited outline dict (or original on failure).
    """
    prompt_file = _get_niche_prompt("audit_outline", niche)
    system_prompt = _load_prompt(prompt_file)

    fw_name = framework.get("name", "") if isinstance(framework, dict) else ""
    compact_style = _extract_style_for_framework(style_json, fw_name) if fw_name else style_json

    user_content = (
        f"CHAPTER RANGE: {chapter_range or 'not specified'}\n\n"
        f"BLUEPRINT:\n{json.dumps(blueprint, ensure_ascii=False, indent=2)}\n\n"
        f"OUTLINE:\n{json.dumps(outline, ensure_ascii=False, indent=2)}\n\n"
        f"FRAMEWORK:\n{json.dumps(framework, ensure_ascii=False, indent=2)}\n\n"
        f"STYLE GUIDE:\n{compact_style}"
    )

    if log_callback:
        log_callback("Auditing review outline...")

    # ── Pass 1: Detect issues only (small output) ──
    pass1_system = (
        system_prompt + "\n\n"
        "IMPORTANT: In this pass, ONLY identify issues. "
        "Do NOT return the outline. Respond with ONLY:\n"
        '{"audit_issues": [{"type": "...", "description": "...", "fix_applied": "..."}]}\n'
        'If no issues: {"audit_issues": []}'
    )

    messages_p1 = [
        {"role": "system", "content": pass1_system},
        {"role": "user", "content": user_content},
    ]

    result_p1 = api_client.call_api(
        messages_p1, temperature=0.2, timeout=120
    )

    if not result_p1["success"]:
        if log_callback:
            log_callback(f"❌ Review audit failed: {result_p1.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result_p1['error']}")

    model = result_p1.get("model", "?")
    if log_callback:
        log_callback(f"✓ Review outline audited via {model}")

    # Parse Pass 1 result
    audit_issues = []
    try:
        content_p1 = result_p1["content"]
        json_match = re.search(r'\{[\s\S]*\}', content_p1, re.DOTALL)
        raw = json_match.group() if json_match else content_p1
        try:
            parsed_p1 = json.loads(raw)
        except json.JSONDecodeError:
            # Repair: trailing commas, comments, unclosed brackets
            t = re.sub(r'//[^\n]*', '', raw)
            t = re.sub(r',\s*([}\]])', r'\1', t)
            ob = t.count('{') - t.count('}')
            if ob > 0:
                t = t.rstrip().rstrip(',') + '}' * ob
            parsed_p1 = json.loads(t)
            if log_callback:
                log_callback("✓ Audit detection JSON repaired")
        audit_issues = parsed_p1.get("audit_issues", [])
    except (json.JSONDecodeError, Exception) as e:
        if log_callback:
            log_callback(f"⚠ Could not parse audit detection: {e}, using original outline")
        return outline

    # No issues → return original outline immediately (fast path)
    if not audit_issues:
        if log_callback:
            log_callback("✓ Audit passed — no issues found")
        return outline

    # ── Pass 2: Fix outline (only when issues found) ──
    if log_callback:
        log_callback(f"✓ Audit found {len(audit_issues)} issue(s) — applying fixes...")
        for iss in audit_issues:
            log_callback(f"  → [{iss.get('type', '?')}] {iss.get('description', '')}")

    pass2_content = (
        f"OUTLINE TO FIX:\n{json.dumps(outline, ensure_ascii=False, indent=2)}\n\n"
        f"ISSUES TO FIX:\n{json.dumps(audit_issues, ensure_ascii=False, indent=2)}\n\n"
        f"CHAPTER RANGE: {chapter_range or 'not specified'}\n\n"
        "Apply ALL fixes above to the outline. "
        "Return ONLY the corrected outline as a JSON object (same format as input). "
        "Do NOT wrap in another object — return the outline directly."
    )

    messages_p2 = [
        {"role": "system", "content": (
            "You are an outline editor. Apply the listed fixes to the outline. "
            "Return ONLY the corrected outline as valid JSON. No other text."
        )},
        {"role": "user", "content": pass2_content},
    ]

    result_p2 = api_client.call_api(
        messages_p2, temperature=0.1, timeout=180
    )

    if not result_p2["success"]:
        if log_callback:
            log_callback(f"⚠ Pass 2 API failed, using original outline")
        return outline

    try:
        content_p2 = result_p2["content"]
        json_match = re.search(r'\{[\s\S]*\}', content_p2, re.DOTALL)
        if json_match:
            fixed_outline = json.loads(json_match.group())
        else:
            fixed_outline = json.loads(content_p2)

        # Validate: must have 'chapters' key
        if "chapters" not in fixed_outline:
            if log_callback:
                log_callback("⚠ Fixed outline missing 'chapters' key, using original")
            return outline

        if log_callback:
            log_callback(f"✓ Outline fixed ({len(fixed_outline.get('chapters', []))} chapters)")

        return fixed_outline

    except (json.JSONDecodeError, Exception) as e:
        if log_callback:
            log_callback(f"⚠ Could not parse fixed outline: {e}, using original outline")
        return outline


