def _extract_pirate_section_matches(blueprint: dict, chapter_outline: dict, result: dict):
    """Extract pirate sections based on outline metadata fields.

    Uses: figures_featured, myth_busted
    These are driven by outline metadata, not key_data text.
    """
    # ── figures_featured → filter key_figures ──
    figures = chapter_outline.get("figures_featured", [])
    if figures and "key_figures" in blueprint and isinstance(blueprint["key_figures"], list):
        for fig_name in figures:
            if not isinstance(fig_name, str):
                continue
            fig_lower = fig_name.lower()
            for item in blueprint["key_figures"]:
                if isinstance(item, dict):
                    item_text = json.dumps(item, ensure_ascii=False).lower()
                    if fig_lower in item_text:
                        existing = result.get("key_figures", [])
                        if item not in existing:
                            result.setdefault("key_figures", []).append(item)

    # ── myth_busted → filter myths_vs_reality ──
    myth_busted = chapter_outline.get("myth_busted", "")
    if myth_busted and myth_busted != "null" and isinstance(myth_busted, str):
        myth_lower = myth_busted.lower()
        if "myths_vs_reality" in blueprint and isinstance(blueprint["myths_vs_reality"], list):
            for item in blueprint["myths_vs_reality"]:
                if isinstance(item, dict):
                    item_text = json.dumps(item, ensure_ascii=False).lower()
                    # Match if multiple words from myth_busted appear
                    myth_words = [w.lower().strip(".,;:'\"!?()") for w in myth_busted.split() if len(w) > 3]
                    hits = sum(1 for w in myth_words if w in item_text)
                    if hits >= min(2, len(myth_words)):
                        result.setdefault("myths_vs_reality", []).append(item)


def _extract_chapter_blueprint(blueprint: dict, chapter_outline: dict,
                                source_map: dict = None, niche: str = "") -> dict:
    """Extract only blueprint sections relevant to this chapter.

    Unified extraction flow for ALL narrative niches:
    1. Always-include: inject texture sections from _NICHE_ALWAYS_INCLUDE
    2. Source map: resolve paths (universal, same for all niches)
    3. Niche section matching: outline metadata → blueprint sections
    """
    result = {}

    # Niche detection: use niche string (always reliable) + blueprint keys (secondary)
    _niche_lower = (niche or "").lower()
    _is_battle = any(k in _niche_lower for k in ("battle", "trận", "combat", "war", "military"))
    _is_biography = any(k in _niche_lower for k in ("tiểu sử", "biography", "nhân vật", "chân dung", "cuộc đời"))
    _is_pirate = any(k in _niche_lower for k in ("cướp biển", "pirate", "hải tặc", "buccaneer"))
    _is_mystery = any(k in _niche_lower for k in ("mystery", "bí ẩn", "enigma"))
    # Blueprint key fallback (if niche string is empty/unknown)
    if not any((_is_battle, _is_biography, _is_pirate, _is_mystery)):
        _is_battle = "battle_phases" in blueprint
        _is_biography = "life_phases" in blueprint or "personal_profile" in blueprint
        _is_pirate = "ship_birth" in blueprint or "capture_and_mutation" in blueprint

    # ══════════════════════════════════════════════════════════════
    # ALL NICHES — source_map is REQUIRED for narrative mode
    # ══════════════════════════════════════════════════════════════
    if source_map is None:
        raise RuntimeError(
            "❌ _extract_chapter_blueprint called WITHOUT source_map. "
            "All narrative niches require source_map for precise extraction. "
            "Ensure phase plan generated _source_map and it's passed through the pipeline."
        )

    # ── Step 1: Always-include texture sections (niche-specific config) ──
    _NICHE_ALWAYS_INCLUDE = {
        "biography": (
            "core_identity",    # who the person is (essential)
            "era_context",      # historical/political background
            "key_quotes",       # dialogue fodder for scenes
            "dark_psychology",  # character depth (inner conflicts, wounds)
        ),
        "battle": (
            "core_topic",       # battle identification
            "key_facts",        # quick reference data
        ),
        "pirate": (
            "core_topic",       # ship identification
            "key_facts",        # quick reference data
            "era_context",      # golden age of piracy context
            "battlefield_experience",  # scene texture
            "narrative_moments",       # dramatic moments
            "texture_and_hooks",       # narrative hooks
        ),
        "mystery": (
            "core_topic",       # mystery identification
            "key_facts",        # quick reference data
            "era_context",      # historical context
        ),
    }

    niche_key = ("biography" if _is_biography else
                 "battle" if _is_battle else
                 "pirate" if _is_pirate else
                 "mystery" if _is_mystery else None)
    if niche_key and niche_key in _NICHE_ALWAYS_INCLUDE:
        for key in _NICHE_ALWAYS_INCLUDE[niche_key]:
            if key in blueprint:
                result[key] = blueprint[key]

    # ── Step 2: Source map path resolution (UNIVERSAL) ──
    key_data = chapter_outline.get("main_key_data", chapter_outline.get("key_data", []))
    sub_key_data = chapter_outline.get("sub_key_data", [])
    all_items = (key_data if isinstance(key_data, list) else []) + \
                (sub_key_data if isinstance(sub_key_data, list) else [])

    all_paths = []
    unresolved = []
    for item_text in all_items:
        if not isinstance(item_text, str):
            continue
        paths = source_map.get(item_text)
        if paths and isinstance(paths, list):
            all_paths.extend(paths)
        else:
            unresolved.append(item_text[:80])

    # Unresolved items: likely added by audit step (not in phase plan _source_map)
    # End chapters commonly get callback items from audit. Log but don't crash.
    if unresolved:
        _ch_type = chapter_outline.get("chapter_type", "body")
        import logging
        _logger = logging.getLogger(__name__)
        _logger.warning(
            f"_source_map: {len(unresolved)} items not found "
            f"(ch_type={_ch_type}): {[u[:60] for u in unresolved[:3]]}"
        )

    # Deduplicate paths
    unique_paths = list(dict.fromkeys(all_paths))

    # Extract blueprint data using paths
    for path in unique_paths:
        _resolve_source_path(blueprint, path, result)

    # ── Step 3: Niche section matching (outline metadata → blueprint sections) ──
    if _is_biography:
        _extract_bio_section_matches(blueprint, chapter_outline, result)
    elif _is_battle:
        _extract_battle_section_matches(blueprint, chapter_outline, result)
    elif _is_pirate:
        _extract_pirate_section_matches(blueprint, chapter_outline, result)

    # ── Safety: raise if nothing extracted for body chapters ──
    _always_keys = {"core_identity", "personal_profile", "core_topic", "key_facts",
                    "era_context", "battlefield_experience", "narrative_moments",
                    "texture_and_hooks", "key_quotes", "dark_psychology"}
    _chapter_type = chapter_outline.get("chapter_type", "").lower()
    if _chapter_type not in ("hook", "intro", "opening", "end") and set(result.keys()) <= _always_keys:
        ch_num = chapter_outline.get("chapter_number", "?")
        ch_title = chapter_outline.get("title", "?")
        kd = chapter_outline.get("main_key_data", chapter_outline.get("key_data", []))
        raise RuntimeError(
            f"❌ Blueprint filter extracted NOTHING for ch{ch_num} '{ch_title}'. "
            f"key_data={kd[:2]}... — check if key_data format matches blueprint structure."
        )

    return result

