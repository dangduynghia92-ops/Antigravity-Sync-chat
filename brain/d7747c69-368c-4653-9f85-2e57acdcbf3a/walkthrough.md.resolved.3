                continue
            cmd_lower = cmd_name.lower()
            for item in blueprint["commanders"]:
                if isinstance(item, dict) and cmd_lower in json.dumps(item, ensure_ascii=False).lower():
                    existing = result.get("commanders", [])
                    if item not in existing:
                        result.setdefault("commanders", []).append(item)

    # ── battle_phases_covered → blueprint.battle_phases (item-level) ──
    bp_covered = chapter_outline.get("battle_phases_covered", [])
    if bp_covered and "battle_phases" in blueprint and isinstance(blueprint["battle_phases"], list):
        for phase_name in bp_covered:
            if not isinstance(phase_name, str):
                continue
