def _get_research_sections(niche: str):
    """Get research sections for a niche. Returns (sections, section_names) or raises RuntimeError."""
    niche_lower = (niche or "").lower()
    # Sort by key length descending → longest match wins
    for keyword, sections in sorted(_NICHE_RESEARCH_MAP.items(), key=lambda x: len(x[0]), reverse=True):
        if keyword in niche_lower:
            names = [f"{i+1}_{s['name'][:30].replace(' ', '_').lower()}" for i, s in enumerate(sections)]
            return sections, names
    supported = sorted(set(
        v[0]["name"].split(",")[0].strip()
        for v in [_RESEARCH_SECTIONS_BIOGRAPHY, _RESEARCH_SECTIONS_BATTLE, _RESEARCH_SECTIONS_PIRATE]
    ))
    raise RuntimeError(
        f"New Content research is not available for niche '{niche}'.\n"
        f"Supported niches: {', '.join(supported)}.\n"
        f"To add support: define _RESEARCH_SECTION_X dicts and add to _NICHE_RESEARCH_MAP."
    )

