def _safe_csv_path(path: str) -> str:
    """Return a writable CSV path. If 'path' is locked (open in Excel etc.),
    append _2, _3, ... until a writable name is found."""
    if not os.path.exists(path):
        return path
    try:
        with open(path, "a"):
            return path  # writable
    except PermissionError:
        base, ext = os.path.splitext(path)
        for i in range(2, 100):
            alt = f"{base}_{i}{ext}"
            if not os.path.exists(alt):
                return alt
            try:
                with open(alt, "a"):
                    return alt
            except PermissionError:
                continue
        return path  # fallback


def _natural_sort_key(name: str):
    """Sort key for natural ordering: Chapter 1, 2, ..., 10 instead of 1, 10, 2."""
    return [int(c) if c.isdigit() else c.lower()
            for c in re.split(r'(\d+)', name)]


