def _get_niche_prompt(step: str, niche: str) -> str:
    """Get the prompt filename for a pipeline step + niche combination.
    Raises ValueError if the niche has no prompt for this step.
    """
    step_map = _NICHE_PROMPT_MAP.get(step, {})
    niche_lower = (niche or "").lower()
    # Sort by key length descending → longest match wins
    # This ensures "phân tích trận đánh" matches before "trận"
    for key, fname in sorted(step_map.items(), key=lambda x: len(x[0]), reverse=True):
        if key in niche_lower:
            return fname
    # No matching niche — tell user to create prompts
    known = ", ".join(step_map.keys())
    raise ValueError(
        f"No '{step}' prompt found for niche '{niche}'. "
        f"Known niches: [{known}]. "
        f"Please create a prompt file for this niche and add it to "
        f"_NICHE_PROMPT_MAP in rewriter.py."
    )


def _require_niche_prompt(step: str, niche: str, log_callback=None,
                         framework_name: str = "") -> str:
    """Get niche-specific prompt or raise RuntimeError with clear guidance.
    `step` should be WITHOUT the 'narrative_' prefix (e.g. 'outline', 'audit').
    If `framework_name` matches an entry in _FRAMEWORK_PROMPT_OVERRIDE,
    the framework-specific prompt is returned instead of the niche default.
    """
    if not niche:
        raise RuntimeError(
            f"Narrative {step} requires a niche. Please set niche in style_data."
        )
    map_key = f"narrative_{step}"
    # ── Check framework-level override first ──
    if framework_name and framework_name in _FRAMEWORK_PROMPT_OVERRIDE:
        override = _FRAMEWORK_PROMPT_OVERRIDE[framework_name].get(map_key)
        if override:
            if log_callback:
                log_callback(f"[framework={framework_name}] {step} → {override}")
            return override
    # ── Fallback to niche-level ──
    try:
        prompt_file = _get_niche_prompt(map_key, niche)
    except ValueError:
        raise RuntimeError(
            f"No narrative {step} prompt for niche '{niche}'. "
            f"Create prompts/system_narrative_{step}_<niche>.txt and add to "
            f"_NICHE_PROMPT_MAP['{map_key}']"
        )
    if log_callback:
        log_callback(f"[niche={niche}] {step} → {prompt_file}")
    return prompt_file


def _extract_style_for_framework(style_json: str, framework_name: str) -> str:
    """Extract only the relevant framework + shared rules from the full style JSON.

    Instead of sending the entire style JSON (939 lines, 4 frameworks),
    send only:
    - core_rules (shared voice/tone/vocabulary)
    - The ONE framework being used (with all its rules)
    - chapter_structures (body chapter templates)
    - closing_types (chapter ending types)

    Returns: a compact JSON string with only relevant data.
    """
    try:
        style = json.loads(style_json) if isinstance(style_json, str) else style_json
    except (json.JSONDecodeError, TypeError) as e:
        raise RuntimeError(f"❌ Style JSON parse failed: {e}")

    frameworks = style.get("frameworks", [])
    target_fw = None
    for fw in frameworks:
        if fw.get("name", "") == framework_name:
            target_fw = fw
            break

    if not target_fw:
        available = [fw.get('name', '?') for fw in frameworks]
        raise RuntimeError(f"❌ Framework '{framework_name}' not found. Available: {available}")

    # Build compact style with only what the AI needs
    # NOTE: chapter_structures and closing_types are already in the writer
    # template with detailed examples, so we exclude them here to avoid
    # duplication (~4.5KB saved per chapter).
    compact = {
        "core_rules": style.get("core_rules", {}),
        "framework": target_fw,  # ONLY the one being used
    }

    # Generate explicit data priority from evaluation_focus
    eval_focus = target_fw.get("evaluation_focus", {})
    primary_field = eval_focus.get("primary_data_field", "")
    secondary_fields = eval_focus.get("secondary_fields", [])
    best_when = eval_focus.get("best_when", "")

    # Determine myth level from technique_emphasis
    tech = target_fw.get("technique_emphasis", {})
    myth_level = "sparingly"
    for level in ["use_heavily", "use_moderately", "use_sparingly"]:
        if "Myth vs Reality" in tech.get(level, []):
            myth_level = level.replace("use_", "")
            break

    if primary_field:
        priority_parts = [f"PRIMARY blueprint data: `{primary_field}`"]
        if secondary_fields:
            priority_parts.append(
                f"SECONDARY data: {', '.join(f'`{f}`' for f in secondary_fields)}"
            )
        priority_parts.append(f"Myth vs Reality: use {myth_level}")
        if best_when:
            priority_parts.append(f"This framework works best when: {best_when}")

        compact["data_priority"] = " | ".join(priority_parts)

    # Strip evaluation_focus from framework — only needed during scoring,
    # not during chapter writing.
    if "evaluation_focus" in compact.get("framework", {}):
        del compact["framework"]["evaluation_focus"]
    return json.dumps(compact, ensure_ascii=False, indent=2)


def _extract_phase_labels(style_json: str, framework_name: str) -> str:
    """Extract only phase label definitions from style JSON.

    Used by phase_plan and outline stages (POV) — they don't need voice/rhythm
    rules, only the phase names and descriptions for tagging events.

    Returns: compact text block with phase labels.
    """
    try:
        style = json.loads(style_json) if isinstance(style_json, str) else style_json
    except (json.JSONDecodeError, TypeError):
        return f"(Could not parse style JSON for phase labels)"

    frameworks = style.get("frameworks", [])
    target_fw = None
    for fw in frameworks:
        if fw.get("name", "") == framework_name:
            target_fw = fw
            break

    if not target_fw:
        return f"(Framework '{framework_name}' not found)"

    steps = target_fw.get("steps", [])
    if not steps:
        return "(No phase steps defined)"

    lines = []
    for step in steps:
        name = step.get("name", "?")
        desc = step.get("description", "")
        purpose = step.get("purpose", "Body")
        lines.append(f"  {name} [{purpose}]: {desc}")

    return "\n".join(lines)


# ── Number words for Level anchor injection ──
_NUM_WORDS = {
    1: "one", 2: "two", 3: "three", 4: "four", 5: "five",
    6: "six", 7: "seven", 8: "eight", 9: "nine", 10: "ten",
    11: "eleven", 12: "twelve", 13: "thirteen", 14: "fourteen", 15: "fifteen",
    16: "sixteen", 17: "seventeen", 18: "eighteen", 19: "nineteen", 20: "twenty",
}


def _inject_level_anchor(text: str, chapter_outline: dict, log_callback=None) -> str:
    """Prepend Level anchor line to writer output (POV only).

    The Level anchor is code-controlled, not AI-generated, to eliminate
    the #1 source of prompt conflicts (4 places defining different rules).

    Format: "Level {word}, {label}. You are {age}."
    If no age available: "Level {word}, {label}."

    If text already starts with "Level", skip injection to avoid duplicates.
    """
    # Skip if AI already wrote a Level anchor
    if text.strip().lower().startswith("level"):
        if log_callback:
            log_callback("  ℹ Level anchor already present — skip injection")
        return text

    level_num = chapter_outline.get(
        "level_number",
        chapter_outline.get("chapter_number", 1)
    )
    title = chapter_outline.get("chapter_title", "") or chapter_outline.get("title", "")

    # Extract label from "Level 3: The Dead Flesh" → "the dead flesh"
    label = ""
    if ":" in title:
        label = title.split(":", 1)[1].strip().lower()
    elif title:
        # Fallback: use full title as label
        label = title.strip().lower()

    # Number → word (e.g., 1 → "one")
    num_word = _NUM_WORDS.get(level_num, str(level_num))

    # Build anchor line
    age = chapter_outline.get("age_anchor", "")
    if label and age:
        anchor = f"Level {num_word}, {label}. {age}."
    elif label:
        anchor = f"Level {num_word}, {label}."
    elif age:
        anchor = f"Level {num_word}. {age}."
    else:
        anchor = f"Level {num_word}."

    if log_callback:
        log_callback(f"  ✏ Injected Level anchor: \"{anchor}\"")

    return f"{anchor}\n\n{text}"


