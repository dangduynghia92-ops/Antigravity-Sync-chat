def convert_units(blueprint: dict, target_country: str = "US", style_data: dict = None) -> dict:
    """Convert all measurement units in blueprint's product_evaluation
    to the target country's system. Pure Python, no API call.

    If style_data has a "units" field, skip conversion entirely — the style
    defines its own measurement system (e.g., military = metric worldwide).

    target_country: 'US' or 'EU'
    style_data: optional style JSON dict
    Returns: modified blueprint with converted units.
    """
    import copy

    # If style declares its own unit system, skip automatic conversion
    if style_data and style_data.get("units"):
        return copy.deepcopy(blueprint)

    bp = copy.deepcopy(blueprint)
    products = bp.get("product_evaluation", [])
    if not products:
        return bp

    # Conversion helpers
    def _kg_to_lbs(val):
        try:
            return round(float(val) * 2.20462, 1)
        except (ValueError, TypeError):
            return val

    def _lbs_to_kg(val):
        try:
            return round(float(val) / 2.20462, 2)
        except (ValueError, TypeError):
            return val

    def _mm_to_inches(val):
        try:
            return round(float(val) / 25.4, 2)
        except (ValueError, TypeError):
            return val

    def _inches_to_mm(val):
        try:
            return round(float(val) * 25.4, 1)
        except (ValueError, TypeError):
            return val

    def _m_to_yards(val):
        try:
            return round(float(val) * 1.09361, 1)
        except (ValueError, TypeError):
            return val

    def _yards_to_m(val):
        try:
            return round(float(val) / 1.09361, 1)
        except (ValueError, TypeError):
            return val

    def _convert_str(text, target):
        """Attempt to convert detected units in a string."""
        if not isinstance(text, str) or not text.strip():
            return text
        import re as _re

        if target == "US":
            # kg → lbs
            text = _re.sub(
                r'(\d+\.?\d*)\s*kg\b',
                lambda m: f"{_kg_to_lbs(m.group(1))} lbs",
                text, flags=_re.IGNORECASE
            )
            # mm → inches
            text = _re.sub(
                r'(\d+\.?\d*)\s*mm\b',
                lambda m: f"{_mm_to_inches(m.group(1))} inches",
                text, flags=_re.IGNORECASE
            )
            # cm → inches
            text = _re.sub(
                r'(\d+\.?\d*)\s*cm\b',
                lambda m: f"{_mm_to_inches(float(m.group(1)) * 10)} inches",
                text, flags=_re.IGNORECASE
            )
            # meters → yards
            text = _re.sub(
                r'(\d+\.?\d*)\s*(?:meters?|m)\b',
                lambda m: f"{_m_to_yards(m.group(1))} yards",
                text, flags=_re.IGNORECASE
            )
            # EUR → USD (approx 1.1)
            text = _re.sub(
                r'€\s*(\d+\.?\d*)',
                lambda m: f"${round(float(m.group(1)) * 1.1, 0):.0f}",
                text
            )
        elif target == "EU":
            # lbs → kg
            text = _re.sub(
                r'(\d+\.?\d*)\s*lbs?\b',
                lambda m: f"{_lbs_to_kg(m.group(1))} kg",
                text, flags=_re.IGNORECASE
            )
            # inches → mm
            text = _re.sub(
                r'(\d+\.?\d*)\s*inch(?:es)?\b',
                lambda m: f"{_inches_to_mm(m.group(1))} mm",
                text, flags=_re.IGNORECASE
            )
            # yards → meters
            text = _re.sub(
                r'(\d+\.?\d*)\s*yards?\b',
                lambda m: f"{_yards_to_m(m.group(1))} m",
                text, flags=_re.IGNORECASE
            )
            # USD → EUR (approx /1.1)
            text = _re.sub(
                r'\$\s*(\d+\.?\d*)',
                lambda m: f"€{round(float(m.group(1)) / 1.1, 0):.0f}",
                text
            )
        return text

    # Walk through all product evaluation data and convert string values
    def _walk_and_convert(obj, target):
        if isinstance(obj, dict):
            return {k: _walk_and_convert(v, target) for k, v in obj.items()}
        elif isinstance(obj, list):
            return [_walk_and_convert(item, target) for item in obj]
        elif isinstance(obj, str):
            return _convert_str(obj, target)
        return obj

    bp["product_evaluation"] = _walk_and_convert(products, target_country)
    return bp


def reality_check_blueprint(
    blueprint: dict,
    api_client,
    lang: str = "en",
    log_callback=None,
    niche: str = "",
) -> dict:
    """Verify and enrich blueprint data against AI's training knowledge.

    Cross-references specs, pricing, and product status.
    Returns: {verification_date_note, products: [...], overall_assessment}
    """
    prompt_file = _get_niche_prompt("reality_check", niche)
    system_template = _load_prompt(prompt_file)
    system_prompt = system_template.replace("{lang}", lang)

    blueprint_json = json.dumps(blueprint, ensure_ascii=False, indent=2)

    user_content = (
        "BLUEPRINT DATA TO VERIFY AND ENRICH:\n"
        f"{blueprint_json}"
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_content},
    ]

    if log_callback:
        log_callback("Reality-checking blueprint data...")

    result = api_client.call_api(
        messages, temperature=0.1, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"❌ Reality check failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"✓ Reality check completed via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        return json.loads(json_match.group())
    return json.loads(content)


def enrich_prices_google(
    blueprint: dict,
    gemini_keys: list,
    api_client=None,
    lang: str = "en",
    log_callback=None,
    stop_check=None,
    price_date: str = "",
) -> dict:
    """Look up current US street prices via Google Search and update blueprint.

    Uses Gemini native API with google_search=True to get real-time prices.
    Supports key rotation across multiple Gemini API keys.

    Args:
        blueprint: blueprint dict with 'product_evaluation' list
        gemini_keys: list of Gemini API keys (AIza...)
        price_date: e.g. "March 2026" — auto-detected if empty

    Returns: dict with 'updated_products', 'price_data', 'price_summary'
    """
    from core.api_client import APIClient
    from datetime import datetime

    if not gemini_keys:
        if log_callback:
            log_callback("⚠ No Gemini API keys — skipping price check")
        return {"updated_products": [], "price_summary": "No API keys"}

    products = blueprint.get("product_evaluation", [])
    if not products:
        if log_callback:
            log_callback("⚠ No products in blueprint — skipping price check")
        return {"updated_products": [], "price_summary": "No products"}

    if not price_date:
        now = datetime.now()
        month_names = [
            "", "January", "February", "March", "April", "May", "June",
            "July", "August", "September", "October", "November", "December"
        ]
        price_date = f"{month_names[now.month]} {now.year}"

    # Build product list for query
    product_names = []
    for p in products:
        name = p.get("product_name", p.get("name", "Unknown"))
        product_names.append(name)

    if log_callback:
        log_callback(
            f"🔍 Looking up prices for {len(product_names)} product(s) "
            f"({price_date})..."
        )

    # Build prompt
    names_list = "\n".join(f"  {i+1}. {n}" for i, n in enumerate(product_names))
    prompt = (
        f"I need the current estimated US street price "
        f"(retail/market price in {price_date}) "
        f"for each of these firearms/ammunition products:\n\n"
        f"{names_list}\n\n"
        f"For each product, provide:\n"
        f"- product_name: exact name as listed\n"
        f"- street_price_usd: estimated price in USD (single number, e.g. 500)\n"
        f"- price_range: e.g. \"$450-$550\"\n"
        f"- price_note: brief note about price context\n\n"
        f"OUTPUT: JSON only, no markdown. Format:\n"
        f'{{"products": [{{"product_name": "...", "street_price_usd": 500, '
        f'"price_range": "$450-$550", "price_note": "..."}}]}}'
    )

    messages = [{"role": "user", "content": prompt}]

    # Create a temporary API client if not provided
    if api_client is None:
        api_client = APIClient([], stop_check=stop_check)

    # Round-robin key rotation
    result = api_client.call_gemini_with_rotation(
        messages,
        gemini_keys=gemini_keys,
        model="gemini-2.5-flash",
        google_search=True,
        timeout=120,
        stop_check=stop_check,
        log_callback=log_callback,
    )

    if result["success"]:
        try:
            content = result["content"]
            jm = re.search(r'\{[\s\S]*\}', content)
            if jm:
                price_data = json.loads(jm.group())
            else:
                price_data = json.loads(content)

            # Merge prices into blueprint
            price_map = {}
            for pp in price_data.get("products", []):
                pname = pp.get("product_name", "")
                price_map[pname.lower()] = pp

            updated = []
            for p in products:
                name = p.get("product_name", p.get("name", ""))
                matched = price_map.get(name.lower(), {})
                if matched:
                    p["street_price_usd"] = matched.get("street_price_usd")
                    p["price_range"] = matched.get("price_range", "")
                    p["price_note"] = matched.get("price_note", "")
                    p["price_date"] = price_date
                    p["price_source"] = "Google Search"
                    updated.append(name)

            if log_callback:
                log_callback(
                    f"✓ Updated prices for {len(updated)}/"
                    f"{len(products)} product(s)"
                )

            return {
                "updated_products": updated,
                "price_data": price_data,
                "price_summary": (
                    f"{len(updated)} prices updated ({price_date})"
                ),
            }
        except Exception as e:
            if log_callback:
                log_callback(f"  ⚠ Price parse error: {e}")
            return {
                "updated_products": [],
                "price_summary": f"Parse error: {e}",
            }

    return {
        "updated_products": [],
        "price_summary": f"Failed: {result.get('error', 'unknown')}",
    }


def verify_specs_google(
    blueprint: dict,
    gemini_keys: list,
    lang: str = "en",
    log_callback=None,
    stop_check=None,
) -> dict:
    """Verify product specs via Google Search Grounding.

    Checks key specs (caliber, capacity, weight, barrel length, action type,
    manufacturer, production status) against real-time Google Search data.
    Corrects any outdated or wrong values in the blueprint.

    Returns: dict with 'corrections', 'verified_count', 'corrected_count'
    """
    from core.api_client import APIClient

    if not gemini_keys:
        if log_callback:
            log_callback("⚠ No Gemini API keys — skipping spec verification")
        return {"corrections": [], "verified_count": 0, "corrected_count": 0}

    products = blueprint.get("product_evaluation", [])
    if not products:
        return {"corrections": [], "verified_count": 0, "corrected_count": 0}

    # Build spec summary for each product
    spec_lines = []
    for i, p in enumerate(products, 1):
        name = p.get("product_name", p.get("name", "Unknown"))
        specs = []
        for key in ("caliber", "capacity", "weight", "barrel_length",
                     "action_type", "manufacturer", "overall_length",
                     "production_status", "country_of_origin", "msrp"):
            val = p.get(key)
            if val:
                specs.append(f"{key}: {val}")
        spec_str = ", ".join(specs) if specs else "no specs listed"
        spec_lines.append(f"  {i}. {name} — {spec_str}")

    product_list = "\n".join(spec_lines)

    if log_callback:
        log_callback(
            f"🔎 Verifying specs for {len(products)} product(s) via Google Search..."
        )

    prompt = (
        "I need you to VERIFY the following firearm/ammunition product specs "
        "using Google Search. For EACH product, search for the official specs "
        "and compare with the values listed below.\n\n"
        f"PRODUCTS AND CURRENT SPECS:\n{product_list}\n\n"
        "For each product, check:\n"
        "- caliber/chambering\n"
        "- magazine capacity\n"
        "- barrel length\n"
        "- overall length\n"
        "- weight\n"
        "- action type\n"
        "- manufacturer (current, after any acquisitions)\n"
        "- production status (current production / discontinued / limited)\n"
        "- MSRP or street price\n\n"
        "OUTPUT: JSON only, no markdown. Format:\n"
        '{"products": [\n'
        '  {"product_name": "...", "status": "CORRECT" or "CORRECTED",\n'
        '   "corrections": [\n'
        '     {"field": "caliber", "old_value": "...", "new_value": "...", '
        '"source": "manufacturer website"}\n'
        '   ],\n'
        '   "verified_specs": {"caliber": "...", "capacity": "...", ...}\n'
        '  }\n'
        ']}'
    )

    messages = [{"role": "user", "content": prompt}]
    api_client = APIClient([], stop_check=stop_check)

    # Round-robin key rotation
    result = api_client.call_gemini_with_rotation(
        messages,
        gemini_keys=gemini_keys,
        model="gemini-2.5-flash",
        google_search=True,
        timeout=180,
        stop_check=stop_check,
        log_callback=log_callback,
    )

    if result["success"]:
        try:
            content = result["content"]
            jm = re.search(r'\{[\s\S]*\}', content)
            if jm:
                verify_data = json.loads(jm.group())
            else:
                verify_data = json.loads(content)

            # Apply corrections to blueprint
            verify_map = {}
            for vp in verify_data.get("products", []):
                vname = vp.get("product_name", "")
                verify_map[vname.lower()] = vp

            corrections_total = 0
            verified_total = 0
            all_corrections = []

            for p in products:
                name = p.get("product_name", p.get("name", ""))
                matched = verify_map.get(name.lower(), {})
                if not matched:
                    continue

                verified_total += 1
                corrections = matched.get("corrections", [])
                verified_specs = matched.get("verified_specs", {})

                # Apply verified specs
                for spec_key, spec_val in verified_specs.items():
                    if spec_val and spec_key not in ("product_name",):
                        p[spec_key] = spec_val

                # Log corrections
                for c in corrections:
                    corrections_total += 1
                    field = c.get("field", "?")
                    old = c.get("old_value", "?")
                    new = c.get("new_value", "?")
                    if log_callback:
                        log_callback(
                            f"  ⚡ {name}: {field} "
                            f"'{old}' → '{new}'"
                        )
                    all_corrections.append({
                        "product": name, **c
                    })

            if log_callback:
                log_callback(
                    f"✓ Specs verified: {verified_total} product(s), "
                    f"{corrections_total} correction(s)"
                )

            return {
                "corrections": all_corrections,
                "verified_count": verified_total,
                "corrected_count": corrections_total,
                "raw_data": verify_data,
            }
        except Exception as e:
            if log_callback:
                log_callback(f"  ⚠ Spec verification parse error: {e}")
            return {"corrections": [], "verified_count": 0, "corrected_count": 0}

    if log_callback:
        log_callback(f"❌ Spec verification: all keys failed")
    return {"corrections": [], "verified_count": 0, "corrected_count": 0}



