def _load_prompt(name: str, lang: str = "english") -> str:
    """Load a prompt template from prompts/ directory.
    Tries prompts/{lang}/{name} first, falls back to prompts/{name}.
    """
    # Try language-specific prompt first
    lang_path = os.path.join(_PROMPTS_DIR, lang, name)
    if os.path.exists(lang_path):
        with open(lang_path, "r", encoding="utf-8") as f:
            return f.read()
    # Fallback to shared prompt
    path = os.path.join(_PROMPTS_DIR, name)
    with open(path, "r", encoding="utf-8") as f:
        return f.read()


def load_rewritten_files(output_dir: str) -> list[dict]:
    """Load all *_rewritten.txt files from an output directory.
    Returns: [{"filename": "...", "filepath": "...", "word_count": N}]
    """
    files = []
    if not os.path.isdir(output_dir):
        return files
    for fname in sorted(os.listdir(output_dir), key=_natural_sort_key):
        if fname.endswith("_rewritten.txt"):
            fpath = os.path.join(output_dir, fname)
            with open(fpath, "r", encoding="utf-8") as f:
                text = f.read()
            files.append({
                "filename": fname,
                "filepath": fpath,
                "word_count": len(text.split()),
            })
    return files


# ── Step 1: Analyze ──────────────────────────────────────────────

def analyze_chapter(
    chapter_text: str,
    api_client,
    lang: str = "english",
    log_callback=None,
) -> dict:
    """Analyze chapter and choose best storytelling method."""
    system_prompt = _load_prompt("system_analyze.txt", lang)

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": chapter_text},
    ]

    if log_callback:
        text_len = len(chapter_text)
        log_callback(f"  Sending to AI ({text_len} chars)...")

    result = api_client.call_api(
        messages, temperature=0.4, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"  ❌ API failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    endpoint = result.get("endpoint_url", "?")
    if log_callback:
        log_callback(f"  ✓ Response from {model}")
        log_callback(f"    Endpoint: {endpoint}")

    content = result["content"]
    if not content or not content.strip():
        if log_callback:
            log_callback("  ❌ Empty response from AI")
        raise RuntimeError("Empty response from AI")

    try:
        json_match = re.search(r'\{[\s\S]*\}', content)
        if json_match:
            analysis = json.loads(json_match.group())
        else:
            analysis = json.loads(content)
    except (json.JSONDecodeError, ValueError) as e:
        if log_callback:
            log_callback(f"  ❌ JSON parse error: {e}")
        raise RuntimeError(f"Invalid JSON from AI: {e}")

    return analysis


# ── Step 2: Rewrite ──────────────────────────────────────────────

def rewrite_chapter(
    chapter_text: str,
    analysis: dict,
    api_client,
    word_count_rule: str = "1300 to 1800 words",
    lang: str = "english",
    log_callback=None,
    system_prompt_override: str = None,
) -> str:
    """Rewrite chapter using the chosen storytelling method."""
    if system_prompt_override:
        system_prompt = system_prompt_override
    else:
        system_template = _load_prompt("system_rewrite.txt", lang)
        system_prompt = system_template.replace(
            "{method}", analysis.get("method", "inquiry_arc")
        ).replace(
            "{hook}", analysis.get("hook", "")
        ).replace(
            "{counter_argument}", analysis.get("counter_argument", "")
        ).replace(
            "{word_count_rule}", word_count_rule
        )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": f"ORIGINAL CHAPTER:\n\n{chapter_text}"},
    ]

    if log_callback:
        method = analysis.get("method", "?")
        log_callback(f"  Rewriting ({method}, {word_count_rule})...")

    result = api_client.call_api(
        messages, temperature=0.7, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"  ❌ API failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"  ✓ Rewritten via {model}")

    return result["content"].strip()


# ── Step 3: Verify ───────────────────────────────────────────────

def verify_chapter(
    original_text: str,
    rewritten_text: str,
    api_client,
    word_count_rule: str = "1300 to 1800 words",
    lang: str = "english",
    log_callback=None,
) -> dict:
    """Verify quality of rewritten chapter."""
    system_template = _load_prompt("system_review.txt", lang)
    system_prompt = system_template.replace("{word_count_rule}", word_count_rule)

    user_content = (
        f"ORIGINAL:\n{original_text}\n\n"
        f"---\n\n"
        f"REWRITTEN:\n{rewritten_text}"
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_content},
    ]

    if log_callback:
        log_callback("  Verifying quality...")

    result = api_client.call_api(
        messages, temperature=0.3, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"  ❌ API failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"  ✓ Verified via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        review = json.loads(json_match.group())
    else:
        review = json.loads(content)

    return review


# ── AI Merge: read content → select + order ─────────────────────

def _read_chapter_content(filepath: str, max_chars: int = 3000) -> str:
    """Read rewritten chapter file, truncate if too long."""
    try:
        with open(filepath, "r", encoding="utf-8") as f:
            text = f.read().strip()
        if len(text) > max_chars:
            return text[:max_chars] + "\n[...truncated...]"
        return text
    except Exception:
        return ""


def summarize_chapter(
    chapter_text: str,
    api_client,
    log_callback=None,
) -> str:
    """Generate a 3-5 sentence English summary of a chapter."""
    messages = [
        {"role": "system", "content": (
            "You are a content summarizer. Write a concise 3-5 sentence "
            "English summary of the chapter below. Focus on: main topic, "
            "key historical events/people, and the narrative angle. "
            "Output ONLY the summary text, nothing else."
        )},
        {"role": "user", "content": chapter_text},
    ]

    if log_callback:
        log_callback("  Summarizing...")

    result = api_client.call_api(
        messages, temperature=0.3, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"  ❌ Summary failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    return result["content"].strip()


def ai_order_chapters(
    chapter_files: list[dict],
    num_range: str,
    api_client,
    log_callback=None,
) -> dict:
    """AI reads actual content, groups chapters by theme.
    chapter_files: [{"filename", "filepath", "score", "word_count", "summary"(optional)}, ...]
    num_range: e.g. '5-10', '5-0' (min only), '0-10' (max only), '0-0' (no limit)
    Returns: {"groups": [...]}
    """
    system_template = _load_prompt("system_order.txt")

    # Build ch_rule from min-max
    parts = num_range.split("-")
    ch_min = int(parts[0]) if len(parts) > 0 else 0
    ch_max = int(parts[1]) if len(parts) > 1 else 0

    if ch_min > 0 and ch_max > 0:
        ch_rule = f"between {ch_min} and {ch_max} chapters"
    elif ch_min > 0:
        ch_rule = f"at least {ch_min} chapters"
    elif ch_max > 0:
        ch_rule = f"at most {ch_max} chapters"
    else:
        ch_rule = "enough chapters for a compelling video (around 5-10)"

    system_prompt = system_template.replace("{ch_rule}", ch_rule)

    blocks = []
    use_summary = len(chapter_files) > 30  # summary mode for large sets
    for ch in chapter_files:
        summary = ch.get("summary", "")
        if use_summary and summary:
            score = ch.get("score", "?")
            wc = ch.get("word_count", "?")
            blocks.append(
                f"=== {ch['filename']} (score: {score}, {wc} words) ===\n"
                f"{summary}"
            )
        else:
            content = _read_chapter_content(ch["filepath"])
            if not content:
                continue
            score = ch.get("score", "?")
            wc = ch.get("word_count", len(content.split()))
            blocks.append(
                f"=== {ch['filename']} (score: {score}, {wc} words) ===\n"
                f"{content}"
            )

    if not blocks:
        raise RuntimeError("No rewritten chapters found")

    mode_note = " (using summaries)" if use_summary else ""
    user_content = (
        f"Available chapters ({len(blocks)} total{mode_note}):\n\n"
        + "\n\n".join(blocks)
        + f"\n\nGroup these chapters into thematic clusters (each group: {ch_rule})."
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_content},
    ]

    if log_callback:
        log_callback(
            f"  AI reading {len(blocks)} chapters "
            f"({sum(len(b) for b in blocks)} chars){mode_note}..."
        )

    result = api_client.call_api(
        messages, temperature=0.4, timeout=500
    )

    if not result["success"]:
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"  ✓ AI grouped via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        return json.loads(json_match.group())
    return json.loads(content)


def export_merge_preview_csv(groups_data: dict, output_path: str,
                              highlight_group_id: int = 0) -> str:
    """Export merge preview analysis to CSV.
    groups_data: {"groups": [...]}
    highlight_group_id: if > 0, mark that group with ★★★ in the CSV
    Returns: path to CSV file.
    """
    groups = groups_data.get("groups", [])
    os.makedirs(os.path.dirname(output_path) or ".", exist_ok=True)
    output_path = _safe_csv_path(output_path)

    with open(output_path, "w", encoding="utf-8-sig", newline="") as f:
        writer = csv.writer(f)

        # Section 1: Group overview
        writer.writerow(["=== TỔNG QUAN CÁC NHÓM ==="])
        writer.writerow(["Nhóm", "Theme", "Mô tả", "Điểm hấp dẫn",
                         "Số chapters", "Lý do nhóm này hợp", "Tiêu đề gợi ý"])
        for g in groups:
            titles = " / ".join(g.get("suggested_titles_vi", []))
            chapters = g.get("chapters", [])
            gid = g.get("group_id", "")
            marker = " ★★★" if highlight_group_id and gid == highlight_group_id else ""
            writer.writerow([
                f"{gid}{marker}",
                g.get("theme", ""),
                g.get("description_vi", ""),
                g.get("appeal_score", ""),
                len(chapters),
                g.get("why_this_group_vi", ""),
                titles,
            ])

        writer.writerow([])
        writer.writerow([])

        # Section 2: Detail per group
        for g in groups:
            gid = g.get("group_id", "?")
            theme = g.get("theme", "")
            marker = " ★★★" if highlight_group_id and gid == highlight_group_id else ""
            writer.writerow([f"=== NHÓM {gid}: {theme}{marker} ==="])
            writer.writerow(["Vị trí", "Chapter", "Fit", "Vai trò", "Lý do xếp vị trí này"])
            for ch in g.get("chapters", []):
                writer.writerow([
                    ch.get("order", ""),
                    ch.get("filename", ""),
                    ch.get("fit_score", "?"),
                    ch.get("role_vi", ""),
                    ch.get("reason_vi", ""),
                ])
            writer.writerow([])

    return output_path


def ai_suggest_order(
    chapter_files: list[dict],
    api_client,
    log_callback=None,
) -> dict:
    """AI suggests order only (user already selected chapters).
    Returns: {selected_chapters: [{order, filename, reason_vi}], overall_strategy_vi}
    """
    system_prompt = (
        "You are a YouTube content strategist. "
        "The user already selected these chapters for their video. "
        "Suggest the BEST ORDER for maximum viewer retention.\n"
        "Reply JSON only:\n"
        '{"selected_chapters": [{"order": 1, "filename": "...", '
        '"reason_vi": "Lý do tiếng Việt"}], '
        '"overall_strategy_vi": "Chiến lược sắp xếp..."}'
    )

    blocks = []
    for ch in chapter_files:
        content = _read_chapter_content(ch["filepath"], max_chars=2000)
        if not content:
            continue
        blocks.append(f"=== {ch['filename']} ===\n{content}")

    if not blocks:
        raise RuntimeError("No chapters to order")

    user_content = (
        f"Order these {len(blocks)} chapters:\n\n"
        + "\n\n".join(blocks)
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_content},
    ]

    if log_callback:
        log_callback(f"  AI suggesting order for {len(blocks)} chapters...")

    result = api_client.call_api(
        messages, temperature=0.4, timeout=500
    )

    if not result["success"]:
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"  ✓ Order suggested via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        return json.loads(json_match.group())
    return json.loads(content)


