    def _do_cut_video_for_group(self, job):
        """Post-rewrite: Cut downloaded video into chapter clips.
        
        Simple flow:
          1. Find video .mp4 in project dir (parent of group_path/01_chapters)
          2. Parse timecodes from merge file
          3. ffmpeg cut into chapter clips
        """
        from core.video_cutter import (
            find_merge_file, parse_merge_timecodes, download_video, cut_video,
            extract_youtube_url_from_merge,
        )
        log_prefix = job.get("log_prefix", "[Cut]")
        stop_event = job.get("stop_event")
        _log_cb = job.get("_log_callback")

        def log(msg):
            if _log_cb:
                _log_cb(f"{log_prefix} {msg}")
            else:
                self._log.log(f"{log_prefix} {msg}")

        def stop_check():
            return stop_event and stop_event.is_set()

        # Determine the chapters directory (contains merge file + chapter text files)
        chapters_dir = job.get("group_path", "")
        if not chapters_dir or not os.path.isdir(chapters_dir):
            log("🎬 Skip video cut: no group_path")
            return

        # Project dir = parent of 01_chapters
        project_dir = os.path.dirname(chapters_dir)

        # 1. Find merge file  
        merge_path = find_merge_file(chapters_dir)
        if not merge_path:
            log(f"🎬 ⚠ No merge file found, skip video cut")
            return

        # 2. Check if already cut
        video_out_dir = os.path.join(project_dir, "02_video_chapters")
        if os.path.isdir(video_out_dir):
            existing_mp4 = [f for f in os.listdir(video_out_dir) if f.endswith(".mp4")]
            if existing_mp4:
                log(f"🎬 ⏭ Already cut ({len(existing_mp4)} clips)")
                return

        # 3. Parse timecodes
        chapters_tc = parse_merge_timecodes(merge_path)
        if not chapters_tc:
            log(f"🎬 ⚠ No timecodes in merge file")
            return

        # 4. Find video file (look in project dir, then chapters dir)
        video_path = ""
        for search_dir in [project_dir, chapters_dir]:
            if not os.path.isdir(search_dir):
                continue
            for vf in os.listdir(search_dir):
                if vf.endswith((".mp4", ".mkv", ".webm")) and not vf.startswith("Ch_"):
                    candidate = os.path.join(search_dir, vf)
                    if os.path.getsize(candidate) > 1_000_000:  # >1MB
                        video_path = candidate
                        log(f"🎬 Found video: {vf}")
                        break
            if video_path:
                break

        # 5. No local video → try download via YouTube URL in merge file
        if not video_path:
            yt_url = extract_youtube_url_from_merge(merge_path)
            if not yt_url:
                log(f"🎬 ⚠ No video file found and no YouTube URL in merge file")
                return
            log(f"🎬 Downloading video: {yt_url}")
            import tempfile
            _tmp_dir = tempfile.mkdtemp(prefix="cutter_")
            video_path = download_video(
                yt_url, _tmp_dir, log_callback=log, stop_check=stop_check
            )
            if not video_path or not os.path.isfile(video_path):
                log(f"🎬 ❌ Download failed")
                return

        if stop_check():
            return

        # 6. Cut!
        log(f"🎬 Cutting {len(chapters_tc)} chapters...")
        saved = cut_video(
            video_path, chapters_tc, video_out_dir,
            log_callback=log, stop_check=stop_check,
        )
        log(f"🎬 ✅ Done: {len(saved)}/{len(chapters_tc)} clips → 02_video_chapters/")

    def _update_input_chapters_status(self, checked, status_text, chapters_data, progress=""):
        """Update all input chapters to a given status and refresh UI."""
        for ch in checked:
            fname = ch["filename"]
            ch_st = chapters_data.setdefault(fname, {})
            ch_st["status"] = status_text
            if progress:
                ch_st["progress"] = progress
        self.tree_refresh.emit()

    def _do_retry(self, specific_folders=None):
        """Retry failed/error/stopped folders."""
        if specific_folders:
            retry_groups = specific_folders
        else:
            # Find folders with failed/error/stopped status
            retry_groups = []
            for i in range(self._folder_tree.topLevelItemCount()):
                item = self._folder_tree.topLevelItem(i)
                if not item:
                    continue
                group_name = item.data(1, Qt.ItemDataRole.UserRole)
                if not group_name:
                    continue
                job = self._get_job_for_group(group_name)
                if job and job["status"] in ("error", "stopped"):
                    retry_groups.append(group_name)
                elif job and job["status"] == "done":
                    # Also retry "done" folders that have chapter-level errors
                    has_ch_error = any(
                        self._status.get(ch["filename"], {}).get("status") == "error"
                        for ch in self._chapters if ch.get("group") == group_name
                    )
                    if has_ch_error:
                        retry_groups.append(group_name)

        if not retry_groups:
            self._log.log("[Style] No failed/stopped folders to retry")
            return

        # Reset status for these folders
        for gn in retry_groups:
            job = self._get_job_for_group(gn)
            if job:
                # Remove old job so _do_rewrite can create new one
                jid = job.get("id")
                if jid and jid in self._jobs:
                    del self._jobs[jid]
            # Reset chapter statuses for this group
            for ch in self._chapters:
                if ch.get("group") == gn:
                    fname = ch["filename"]
                    if fname in self._status:
                        # Reset error/failed chapters
                        ch_st = self._status[fname]
                        if ch_st.get("status") in ("error", "pending"):
                            self._status.pop(fname, None)

        self._log.log(f"[Style] Retrying {len(retry_groups)} folder(s): {', '.join(g.split(']_', 1)[-1][:30] if ']_' in g else g[:30] for g in retry_groups)}")

        # Check the retry folders in the folder tree
        retry_set = set(retry_groups)
        for i in range(self._folder_tree.topLevelItemCount()):
            item = self._folder_tree.topLevelItem(i)
            if not item:
                continue
            gn = item.data(1, Qt.ItemDataRole.UserRole)
            if gn in retry_set:
                item.setCheckState(1, Qt.CheckState.Checked)
            else:
                item.setCheckState(1, Qt.CheckState.Unchecked)

        self.job_update.emit()
        # Trigger rewrite for checked folders
        self._do_rewrite()

    def _do_stop(self):
        running_jobs = {jid: j for jid, j in self._jobs.items() if j["status"] == "running"}
        if not running_jobs:
            self._stop_flag = True  # legacy fallback
            self._log.log("[Style] Stopping...")
            return

        if len(running_jobs) == 1:
            # Only 1 job — stop it directly
            jid, job = next(iter(running_jobs.items()))
            job["stop_event"].set()
            job["status"] = "stopped"
            job["progress"] = "Stopped"
            self._log.log(f"[Job] Stopping: {job['folder_name']}")
            self.job_update.emit()
        else:
            # Multiple jobs — show menu
            from PyQt6.QtWidgets import QMenu
            menu = QMenu(self)
            for jid, job in running_jobs.items():
                action = menu.addAction(f"Stop: {job['folder_name']}")
                action.setData(jid)
            menu.addSeparator()
            stop_all = menu.addAction("■ Stop All")
            stop_all.setData("__all__")

            action = menu.exec(self._btn_stop.mapToGlobal(self._btn_stop.rect().bottomLeft()))
            if action:
                chosen = action.data()
                if chosen == "__all__":
                    for jid, job in running_jobs.items():
                        job["stop_event"].set()
                        job["status"] = "stopped"
                        job["progress"] = "Stopped"
                    self._log.log("[Job] Stopping ALL jobs")
                else:
                    job = self._jobs.get(chosen)
                    if job:
                        job["stop_event"].set()
                        job["status"] = "stopped"
                        job["progress"] = "Stopped"
                        self._log.log(f"[Job] Stopping: {job['folder_name']}")
                self.job_update.emit()

