# ── Framework-level prompt overrides ──
# When a specific framework needs different prompts than its parent niche,
# add it here. Checked BEFORE the niche-level _NICHE_PROMPT_MAP.
_FRAMEWORK_PROMPT_OVERRIDE = {
    "Thành Trì Vô Luật": {
        "narrative_outline": "system_narrative_outline_pirate_haven.txt",
        "narrative_writer":  "system_narrative_write_pirate_haven.txt",
