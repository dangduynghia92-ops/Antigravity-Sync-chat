    ).replace(
        "{closing_type}", chapter_outline.get("closing_type") or "N/A"
    ).replace(
        "{debate_seed}", chapter_outline.get("debate_seed") or "N/A"
    )

    # ── Human moment template replacements ──
    hm = chapter_outline.get("human_moment", {}) or {}
    system_prompt = system_prompt.replace(
        "{human_moment_trigger}", hm.get("trigger_data") or "N/A"
    ).replace(
        "{human_moment_type}", hm.get("moment_type") or "none"
    ).replace(
        "{human_moment_angle}", hm.get("angle") or "N/A"
    )

    # ── Build alternative_rhetoric block for writer ──
    # Filter by data_focus: only show alternatives relevant to THIS chapter's topic
    alt_rhetoric_lines = []
    ch_data_focus = set(f.lower() for f in chapter_outline.get("data_focus", []))
    for prod_name in (products if products else []):
        # Read from ORIGINAL blueprint (not _bp_sanitized which strips data_source)
        for prod in blueprint.get("product_evaluation", []):
            if prod.get("product_name") == prod_name:
                alts = prod.get("alternative_rhetoric", [])
                if alts:
                    relevant_alts = []
                    for alt in alts:
                        if isinstance(alt, dict):
                            ds = (alt.get("data_source") or "").lower()
                            # Skip alternatives whose data_source doesn't match chapter's focus
                            if ch_data_focus and ds and not any(f in ds for f in ch_data_focus):
                                continue
                            alt_type = alt.get("type", "")
                            alt_text = alt.get("alternative", "")
                            if alt_text:
                                relevant_alts.append(f"  - ({alt_type}) DIRECTION: {alt_text}")
                    if relevant_alts:
                        alt_rhetoric_lines.append(f"[{prod_name}]")
                        alt_rhetoric_lines.extend(relevant_alts)
                break
    alt_rhetoric_str = "\n".join(alt_rhetoric_lines) if alt_rhetoric_lines else "(No alternative angles provided — create your own ORIGINAL angles)"
    system_prompt = system_prompt.replace("{alternative_rhetoric}", alt_rhetoric_str)

    # ── Extract next chapter topic for transition accuracy ──
    next_topic = "N/A"
    try:
        _outline_data = json.loads(full_outline) if isinstance(full_outline, str) else (full_outline or {})
        _chapters_list = _outline_data.get("chapters", [])
        for _ch in _chapters_list:
            if _ch.get("chapter_number") == chapter_number + 1:
                _next_title = _ch.get("title", "")
                _next_crit = _ch.get("primary_criterion", "")
                next_topic = f"{_next_title} ({_next_crit})" if _next_crit else _next_title
                break
    except Exception:
        pass
    system_prompt = system_prompt.replace("{next_chapter_topic}", next_topic)

    # ── Conditional transition stripping ──
    if not use_transitions:
        import re
        # Mystery prompt: has a dedicated ═══ TRANSITIONS ═══ section
        transition_block = re.search(
            r'═+\s*TRANSITIONS BETWEEN CHAPTERS\s*═+.*?(?=═+|$)',
            system_prompt, re.DOTALL
        )
        if transition_block:
            no_transition_rule = (
                "═══════════════════════════════════════\n"
                "CHAPTER OPENING RULE (NO TRANSITIONS)\n"
                "═══════════════════════════════════════\n\n"
                "Do NOT write bridge sentences between chapters.\n"
                "Do NOT execute `ends_with` from the outline.\n"
                "Open each body chapter DIRECTLY with its assigned structure.\n"
                "End each chapter with its closing type — do NOT add any transition to the next chapter.\n"
            )
            system_prompt = (
                system_prompt[:transition_block.start()]
                + no_transition_rule
                + system_prompt[transition_block.end():]
            )
        else:
            # Firearms/Military: inject override rule before messages
            system_prompt += (
                "\n\n═══════════════════════════════════════\n"
                "CHAPTER OPENING RULE (NO TRANSITIONS)\n"
                "═══════════════════════════════════════\n\n"
                "Do NOT write bridge sentences connecting to the previous chapter.\n"
                "Open each body chapter DIRECTLY with its rank number + product/system name,\n"
                "then proceed immediately with the assigned structure.\n"
            )

        # Strip ALL remaining transition/ends_with instructions from prompt
        # These exist outside the TRANSITIONS block and cause AI to still write transitions
        system_prompt = re.sub(
            r'^.*?[Ee]xecute\s+`?ends_with`?.*?$', '', system_prompt, flags=re.MULTILINE
        )
        system_prompt = re.sub(
            r'^.*?GEOGRAPHIC/TEMPORAL TRANSITIONS.*?$', '', system_prompt, flags=re.MULTILINE
        )
        system_prompt = re.sub(
            r'Ends with:.*$', 'Ends with: (transitions OFF — end with closing type only)',
            system_prompt, count=1, flags=re.MULTILINE
        )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": (
            f"Write chapter {chapter_number} of {total_chapters}: "
            f"{chapter_outline.get('title') or chapter_outline.get('chapter_title', '')}\n\n"
            f"Use the blueprint and style guide in the system prompt. "
            f"Write in {lang}.\n\n"
            f"MANDATORY WORD COUNT: {word_count_rule}. "
            f"Count your output — do NOT submit if below minimum."
        )},
    ]

    if log_callback:
        log_callback(f"  Writing Ch.{chapter_number} [{chapter_type}] from blueprint ({framework_name})...")

    result = api_client.call_api(
        messages, temperature=0.6, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"  ❌ API failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"  ✓ Ch.{chapter_number} written via {model}")

    return result["content"].strip()
