def create_review_outline(
    blueprint: dict,
    style_guide: dict,
    framework_name: str,
    api_client,
    lang: str = "en",
    chapter_range: str = "a suitable number of chapters",
    log_callback=None,
    niche: str = "",
) -> dict:
    """Create a chapter outline for a review script using framework-specific
    Hook/Body/End structure and evaluation_focus.

    Returns: {framework_used, total_chapters, thesis, chapters: [...],
              cta, products_coverage_map}
    """
    prompt_file = _get_niche_prompt("outline", niche)
    system_template = _load_prompt(prompt_file)
    system_prompt = system_template.replace("{lang}", lang)

    # ── Strip author_rhetoric from blueprint before outline sees it ──
    # Same logic as writer: outline must choose angles from alternative_rhetoric,
    # not replicate the original author's editorial framing.
    import copy
    _bp_for_outline = copy.deepcopy(blueprint)
    for product in _bp_for_outline.get("product_evaluation", []):
        product.pop("author_rhetoric", None)
        for alt in product.get("alternative_rhetoric", []):
            if isinstance(alt, dict):
                alt.pop("original", None)
                alt.pop("data_source", None)
    blueprint_json = json.dumps(_bp_for_outline, ensure_ascii=False, indent=2)

    # Extract the specific framework
    framework = None
    for fw in style_guide.get("frameworks", []):
        if fw.get("name", "") == framework_name:
            framework = fw
            break

    if not framework:
        raise RuntimeError(f"Framework '{framework_name}' not found in style guide")

    framework_json = json.dumps(framework, ensure_ascii=False, indent=2)

    # Extract openings, closings, techniques
    meta = {
        "openings": [o.get("name", "") for o in style_guide.get("openings", [])],
        "closings": [c.get("name", "") for c in style_guide.get("closings", [])],
        "techniques": [t.get("name", "") for t in style_guide.get("techniques", [])],
    }
    meta_json = json.dumps(meta, ensure_ascii=False, indent=2)
    # Pre-calculate subject/product constraints from chapter range
    _niche_lower = (niche or "").lower()
    _is_mystery_niche = "mystery" in _niche_lower

    if _is_mystery_niche:
        # Mystery: count subjects from key_events/key_facts/product_evaluation
        n_events = len(blueprint.get("key_events", []))
        n_facts = len(blueprint.get("key_facts", []))
        n_pe = len(blueprint.get("product_evaluation", []))
        n_subjects = max(n_events, n_facts, n_pe, 1)
        _label = "MYSTERY CONSTRAINT"
        _item = "mysteries"
        _item_singular = "mystery"
        _order = "Order by ESCALATING impossibility/significance."
        _dropped_key = "mysteries_dropped"
    else:
        # Product review: count products
        n_subjects = len(blueprint.get("product_evaluation", []))
        _label = "PRODUCT CONSTRAINT"
        _item = "products"
        _item_singular = "product"
        _order = ""
        _dropped_key = "products_dropped"

    product_names = [
        p.get("product_name", f"Item {i+1}")
        for i, p in enumerate(blueprint.get("product_evaluation", []))
    ]

    # Parse chapter range to extract min/max
    import re as _re
    ch_match = _re.search(r'between\s+(\d+)\s+and\s+(\d+)', chapter_range)
    ch_min_match = _re.search(r'at least\s+(\d+)', chapter_range)
    ch_max_match = _re.search(r'at most\s+(\d+)', chapter_range)

    if ch_match:
        ch_min, ch_max = int(ch_match.group(1)), int(ch_match.group(2))
    elif ch_min_match:
        ch_min, ch_max = int(ch_min_match.group(1)), 0
    elif ch_max_match:
        ch_min, ch_max = 0, int(ch_max_match.group(1))
    else:
        ch_min, ch_max = 0, 0

    # Body chapters = total - hook(1) - end(1)
    if ch_min and ch_max:
        body_min = max(1, ch_min - 2)
        body_max = max(1, ch_max - 2)
        subject_instruction = (
            f"{_label} (pre-calculated):\n"
            f"- Blueprint has {n_subjects} {_item}.\n"
            f"- Body chapters: {body_min}-{body_max} (1 {_item_singular} per chapter).\n"
            f"- Select {min(n_subjects, body_min)}-{min(n_subjects, body_max)} {_item}.\n"
            + (f"- {_order}\n" if _order else "")
            + f"- List dropped {_item} in `{_dropped_key}`."
        )
        chapter_instruction = f"**CHAPTER COUNT (HARD LIMIT):** {ch_min}-{ch_max} chapters total."
    elif ch_max:
        body_max = max(1, ch_max - 2)
        subject_instruction = (
            f"{_label} (pre-calculated):\n"
            f"- Blueprint has {n_subjects} {_item}.\n"
            f"- Maximum {min(n_subjects, body_max)} {_item} (1 per body chapter).\n"
            + (f"- {_order}\n" if _order else "")
            + f"- List dropped {_item} in `{_dropped_key}`."
        )
        chapter_instruction = f"**CHAPTER COUNT (HARD LIMIT):** at most {ch_max} chapters total."
    elif ch_min:
        body_min = max(1, ch_min - 2)
        subject_instruction = (
            f"{_label} (pre-calculated):\n"
            f"- Blueprint has {n_subjects} {_item}.\n"
            f"- Minimum {min(n_subjects, body_min)} {_item} (1 per body chapter)."
            + (f"\n- {_order}" if _order else "")
        )
        chapter_instruction = f"**CHAPTER COUNT (HARD LIMIT):** at least {ch_min} chapters total."
    else:
        subject_instruction = (
            f"{_label}:\n"
            f"- Blueprint has {n_subjects} {_item}. Include as appropriate."
            + (f"\n- {_order}" if _order else "")
        )
        chapter_instruction = "**CHAPTER COUNT:** use a suitable number of chapters."

    user_content = (
        f"BLUEPRINT:\n{blueprint_json}\n\n"
        f"FRAMEWORK:\n{framework_json}\n\n"
        f"AVAILABLE OPENINGS/CLOSINGS/TECHNIQUES:\n{meta_json}\n\n"
        f"{subject_instruction}\n\n"
        f"{chapter_instruction}"
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_content},
    ]

    if log_callback:
        log_callback(f"Creating review outline with '{framework_name}'...")

    result = api_client.call_api(
        messages, temperature=0.3, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"❌ Outline creation failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"✓ Review outline created via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        return json.loads(json_match.group())
    return json.loads(content)


def write_review_chapter(
    blueprint: dict,
    style_json: str,
    framework_name: str,
    chapter_outline: dict,
    chapter_number: int,
    total_chapters: int,
    api_client,
    word_count_rule: str = "1300 to 1800 words",
    lang: str = "en",
    previous_context: str = "",
    target_country: str = "US",
    full_outline: str = "",
    log_callback=None,
    use_transitions: bool = True,
) -> str:
    """Write a NEW review chapter from a content blueprint + style guide.
    Uses the review-specific prompt with chapter_type, target_country,
    products_covered, evaluation_criteria, etc.

    Returns: the written chapter text.
    """
    # Load style-specific writer prompt — no fallback, niche must match
    _niche_prompt_map = {
        "firearms_v2": "system_write_review_firearms_v2.txt",
        "firearms": "system_write_review_firearms.txt",
        "military": "system_write_review_military.txt",
        "mystery": "system_write_review_mystery.txt",
    }
    prompt_file = None
    try:
        _style_data = json.loads(style_json) if isinstance(style_json, str) else style_json
        _niche = _style_data.get("niche", "").lower()
        for key, fname in _niche_prompt_map.items():
            if key in _niche:
                prompt_file = fname
                break
    except Exception:
        pass
    if not prompt_file:
        raise ValueError(
            f"No writer prompt found for niche '{_style_data.get('niche', '?')}'. "
            f"Create a prompt file and add it to _niche_prompt_map in rewriter.py."
        )

    # ── Mystery niche: modular base + structure architecture ──
    _prompts_dir = os.path.join(os.path.dirname(__file__), "..", "prompts")
    _base_path = os.path.join(_prompts_dir, "base_mystery_writer.txt")
    _ch_structure = chapter_outline.get("chapter_structure", "mythbuster")

    if "mystery" in (_niche or "") and os.path.exists(_base_path):
        system_template = _load_prompt("base_mystery_writer.txt")

        # Load structure-specific prompt
        _struct_file = f"mystery_structures/structure_{_ch_structure}.txt"
        _struct_path = os.path.join(_prompts_dir, _struct_file)
        if os.path.exists(_struct_path):
            _struct_content = _load_prompt(_struct_file)
        else:
            _struct_content = (
                f"Follow the '{_ch_structure}' storytelling structure. "
                "Use the outline's chapter_structure field as your guide."
            )
        system_template = system_template.replace(
            "{structure_prompt}", _struct_content
        )

        # Inject conditional MAINSTREAM/COUNTER based on structure
        _dialectic_structures = {
            "mythbuster", "detective_trail", "conflicting_accounts"
        }
        if _ch_structure in _dialectic_structures:
            _cond = (
                "CONDITIONAL — this structure REQUIRES [MAINSTREAM] + [COUNTER]:\n\n"
                "  [MAINSTREAM] Official/conventional explanation — present FAIRLY\n"
                "    - From `mainstream_theory` in outline\n"
                "    - Give genuine intellectual weight — this is NOT a strawman\n"
                "    - BAD: \"Mainstream historians are wrong\"\n"
                "    - GOOD: \"Historians classify them as a hereditary criminal cult. "
                "The consistency is explained as oral tradition. These are not foolish arguments.\"\n\n"
                "  [COUNTER] Pivot + counter-evidence — expose the gaps\n"
                "    - From `core_impossibility` in outline\n"
                "    - SHARP PIVOT required — the most important sentence in the chapter\n"
                "    - PIVOT BLACKLIST (HARD BAN — may NOT appear more than ONCE in the entire video):\n"
                "      × \"This/That explanation, however, [verb]s...\"\n"
                "      × \"The mainstream/conventional explanation holds that...\"\n"
                "      × \"The mainstream historical view classifies/dismisses...\"\n"
                "    - USE INSTEAD (one per chapter, no repeats):\n"
                "      * Data contradiction: \"That accounts for X. It does not account for Y.\"\n"
                "      * Scale impossibility: \"Hereditary gangs do not produce 600 years of identical methodology.\"\n"
                "      * Direct challenge: \"To accept this requires believing that...\"\n"
                "      * Temporal paradox: \"This compound was not identified until 1840. They were deploying it in 672.\"\n"
                "      * Methodological gap: \"The technique targets structures not mapped until...\"\n"
                "      * Absence as evidence: \"Every record survives — except this one.\""
            )
        else:
            _cond = (
                f"NOTE: Structure '{_ch_structure}' does NOT require [MAINSTREAM] or [COUNTER].\n"
                "Focus on [EVIDENCE] and the structure's own storytelling flow.\n"
                "Do NOT force a mainstream→counter dialectic into this chapter."
            )
        system_template = system_template.replace(
            "{required_elements_conditional}", _cond
        )
        if log_callback:
            log_callback(f"  [Prompt] base + structure_{_ch_structure}.txt")
    else:
        # Fallback to monolithic prompt for non-mystery niches
        system_template = _load_prompt(prompt_file)

    # ── Strip author_rhetoric from blueprint before writer sees it ──
    # Writer must use alternative_rhetoric (creative fuel) only.
    # Keeping author_rhetoric would let writer copy original rhetoric.
    # Also strip `original` and `data_source` from alternative_rhetoric items —
    # writer only needs `type` + `alternative` text. data_source leaks original
    # phrases (e.g., "manos perezosas") that the writer copies verbatim.
    import copy
    _bp_sanitized = copy.deepcopy(blueprint)
    for product in _bp_sanitized.get("product_evaluation", []):
        product.pop("author_rhetoric", None)
        for alt in product.get("alternative_rhetoric", []):
            if isinstance(alt, dict):
                alt.pop("original", None)
                alt.pop("data_source", None)
    blueprint_json = json.dumps(_bp_sanitized, ensure_ascii=False, indent=2)

    # ── Hook chapters get SLIM blueprint — no product specs ──
    # Hook should NOT see detailed data; it only needs topic + product names
    # to write Challenge/Tease/Launch pattern without stuffing specs.
    chapter_type = chapter_outline.get("chapter_type", "body")
    if chapter_type == "hook":
        _outline_data = {}
        try:
            _outline_data = json.loads(full_outline) if isinstance(full_outline, str) else (full_outline or {})
        except Exception:
            pass
        _hook_bp = {
            "core_topic": _bp_sanitized.get("core_topic", ""),
            "thesis": _outline_data.get("thesis", ""),
            "total_products": len(_bp_sanitized.get("product_evaluation", [])),
            "product_names": [
                p.get("product_name", "?")
                for p in _bp_sanitized.get("product_evaluation", [])
            ],
        }
        blueprint_json = json.dumps(_hook_bp, ensure_ascii=False, indent=2)

    # Extract review-specific outline fields
    products = chapter_outline.get("products_covered", [])
    products_str = ", ".join(products) if products else "N/A"
    eval_criteria = chapter_outline.get("evaluation_criteria", [])
    eval_str = ", ".join(eval_criteria) if eval_criteria else "N/A"
    primary = chapter_outline.get("primary_criterion", "")
    techniques = chapter_outline.get("techniques_to_use", [])
    techniques_str = ", ".join(techniques) if techniques else "N/A"
    chapter_type = chapter_outline.get("chapter_type", "body")

    compact_style = _extract_style_for_framework(style_json, framework_name)

    system_prompt = system_template.replace(
        "{style_json}", compact_style
    ).replace(
        "{framework_name}", framework_name
    ).replace(
        "{chapter_type}", chapter_type or "body"
    ).replace(
        "{target_country}", target_country
    ).replace(
        "{blueprint}", blueprint_json
    ).replace(
        "{full_outline}", full_outline or "(not provided)"
    ).replace(
        "{chapter_number}", str(chapter_number)
    ).replace(
        "{total_chapters}", str(total_chapters)
    ).replace(
        "{chapter_title}", chapter_outline.get("title") or chapter_outline.get("chapter_title") or f"Chapter {chapter_number}"
    ).replace(
        "{chapter_summary}", chapter_outline.get("summary") or ""
    ).replace(
        "{products_covered}", products_str
    ).replace(
        "{evaluation_criteria}", eval_str
    ).replace(
        "{primary_criterion}", primary or "N/A"
    ).replace(
        "{depth_focus}", chapter_outline.get("depth_focus") or "N/A"
    ).replace(
        "{techniques_to_use}", techniques_str
    ).replace(
        "{emotional_beat}", chapter_outline.get("emotional_beat") or ""
    ).replace(
        "{ends_with}", chapter_outline.get("ends_with") or ""
    ).replace(
