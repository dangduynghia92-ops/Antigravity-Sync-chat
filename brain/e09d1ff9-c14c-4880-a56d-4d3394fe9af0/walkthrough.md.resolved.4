def transform_rhetoric(
    blueprint: dict,
    niche: str = "",
    lang: str = "en",
    target_country: str = "US",
    log_callback=None,
    stop_check=None,
    api_endpoints: list = None,
    gemini_keys: list = None,
) -> dict:
    """Transform original author rhetoric into original alternatives.

    Reads `author_rhetoric` from each product in the blueprint,
    sends it (with the product's `detailed_facts`) to the AI,
    and writes `alternative_rhetoric` back into the blueprint.

    Runs independently from data enrichment — no field overlap.

    Returns: dict with 'products_transformed', 'summary'
    """
    from core.api_client import APIClient

    def log(msg):
        if log_callback:
            log_callback(msg)

    # Check if any product has author_rhetoric
    products = blueprint.get("product_evaluation", [])
    has_rhetoric = any(
        p.get("author_rhetoric") for p in products if isinstance(p, dict)
    )
    if not has_rhetoric:
        log("⊘ No author_rhetoric in blueprint — skipping rhetoric transform")
        return {"products_transformed": 0, "summary": "No rhetoric to transform"}

    # Find niche-specific transform prompt
    niche_lower = (niche or "").lower()
    prompt_file = None
    for keyword, pfile in _NICHE_TRANSFORM_RHETORIC_MAP.items():
        if keyword in niche_lower:
            prompt_file = pfile
            break

    if not prompt_file:
        log(f"⊘ No rhetoric transform prompt for niche '{niche}' — skipping")
        return {"products_transformed": 0, "summary": f"No prompt for niche '{niche}'"}

    # Need at least one API source
    if not api_endpoints and not gemini_keys:
        log("⚠ No API keys or endpoints — skipping rhetoric transform")
        return {"products_transformed": 0, "summary": "No API keys"}

    # Build prompt
    system_template = _load_prompt(prompt_file)
    if not system_template:
        log(f"⚠ Could not load prompt: {prompt_file}")
        return {"products_transformed": 0, "summary": "Prompt file not found"}

    # Prepare slim blueprint: product_name + detailed_facts + subjective fields to rewrite
    slim_products = []
    for p in products:
        if not isinstance(p, dict):
            continue
        slim = {
            "product_name": p.get("product_name", "Unknown"),
            # Subjective fields to rewrite
            "author_rhetoric": p.get("author_rhetoric", []),
            "myths_misconceptions": p.get("myths_misconceptions", []),
            "comparisons": [c for c in p.get("comparisons", []) if c.get("source") == "transcript"],
            # Structured fields (AI scans these for subjective content)
            "key_specs": p.get("key_specs", {}),
            "practical_use_case": p.get("practical_use_case", []),
            "origin_history": p.get("origin_history", []),
            "ergonomics_handling": p.get("ergonomics_handling", {}),
            "action_mechanism": p.get("action_mechanism", {}),
            "accuracy_precision": p.get("accuracy_precision", {}),
            "materials_finish": p.get("materials_finish", {}),
            "cost_economics": p.get("cost_economics", {}),
        }
        slim_products.append(slim)

    slim_bp_json = json.dumps(slim_products, indent=2, ensure_ascii=False)

    system_prompt = (
        system_template
        .replace("{lang}", lang)
        .replace("{target_country}", target_country)
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": f"PRODUCT DATA:\n{slim_bp_json}"},
    ]

    # Call API
    log(f"🎨 Transforming rhetoric for {len(slim_products)} product(s) → {target_country}...")

    try:
        if api_endpoints:
            api_client = APIClient(api_endpoints, tier="flash", stop_check=stop_check)
        else:
            api_client = APIClient(
                [{"url": f"https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key={k}"}
                 for k in gemini_keys],
                tier="flash", stop_check=stop_check
            )
        result = api_client.call_api(messages, temperature=0.7, timeout=120)

        if not result.get("success"):
            log(f"⚠ Rhetoric transform failed: {result.get('error', 'unknown')}")
            return {"products_transformed": 0, "summary": f"API error: {result.get('error', '?')}"}

        content = (result.get("content") or "").strip()
        if not content:
            log("⚠ Rhetoric transform: empty response")
            return {"products_transformed": 0, "summary": "Empty response"}

        # Parse response
        transform_data = _clean_and_parse_json(content)
        if not transform_data:
            log("⚠ Rhetoric transform: could not parse JSON response")
            return {"products_transformed": 0, "summary": "Invalid JSON"}

        # Merge alternative_rhetoric back into blueprint
        transformed_products = transform_data.get("products", [])
        count = 0
        for tp in transformed_products:
            if not isinstance(tp, dict):
                continue
            tp_name = (tp.get("product_name") or "").lower()
            alt_rhetoric = tp.get("alternative_rhetoric", [])

            # Find matching product in blueprint
            for bp_product in products:
                bp_name = (bp_product.get("product_name") or "").lower()
                if bp_name == tp_name or tp_name in bp_name or bp_name in tp_name:
                    bp_product["alternative_rhetoric"] = alt_rhetoric

                    # ── Merge cleaned_fields back into blueprint ──
                    cleaned = tp.get("cleaned_fields", {})
                    if cleaned and isinstance(cleaned, dict):
                        for field_name, field_value in cleaned.items():
                            if field_value:  # Only replace non-empty
                                bp_product[field_name] = field_value

                    # ── Also merge rewritten myths & comparisons ──
                    rewritten_myths = tp.get("rewritten_myths", [])
                    if rewritten_myths and isinstance(rewritten_myths, list):
                        bp_product["myths_misconceptions"] = rewritten_myths
                    rewritten_comps = tp.get("rewritten_comparisons", [])
                    if rewritten_comps and isinstance(rewritten_comps, list):
                        bp_product["comparisons"] = rewritten_comps

                    count += 1
                    break

        model = result.get("model", "?")
        log(f"✓ Rhetoric transform: {count}/{len(slim_products)} product(s) via {model}")

        return {
            "products_transformed": count,
            "transform_data": transform_data,
            "summary": f"Transformed {count} products for {target_country}",
        }

    except Exception as e:
        log(f"⚠ Rhetoric transform error: {e}")
        return {"products_transformed": 0, "summary": str(e)}


def enrich_blueprint_google(
    blueprint: dict,
    gemini_keys: list,
    niche: str = "",
    lang: str = "en",
    log_callback=None,
    stop_check=None,
    use_google_search: bool = True,
    api_endpoints: list = None,
) -> dict:
    """Fill empty blueprint fields using 2-phase enrichment.

    Phase 1: AI internal knowledge via main endpoints (no search).
             Uses 9Router/proxy. Falls back to Gemini keys if no endpoints.
    Phase 2: Google Search grounding (Gemini keys direct) — only for
             fields STILL empty after Phase 1.

    If use_google_search=False, only Phase 1 runs.

    Args:
        blueprint: blueprint dict from extract_blueprint
        gemini_keys: list of Gemini API keys (for Phase 2 search)
        niche: niche keyword (e.g. "battle", "mystery")
        lang: language code
        log_callback: optional logging function
        stop_check: optional callable returning True to abort
        use_google_search: if True, runs Phase 2 with Google Search
        api_endpoints: main API endpoints for Phase 1 (via 9Router)

    Returns: dict with 'fields_filled', 'enrichment_data', 'summary'
    """
    from core.api_client import APIClient

    def log(msg):
        if log_callback:
            log_callback(msg)

    # Need at least one source
    if not gemini_keys and not api_endpoints:
        log("⚠ No API keys or endpoints — skipping enrichment")
        return {"fields_filled": 0, "summary": "No API keys"}

    # Find empty fields
    empties = _find_empty_fields(blueprint)
    if not empties:
        log("✓ Blueprint is complete — no empty fields to enrich")
        return {"fields_filled": 0, "summary": "Blueprint already complete"}

    log(f"📋 Found {len(empties)} empty field(s): {', '.join(empties[:10])}"
        + (f" (+{len(empties)-10} more)" if len(empties) > 10 else ""))

    # Find niche-specific enrichment prompt
    niche_lower = (niche or "").lower()
    prompt_file = None
    for keyword, pfile in _NICHE_ENRICH_PROMPT_MAP.items():
        if keyword in niche_lower:
            prompt_file = pfile
            break

    if not prompt_file:
        log(f"⚠ No enrichment prompt for niche '{niche}' — skipping")
        return {"fields_filled": 0, "summary": f"No prompt for niche '{niche}'"}

    total_filled = 0
    all_enrichment_data = {}

    # ══════════════════════════════════════════
    # PHASE 1: AI Internal Knowledge (via endpoints, no search)
    # ══════════════════════════════════════════
    log("── Phase 1: Enriching via AI knowledge...")
    if api_endpoints:
        # Use main endpoints (9Router/proxy)
        p1_result = _run_enrich_phase_endpoints(
            blueprint, api_endpoints, prompt_file, lang,
            phase_label="Phase 1 (AI knowledge)",
            log=log, stop_check=stop_check,
        )
    elif gemini_keys:
        # Fallback: use Gemini keys directly
        p1_result = _run_enrich_phase(
            blueprint, gemini_keys, prompt_file, lang,
            google_search=False,
            phase_label="Phase 1 (AI knowledge)",
            log=log, stop_check=stop_check,
        )
    else:
        p1_result = None
    if p1_result:
        total_filled += p1_result.get("fields_filled", 0)
        if p1_result.get("enrichment_data"):
            all_enrichment_data["phase1_ai"] = p1_result["enrichment_data"]

    if stop_check and stop_check():
        return {"fields_filled": total_filled, "summary": "Stopped by user"}

    # Check remaining empties
    remaining = _find_empty_fields(blueprint)

    # ══════════════════════════════════════════
    # PHASE 2: Google Search (only if enabled AND still empty fields)
    # ══════════════════════════════════════════
    if use_google_search and remaining:
        log(f"── Phase 2: {len(remaining)} field(s) still empty → Google Search...")
        p2_result = _run_enrich_phase(
            blueprint, gemini_keys, prompt_file, lang,
            google_search=True,
            phase_label="Phase 2 (Google Search)",
            log=log, stop_check=stop_check,
        )
        if p2_result:
            total_filled += p2_result.get("fields_filled", 0)
            if p2_result.get("enrichment_data"):
                all_enrichment_data["phase2_search"] = p2_result["enrichment_data"]
    elif use_google_search and not remaining:
        log("✓ All fields filled in Phase 1 — skipping Google Search")
    else:
        log("── Google Search disabled — Phase 1 only")

    # Final summary
    final_empties = _find_empty_fields(blueprint)
    if final_empties:
        log(f"  Still empty after enrichment: {', '.join(final_empties[:5])}"
            + (f" (+{len(final_empties)-5} more)"
               if len(final_empties) > 5 else ""))
    else:
        log("✓ Blueprint fully enriched — no empty fields remain")

    return {
        "fields_filled": total_filled,
        "enrichment_data": all_enrichment_data,
        "summary": f"Filled {total_filled} fields (2-phase)",
        "still_empty": final_empties,
    }


def _build_enrich_prompt(blueprint, prompt_file, lang):
    """Build enrichment prompt from template + blueprint data."""
    system_template = _load_prompt(prompt_file)
    core_topic = blueprint.get("core_topic", "Unknown")
    blueprint_json = json.dumps(blueprint, indent=2, ensure_ascii=False)
    return (
        system_template
        .replace("{lang}", lang)
        .replace("{core_topic}", core_topic if isinstance(core_topic, str)
                 else json.dumps(core_topic, ensure_ascii=False))
        .replace("{blueprint_json}", blueprint_json)
    )


def _merge_enrich_result(content, blueprint, phase_label, log):
    """Parse AI response and merge into blueprint. Returns result dict or None."""
    if not content:
        return None

    enrichment_data = _clean_and_parse_json(content)
    if enrichment_data is None:
        raise json.JSONDecodeError("Could not extract valid JSON after cleaning", content[:200], 0)

    pre_count = len(_find_empty_fields(blueprint))
    _deep_merge_empty(blueprint, enrichment_data)
    post_empties = _find_empty_fields(blueprint)
    fields_filled = pre_count - len(post_empties)

    return {
        "fields_filled": fields_filled,
        "enrichment_data": enrichment_data,
    }


def _clean_and_parse_json(text: str) -> dict | None:
    """Extract and parse JSON from AI response with aggressive cleaning.

    Handles: markdown fences, trailing commas, extra text after JSON,
    multiple JSON objects, comments.
    """
    if not text:
        return None

    text = text.strip()

    # 1. Strip markdown code fences
    text = re.sub(r'^```(?:json)?\s*\n?', '', text)
    text = re.sub(r'\n?\s*```\s*$', '', text)
    text = text.strip()

    # 2. Try direct parse first
    try:
        return json.loads(text)
    except json.JSONDecodeError:
        pass

    # 3. Find the FIRST complete top-level JSON object using brace matching
    json_str = _extract_matched_braces(text)
    if json_str:
        try:
            return json.loads(json_str)
        except json.JSONDecodeError:
            # 4. Try fixing trailing commas
            cleaned = _fix_trailing_commas(json_str)
            try:
                return json.loads(cleaned)
            except json.JSONDecodeError:
                pass

    # 5. Fallback: greedy regex (old behavior)
    jm = re.search(r'\{[\s\S]*\}', text)
    if jm:
        try:
            return json.loads(jm.group())
        except json.JSONDecodeError:
            cleaned = _fix_trailing_commas(jm.group())
            try:
                return json.loads(cleaned)
            except json.JSONDecodeError:
                pass

    return None


def _extract_matched_braces(text: str) -> str | None:
    """Find the first complete {...} with properly matched braces."""
    start = text.find('{')
    if start == -1:
        return None

    depth = 0
    in_string = False
    escape_next = False

    for i in range(start, len(text)):
        ch = text[i]

        if escape_next:
            escape_next = False
            continue

        if ch == '\\' and in_string:
            escape_next = True
            continue

        if ch == '"' and not escape_next:
            in_string = not in_string
            continue

        if in_string:
            continue

        if ch == '{':
            depth += 1
        elif ch == '}':
            depth -= 1
            if depth == 0:
                return text[start:i + 1]

    return None


def _fix_trailing_commas(text: str) -> str:
    """Remove trailing commas before } or ] (common AI mistake)."""
    # ,  } or ,  ]  (with optional whitespace/newlines)
    text = re.sub(r',\s*([}\]])', r'\1', text)
    return text


def _run_enrich_phase_endpoints(
    blueprint: dict,
    api_endpoints: list,
    prompt_file: str,
    lang: str,
    phase_label: str,
    log,
    stop_check=None,
) -> dict | None:
    """Run enrichment via main endpoints (9Router/proxy). No Google Search."""
    from core.api_client import APIClient

    system_prompt = _build_enrich_prompt(blueprint, prompt_file, lang)
    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": "Fill the empty fields in the blueprint above. Return the COMPLETE enriched blueprint JSON."},
    ]

    api_client = APIClient(api_endpoints, tier="flash", stop_check=stop_check)
    try:
        result = api_client.call_api(messages, temperature=0.2, timeout=120)
        if result["success"]:
            content = (result.get("content") or "").strip()
            if not content:
                log(f"  ⚠ {phase_label}: empty response")
                return None
            merge_result = _merge_enrich_result(content, blueprint, phase_label, log)
            model = result.get("model", "?")
            filled = merge_result["fields_filled"] if merge_result else 0
            log(f"  ✓ {phase_label}: filled {filled} field(s) via {model}")
            return merge_result
        else:
            log(f"  ⚠ {phase_label} failed: {result.get('error', 'unknown')}")
            return None
    except json.JSONDecodeError as e:
        log(f"  ⚠ {phase_label}: JSON parse error: {e}")
        return None
    except Exception as e:
        log(f"  ⚠ {phase_label} error: {e}")
        return None


def _run_enrich_phase(
    blueprint: dict,
    gemini_keys: list,
    prompt_file: str,
    lang: str,
    google_search: bool,
    phase_label: str,
    log,
    stop_check=None,
) -> dict | None:
    """Run enrichment via Gemini keys directly (supports Google Search).

    Uses round-robin key rotation to distribute load evenly.
    """
    from core.api_client import APIClient

    system_prompt = _build_enrich_prompt(blueprint, prompt_file, lang)
    messages = [{"role": "user", "content": system_prompt}]

    api_client = APIClient([], stop_check=stop_check)

    result = api_client.call_gemini_with_rotation(
        messages,
        gemini_keys=gemini_keys,
        model="gemini-2.5-flash",
        google_search=google_search,
        timeout=120,
        stop_check=stop_check,
        log_callback=log,
    )

    if result["success"]:
        content = (result.get("content") or "").strip()
        if not content:
            log(f"  ⚠ {phase_label}: API returned empty content")
            return None

        try:
            merge_result = _merge_enrich_result(content, blueprint, phase_label, log)
            model = result.get("model", "?")
            filled = merge_result["fields_filled"] if merge_result else 0
            log(f"  ✓ {phase_label}: filled {filled} field(s) via {model}")
            return merge_result
        except json.JSONDecodeError as e:
            log(f"  ⚠ {phase_label}: JSON parse error: {e}")
            return None
        except Exception as e:
            log(f"  ⚠ {phase_label}: error: {e}")
            return None

    log(f"  ⚠ {phase_label}: all keys failed")
    return None


def extract_blueprint_review(
    full_text: str,
    api_client,
    lang: str = "en",
    log_callback=None,
    niche: str = "",
) -> dict:
    """Extract a REVIEW-specific blueprint focused on product data only.
    No narrative fields (key_events, key_characters, narrative_moments).

    For mystery niche: includes key_figures, historical_context, geography,
    technology_and_artifacts, scholarly_debate (no ranking_criteria/original_order/thesis_angle).

    Returns: dict with core_topic, product_evaluation, key_claims, etc.
    """
    prompt_file = _get_niche_prompt("extract_blueprint", niche)
    system_template = _load_prompt(prompt_file)
    system_prompt = system_template.replace("{lang}", lang)

    # Extract first ~2000 chars (≈90s speech) and last ~2000 chars for thesis
    _THESIS_CHARS = 2000
    _first_segment = full_text[:_THESIS_CHARS].strip()
    _last_segment = full_text[-_THESIS_CHARS:].strip() if len(full_text) > _THESIS_CHARS else ""

    _thesis_hint = (
        f"\n\n=== THESIS CONTEXT (first ~90s + last ~90s of script) ===\n"
        f"--- OPENING (first ~90 seconds) ---\n{_first_segment}\n\n"
    )
    if _last_segment:
        _thesis_hint += f"--- CLOSING (last ~90 seconds) ---\n{_last_segment}\n"
    _thesis_hint += (
        "=== END THESIS CONTEXT ===\n"
        "IMPORTANT: Extract thesis_angle ONLY from the OPENING or CLOSING sections above. "
        "Use the author's near-verbatim words. Do NOT rephrase or generalize.\n"
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": f"REVIEW SCRIPT TO EXTRACT FROM:\n\n{full_text}{_thesis_hint}"},
    ]

    if log_callback:
        log_callback(f"Extracting review blueprint ({len(full_text):,} chars)...")

    result = api_client.call_api(
        messages, temperature=0.2, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"❌ Review blueprint extraction failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"✓ Review blueprint extracted via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        return json.loads(json_match.group())
    return json.loads(content)


def audit_outline_review(
    blueprint: dict,
    outline: dict,
    framework: dict,
    style_json: str,
    api_client,
    chapter_range: str = "",
    log_callback=None,
    niche: str = "",
) -> dict:
    """Audit a REVIEW outline using code-based structural checks + AI fix pass.

    Phase 1 (CODE): Detect structural issues programmatically (fast, no API).
    Phase 2 (AI):   Fix outline only when issues are found (slim payload).

    Returns: the audited outline dict (or original on failure).
    """
    def log(msg):
        if log_callback:
            log_callback(msg)

    chapters = outline.get("chapters", [])
    total = len(chapters)
    fw_name = (framework.get("name", "") if isinstance(framework, dict) else "").lower()
    issues = []

    # ── Code Check 1: Chapter count ──
    if chapter_range:
        try:
            parts = chapter_range.replace(" ", "").split("-")
            ch_min = int(parts[0])
            ch_max = int(parts[-1])
            if total < ch_min:
                issues.append({"type": "chapter_count", "description": f"Only {total} chapters, minimum is {ch_min}", "fix_needed": "add_chapters_or_merge"})
            elif total > ch_max:
                issues.append({"type": "chapter_count", "description": f"{total} chapters exceeds maximum {ch_max}", "fix_needed": "remove_or_merge_chapters"})
        except (ValueError, IndexError):
            pass

    # ── Code Check 2: Chapter type labels ──
    if chapters:
        first = chapters[0]
        last = chapters[-1]
        if first.get("chapter_type") != "hook":
            issues.append({"type": "structure", "description": f"First chapter type is '{first.get('chapter_type')}', should be 'hook'", "fix_needed": "change_type_to_hook"})
        if last.get("chapter_type") != "end":
            issues.append({"type": "structure", "description": f"Last chapter type is '{last.get('chapter_type')}', should be 'end'", "fix_needed": "change_type_to_end"})

    # ── Code Check 3: Title uniqueness ──
    body_titles = []
    for ch in chapters:
        if ch.get("chapter_type") in ("body", "topic_block", "criterion"):
            title = (ch.get("title") or "").strip().lower()
            if title:
                body_titles.append(title)
    seen = set()
    dupes = set()
    for t in body_titles:
        if t in seen:
            dupes.add(t)
        seen.add(t)
    if dupes:
        issues.append({"type": "title", "description": f"Duplicate body titles found: {list(dupes)}", "fix_needed": "rename_duplicate_titles"})

    # ── Code Check 4: data_focus validation ──
    available_fields = set()
    for prod in blueprint.get("product_evaluation", []):
        for k, v in prod.items():
            if isinstance(v, (dict, list)) and v:  # dict OR list fields
                available_fields.add(k)
    for ch in chapters:
        if ch.get("chapter_type") in ("body", "topic_block", "criterion"):
            df = ch.get("data_focus")
            if not df:
                issues.append({"type": "data_focus", "description": f"Ch.{ch.get('chapter_number', '?')} '{ch.get('title', '')}' missing data_focus", "fix_needed": "add_data_focus"})
            elif isinstance(df, list):
                for field in df:
                    if field not in available_fields:
                        issues.append({"type": "data_focus", "description": f"Ch.{ch.get('chapter_number', '?')} data_focus '{field}' not found in blueprint", "fix_needed": "replace_invalid_field"})

    # ── Code Check 5: Framework-specific ──
    if "ranking" in fw_name:
        positions = [ch.get("countdown_position") for ch in chapters if ch.get("chapter_type") == "body"]
        positions_clean = [p for p in positions if p is not None]
        if positions_clean and len(set(positions_clean)) != len(positions_clean):
            issues.append({"type": "ordering", "description": "Duplicate countdown positions found", "fix_needed": "fix_countdown_positions"})

    # ── Code Check 6: Product coverage ──
    product_names = {p.get("product_name", "") for p in blueprint.get("product_evaluation", [])}
    for ch in chapters:
        if ch.get("chapter_type") in ("body",):
            covered = ch.get("products_covered", [])
            for p in covered:
                if p not in product_names:
                    issues.append({"type": "product_coverage", "description": f"Ch.{ch.get('chapter_number', '?')} covers unknown product '{p}'", "fix_needed": "fix_product_name"})

    # ── Results ──
    if not issues:
        log("✓ Audit passed — no issues found (code check)")
        return outline

    log(f"✓ Audit found {len(issues)} issue(s) via code check:")
    for iss in issues:
        log(f"  → [{iss['type']}] {iss['description']}")

    # ── Pass 2 (AI): Fix outline — slim payload (no blueprint/style) ──
    log("Sending outline to AI for fixes...")
    slim_context = {
        "product_names": [p.get("product_name", "") for p in blueprint.get("product_evaluation", [])],
        "available_field_groups": sorted(available_fields),
        "framework": fw_name,
    }
    pass2_content = (
        f"OUTLINE TO FIX:\n{json.dumps(outline, ensure_ascii=False, indent=2)}\n\n"
        f"ISSUES TO FIX:\n{json.dumps(issues, ensure_ascii=False, indent=2)}\n\n"
        f"CONTEXT:\n{json.dumps(slim_context, ensure_ascii=False, indent=2)}\n\n"
        f"CHAPTER RANGE: {chapter_range or 'not specified'}\n\n"
        "Apply ALL fixes above to the outline. "
        "Return ONLY the corrected outline as a JSON object (same format as input). "
        "Do NOT wrap in another object — return the outline directly."
    )

    messages_p2 = [
        {"role": "system", "content": (
            "You are an outline editor. Apply the listed fixes to the outline. "
            "Return ONLY the corrected outline as valid JSON. No other text."
        )},
        {"role": "user", "content": pass2_content},
    ]

    result_p2 = api_client.call_api(
        messages_p2, temperature=0.1, timeout=180
    )

    if not result_p2["success"]:
        log(f"⚠ AI fix failed, using original outline")
        return outline

    try:
        content_p2 = result_p2["content"]
        json_match = re.search(r'\{[\s\S]*\}', content_p2, re.DOTALL)
        if json_match:
            fixed_outline = json.loads(json_match.group())
        else:
            fixed_outline = json.loads(content_p2)

        if "chapters" not in fixed_outline:
            log("⚠ Fixed outline missing 'chapters' key, using original")
            return outline

        model = result_p2.get("model", "?")
        log(f"✓ Outline fixed via {model} ({len(fixed_outline.get('chapters', []))} chapters)")
        return fixed_outline

    except (json.JSONDecodeError, Exception) as e:
        log(f"⚠ Could not parse fixed outline: {e}, using original outline")
        return outline

def review_cross_chapter(
    full_script: str,
    api_client,
    lang: str = "en",
    log_callback=None,
    niche: str = "",
) -> dict:
    """Cross-chapter review for REVIEW mode — checks data consistency,
    comparison conflicts, benchmark consistency, transitions.

    Returns: {overall_flow_score, flow_report, issues: [...],
              no_issues_chapters: [...]}
    """
    prompt_file = _get_niche_prompt("cross_chapter", niche)
    system_template = _load_prompt(prompt_file)
    system_prompt = system_template.replace("{lang}", lang)

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": f"FULL REVIEW SCRIPT:\n\n{full_script}"},
    ]

    if log_callback:
        log_callback("Running cross-chapter review...")

    result = api_client.call_api(
        messages, temperature=0.2, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"❌ Cross-chapter review failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"✓ Cross-chapter review via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content, re.DOTALL)
    if json_match:
        return json.loads(json_match.group())
    return json.loads(content)


def generate_narrative_phase_plan(
    blueprint: dict,
    style_json: str,
    framework_name: str,
    api_client,
    chapter_range: str = "between 5 and 20 chapters",
    lang: str = "en",
    log_callback=None,
    niche: str = "",
) -> dict:
    """Step 1: Classify blueprint events into framework phases.

    AI assigns main_key_data and sub_key_data per phase.
    Chapter splitting is done separately by apply_chapter_splits().

    Returns: {framework_used, biography_subject,
              phase_chapter_plan: [{phase, main_key_data, sub_key_data, node_count}]}
    """
    prompt_file = _require_niche_prompt("phase_plan", niche, log_callback)
    system_prompt = _load_prompt(prompt_file)
    if "{lang}" in system_prompt:
        system_prompt = system_prompt.replace("{lang}", lang)

    blueprint_json = json.dumps(blueprint, ensure_ascii=False, indent=2)
    compact_style = _extract_style_for_framework(style_json, framework_name)

    user_content = (
        f"STYLE GUIDE:\n{compact_style}\n\n"
        f"MANDATORY FRAMEWORK: \"{framework_name}\"\n\n"
        f"CONTENT BLUEPRINT:\n{blueprint_json}"
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_content},
    ]

    if log_callback:
        log_callback(f"Planning phases for '{framework_name}'...")

    result = api_client.call_api(messages, temperature=0.0, timeout=300, step_label="phase_plan")

    if not result["success"]:
        if log_callback:
            log_callback(f"❌ Phase plan failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"✓ Phase plan via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        plan = json.loads(json_match.group())
    else:
        plan = json.loads(content)

    # Validate — route by niche
    _niche_lower = (niche or "").lower()
    _is_pov_pp = any(k in _niche_lower for k in ("pov", "góc nhìn", "nhập vai"))

    if _is_pov_pp and "event_timeline" in plan:
        # POV: validate event_timeline
        events = plan.get("event_timeline", [])
        if log_callback:
            log_callback(f"  Events: {len(events)}")
            for ev in events:
                log_callback(f"  event {ev.get('event_id', '?')}: age {ev.get('age', '?')} — {ev.get('event_title', '?')} [{ev.get('phase_label', '')}]")

        # Validate _source_map
        source_map = plan.get("_source_map")
        if not source_map or not isinstance(source_map, dict):
            raise RuntimeError(
                "❌ Phase plan is missing '_source_map'. "
                "The phase plan AI MUST output a _source_map dict mapping every "
                "event_description/sub_key_data text to its blueprint source fields."
            )
        # Check event_description + sub_key_data items have source entries
        missing = []
        for ev in events:
            desc = ev.get("event_description", "")
            if isinstance(desc, str) and desc and desc not in source_map:
                missing.append(desc[:80])
            for item in ev.get("sub_key_data", []):
                if isinstance(item, str) and item not in source_map:
                    missing.append(item[:80])
        if missing:
            if log_callback:
                log_callback(f"  ⚠ _source_map incomplete — {len(missing)} items missing (non-fatal)")
                for m in missing[:3]:
                    log_callback(f"    • {m}")
        if log_callback:
            log_callback(f"  ✓ _source_map: {len(source_map)} entries")

    else:
        # Non-POV: validate phase_chapter_plan
        phases = plan.get("phase_chapter_plan", [])

        if log_callback:
            log_callback(f"  Phases: {len(phases)}")
            for p in phases:
                nodes = len(p.get("main_key_data", []))
                p["node_count"] = nodes
                log_callback(f"  {p.get('phase','?')}: {nodes} main, {len(p.get('sub_key_data', []))} sub")

        # Validate _source_map
        source_map = plan.get("_source_map")
        if not source_map or not isinstance(source_map, dict):
            raise RuntimeError(
                "❌ Phase plan is missing '_source_map'. "
                "The phase plan AI MUST output a _source_map dict mapping every "
                "main_key_data/sub_key_data text to its blueprint source fields. "
                "Check the phase plan prompt for SOURCE TRACING rule."
            )
        missing = []
        for phase in phases:
            for item in phase.get("main_key_data", []) + phase.get("sub_key_data", []):
                if isinstance(item, str) and item not in source_map:
                    missing.append(item[:80])
        if missing:
            raise RuntimeError(
                f"❌ _source_map is INCOMPLETE — {len(missing)} key_data items have no source entry:\n"
                + "\n".join(f"  • {m}" for m in missing[:5])
                + ("\n  ..." if len(missing) > 5 else "")
                + "\nFix the phase plan prompt or re-run."
            )
        if log_callback:
            log_callback(f"  ✓ _source_map validated: {len(source_map)} entries")

    return plan


def _validate_event_timeline_pov(
    phase_plan: dict,
    blueprint: dict,
    api_endpoints: list,
    log_callback=None,
    stop_check=None,
    niche: str = "",
) -> dict:
    """POV-specific: validate event_timeline completeness against blueprint.

    Checks: age accuracy, event completeness (WHERE/WHAT/CONSEQUENCE),
    missing milestones, body state as standalone, chronological order,
    same-age independence.

    Returns: modified phase_plan with corrected event_timeline.
    """
    import copy

    events = phase_plan.get("event_timeline", [])
    if not events:
        if log_callback:
            log_callback("  ⚠ No event_timeline found — skipping validation")
        return phase_plan

    if log_callback:
        log_callback(f"  Validating event_timeline ({len(events)} events)...")

    # Load POV validate prompt
    prompt_file = _require_niche_prompt("validate_sub_key", niche, log_callback)
    system_prompt = _load_prompt(prompt_file)

    # Build blueprint excerpt for cross-reference
    bp_excerpt = {}
    for key in ("turning_points", "key_relationships", "death_and_funeral",
                "age_timeline", "life_phases", "conflicts", "achievements",
                "physical_state_arc"):
        val = blueprint.get(key)
        if val:
            bp_excerpt[key] = val

    user_content = (
        f"EVENT_TIMELINE TO VALIDATE:\n{json.dumps(events, ensure_ascii=False, indent=2)}\n\n"
        f"BLUEPRINT (source of truth):\n{json.dumps(bp_excerpt, ensure_ascii=False, indent=2)}"
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_content},
    ]

    MAX_RETRIES = 3
    RETRY_DELAY = 10

    for attempt in range(MAX_RETRIES + 1):
        if stop_check and stop_check():
            return phase_plan

        from core.api_client import APIClient
        api = APIClient(api_endpoints, log_api=lambda *a: None, tier="flash", stop_check=stop_check)
        result = api.call_api(messages, temperature=0.1, timeout=180,
                              step_label="validate_event_timeline")

        if not result["success"]:
            if attempt < MAX_RETRIES:
                if log_callback:
                    log_callback(f"  ⚠ Validate failed (attempt {attempt+1}/{MAX_RETRIES}), retrying...")
                for _ in range(RETRY_DELAY * 2):
                    if stop_check and stop_check():
                        return phase_plan
                    import time; time.sleep(0.5)
                continue
            if log_callback:
                log_callback(f"  ❌ Validate failed after {MAX_RETRIES} retries: {result.get('error', '?')}")
            return phase_plan

        content = result["content"]
        json_match = re.search(r'\{[\s\S]*\}', content)
        try:
            parsed = json.loads(json_match.group() if json_match else content)

            validation_result = parsed.get("validation_result", "UNKNOWN")
            corrected_timeline = parsed.get("event_timeline", [])
            fixes = parsed.get("fixes", [])

            if log_callback:
                log_callback(f"  📊 Validation: {validation_result}")
                if fixes:
                    for fix in fixes:
                        fix_type = fix.get("type", "?")
                        if fix_type == "age_error":
                            log_callback(f"    🔧 Age fix: event {fix.get('event_id')} — {fix.get('old_age')} → {fix.get('new_age')}")
                        elif fix_type == "missing_milestone":
                            log_callback(f"    ➕ Added: event {fix.get('new_event_id')} — age {fix.get('age')}: {fix.get('event_title', '?')}")
                        elif fix_type == "incomplete_event":
                            log_callback(f"    📝 Completed: event {fix.get('event_id')} — added {fix.get('added', '?')}")
                        elif fix_type == "body_state_removed":
                            log_callback(f"    ↓ Body state: event {fix.get('removed_event_id')} → sub of event {fix.get('moved_to_event_id')}")
                        elif fix_type == "merged_same_age":
                            log_callback(f"    🔗 Merged: events {fix.get('merged_ids')} → event {fix.get('new_event_id')}")
                        elif fix_type == "reordered":
                            log_callback(f"    🔄 Reordered: event {fix.get('event_id')}")
                        else:
                            log_callback(f"    🔧 {fix_type}: {fix.get('reason', '?')[:60]}")
                    log_callback(f"  ✓ {len(fixes)} fix(es) applied — {parsed.get('total_events_before', '?')} → {parsed.get('total_events_after', '?')} events")
                else:
                    log_callback(f"  ✓ All events validated — no changes needed")

            # Apply corrected timeline
            if corrected_timeline:
                modified = copy.deepcopy(phase_plan)
                modified["event_timeline"] = corrected_timeline
                modified["_validation_log"] = {
                    "validation_result": validation_result,
                    "fixes": fixes,
                    "total_events_before": parsed.get("total_events_before"),
                    "total_events_after": parsed.get("total_events_after"),
                }
                return modified
            else:
                return phase_plan

        except (json.JSONDecodeError, Exception) as e:
            if attempt < MAX_RETRIES:
                if log_callback:
                    log_callback(f"  ⚠ Parse error (attempt {attempt+1}/{MAX_RETRIES}), retrying...")
                for _ in range(RETRY_DELAY * 2):
                    if stop_check and stop_check():
                        return phase_plan
                    import time; time.sleep(0.5)
                continue
            if log_callback:
                log_callback(f"  ❌ Parse failed after {MAX_RETRIES} retries: {e}")
            return phase_plan

    return phase_plan


def validate_phase_plan_sub_keys(
    phase_plan: dict,
    blueprint: dict,
    api_endpoints: list,
    log_callback=None,
    stop_check=None,
    niche: str = "",
) -> dict:
    """Validate sub_key_data items in each phase — promote wrongly demoted events.

    POV niches: validates event_timeline completeness (age, milestones, event descriptions).
    Other niches: parallel Flash calls per phase for promote/demote classification.

    Returns: modified phase_plan with fixes applied.
    """
    import copy
    from concurrent.futures import ThreadPoolExecutor, as_completed

    # ── POV: Event Timeline Completeness Validation ──
    _niche_lower = (niche or "").lower()
    _is_pov = any(k in _niche_lower for k in ("pov", "góc nhìn", "nhập vai"))

    if _is_pov:
        return _validate_event_timeline_pov(
            phase_plan, blueprint, api_endpoints,
            log_callback=log_callback, stop_check=stop_check, niche=niche,
        )

    # ── Non-POV: Original phase-based promote/demote logic ──
    phases = phase_plan.get("phase_chapter_plan", [])
    if not phases:
        return phase_plan

    # Find phases that need validation (body phases only, skip hook/end)
    phases_to_validate = []
    for idx, phase in enumerate(phases):
        # Skip hook (first) and end (last) — always 1 chapter, no benefit
        if idx == 0 or idx == len(phases) - 1:
            continue
        sub_items = phase.get("sub_key_data", [])
        main_items = phase.get("main_key_data", [])
        # Need either sub items (for promote) or main items (for demote)
        if not sub_items and not main_items:
            continue
        phases_to_validate.append((idx, phase))

    if not phases_to_validate:
        if log_callback:
            log_callback("  No phases to validate — skipping")
        return phase_plan

    if log_callback:
        log_callback(f"  Validating sub_key_data in {len(phases_to_validate)} phase(s)...")

    # Load niche-specific prompt
    prompt_file = _require_niche_prompt("validate_sub_key", niche, log_callback)
    system_prompt = _load_prompt(prompt_file)

    # Build blueprint excerpt per phase — niche-aware
    _BATTLE_KW = ("battle", "war", "military", "trận", "chiến", "combat", "siege", "phân tích trận đánh")
    _PIRATE_KW = ("hải tặc", "cướp biển", "pirate", "buccaneer", "corsair", "lịch sử hải tặc")
    _is_battle = any(kw in (niche or "").lower() for kw in _BATTLE_KW)
    _is_pirate = any(kw in (niche or "").lower() for kw in _PIRATE_KW)

    if _is_battle:
        bp_battle_phases = blueprint.get("battle_phases", [])
        bp_commanders = blueprint.get("commanders", [])
        bp_weapons = blueprint.get("technology_and_weapons", [])
        bp_turning_points = blueprint.get("climactic_turning_points", [])
    elif _is_pirate:
        bp_ship_birth = blueprint.get("ship_birth", {})
        bp_capture_mutation = blueprint.get("capture_and_mutation", {})
        bp_key_figures = blueprint.get("key_figures", [])
        bp_ship_life = blueprint.get("ship_life_and_crew", {})
        bp_combat = blueprint.get("combat_events", [])
        bp_death = blueprint.get("death_and_collapse", {})
    else:
        bp_life_phases = blueprint.get("life_phases", [])
        bp_turning_points = blueprint.get("turning_points", [])
        bp_conflicts = blueprint.get("conflicts", [])

    def _build_excerpt(phase_data):
        """Build relevant blueprint excerpt for a phase."""
        excerpt = {}
        if _is_battle:
            if bp_battle_phases:
                excerpt["battle_phases"] = bp_battle_phases
            if bp_commanders:
                excerpt["commanders"] = bp_commanders
            if bp_weapons:
                excerpt["technology_and_weapons"] = bp_weapons
            if bp_turning_points:
                excerpt["climactic_turning_points"] = bp_turning_points
        elif _is_pirate:
            if bp_ship_birth:
                excerpt["ship_birth"] = bp_ship_birth
            if bp_capture_mutation:
                excerpt["capture_and_mutation"] = bp_capture_mutation
            if bp_key_figures:
                excerpt["key_figures"] = bp_key_figures
            if bp_ship_life:
                excerpt["ship_life_and_crew"] = bp_ship_life
            if bp_combat:
                excerpt["combat_events"] = bp_combat
            if bp_death:
                excerpt["death_and_collapse"] = bp_death
        else:
            if bp_turning_points:
                excerpt["turning_points"] = bp_turning_points
            if bp_conflicts:
                excerpt["conflicts"] = bp_conflicts
            if bp_life_phases:
                excerpt["life_phases"] = bp_life_phases
        return excerpt

    def _validate_single_phase(idx, phase_data):
        """Validate sub_key_data for a single phase (with retry)."""
        MAX_RETRIES = 3
        RETRY_DELAY = 10

        if stop_check and stop_check():
            return idx, [], [], []

        sub_items = phase_data.get("sub_key_data", [])
        main_items = phase_data.get("main_key_data", [])
        phase_name = phase_data.get("phase", "?")
        excerpt = _build_excerpt(phase_data)

        user_content = (
            f"PHASE: {phase_name}\n\n"
            f"MAIN_KEY_DATA TO EVALUATE (check for DEMOTE):\n{json.dumps(main_items, ensure_ascii=False, indent=2)}\n\n"
            f"SUB_KEY_DATA TO EVALUATE (check for PROMOTE):\n{json.dumps(sub_items, ensure_ascii=False, indent=2)}\n\n"
            f"BLUEPRINT EXCERPT (for cross-reference):\n"
            f"{json.dumps(excerpt, ensure_ascii=False, indent=2)}"
        )

        messages = [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": user_content},
        ]

        for attempt in range(MAX_RETRIES + 1):
            if stop_check and stop_check():
                return idx, [], [], []

            from core.api_client import APIClient
            api = APIClient(api_endpoints, log_api=lambda *a: None, tier="flash", stop_check=stop_check)
            result = api.call_api(messages, temperature=0.1, timeout=120)

            if not result["success"]:
                if attempt < MAX_RETRIES:
                    if log_callback:
                        log_callback(f"  ⚠ Validate {phase_name} failed (attempt {attempt+1}/{MAX_RETRIES}), retry in {RETRY_DELAY}s...")
                    # Interruptible sleep
                    for _ in range(RETRY_DELAY * 2):
                        if stop_check and stop_check():
                            return idx, [], [], []
                        import time; time.sleep(0.5)
                    continue
                if log_callback:
                    log_callback(f"  ❌ Validate {phase_name} failed after {MAX_RETRIES} retries: {result.get('error', '?')}")
                return idx, [], [], []

            content = result["content"]
            json_match = re.search(r'\{[\s\S]*\}', content)
            try:
                parsed = json.loads(json_match.group() if json_match else content)
                # New format: {promote: [...], demote: [...], main_kept: [...]}
                # Backward compat: {evaluations: [...]}
                if "promote" in parsed:
                    promotions = [e for e in parsed.get("promote", []) if e.get("decision") == "PROMOTE"]
                    demotions = [e for e in parsed.get("demote", []) if e.get("decision") == "DEMOTE"]
                    all_evals = (parsed.get("promote", []) + parsed.get("demote", [])
                                 + parsed.get("main_kept", []) + parsed.get("sub_kept", []))
                else:
                    evaluations = parsed.get("evaluations", [])
                    promotions = [e for e in evaluations if e.get("decision") == "PROMOTE"]
                    demotions = [e for e in evaluations if e.get("decision") == "DEMOTE"]
                    all_evals = evaluations
                if log_callback:
                    log_callback(
                        f"  📊 {phase_name}: promote={len(parsed.get('promote', []))} "
                        f"demote={len(parsed.get('demote', []))} "
                        f"main_kept={len(parsed.get('main_kept', []))} "
                        f"sub_kept={len(parsed.get('sub_kept', []))}"
                    )
                return idx, promotions, demotions, all_evals
            except (json.JSONDecodeError, Exception) as e:
                if attempt < MAX_RETRIES:
                    if log_callback:
                        log_callback(f"  ⚠ Validate {phase_name} parse error (attempt {attempt+1}/{MAX_RETRIES}), retry in {RETRY_DELAY}s...")
                    for _ in range(RETRY_DELAY * 2):
                        if stop_check and stop_check():
                            return idx, [], [], []
                        import time; time.sleep(0.5)
                    continue
                if log_callback:
                    log_callback(f"  ❌ Validate {phase_name} parse failed after {MAX_RETRIES} retries: {e}")
                return idx, [], [], []

        return idx, [], [], []

    # Run validations in parallel
    results = {}  # {phase_idx: (promotions, demotions)}
    all_evaluations = {}  # Store full eval reasoning for audit
    with ThreadPoolExecutor(max_workers=min(4, len(phases_to_validate))) as pool:
        futures = {
            pool.submit(_validate_single_phase, idx, phase): idx
            for idx, phase in phases_to_validate
        }
        for future in as_completed(futures):
            if stop_check and stop_check():
                break
            try:
                phase_idx, promotions, demotions, all_evals = future.result()
            except Exception as exc:
                if log_callback:
                    log_callback(f"  ⚠ Validate thread error: {exc}")
                continue
            if promotions or demotions:
                results[phase_idx] = (promotions, demotions)
            if all_evals:
                all_evaluations[phase_idx] = all_evals

    if not results:
        if log_callback:
            log_callback("  ✓ All classifications confirmed — no changes needed")
        return phase_plan

    # Apply promotions and demotions
    modified_plan = copy.deepcopy(phase_plan)
    modified_phases = modified_plan.get("phase_chapter_plan", [])
    total_promoted = 0
    total_demoted = 0

    for phase_idx, (promotions, demotions) in sorted(results.items()):
        phase = modified_phases[phase_idx]

        # --- Apply PROMOTIONS (sub → main) ---
        for promo in promotions:
            item_text = promo["item"]
            sub_list = phase.get("sub_key_data", [])

            # Exact match first
            if item_text in sub_list:
                matched = item_text
            else:
                # Fuzzy fallback: find sub item that contains or is contained by AI text
                item_lower = item_text.lower().strip()
                matched = None
                for sub in sub_list:
                    sub_lower = sub.lower().strip()
                    if item_lower in sub_lower or sub_lower in item_lower:
                        matched = sub
                        break

            if matched:
                phase["sub_key_data"].remove(matched)
                phase.setdefault("main_key_data", []).append(matched)
                total_promoted += 1
                if log_callback:
                    reason = promo.get("reason", "")[:60]
                    log_callback(f"  ↑ PROMOTE [{phase.get('phase', '?')}]: \"{matched[:50]}\" — {reason}")
            else:
                if log_callback:
                    log_callback(f"  ⚠ Promote skipped [{phase.get('phase', '?')}]: \"{item_text[:50]}\" — no match in sub_key_data")

        # --- Apply DEMOTIONS (main → sub) ---
        for demo in demotions:
            item_text = demo["item"]
            main_list = phase.get("main_key_data", [])

            # Exact match first
            if item_text in main_list:
                matched = item_text
            else:
                # Fuzzy fallback
                item_lower = item_text.lower().strip()
                matched = None
                for main_item in main_list:
                    main_lower = main_item.lower().strip()
                    if item_lower in main_lower or main_lower in item_lower:
                        matched = main_item
                        break

            if matched:
                phase["main_key_data"].remove(matched)
                phase.setdefault("sub_key_data", []).append(matched)
                total_demoted += 1
                if log_callback:
                    reason = demo.get("reason", "")[:60]
                    log_callback(f"  ↓ DEMOTE [{phase.get('phase', '?')}]: \"{matched[:50]}\" — {reason}")
            else:
                if log_callback:
                    log_callback(f"  ⚠ Demote skipped [{phase.get('phase', '?')}]: \"{item_text[:50]}\" — no match in main_key_data")

        # Recalculate node_count after changes
        new_count = len(phase.get("main_key_data", []))
        old_count = phase.get("node_count", 0)
        if new_count != old_count:
            phase["node_count"] = new_count

    if log_callback:
        parts = []
        if total_promoted:
            parts.append(f"Promoted {total_promoted}")
        if total_demoted:
            parts.append(f"Demoted {total_demoted}")
        action_str = ", ".join(parts) if parts else "No changes"
        log_callback(f"  ✓ {action_str} item(s) across {len(results)} phase(s)")

    # Attach full evaluation log for audit (saved by pipeline)
    if all_evaluations:
        eval_log = {}
        for phase_idx, evals in all_evaluations.items():
            phase_name = modified_plan["phase_chapter_plan"][phase_idx].get("phase", f"phase_{phase_idx}")
            eval_log[phase_name] = evals
        modified_plan["_validation_log"] = eval_log

    return modified_plan


def plan_chapters_pov(
    phase_plan: dict,
    blueprint: dict,
    api_client,
    log_callback=None,
    niche: str = "",
) -> dict:
    """POV Chapter Planning — Scene Test round 2.

    Evaluates each event in the validated timeline:
    - Events with character agency + conflict + scene potential → KEEP
    - Events lacking agency (things happening TO character) → DEMOTE to sub_key_data
    - Generates event_cause for each surviving event

    Returns: modified phase_plan with curated event_timeline.
    """
    events = phase_plan.get("event_timeline", [])
    if not events:
        return phase_plan

    total_before = len(events)
    if log_callback:
        log_callback(f"  Planning chapters ({total_before} events)...")

    prompt_file = _require_niche_prompt("chapter_plan", niche, log_callback)
    system_prompt = _load_prompt(prompt_file)

    blueprint_json = json.dumps(blueprint, ensure_ascii=False, indent=2)
    events_json = json.dumps(events, ensure_ascii=False, indent=2)

    user_content = (
        f"BLUEPRINT:\n{blueprint_json}\n\n"
        f"EVENT_TIMELINE ({total_before} events):\n{events_json}"
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_content},
    ]

    raw = api_client.call_ai(messages, expect_json=True, temperature=0.3)
    result = _parse_json_response(raw)
    if not result:
        if log_callback:
            log_callback("  ⚠ Chapter planning returned invalid JSON — keeping original timeline")
        return phase_plan

    # Extract updated event_timeline
    new_events = result.get("event_timeline", [])
    if not new_events:
        if log_callback:
            log_callback("  ⚠ Chapter planning returned empty timeline — keeping original")
        return phase_plan

    total_after = len(new_events)
    demoted = result.get("demoted_events", [])

    # Update phase_plan
    phase_plan["event_timeline"] = new_events

    if log_callback:
        if demoted:
            for d in demoted:
                log_callback(
                    f"    ↓ DEMOTE event {d.get('original_event_id', '?')}: "
                    f"{d.get('event_title', '?')} → event {d.get('moved_to_event_id', '?')} "
                    f"({d.get('reason', '')[:60]})"
                )
        log_callback(f"  ✓ Chapter planning: {total_before} → {total_after} events")

    # Save planning reasoning
    phase_plan["_chapter_planning"] = {
        "total_before": total_before,
        "total_after": total_after,
        "demoted_events": demoted,
    }

    return phase_plan


def apply_chapter_splits(phase_plan: dict, log_callback=None, niche: str = "") -> dict:
    """Deterministic chapter splitting based on final node_count per phase.

    Rules (standard):
      - Hook phase (first) → always 1 chapter
      - End phase (last)   → always 1 chapter
      - Body phases with 0 main_key_data → MERGE into nearest adjacent phase
      - Body phases:
          1-3 main_key_data → 1 chapter
          4-6 main_key_data → 2 chapters
          7+  main_key_data → 3 chapters

    Rules (POV):
      - Every main_key_data item = 1 chapter (1 Level = 1 chapter)
      - End phase → always 1 chapter

    Assigns sequential chapter numbers and updates total_chapters.
    """
    _niche_lower = (niche or "").lower()
    _is_pov = any(k in _niche_lower for k in ("pov", "góc nhìn", "nhập vai"))

    # ── POV: Event Timeline → simple sequential chapters ──
    if _is_pov:
        events = phase_plan.get("event_timeline", [])
        if not events:
            # Fallback to phase-based if no event_timeline
            pass  # fall through to standard logic below
        else:
            total = len(events)
            for idx, event in enumerate(events):
                event["chapters"] = [idx + 1]
            phase_plan["event_timeline"] = events
            phase_plan["total_chapters"] = total
            if log_callback:
                log_callback(f"  ✓ POV: {total} events → {total} chapters (1:1 mapping)")
            return phase_plan

    # ── Non-POV: Standard phase-based split logic ──
    phases = phase_plan.get("phase_chapter_plan", [])
    if not phases:
        return phase_plan

    # ── Step 1: Merge empty body phases into neighbors ──
    merged_indices = set()
    for idx in range(1, len(phases) - 1):  # skip hook (0) and end (last)
        phase = phases[idx]
        node_count = len(phase.get("main_key_data", []))
        if node_count == 0:
            # Find best neighbor to merge into (prefer next, fallback prev)
            target_idx = idx + 1 if idx + 1 < len(phases) - 1 else idx - 1
            if target_idx < 1:
                target_idx = 1  # never merge into hook
            target = phases[target_idx]

            # Move sub_key_data to target
            target.setdefault("sub_key_data", []).extend(
                phase.get("sub_key_data", [])
            )
            merged_indices.add(idx)
            if log_callback:
                log_callback(
                    f"  [MERGE] {phase.get('phase', '?')} (0 main) → merged into {target.get('phase', '?')}"
                )

    if merged_indices:
        phases = [p for i, p in enumerate(phases) if i not in merged_indices]
        phase_plan["phase_chapter_plan"] = phases

    # ── Step 2: Assign chapters ──
    chapter_num = 1
    total_chapters = 0

    for idx, phase in enumerate(phases):
        is_hook = (idx == 0)
        is_end = (idx == len(phases) - 1)
        node_count = len(phase.get("main_key_data", []))
        phase["node_count"] = node_count

        if is_end:
            num_chapters = 1
        elif _is_pov:
            # POV: 1 main = 1 chapter (each Level gets its own chapter)
            num_chapters = max(1, node_count)
        elif is_hook:
            num_chapters = 1
        elif node_count <= 3:
            num_chapters = 1
        elif node_count <= 6:
            num_chapters = 2
        else:
            num_chapters = 3

        chapters = list(range(chapter_num, chapter_num + num_chapters))
        phase["chapters"] = chapters

        if num_chapters > 1:
            phase["capacity_check"] = f"{node_count} main > {3 if num_chapters == 2 else 6} → SPLIT into {num_chapters} chapters"
            phase["reason_for_split"] = f"{node_count} main events across {num_chapters} chapters"
        else:
            phase["capacity_check"] = f"{node_count} main ≤ 3 → KEEP"
            phase["reason_for_split"] = None

        action = "SPLIT" if num_chapters > 1 else "KEEP"
        if log_callback:
            log_callback(
                f"  [{action}] {phase.get('phase', '?')}: ch{chapters} ({node_count} main)"
            )

        chapter_num += num_chapters
        total_chapters += num_chapters

    phase_plan["total_chapters"] = total_chapters

    if log_callback:
        log_callback(f"  Total: {total_chapters} chapters across {len(phases)} phases")

    return phase_plan


def generate_narrative_outline(
    blueprint: dict,
    style_json: str,
    framework_name: str,
    api_client,
    chapter_range: str = "between 5 and 20 chapters",
    lang: str = "en",
    log_callback=None,
    niche: str = "",
    phase_plan: dict = None,
) -> dict:
    """Generate a new outline using a SPECIFIC framework and a content blueprint.
    Unlike generate_renew_outline, this does NOT receive the original text —
    only the extracted blueprint.

    If phase_plan is provided, it is injected into the prompt so AI follows the
    pre-planned phase→chapter mapping.

    Returns: {chosen_framework, narrative_arc, total_chapters,
              chapters: [{number, title, summary, key_points, ...}]}
    """
    prompt_file = _require_niche_prompt("outline", niche, log_callback, framework_name)
    system_prompt = _load_prompt(prompt_file)
    if "{lang}" in system_prompt:
        system_prompt = system_prompt.replace("{lang}", lang)

    blueprint_json = json.dumps(blueprint, ensure_ascii=False, indent=2)

    # Send only the relevant framework, not all 4
    compact_style = _extract_style_for_framework(style_json, framework_name)

    # Build phase plan injection
    phase_plan_block = ""
    if phase_plan:
        _niche_lower = (niche or "").lower()
        _is_pov_outline = any(k in _niche_lower for k in ("pov", "góc nhìn", "nhập vai"))

        if _is_pov_outline and "event_timeline" in phase_plan:
            # POV: pass event_timeline
            et_json = json.dumps(phase_plan.get("event_timeline", []), ensure_ascii=False, indent=2)
            total_ch = phase_plan.get("total_chapters", "?")
            phase_plan_block = (
                f"\n\nPRE-PLANNED EVENT TIMELINE (FOLLOW THIS EXACTLY):\n"
                f"Total chapters: {total_ch}\n"
                f"{et_json}\n"
                f"You MUST generate exactly {total_ch} chapters — 1 event = 1 chapter.\n"
                f"Build scene_open/scene_action/scene_close from each event_description.\n"
            )
        else:
            # Non-POV: pass phase_chapter_plan
            pp_json = json.dumps(phase_plan.get("phase_chapter_plan", []), ensure_ascii=False, indent=2)
            total_ch = phase_plan.get("total_chapters", "?")
            phase_plan_block = (
                f"\n\nPRE-PLANNED PHASE → CHAPTER MAPPING (FOLLOW THIS EXACTLY):\n"
                f"Total chapters: {total_ch}\n"
                f"{pp_json}\n"
                f"You MUST generate exactly {total_ch} chapters following this mapping. "
                f"Copy the phase_chapter_plan into your output JSON as-is.\n"
            )

    # Only include chapter_range when there's no phase_plan
    # (phase_plan already specifies exact chapter count)
    ch_range_block = "" if phase_plan else f"CHAPTER COUNT REQUIREMENT: {chapter_range}\n\n"

    user_content = (
        f"STYLE GUIDE:\n{compact_style}\n\n"
        f"MANDATORY FRAMEWORK: You MUST use the framework named \"{framework_name}\". "
        f"Do NOT choose a different one.\n\n"
        f"{ch_range_block}"
        f"LANGUAGE: Write ALL text (titles, summaries, key_points, narrative_arc, ends_with) in {lang}.\n"
        f"{phase_plan_block}\n"
        f"CONTENT BLUEPRINT (use these facts and events as source material):\n{blueprint_json}"
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_content},
    ]

    if log_callback:
        log_callback(f"Generating outline with framework '{framework_name}'...")

    result = api_client.call_api(
        messages, temperature=0.3, timeout=500, step_label="outline"
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"❌ Outline failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"✓ Outline generated via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        outline = json.loads(json_match.group())
    else:
        outline = json.loads(content)

    # Ensure phase_chapter_plan exists in output
    if phase_plan and "phase_chapter_plan" not in outline:
        outline["phase_chapter_plan"] = phase_plan.get("phase_chapter_plan", [])

    return outline


def audit_outline(
    outline: dict,
    blueprint: dict,
    style_json: str,
    framework_name: str,
    api_client,
    log_callback=None,
    niche: str = "",
    chapter_range: str = "",
) -> tuple:
    """Audit an outline for structural issues and return a corrected version.

    Returns: (audited_outline: dict, issues: list)
    """
    prompt_file = _require_niche_prompt("audit", niche, log_callback, framework_name)
    system_prompt = _load_prompt(prompt_file)

    outline_json = json.dumps(outline, ensure_ascii=False, indent=2)
    blueprint_json = json.dumps(blueprint, ensure_ascii=False, indent=2)

    _ch_range_str = f"\nCHAPTER RANGE: {chapter_range}\n" if chapter_range else ""
    compact_style = _extract_style_for_framework(style_json, framework_name)
    user_content = (
        f"STYLE GUIDE:\n{compact_style}\n\n"
        f"FRAMEWORK: {framework_name}\n"
        f"{_ch_range_str}\n"
        f"CONTENT BLUEPRINT:\n{blueprint_json}\n\n"
        f"OUTLINE TO AUDIT:\n{outline_json}"
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_content},
    ]

    if log_callback:
        log_callback("Auditing outline for structural issues...")

    result = api_client.call_api(
        messages, temperature=0.1, timeout=500, step_label="audit"
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"⚠ Audit failed: {result.get('error', 'unknown')}, using original outline")
        return outline, []

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    raw_json = json_match.group() if json_match else content

    def _try_parse(text):
        return json.loads(text)

    def _repair_json(text):
        """Attempt to fix common LLM JSON issues."""
        t = text.strip()
        # Strip markdown code fences
        t = re.sub(r'^```(?:json)?\s*', '', t)
        t = re.sub(r'\s*```$', '', t)
        # Remove JS-style comments  // ...
        t = re.sub(r'//[^\n]*', '', t)
        # Remove trailing commas before } or ]
        t = re.sub(r',\s*([}\]])', r'\1', t)
        # Fix missing commas: "value"\n"key" → "value",\n"key"
        # Pattern: end of value (string/number/bool/null/}/]) followed by newline+whitespace+quote
        t = re.sub(r'(")\s*\n(\s*")', r'\1,\n\2', t)
        # Fix missing commas: }\n{ or ]\n{ etc.
        t = re.sub(r'([}\]])\s*\n(\s*[{\["])', r'\1,\n\2', t)
        # Fix single quotes to double quotes (but not inside strings)
        # Simple approach: replace 'key': with "key":
        t = re.sub(r"'([^']+)'\s*:", r'"\1":', t)
        # Try to close unclosed brackets/braces
        open_b = t.count('{') - t.count('}')
        open_s = t.count('[') - t.count(']')
        if open_b > 0:
            t = t.rstrip().rstrip(',') + '}' * open_b
        if open_s > 0:
            t = t.rstrip().rstrip(',') + ']' * open_s
        return t

    def _repair_at_position(text, error):
        """Try to fix JSON at the exact error position."""
        if not isinstance(error, json.JSONDecodeError):
            return text
        pos = error.pos
        if pos is None or pos >= len(text):
            return text
        # "Expecting ',' delimiter" → insert comma before the error position
        if "Expecting ',' delimiter" in str(error) or "Expecting \\u002c" in str(error):
            # Walk backwards to find end of previous value
            i = pos - 1
            while i >= 0 and text[i] in ' \t\n\r':
                i -= 1
            if i >= 0:
                return text[:i+1] + ',' + text[i+1:]
        # "Expecting ':' delimiter" → insert colon
        if "Expecting ':' delimiter" in str(error):
            return text[:pos] + ':' + text[pos:]
        # "Expecting value" → empty value after colon, insert null
        if "Expecting value" in str(error):
            # Check if preceded by ':' or ',' with optional whitespace
            before = text[:pos].rstrip()
            if before.endswith(':') or before.endswith(','):
                return text[:pos] + 'null' + text[pos:]
            # Could be a truncated string → try to close and continue
            return text[:pos] + 'null' + text[pos:]
        return text

    audit_result = None
    parse_error = None
    # Try 1: direct parse
    try:
        audit_result = _try_parse(raw_json)
    except (json.JSONDecodeError, Exception) as e:
        parse_error = e
        # Try 2: repair then parse
        try:
            repaired = _repair_json(raw_json)
            audit_result = _try_parse(repaired)
            if log_callback:
                log_callback(f"✓ Audit JSON repaired (original error: {parse_error})")
            parse_error = None
        except (json.JSONDecodeError, Exception) as e2:
            parse_error = e2
            # Try 3: iterative position-based repair (up to 5 fixes)
            text_to_fix = repaired
            for _attempt in range(5):
                try:
                    text_to_fix = _repair_at_position(text_to_fix, parse_error)
                    audit_result = _try_parse(text_to_fix)
                    if log_callback:
                        log_callback(f"✓ Audit JSON repaired after {_attempt+1} positional fix(es)")
                    parse_error = None
                    break
                except json.JSONDecodeError as e3:
                    parse_error = e3
                    continue

    if audit_result is None:
        # RETRY: call API once more before giving up
        if log_callback:
            log_callback(f"⚠ Audit JSON parse failed ({parse_error}), retrying...")
        retry_result = api_client.call_api(messages, temperature=0.1, timeout=500)
        if retry_result["success"]:
            retry_content = retry_result["content"]
            retry_match = re.search(r'\{[\s\S]*\}', retry_content)
            retry_raw = retry_match.group() if retry_match else retry_content
            try:
                repaired = _repair_json(retry_raw)
                audit_result = _try_parse(repaired)
                if log_callback:
                    log_callback("✓ Audit JSON parsed on retry")
            except (json.JSONDecodeError, Exception):
                pass

    if audit_result is None:
        if log_callback:
            log_callback(f"⚠ Could not parse audit result after retry, using original outline")
        return outline, []

    try:
        issues = audit_result.get("audit_issues", [])

        if log_callback:
            if issues:
                log_callback(f"✓ Audit found {len(issues)} issue(s)")
                for iss in issues:
                    log_callback(f"  → [{iss.get('type', '?')}] {iss.get('description', '')}")
            else:
                log_callback("✓ Audit passed — no issues found")

        # ── DIFF-BASED: apply fixes to original outline ──────────────
        # Support both old format (full "outline" key) and new diff format ("fixes" in issues)
        if "outline" in audit_result and isinstance(audit_result["outline"], dict):
            # Legacy: full outline copy returned
            return audit_result["outline"], issues

        # New: apply targeted fixes from each issue
        import copy
        audited_outline = copy.deepcopy(outline)
        chapters = audited_outline.get("chapters", [])
        fixes_applied = 0

        for issue in issues:
            for fix in issue.get("fixes", []):
                action = fix.get("action", "")
                ch_num = fix.get("chapter")

                try:
                    if action == "set" and ch_num is not None:
                        ch_idx = ch_num - 1
                        if 0 <= ch_idx < len(chapters):
                            field = fix.get("field", "")
                            if field:
                                chapters[ch_idx][field] = fix["value"]
                                fixes_applied += 1

                    elif action == "remove" and ch_num is not None:
                        ch_idx = ch_num - 1
                        if 0 <= ch_idx < len(chapters):
                            field = fix.get("field", "")
                            index = fix.get("index", 0)
                            if field and isinstance(chapters[ch_idx].get(field), list):
                                lst = chapters[ch_idx][field]
                                if 0 <= index < len(lst):
                                    lst.pop(index)
                                    fixes_applied += 1

                    elif action == "add" and ch_num is not None:
                        ch_idx = ch_num - 1
                        if 0 <= ch_idx < len(chapters):
                            field = fix.get("field", "")
                            if field and isinstance(chapters[ch_idx].get(field), list):
                                chapters[ch_idx][field].append(fix["value"])
                                fixes_applied += 1

                    elif action == "swap_chapters":
                        a = fix.get("chapter_a", 0) - 1
                        b = fix.get("chapter_b", 0) - 1
                        if 0 <= a < len(chapters) and 0 <= b < len(chapters):
                            chapters[a], chapters[b] = chapters[b], chapters[a]
                            # Renumber
                            for i, ch in enumerate(chapters):
                                ch["chapter_number"] = i + 1
                            fixes_applied += 1

                    elif action == "remove_chapter" and ch_num is not None:
                        ch_idx = ch_num - 1
                        if 0 <= ch_idx < len(chapters):
                            chapters.pop(ch_idx)
                            # Renumber
                            for i, ch in enumerate(chapters):
                                ch["chapter_number"] = i + 1
                            fixes_applied += 1

                except (KeyError, IndexError, TypeError) as fix_err:
                    if log_callback:
                        log_callback(f"  ⚠ Fix skip: {fix_err}")

        if fixes_applied > 0 and log_callback:
            log_callback(f"✓ Applied {fixes_applied} fix(es) to outline")

        return audited_outline, issues

    except Exception as e:
        if log_callback:
            log_callback(f"⚠ Audit result structure error: {e}, using original outline")
        return outline, []


def write_from_blueprint(
    blueprint: dict,
    style_json: str,
    framework_name: str,
    chapter_outline: dict,
    chapter_number: int,
    total_chapters: int,
    api_client,
    word_count_rule: str = "1300 to 1800 words",
    lang: str = "en",
    previous_context: str = "",
    full_outline: str = "",
    log_callback=None,
    niche: str = "",
    save_dir: str = "",
    source_map: dict = None,
) -> str:
    """Write a NEW chapter from a content blueprint + style guide.
    Does NOT receive original text — only blueprint and outline.

    Args:
        source_map: _source_map dict from phase plan (required for all narrative niches).
                    Maps key_data text → list of blueprint source paths.

    Returns: the written chapter text.
    """
    prompt_file = _require_niche_prompt("writer", niche, log_callback, framework_name)
    system_template = _load_prompt(prompt_file)

    # ── Extract only chapter-relevant blueprint data ──
    # Niche-specific hook strategy: each niche decides what hook chapters receive.
    ch_type = chapter_outline.get("chapter_type", "body")
    _is_hook = ch_type in ("hook", "intro", "opening")

    # Niche detection: use niche string (always reliable) + blueprint keys (secondary)
    _niche_lower = (niche or "").lower()
    _is_pov = any(k in _niche_lower for k in ("pov", "góc nhìn", "nhập vai"))
    _is_battle = any(k in _niche_lower for k in ("battle", "trận", "combat", "war", "military"))
    _is_biography = (not _is_pov) and any(k in _niche_lower for k in ("tiểu sử", "biography", "nhân vật", "chân dung", "cuộc đời"))
    _is_pirate = any(k in _niche_lower for k in ("cướp biển", "pirate", "hải tặc", "buccaneer"))
    _is_mystery = any(k in _niche_lower for k in ("mystery", "bí ẩn", "enigma"))
    _is_firearms_v2 = "firearms_v2" in _niche_lower
    # Blueprint key fallback (if niche string is empty/unknown)
    if not any((_is_pov, _is_battle, _is_biography, _is_pirate, _is_mystery, _is_firearms_v2)):
        _is_battle = "battle_phases" in blueprint
        _is_biography = "life_phases" in blueprint or "personal_profile" in blueprint
        _is_pirate = "ship_birth" in blueprint or "capture_and_mutation" in blueprint
        _is_firearms_v2 = "product_evaluation" in blueprint and any(
            p.get("product_type") in ("firearm", "ammunition")
            for p in blueprint.get("product_evaluation", [])
        )

    if _is_firearms_v2:
        # ── Firearms v2: filter blueprint by data_focus field groups ──
        chapter_bp = _extract_firearms_v2_blueprint(
            blueprint, chapter_outline, ch_type, log_callback
        )
    elif _is_hook:
        if _is_battle:
            # Battle hooks: filtered (lean scene-building data only)
            chapter_bp = _extract_chapter_blueprint(blueprint, chapter_outline, source_map=source_map, niche=niche)
        elif _is_pov:
            # POV hooks: FULL blueprint (need age_timeline + physical_state_arc for immersive opening)
            chapter_bp = blueprint
        elif _is_biography:
            # Biography hooks: FULL blueprint (need cross-section data for paradox/contrast)
            chapter_bp = blueprint
        elif _is_pirate:
            # Pirate hooks: filtered (lean) — like battle
            chapter_bp = _extract_chapter_blueprint(blueprint, chapter_outline, source_map=source_map, niche=niche)
        elif _is_mystery:
            # Mystery hooks: filtered
            chapter_bp = _extract_chapter_blueprint(blueprint, chapter_outline, source_map=source_map, niche=niche)
        else:
            # Unknown niche — use full blueprint as safe fallback
            if log_callback:
                log_callback(f"  ⚠ Unknown niche for hook strategy — using full blueprint")
            chapter_bp = blueprint
    else:
        # Body/verdict chapters: always filtered (source_map used for biography)
        chapter_bp = _extract_chapter_blueprint(blueprint, chapter_outline, source_map=source_map, niche=niche)
    blueprint_json = json.dumps(chapter_bp, ensure_ascii=False, indent=2)

    if log_callback:
        full_size = len(json.dumps(blueprint, ensure_ascii=False))
        ch_size = len(blueprint_json)
        log_callback(f"  Blueprint: {ch_size:,} chars (filtered from {full_size:,})")

    # ── Save filtered data for debugging ──
    if save_dir:
        ch_data_dir = os.path.join(save_dir, "_chapter_data")
        os.makedirs(ch_data_dir, exist_ok=True)
        ch_label = f"ch{chapter_number:02d}"
        with open(os.path.join(ch_data_dir, f"{ch_label}_blueprint.json"), "w", encoding="utf-8") as f:
            json.dump(chapter_bp, f, indent=2, ensure_ascii=False)
        if log_callback:
            log_callback(f"  💾 Saved filtered blueprint → _chapter_data/{ch_label}_blueprint.json")

    key_points = chapter_outline.get("key_points", [])
    key_points_str = ", ".join(key_points) if key_points else "N/A"

    # Send only the relevant framework, not all 4
    compact_style = _extract_style_for_framework(style_json, framework_name)

    # Common field replacements (shared by all prompts)
    system_prompt = system_template.replace(
        "{style_json}", compact_style
    ).replace(
        "{framework_name}", framework_name
    ).replace(
        "{blueprint}", blueprint_json
    ).replace(
        "{full_outline}", full_outline or "(not provided)"
    ).replace(
        "{chapter_number}", str(chapter_number)
    ).replace(
        "{total_chapters}", str(total_chapters)
    ).replace(
        "{chapter_title}", chapter_outline.get("title") or chapter_outline.get("chapter_title", f"Chapter {chapter_number}")
    ).replace(
        "{chapter_summary}", chapter_outline.get("summary", "")
    ).replace(
        "{key_points}", key_points_str
    ).replace(
        "{emotional_beat}", chapter_outline.get("emotional_beat", "")
    ).replace(
        "{ends_with}", chapter_outline.get("ends_with", "")
    ).replace(
        "{word_count_rule}", word_count_rule
    ).replace(
        "{previous_context}", previous_context if previous_context else "(This is the first chapter)"
    ).replace(
        "{lang}", lang
    )

    # Niche-specific field replacements (only present in niche prompts)
    for placeholder, field in _NICHE_OUTLINE_FIELDS.items():
        if placeholder in system_prompt:
            val = chapter_outline.get(field, "")
            if isinstance(val, list):
                val = ", ".join(str(v) for v in val)
            system_prompt = system_prompt.replace(placeholder, str(val) if val else "N/A")

    # ── Strip irrelevant sections by chapter_type ──
    pre_filter_len = len(system_prompt)
    system_prompt = _apply_chapter_type_filter(
        system_prompt,
        chapter_type=ch_type,
        chapter_structure=chapter_outline.get("chapter_structure", ""),
        niche=niche,
        framework_name=framework_name,
    )
    if log_callback:
        saved = pre_filter_len - len(system_prompt)
        if saved > 0:
            log_callback(f"  Prompt trimmed: -{saved:,} chars ({saved*100//max(1,pre_filter_len)}% saved by chapter_type filter)")

    # ── Build user message ──
    ch_title = chapter_outline.get('title') or chapter_outline.get('chapter_title', '')

    # POV: include scene fields + event_cause for richer writer guidance
    _scene_open = chapter_outline.get("scene_open", "")
    _scene_action = chapter_outline.get("scene_action", "")
    _scene_close = chapter_outline.get("scene_close", "")
    _event_cause = chapter_outline.get("event_cause", "")

    if _scene_open or _scene_action or _scene_close:
        cause_line = f"CONTEXT (why this event happens):\n  {_event_cause}\n\n" if _event_cause else ""
        user_msg = (
            f"Write chapter {chapter_number} of {total_chapters}: {ch_title}\n\n"
            f"{cause_line}"
            f"SCENE STRUCTURE (develop these into a full chapter):\n"
            f"  OPEN:   {_scene_open}\n"
            f"  ACTION: {_scene_action}\n"
            f"  CLOSE:  {_scene_close}\n\n"
            f"Use the blueprint and style guide in the system prompt. "
            f"Write in {lang} as a native speaker. {word_count_rule}."
        )
    else:
        user_msg = (
            f"Write chapter {chapter_number} of {total_chapters}: {ch_title}\n\n"
            f"Use the blueprint and style guide in the system prompt. "
            f"Write in {lang} as a native speaker. {word_count_rule}."
        )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_msg},
    ]

    # ── Save FULL prompt for debugging ──
    if save_dir:
        ch_data_dir = os.path.join(save_dir, "_chapter_data")
        os.makedirs(ch_data_dir, exist_ok=True)
        ch_label = f"ch{chapter_number:02d}"
        debug_path = os.path.join(ch_data_dir, f"{ch_label}_prompt_debug.txt")
        with open(debug_path, "w", encoding="utf-8") as f:
            f.write("=" * 80 + "\n")
            f.write(f"CHAPTER {chapter_number}: {chapter_outline.get('title') or chapter_outline.get('chapter_title', '')}\n")
            f.write("=" * 80 + "\n\n")

            f.write("─── OUTLINE FOR THIS CHAPTER ───\n")
            f.write(json.dumps(chapter_outline, indent=2, ensure_ascii=False))
            f.write("\n\n")

            f.write(f"─── FILTERED BLUEPRINT ({len(blueprint_json):,} chars) ───\n")
            f.write(f"Sections included: {list(chapter_bp.keys())}\n")
            f.write(f"Full blueprint: {len(json.dumps(blueprint, ensure_ascii=False)):,} chars\n")
            f.write(f"Filter ratio: {len(blueprint_json)*100//max(1, len(json.dumps(blueprint, ensure_ascii=False)))}%\n\n")

            f.write("─── SYSTEM PROMPT (sent to AI) ───\n")
            f.write(system_prompt)
            f.write("\n\n")

            f.write("─── USER MESSAGE ───\n")
            f.write(messages[1]["content"])
            f.write("\n")
        if log_callback:
            log_callback(f"  💾 Saved prompt debug → _chapter_data/{ch_label}_prompt_debug.txt")

        # ── Hook variants: 2 alternative opening prompts for manual use ──
        if chapter_outline.get("chapter_type") == "hook":
            _HOOK_VARIANTS = {
                "variant_A": (
                    "THE ICONIC DETAIL — Object/Scene Zoom",
                    "HOOK METHOD OVERRIDE:\n"
                    "IGNORE the default hook opening strategy. Instead use THE ICONIC DETAIL:\n"
                    "1. OPEN with ONE hyper-specific, cinematic detail about the subject — "
                    "an object, a body part, a room, a document, a specific moment frozen in time.\n"
                    "   Describe it vividly as if the camera is RIGHT THERE.\n"
                    "2. ZOOM OUT slowly — reveal WHO this detail belongs to, WHEN, and WHY it matters.\n"
                    "   Each sentence expands the frame: detail → person → era → significance.\n"
                    "3. The detail must CONNECT to the subject's fate or legacy — it's not random.\n"
                    "4. QUESTION: Ask 'How did [subject] end up here?' — a genuine causal mystery.\n"
                    "5. BRIDGE OUT (MANDATORY): After the question, write 1-2 sentences that POINT the listener\n"
                    "   toward the beginning of the story — a specific date, place, or moment.\n"
                    "   ✓ 'To find the answer, we must go back to Pisa, February 1564.'\n"
                    "   ✗ Do NOT end on the question alone — the BRIDGE OUT converts curiosity into momentum.\n"
                    "EXAMPLE APPROACH: 'In a museum in Florence, behind glass, a middle finger points "
                    "at the ceiling. It has been pointing there for 285 years...' → zoom out to Galileo\n"
                    "→ question → 'To understand how, we must go back to Pisa, 1564...'\n"
                    "EMOTIONAL ARC: Curiosity → Intrigue → Revelation → Direction\n"
                    "Keep ALL other rules (language, word count, outline data, blueprint) unchanged."
                ),
                "variant_B": (
                    "THE PARADOX COLLISION — Contradictory Facts",
                    "HOOK METHOD OVERRIDE:\n"
                    "IGNORE the default hook opening strategy. Instead use THE PARADOX COLLISION:\n"
                    "1. OPEN with exactly 2 CONTRADICTORY facts about the subject, placed side by side.\n"
                    "   Format: '[Fact A — success/greatness]. [Fact B — tragedy/destruction]. Same person.'\n"
                    "   The gap between A and B must be SHOCKING.\n"
                    "2. Let the contradiction sit for 1-2 sentences — do NOT explain it yet.\n"
                    "3. Add 2-3 specific facts that DEEPEN the paradox (dates, names, consequences).\n"
                    "4. QUESTION: 'The question is not what happened — but HOW it happened.'\n"
                    "5. BRIDGE OUT (MANDATORY): After the question, write 1-2 sentences that POINT the listener\n"
                    "   toward the beginning of the story — a specific date, place, or moment.\n"
                    "   ✓ 'The answer starts in [city], [year]. With [concrete starting image].'\n"
                    "   ✗ Do NOT end on the question alone — the BRIDGE OUT converts curiosity into momentum.\n"
                    "EXAMPLE APPROACH: 'He was the most celebrated scientist in Europe. "
                    "He died blind, alone, forbidden from speaking the truth. Same person.'\n"
                    "→ question → 'To understand how, we must return to a house in Pisa, 1564...'\n"
                    "EMOTIONAL ARC: Shock → Confusion → 'Wait, HOW?' → Direction\n"
                    "Keep ALL other rules (language, word count, outline data, blueprint) unchanged."
                ),
            }
            for variant_key, (variant_title, variant_instruction) in _HOOK_VARIANTS.items():
                variant_path = os.path.join(ch_data_dir, f"{ch_label}_hook_{variant_key}.txt")
                with open(variant_path, "w", encoding="utf-8") as vf:
                    vf.write("=" * 80 + "\n")
                    vf.write(f"HOOK VARIANT: {variant_title}\n")
                    vf.write("=" * 80 + "\n")
                    vf.write("⚠ This file is for MANUAL USE ONLY — copy-paste to web AI.\n")
                    vf.write("   Same outline + blueprint + system prompt as original prompt_debug.\n")
                    vf.write("   Only the HOOK METHOD is different.\n\n")

                    vf.write("─── OUTLINE FOR THIS CHAPTER ───\n")
                    vf.write(json.dumps(chapter_outline, indent=2, ensure_ascii=False))
                    vf.write("\n\n")

                    vf.write("─── SYSTEM PROMPT (same as original) ───\n")
                    vf.write(system_prompt)
                    vf.write("\n\n")

                    vf.write("─── USER MESSAGE (with hook method override) ───\n")
                    vf.write(messages[1]["content"])
                    vf.write("\n\n")
                    vf.write(variant_instruction)
                    vf.write("\n")
            if log_callback:
                log_callback(f"  💾 Saved 2 hook variants → _chapter_data/{ch_label}_hook_variant_A/B.txt")

    if log_callback:
        log_callback(f"  Writing Ch.{chapter_number} from blueprint ({framework_name})...")

    result = api_client.call_api(
        messages, temperature=0.6, timeout=500,
        step_label=f"write_ch{chapter_number:02d}"
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"  ❌ API failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"  ✓ Ch.{chapter_number} written via {model}")

    return result["content"].strip()


def rewrite_chapter_narrative(
    chapter_text: str,
    chapter_index: int,
    total_chapters: int,
    analysis: dict,
    outline: dict,
    previous_rewritten: list[str],
    api_client,
    word_count_rule: str = "1300 to 1800 words",
    lang: str = "en",
    log_callback=None,
) -> str:
    """Rewrite a single chapter with full narrative context.
    chapter_index: 0-based
    previous_rewritten: list of full text of already-rewritten chapters
    """
    system_template = _load_prompt("system_narrative_rewrite.txt", lang)

    # Get outline info for this chapter
    ch_outline = {}
    for ch in outline.get("chapters", []):
        if ch.get("number") == chapter_index + 1:
            ch_outline = ch
            break

    # Build previous chapters context
    prev_text = ""
    if previous_rewritten:
        for i, prev in enumerate(previous_rewritten, 1):
            prev_text += f"\n\n=== CHAPTER {i} (already rewritten) ===\n{prev}"
    else:
        prev_text = "(This is the first chapter — no previous chapters)"

    # Build outline summary
    outline_text = json.dumps(outline, indent=2, ensure_ascii=False)

    system_prompt = system_template.replace(
        "{method}", analysis.get("method", "inquiry_arc")
    ).replace(
        "{hook}", analysis.get("hook", "")
    ).replace(
        "{counter_argument}", analysis.get("counter_argument", "")
    ).replace(
        "{outline}", outline_text
    ).replace(
        "{chapter_number}", str(chapter_index + 1)
    ).replace(
        "{total_chapters}", str(total_chapters)
    ).replace(
        "{role_in_flow}", ch_outline.get("role_in_flow", "")
    ).replace(
        "{connects_to_next}", ch_outline.get("connects_to_next", "")
    ).replace(
        "{previous_chapters}", prev_text
    ).replace(
        "{word_count_rule}", word_count_rule
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": f"ORIGINAL CHAPTER:\n\n{chapter_text}"},
    ]

    if log_callback:
        method = analysis.get("method", "?")
        log_callback(f"  Rewriting Ch.{chapter_index+1} ({method}, narrative)...")

    result = api_client.call_api(
        messages, temperature=0.6, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"  ❌ API failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"  ✓ Ch.{chapter_index+1} rewritten via {model}")

    return result["content"].strip()


def review_narrative_full(
    rewritten_chapters: list[dict],
    api_client,
    log_callback=None,
    niche: str = "",
    lang: str = "vi",
    framework_name: str = "",
) -> dict:
    """Review the full script for cross-chapter issues.
    rewritten_chapters: [{filename, text}, ...]
    Returns: {overall_flow_score, flow_report, issues: [...]}
    """
    prompt_file = _require_niche_prompt("review", niche, log_callback, framework_name)
    system_prompt = _load_prompt(prompt_file)
    if "{lang}" in system_prompt:
        system_prompt = system_prompt.replace("{lang}", lang)

    # Use [CHAPTER_FILE N] labeling (adopted from review pipeline)
    all_text = ""
    for i, ch in enumerate(rewritten_chapters, 1):
        all_text += f"\n\n[CHAPTER_FILE {i}] {ch['filename']}\n{ch['text']}"

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": f"FULL REWRITTEN SCRIPT ({len(rewritten_chapters)} chapters):\n{all_text}"},
    ]

    if log_callback:
        log_callback(f"Reviewing full script ({len(rewritten_chapters)} chapters)...")

    result = api_client.call_api(
        messages, temperature=0.3, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"❌ Review failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"✓ Review completed via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        review = json.loads(json_match.group())
    else:
        review = json.loads(content)

    return review


def patch_chapter_overlap(
    chapter_text: str,
    issue: dict,
    full_context: str,
    api_client,
    log_callback=None,
) -> str:
    """Patch a specific overlap/flow issue in one chapter.
    issue: {type, detail, suggested_fix, ...}
    full_context: summary of full script for context
    Returns: patched chapter text
    """
    # ── Trim context: only keep adjacent chapters (prev + target + next) ──
    import re as _re
    # Split full_context into individual chapter blocks
    # Supports both "=== Ch.N ===" and "[CHAPTER_FILE N]" formats
    chapter_blocks = _re.split(
        r'\n*(?=(?:=== Ch\.\d+|(?:\[CHAPTER_FILE \d+\])))', full_context
    )
    chapter_blocks = [b.strip() for b in chapter_blocks if b.strip()]

    # Find which block contains the chapter_text (fuzzy match first 80 chars)
    target_snippet = chapter_text[:80].strip()
    target_idx = -1
    for i, block in enumerate(chapter_blocks):
        if target_snippet in block:
            target_idx = i
            break

    if target_idx >= 0 and len(chapter_blocks) > 3:
        # Keep only prev + target + next
        start = max(0, target_idx - 1)
        end = min(len(chapter_blocks), target_idx + 2)
        trimmed_blocks = chapter_blocks[start:end]
        adjacent_context = "\n\n".join(trimmed_blocks)
    else:
        # WARNING: can't identify target chapter — using full context (token waste)
        if log_callback:
            log_callback(f"⚠️ Review: could not identify target chapter — using FULL context ({len(full_context):,} chars)")
        adjacent_context = full_context

    system_prompt = (
        "You are a script editor. You need to make a MINIMAL, TARGETED fix to one chapter.\n\n"
        "ISSUE TO FIX:\n"
        f"Type: {issue.get('type', 'overlap')}\n"
        f"Detail: {issue.get('detail', '')}\n"
        f"Fix: {issue.get('suggested_fix', '')}\n\n"
        "RULES:\n"
        "1. Make the SMALLEST possible change to fix the issue.\n"
        "2. Keep the chapter's overall structure, flow, and narrative intact.\n"
        "3. If reducing overlap, condense the overlapping section to 1-2 brief sentences.\n"
        "4. If fixing a flow break, add only a brief transition (1-2 sentences).\n"
        "5. Do NOT rewrite the entire chapter. Only modify the specific section.\n"
        "6. Do NOT include [CHAPTER_FILE] labels, filenames, or metadata in your output.\n\n"
        "ADJACENT CHAPTERS (for context only, do not modify other chapters):\n"
        f"{adjacent_context}\n\n"
        "OUTPUT: The complete chapter text with the fix applied. No comments or explanations."
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": f"CHAPTER TO FIX:\n\n{chapter_text}"},
    ]

    if log_callback:
        log_callback(f"  Patching: {issue.get('type', '?')} — {issue.get('detail', '')[:60]}...")

    result = api_client.call_api(
        messages, temperature=0.3, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"  ❌ Patch failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    if log_callback:
        log_callback(f"  ✓ Patched via {result.get('model', '?')}")

    patched = result["content"].strip()
    # Strip any leaked [CHAPTER_FILE N] labels from patched content
    import re as _re
    patched = _re.sub(
        r'^\s*\[CHAPTER_FILE\s*\d+\]\s*[^\n]*\n?', '', patched
    ).strip()
    return patched


def merge_to_version(
    output_dir: str,
    version: int,
    chapters: list[dict],
    lang: str = "",
) -> str:
    """Merge chapters into a versioned output directory.
    chapters: [{filename, text}, ...]
    Creates output_dir/v{version}/ with individual files + FULL_SCRIPT.txt
    Returns: path to FULL_SCRIPT.txt
    """
    if version == 0:
        ver_dir = os.path.join(output_dir, "final")
    else:
        ver_dir = os.path.join(output_dir, f"v{version}")
    os.makedirs(ver_dir, exist_ok=True)

    # Language prefix for filenames
    prefix = f"{lang}_" if lang else ""

    # Save individual chapters (body only, no title)
    for ch in chapters:
        title, body = _split_title_body(ch["text"])
        fname = f"{prefix}{ch['filename']}"
        fpath = os.path.join(ver_dir, fname)
        with open(fpath, "w", encoding="utf-8") as f:
            f.write(body if body else ch["text"])

    # Save merged full script with formatted headers
    full_path = os.path.join(ver_dir, "FULL_SCRIPT.txt")
    with open(full_path, "w", encoding="utf-8") as f:
        for i, ch in enumerate(chapters):
            title, body = _split_title_body(ch["text"])
            if i > 0:
                f.write("\n\n" + "=" * 60 + "\n\n")
            f.write(f"[{i+1:02d}]: {title}\n")
            f.write("=" * 60 + "\n\n")
            f.write(body if body else ch["text"])

    return full_path


