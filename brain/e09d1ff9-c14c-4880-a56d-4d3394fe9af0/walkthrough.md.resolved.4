# Fuzzy alias table: maps enum tier names → lowercase keywords for fallback matching.
# Used ONLY when blueprint tier values don't exactly match the style JSON enums
# (common with older blueprints or when AI ignores enum constraints).
_TIER_FUZZY_MAP = {
    # --- Hai Mặt: dark_side_severity ---
    "Personal_Flaws": ["personal", "flaws", "toxic", "addiction", "affair", "low"],
    "Professional_Unethical": ["professional", "unethical", "fraud", "plagiarism", "sabotage", "moderate", "medium"],
    "Crimes_Against_Humanity": ["crimes", "genocide", "mass death", "eugenics", "war crimes", "extreme", "high"],
    # --- Sử Thi: impact_radius ---
    "Domain_Level": ["domain", "field", "regional", "professional", "discipline", "local"],
    "Societal_Level": ["societal", "national", "continental", "cultural", "economy"],
    "Civilizational_Level": ["civilizational", "global", "humanity", "world", "universal", "intercontinental"],
    # --- Bản Án: opposition_severity ---
    "Censorship_Reputation": ["censorship", "reputation", "smear", "banned", "fired", "low", "moderate", "medium"],
    "Exile_Imprisonment": ["exile", "imprisonment", "prison", "seized", "arrested", "high"],
    "Lethal_Eradication": ["lethal", "death", "assassination", "suicide", "execution", "extreme"],
    # --- Kẻ Xét Lại: historical_distortion_level ---
    "Oversimplification": ["oversimplification", "simplified", "one-dimensional", "moderate", "low"],
    "Erasure_Stolen_Legacy": ["erasure", "stolen", "erased", "credited to others"],
    "Demonization_Framing": ["demonization", "framing", "fabricated", "villain", "propaganda", "high", "extreme", "distorted"],
    # --- Sự Lụi Tàn: severity ---
    "Poor_Judgment": ["poor judgment", "bad decision", "mismanagement", "miscalculation", "overconfidence", "reckless", "careless"],
    "Systematic_Corruption": ["systematic", "corruption", "illegal", "unethical system", "abuse of power", "exploitation", "greed"],
    "Megalomaniac_Collapse": ["megalomaniac", "invincible", "divine", "god complex", "total", "violent", "catastrophic", "absolute", "self-destruct", "complete collapse", "assassination"],
    # --- Bóng Tối: victim_scale ---
    "Local_Harm": ["local", "individual", "personal", "family", "household", "single victim"],
    "National_Destruction": ["national", "political elite", "senate", "equestrian", "aristocrat", "regional", "state", "empire", "hundreds", "nobility"],
    "Genocide_Level": ["genocide", "ethnic", "extermination", "population", "mass", "millions", "systematic murder", "entire people"],
}


def _resolve_tier(raw_value: str, tier_scoring: dict) -> tuple:
    """Match a raw blueprint tier value to its score.

    Returns: (matched_tier_name, score, match_type)
    match_type: "exact" | "fuzzy" | "none"
    """
    if not raw_value or not isinstance(raw_value, str):
        return None, 0, "none"

    # 1. Exact match
    if raw_value in tier_scoring:
        return raw_value, tier_scoring[raw_value], "exact"

    # 2. Case-insensitive exact match
    for tier_name, score in tier_scoring.items():
        if raw_value.strip().lower() == tier_name.lower():
            return tier_name, score, "exact"

    # 3. Fuzzy keyword match
    raw_lower = raw_value.lower()
    best_tier = None
    best_score = 0
    for tier_name, keywords in _TIER_FUZZY_MAP.items():
        if tier_name not in tier_scoring:
            continue
        for kw in keywords:
            if kw in raw_lower:
                if tier_scoring[tier_name] > best_score:
                    best_tier = tier_name
                    best_score = tier_scoring[tier_name]
                break
    if best_tier:
        return best_tier, best_score, "fuzzy"

    return None, 0, "none"


def _pre_score_frameworks(blueprint: dict, style_guide: dict, log_callback=None) -> list:
    """Pre-compute data_richness scores for each framework.

    Scans the blueprint for tier-tagged fields and uses the style JSON's
    tier_scoring table to calculate deterministic scores.

    Returns: list of dicts with {name, data_richness, highest_tier,
             match_type, tier_values_found, warnings}
    """
    frameworks = style_guide.get("frameworks", [])
    results = []

    if log_callback:
        log_callback("📊 Pre-scoring frameworks (deterministic)...")

    for fw in frameworks:
        name = fw.get("name", "?")
        ef = fw.get("evaluation_focus", {})
        pdf = ef.get("primary_data_field", "")
        tf = ef.get("tier_field", "")
        ts = ef.get("tier_scoring", {})

        entry = {
            "name": name,
            "data_richness": 0,
            "highest_tier": None,
            "match_type": "none",
            "tier_values_found": [],
            "warnings": [],
        }

        if log_callback:
            log_callback(f"  ┌─ {name} ─────────────────────────")

        # Skip if framework has no evaluation_focus (e.g. review frameworks)
        if not ef or not pdf:
            entry["data_richness"] = -1  # -1 = not applicable, let AI decide
            entry["match_type"] = "n/a"
            entry["warnings"].append("No evaluation_focus — AI scoring only")
            if log_callback:
                log_callback(f"  │ No evaluation_focus — skipping deterministic score")
                log_callback(f"  └────────────────────────────────")
            results.append(entry)
            continue

        # Check if primary_data_field exists in blueprint
        if pdf not in blueprint:
            entry["data_richness"] = 0
            entry["warnings"].append(f"Field '{pdf}' not found in blueprint")
            if log_callback:
                log_callback(f"  │ Field: {pdf} → NOT FOUND")
                log_callback(f"  │ data_richness = 0")
                log_callback(f"  └────────────────────────────────")
            results.append(entry)
            continue

        data = blueprint[pdf]

        # Collect all tier values depending on data structure
        tier_values_raw = []

        if isinstance(data, list):
            # Handler 1: List of dicts (Sử Thi, Bản Án, Sự Lụi Tàn)
            if log_callback:
                log_callback(f"  │ Field: {pdf} (list, {len(data)} items)")
            for item in data:
                if isinstance(item, dict) and tf in item:
                    tier_values_raw.append(item[tf])

        elif isinstance(data, dict):
            # Handler 2: Check if tier_field is directly in dict (Kẻ Xét Lại)
            if tf in data:
                if log_callback:
                    log_callback(f"  │ Field: {pdf} (dict, direct key)")
                tier_values_raw.append(data[tf])
            else:
                # Handler 3: Nested dict — scan sub-lists (Hai Mặt)
                if log_callback:
                    log_callback(f"  │ Field: {pdf} (dict, scanning sub-lists)")
                for sub_key, sub_val in data.items():
                    if isinstance(sub_val, list):
                        for item in sub_val:
                            if isinstance(item, dict) and tf in item:
                                tier_values_raw.append(item[tf])

        entry["tier_values_found"] = tier_values_raw

        if log_callback:
            log_callback(f"  │ Tier field: {tf}")
            # Truncate long values for display
            display_vals = [str(v)[:50] for v in tier_values_raw]
            log_callback(f"  │ Values found: {display_vals}")

        if not tier_values_raw:
            # FALLBACK: no tier tags found, but data EXISTS → score by volume
            item_count = 0
            if isinstance(data, list):
                item_count = len(data)
            elif isinstance(data, dict):
                # Count items across all sub-lists (e.g., dual_nature.dark_side + light_side)
                for sub_val in data.values():
                    if isinstance(sub_val, list):
                        item_count += len(sub_val)

            if item_count == 0:
                fallback_score = 0
            elif item_count <= 2:
                fallback_score = 4
            elif item_count <= 4:
                fallback_score = 6
            else:
                fallback_score = 7  # cap at 7 — only tier tags unlock 8-10

            entry["data_richness"] = fallback_score
            entry["match_type"] = "volume"
            entry["warnings"].append(
                f"No '{tf}' tags → fallback by data volume ({item_count} items → {fallback_score})"
            )
            if log_callback:
                log_callback(f"  │ ⚠️ No tier tags found")
                log_callback(f"  │ Fallback: {item_count} data items → data_richness = {fallback_score}")
                log_callback(f"  └────────────────────────────────")
            results.append(entry)
            continue


        # Resolve each value, keep highest score
        best_score = 0
        best_tier = None
        best_match_type = "none"
        unmatched = []

        for raw in tier_values_raw:
            tier_name, score, match_type = _resolve_tier(raw, ts)
            if tier_name and score > best_score:
                best_score = score
                best_tier = tier_name
                best_match_type = match_type
            if match_type == "none":
                unmatched.append(raw)

        entry["data_richness"] = best_score
        entry["highest_tier"] = best_tier
        entry["match_type"] = best_match_type

        if unmatched:
            trunc = [str(u)[:40] for u in unmatched]
            entry["warnings"].append(f"Unmatched tier values: {trunc}")

        if log_callback:
            if best_tier:
                match_label = "EXACT ✓" if best_match_type == "exact" else "FUZZY ⚠️"
                log_callback(f"  │ Match: {match_label} → {best_tier} → {best_score}")
                if best_match_type == "fuzzy":
                    log_callback(f"  │ ⚠️ Fuzzy match — consider re-extracting blueprint")
            else:
                log_callback(f"  │ ❌ No tier values matched scoring table")
            if unmatched:
                log_callback(f"  │ ⚠️ Unmatched: {[str(u)[:40] for u in unmatched]}")
            log_callback(f"  │ data_richness = {best_score}")
            log_callback(f"  └────────────────────────────────")

        results.append(entry)

    # Summary log
    if log_callback:
        summary = ", ".join([f"{r['name']}={r['data_richness']}" for r in results])
        log_callback(f"📊 Pre-scores: {summary}")

    return results


def recommend_framework(
    blueprint: dict,
    style_guide: dict,
    api_client,
    lang: str = "en",
    log_callback=None,
) -> dict:
    """Score and rank all review frameworks against a blueprint.

    Uses pre-computed data_richness scores (deterministic) combined with
    AI-judged topic_fit and narrative_potential scores.

    Returns: {products_found, topic_summary, rankings: [...],
              recommended, alternative, not_recommended}
    """
    system_template = _load_prompt("system_recommend_framework.txt")
    system_prompt = system_template.replace("{lang}", lang)

    # Build frameworks list from style guide
    frameworks = style_guide.get("frameworks", [])
    fw_list = []
    for fw in frameworks:
        fw_list.append({
            "name": fw.get("name", ""),
            "use_when": fw.get("use_when", ""),
            "evaluation_focus": fw.get("evaluation_focus", {}),
        })
    fw_list_str = json.dumps(fw_list, ensure_ascii=False, indent=2)
    system_prompt = system_prompt.replace("{frameworks_list}", fw_list_str)

    blueprint_json = json.dumps(blueprint, ensure_ascii=False, indent=2)

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": f"BLUEPRINT TO ANALYZE:\n\n{blueprint_json}"},
    ]

    if log_callback:
        log_callback("Recommending framework for blueprint...")

    result = api_client.call_api(
        messages, temperature=0.2, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"❌ Framework recommendation failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"✓ Frameworks ranked via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        return json.loads(json_match.group())
    return json.loads(content)


def recommend_framework_new_content(
    blueprint: dict,
    style_guide: dict,
    api_client,
    lang: str = "en",
    log_callback=None,
    niche: str = "",
) -> dict:
    """New Content framework recommendation with pre-scoring.

    Uses deterministic data_richness scores from evaluation_focus + tier_scoring
    to supplement AI judgment. Only for niches with research blueprint support.

    Raises RuntimeError if niche is not supported.
    """
    # Check niche is supported (same map as research_blueprint_multicall)
    niche_lower = (niche or "").lower()
    supported = any(kw in niche_lower for kw in _NICHE_RESEARCH_MAP)
    if not supported:
        raise RuntimeError(
            f"recommend_framework_new_content is not available for niche '{niche}'.\n"
            f"Use recommend_framework() (generic AI scoring) instead.\n"
            f"Supported niches for New Content: {', '.join(sorted(set(_NICHE_RESEARCH_MAP.keys())))}"
        )
    system_template = _load_prompt("system_recommend_framework_biography.txt")
    system_prompt = system_template.replace("{lang}", lang)

    frameworks = style_guide.get("frameworks", [])
    fw_list = []
    for fw in frameworks:
        fw_list.append({
            "name": fw.get("name", ""),
            "use_when": fw.get("use_when", ""),
            "evaluation_focus": fw.get("evaluation_focus", {}),
        })
    fw_list_str = json.dumps(fw_list, ensure_ascii=False, indent=2)
    system_prompt = system_prompt.replace("{frameworks_list}", fw_list_str)

    blueprint_json = json.dumps(blueprint, ensure_ascii=False, indent=2)

    # Pre-compute data_richness scores (biography-specific)
    pre_scores = _pre_score_frameworks(blueprint, style_guide, log_callback)
    pre_scores_clean = []
    for ps in pre_scores:
        pre_scores_clean.append({
            "name": ps["name"],
            "data_richness": ps["data_richness"],
            "highest_tier": ps["highest_tier"],
            "match_type": ps["match_type"],
            "warnings": ps["warnings"],
        })
    pre_scores_str = json.dumps(pre_scores_clean, ensure_ascii=False, indent=2)

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": (
            f"PRE-COMPUTED DATA RICHNESS SCORES (use these, do NOT recalculate):\n"
            f"{pre_scores_str}\n\n"
            f"BLUEPRINT TO ANALYZE:\n\n{blueprint_json}"
        )},
    ]

    if log_callback:
        log_callback("Recommending framework for biography blueprint...")

    result = api_client.call_api(messages, temperature=0.2, timeout=500)

    if not result["success"]:
        if log_callback:
            log_callback(f"❌ Framework recommendation failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"✓ Frameworks ranked via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        return json.loads(json_match.group())
    return json.loads(content)


