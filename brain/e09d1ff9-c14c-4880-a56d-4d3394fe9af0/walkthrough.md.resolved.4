def _apply_chapter_type_filter(
    prompt: str,
    chapter_type: str,
    chapter_structure: str = "",
    niche: str = "",
    framework_name: str = "",
) -> str:
    """Strip irrelevant sections from the writer prompt based on chapter_type.

    Removes:
    - Hook rules for non-hook chapters (saves ~8KB)
    - End rules for non-end chapters (saves ~1.5KB)
    - Injects only the assigned body structure (saves ~3.5KB)
    """
    import re

    _is_hook = chapter_type in ("hook", "intro", "opening")
    _is_end = chapter_type in ("end", "verdict", "closing")

    # ── Strip Hook rules for non-hook chapters ──
    if _is_hook:
        # Keep hook rules, just remove markers
        prompt = prompt.replace("{%IF_HOOK%}", "").replace("{%ENDIF_HOOK%}", "")
    else:
        # Remove entire hook section
        prompt = re.sub(
            r"\{%IF_HOOK%\}.*?\{%ENDIF_HOOK%\}",
            "", prompt, flags=re.DOTALL
        )

    # ── Strip End rules for non-end chapters ──
    if _is_end:
        prompt = prompt.replace("{%IF_END%}", "").replace("{%ENDIF_END%}", "")
    else:
        prompt = re.sub(
            r"\{%IF_END%\}.*?\{%ENDIF_END%\}",
            "", prompt, flags=re.DOTALL
        )

    # ── Inject only the assigned body structure ──
    # Step 1: Check framework-level override first (handles sub-niches like pirate haven)
    #   When a framework has a _FRAMEWORK_PROMPT_OVERRIDE entry, its name may also
    #   identify a sub-niche with its own body structures.
    niche_structures = {}
    fw_lower = (framework_name or "").lower()
    if fw_lower:
        for niche_key in sorted(_BODY_STRUCTURES.keys(), key=len, reverse=True):
            if niche_key in fw_lower:
                niche_structures = _BODY_STRUCTURES[niche_key]
                break

    # Step 2: Fall back to niche-level matching
    if not niche_structures:
        niche_lower = (niche or "").lower()
        for niche_key in sorted(_BODY_STRUCTURES.keys(), key=len, reverse=True):
            if niche_key in niche_lower:
                niche_structures = _BODY_STRUCTURES[niche_key]
                break

    # Step 3: Ultimate fallback to biography
    if not niche_structures:
        niche_structures = _BODY_STRUCTURES.get("tiểu sử", {})

    structure_key = (chapter_structure or "").lower().strip()
    if structure_key and structure_key in niche_structures:
        structure_text = niche_structures[structure_key]
    elif structure_key:
        # Unknown structure — inject all as fallback
        structure_text = "\n\n".join(niche_structures.values())
    else:
        # No structure assigned (hook/end) — empty
        structure_text = ""
    prompt = prompt.replace("{body_structure_block}", structure_text)

    # Clean up excessive blank lines left by removals
    prompt = re.sub(r"\n{4,}", "\n\n\n", prompt)

    return prompt


def _resolve_source_path(blueprint: dict, path: str, result: dict):
    """Resolve a _source_map path and add the matching data to result.

    Path formats:
      "section_name"                        → include entire section
      "section_name.identifier"             → match item within section by name/label
      "section_name.sub_section"            → match sub-field of a dict section
    """
    parts = path.split(".", 1)
    section_name = parts[0].strip()
    identifier = parts[1].strip() if len(parts) > 1 else None

    if section_name not in blueprint:
        return  # section doesn't exist — skip silently (data might not exist in this blueprint)

    section = blueprint[section_name]

    if identifier is None:
        # Include entire section
        if section_name not in result:
            result[section_name] = section
        return

    identifier_lower = identifier.lower()

    if isinstance(section, list):
        # List section (life_phases, achievements, conflicts, key_relationships, etc.)
        # Match items that contain the identifier in their JSON text
        for item in section:
            if not isinstance(item, dict):
                continue
            item_text = json.dumps(item, ensure_ascii=False).lower()
            if identifier_lower in item_text:
                existing = result.get(section_name, [])
                if item not in existing:
                    result.setdefault(section_name, []).append(item)

    elif isinstance(section, dict):
        # Dict section (personal_profile, dark_psychology)
        # Match sub-key within the dict
        if identifier in section:
            result.setdefault(section_name, {})[identifier] = section[identifier]
        else:
            # Fuzzy match sub-key
            for k, v in section.items():
                if identifier_lower in k.lower():
                    result.setdefault(section_name, {})[k] = v


def _extract_bio_section_matches(blueprint: dict, chapter_outline: dict, result: dict):
    """Extract biography sections based on outline metadata fields.

    Uses: life_phase_covered, relationships_featured, myths_debunked
    These are driven by outline metadata, not key_data text.
    """
    # ── life_phase_covered → blueprint.life_phases ──
    life_phase_raw = chapter_outline.get("life_phase_covered", "")
    if life_phase_raw and life_phase_raw != "null" and isinstance(life_phase_raw, str):
        phase_queries = [p.strip().lower() for p in life_phase_raw.split(",") if p.strip()]
        if "life_phases" in blueprint and isinstance(blueprint["life_phases"], list):
            for item in blueprint["life_phases"]:
                if not isinstance(item, dict):
                    continue
                item_text = json.dumps(item, ensure_ascii=False).lower()
                for pq in phase_queries:
                    if pq in item_text:
                        existing = result.get("life_phases", [])
                        if item not in existing:
                            result.setdefault("life_phases", []).append(item)
                        break

    # ── relationships_featured → blueprint.key_relationships ──
    rels = chapter_outline.get("relationships_featured", [])
    if rels and "key_relationships" in blueprint and isinstance(blueprint["key_relationships"], list):
        for rel_name in rels:
            if not isinstance(rel_name, str):
                continue
            rel_lower = rel_name.lower()
            for item in blueprint["key_relationships"]:
                if isinstance(item, dict) and rel_lower in json.dumps(item, ensure_ascii=False).lower():
                    existing = result.get("key_relationships", [])
                    if item not in existing:
                        result.setdefault("key_relationships", []).append(item)

    # ── myths_debunked → blueprint.myths_vs_reality ──
    myths = chapter_outline.get("myths_debunked", [])
    if myths and "myths_vs_reality" in blueprint and isinstance(blueprint["myths_vs_reality"], list):
        for myth in myths:
            if not isinstance(myth, str) or myth == "null":
                continue
            myth_lower = myth.lower()
            for item in blueprint["myths_vs_reality"]:
                if isinstance(item, dict) and myth_lower in json.dumps(item, ensure_ascii=False).lower():
                    existing = result.get("myths_vs_reality", [])
                    if item not in existing:
                        result.setdefault("myths_vs_reality", []).append(item)


