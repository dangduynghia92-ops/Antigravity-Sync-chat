def audit_blueprint(
    blueprint: dict,
    topic: str,
    niche: str,
    api_client,
    lang: str = "en",
    log_callback=None,
) -> dict | None:
    """Audit a completed blueprint for missing key data.

    Dispatches prompt by niche. Returns None if no prompt or prompt is empty.
    Merges discovered data back into the blueprint dict (in-place).

    Args:
        blueprint: completed blueprint dict (modified in-place)
        topic: subject name
        niche: niche string for prompt dispatch
        api_client: APIClient instance
        lang: output language
        log_callback: function(str) for logging

    Returns:
        dict: audit result, or None if skipped
    """
    log = log_callback or (lambda m: None)

    # Dispatch prompt by niche
    prompt_file = None
    niche_lower = niche.lower()
    for kw, pf in _AUDIT_PROMPT_MAP.items():
        if kw in niche_lower:
            prompt_file = pf
            break
    if not prompt_file:
        log("Step 1.5: No audit prompt for this niche — skip")
        return None

    system_template = _load_prompt(prompt_file)
    if not system_template.strip():
        log("Step 1.5: Audit prompt is empty — skip")
        return None

    system_prompt = system_template.replace("{lang}", lang)

    bp_json = json.dumps(blueprint, indent=2, ensure_ascii=False)
    user_msg = (
        f"TOPIC: {topic}\n\n"
        f"COMPLETED BLUEPRINT:\n{bp_json}"
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_msg},
    ]

    log("Auditing blueprint for missing key data...")
    result = api_client.call_api(messages, temperature=0.3, timeout=300)

    if not result["success"]:
        log(f"⚠️ Audit failed (non-fatal): {result.get('error', '?')}")
        return {"merge_into_existing": {}, "additional_findings": [], "audit_summary": "Audit failed"}

    model = result.get("model", "?")
    content = result["content"]

    # Parse JSON response
    audit = _clean_and_parse_json(content)
    if audit is None:
        json_match = re.search(r'\{[\s\S]*\}', content)
        if json_match:
            try:
                audit = json.loads(json_match.group())
            except json.JSONDecodeError:
                log("⚠️ Audit returned invalid JSON (non-fatal)")
                return {"merge_into_existing": {}, "additional_findings": [], "audit_summary": "Parse failed"}
        else:
            log("⚠️ Audit returned no JSON (non-fatal)")
            return {"merge_into_existing": {}, "additional_findings": [], "audit_summary": "No JSON"}

    # Merge discovered data into blueprint
    merge = audit.get("merge_into_existing", {})
    merged_count = 0
    for section_name, items in merge.items():
        if not isinstance(items, list) or not items:
            continue
        existing = blueprint.get(section_name)
        if isinstance(existing, list):
            blueprint[section_name].extend(items)
            merged_count += len(items)
            log(f"  + {len(items)} items merged → {section_name}")
        else:
            blueprint[section_name] = items
            merged_count += len(items)
            log(f"  + {len(items)} items added → {section_name} (new)")

    # Safety net: if AI still returns additional_findings despite prompt removal,
    # route items into texture_and_hooks.must_include_details so data reaches writer
    additional = audit.get("additional_findings", [])
    if additional:
        log(f"  ⚠ AI returned {len(additional)} additional_findings (should classify into fields)")
        th = blueprint.setdefault("texture_and_hooks", {})
        mid = th.setdefault("must_include_details", [])
        for item in additional:
            fact_text = item.get("fact", str(item)) if isinstance(item, dict) else str(item)
            mid.append(fact_text)
        merged_count += len(additional)

    summary = audit.get("audit_summary", "")
    total = merged_count
    log(f"✓ Audit complete via {model}: {total} items added" + (f" — {summary}" if summary else ""))

    return audit


def crossref_blueprint(
    blueprint: dict,
    reference_texts: list[str],
    niche: str,
    api_client,
    lang: str = "en",
    log_callback=None,
) -> dict | None:
    """Cross-reference blueprint against user-provided transcripts.

    Dispatches prompt by niche. Returns None if no prompt found.
    Extracts facts from transcripts missing from the blueprint.
    Merges discovered data back into blueprint dict (in-place).

    Args:
        blueprint: completed blueprint dict (modified in-place)
        reference_texts: list of transcript strings
        niche: niche string for prompt dispatch
        api_client: APIClient instance
        lang: output language
        log_callback: function(str) for logging

    Returns:
        dict: crossref result, or None if skipped
    """
    log = log_callback or (lambda m: None)

    # Dispatch prompt by niche
    prompt_file = None
    niche_lower = niche.lower()
    for kw, pf in _CROSSREF_PROMPT_MAP.items():
        if kw in niche_lower:
            prompt_file = pf
            break
    if not prompt_file:
        log("Step 1.6: No crossref prompt for this niche — skip")
        return None

    system_template = _load_prompt(prompt_file)
    system_prompt = system_template.replace("{lang}", lang)

    bp_json = json.dumps(blueprint, indent=2, ensure_ascii=False)

    # Combine all reference texts with separators
    combined_refs = ""
    for i, text in enumerate(reference_texts, 1):
        combined_refs += f"\n\n{'='*40}\nTRANSCRIPT {i}:\n{'='*40}\n{text}"

    user_msg = (
        f"BLUEPRINT:\n{bp_json}\n\n"
        f"REFERENCE TRANSCRIPTS ({len(reference_texts)} total):"
        f"{combined_refs}"
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_msg},
    ]

    log(f"Cross-referencing with {len(reference_texts)} transcript(s)...")
    result = api_client.call_api(messages, temperature=0.2, timeout=400)

    if not result["success"]:
        log(f"⚠️ Cross-reference failed (non-fatal): {result.get('error', '?')}")
        return {"merge_into_existing": {}, "additional_findings": [], "crossref_summary": "Failed"}

    model = result.get("model", "?")
    content = result["content"]

    # Parse JSON response
    crossref = _clean_and_parse_json(content)
    if crossref is None:
        json_match = re.search(r'\{[\s\S]*\}', content)
        if json_match:
            try:
                crossref = json.loads(json_match.group())
            except json.JSONDecodeError:
                log("⚠️ Cross-reference returned invalid JSON (non-fatal)")
                return {"merge_into_existing": {}, "additional_findings": [], "crossref_summary": "Parse failed"}
        else:
            log("⚠️ Cross-reference returned no JSON (non-fatal)")
            return {"merge_into_existing": {}, "additional_findings": [], "crossref_summary": "No JSON"}

    # Merge discovered data into blueprint (same logic as audit)
    merge = crossref.get("merge_into_existing", {})
    merged_count = 0
    for section_name, items in merge.items():
        if not isinstance(items, list) or not items:
            continue
        existing = blueprint.get(section_name)
        if isinstance(existing, list):
            blueprint[section_name].extend(items)
            merged_count += len(items)
            log(f"  + {len(items)} items merged → {section_name}")
        else:
            blueprint[section_name] = items
            merged_count += len(items)
            log(f"  + {len(items)} items added → {section_name} (new)")

    # Safety net: route stray additional_findings into texture_and_hooks
    additional = crossref.get("additional_findings", [])
    if additional:
        log(f"  ⚠ AI returned {len(additional)} additional_findings (should classify into fields)")
        th = blueprint.setdefault("texture_and_hooks", {})
        mid = th.setdefault("must_include_details", [])
        for item in additional:
            fact_text = item.get("fact", str(item)) if isinstance(item, dict) else str(item)
            mid.append(fact_text)
        merged_count += len(additional)

    summary = crossref.get("crossref_summary", "")
    total = merged_count
    log(f"✓ Cross-reference via {model}: {total} items extracted" + (f" — {summary}" if summary else ""))

    return crossref


def research_blueprint(
    topic: str,
    api_client,
    lang: str = "en",
    log_callback=None,
    niche: str = "",
) -> dict:
    """Generate a content blueprint from scratch using AI knowledge.
    No source script needed — AI researches the topic and creates the blueprint.

    Returns: blueprint dict (same schema as extract_blueprint)
    """
    _RESEARCH_PROMPT_MAP = {
        "biography": "system_research_blueprint_biography.txt",
        "tiểu sử": "system_research_blueprint_biography.txt",
        "nhân vật": "system_research_blueprint_biography.txt",
        "chân dung": "system_research_blueprint_biography.txt",
        "cuộc đời": "system_research_blueprint_biography.txt",
        # ── Pirate / Hải tặc ──
        "lịch sử hải tặc": "system_research_blueprint_pirate.txt",
        "hải tặc": "system_research_blueprint_pirate.txt",
        "cướp biển": "system_research_blueprint_pirate.txt",
        "pirate": "system_research_blueprint_pirate.txt",
        "buccaneer": "system_research_blueprint_pirate.txt",
        "corsair": "system_research_blueprint_pirate.txt",
    }
    niche_lower = (niche or "").lower()
    prompt_file = None
    for keyword, pfile in _RESEARCH_PROMPT_MAP.items():
        if keyword in niche_lower:
            prompt_file = pfile
            break
    if not prompt_file:
        msg = f"No research prompt for niche '{niche}'"
        if log_callback:
            log_callback(f"✗ {msg}")
        raise RuntimeError(msg)

    if log_callback:
        log_callback(f"Using research prompt: {prompt_file}")

    system_template = _load_prompt(prompt_file)
    system_prompt = system_template.replace("{lang}", lang)

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": f"RESEARCH THIS PERSON AND CREATE A COMPLETE BLUEPRINT:\n\n{topic}"},
    ]

    if log_callback:
        log_callback(f"Researching '{topic}'...")

    result = api_client.call_api(messages, temperature=0.3, timeout=500)

    if not result["success"]:
        if log_callback:
            log_callback(f"❌ Research failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"✓ Blueprint researched via {model}")

    content = result["content"]
    blueprint = _clean_and_parse_json(content)
    if blueprint is None:
        json_match = re.search(r'\{[\s\S]*\}', content)
        if json_match:
            blueprint = json.loads(json_match.group())
        else:
            blueprint = json.loads(content)

    if log_callback:
        phases = len(blueprint.get("life_phases", []))
        achv = len(blueprint.get("achievements", []))
        conf = len(blueprint.get("conflicts", []))
        tp = len(blueprint.get("turning_points", []))
        so = len(blueprint.get("systemic_opposition", []))
        rel = len(blueprint.get("key_relationships", []))
        log_callback(
            f"✓ Blueprint: {phases} life phases, {achv} achievements, "
            f"{conf} conflicts, {tp} turning points, {so} systemic opposition, "
            f"{rel} relationships"
        )

    return blueprint


