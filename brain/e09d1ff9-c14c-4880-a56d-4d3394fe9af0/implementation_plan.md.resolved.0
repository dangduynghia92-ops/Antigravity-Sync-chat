      "shot_type": "Medium Close-up",
      "roll_type": "B-Roll",
      "camera_motion": "Static",
      "lighting_and_atmosphere": "Cold moonlight crashing through windows, chaotic and violent mood.",
      "background_and_extras": "Broken furniture and scattered gold coins shimmering faintly on the marble floor.",
      "physical_action": "Two heavy, armored arms of Roman soldiers aggressively ripping a sacred white priest scarf off."
    },
    {
      "global_scene_id": "SEQ_02_SCN_03",
      "duration": 5.0,
      "matched_text": "They want every stone attached to your name.",
      "shot_type": "Low Angle Shot",
      "roll_type": "B-Roll",
      "camera_motion": "Static",
      "lighting_and_atmosphere": "Dusty air filled with marble particles, harsh contrast lighting.",
      "background_and_extras": "Empty, destroyed courtyard with scattered ancient Roman scrolls blowing in the wind.",
      "physical_action": "Roman soldiers swinging heavy metal hammers, smashing a white marble family statue to pieces."
    }
