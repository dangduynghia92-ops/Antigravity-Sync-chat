### Python Code Changes

#### [MODIFY] [rewriter.py](file:///f:/1.%20Edit%20Videos/8.AntiCode/2.Script_Split_Chapter/core/rewriter.py)

Thay thế tất cả binary `_is_mystery` dispatch bằng **niche prompt map** pattern thống nhất:

```python
# Helper function (add once at top of file)
_NICHE_PROMPT_MAP = {
    "extract_blueprint": {
        "firearms": "system_extract_blueprint_firearms.txt",
        "military": "system_extract_blueprint_military.txt",
        "mystery":  "system_extract_blueprint_mystery.txt",
        "_default": "system_extract_blueprint_review.txt",
    },
    "reality_check": {
        "firearms": "system_reality_check_firearms.txt",
        "military": "system_reality_check_military.txt",
        "mystery":  "system_reality_check_mystery.txt",
        "_default": "system_reality_check.txt",
    },
    "check_blueprint": {
        "firearms": "system_check_blueprint_firearms.txt",
        "military": "system_check_blueprint_military.txt",
        "mystery":  "system_check_blueprint_mystery.txt",
        "_default": "system_check_blueprint.txt",
    },
    "audit_outline": {
        "firearms": "system_audit_outline_firearms.txt",
        "military": "system_audit_outline_military.txt",
        "mystery":  "system_audit_outline_mystery.txt",
        "_default": "system_audit_outline_review.txt",
    },
    "cross_chapter": {
        "firearms": "system_review_cross_chapter_firearms.txt",
        "military": "system_review_cross_chapter_military.txt",
        "mystery":  "system_review_cross_chapter_mystery.txt",
        "_default": "system_review_cross_chapter.txt",
    },
    "outline": {
        "firearms": "system_review_outline_firearms.txt",
        "military": "system_review_outline_military.txt",
        "mystery":  "system_mystery_outline.txt",
        "_default": "system_review_outline.txt",
    },
}

def _get_niche_prompt(step: str, niche: str) -> str:
    """Get the prompt file for a specific step + niche combo."""
    step_map = _NICHE_PROMPT_MAP.get(step, {})
    niche_lower = (niche or "").lower()
    for key, fname in step_map.items():
        if key != "_default" and key in niche_lower:
            return fname
    return step_map.get("_default", "")
```

