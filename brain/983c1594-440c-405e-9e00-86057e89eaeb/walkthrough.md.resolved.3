def ai_suggest_order(
    chapter_files: list[dict],
    api_client,
    log_callback=None,
) -> dict:
    """AI suggests order only (user already selected chapters).
    Returns: {selected_chapters: [{order, filename, reason_vi}], overall_strategy_vi}
    """
    system_prompt = (
        "You are a YouTube content strategist. "
        "The user already selected these chapters for their video. "
        "Suggest the BEST ORDER for maximum viewer retention.\n"
        "Reply JSON only:\n"
        '{"selected_chapters": [{"order": 1, "filename": "...", '
        '"reason_vi": "Lý do tiếng Việt"}], '
        '"overall_strategy_vi": "Chiến lược sắp xếp..."}'
    )

    blocks = []
    for ch in chapter_files:
        content = _read_chapter_content(ch["filepath"], max_chars=2000)
        if not content:
            continue
        blocks.append(f"=== {ch['filename']} ===\n{content}")

    if not blocks:
        raise RuntimeError("No chapters to order")

    user_content = (
        f"Order these {len(blocks)} chapters:\n\n"
        + "\n\n".join(blocks)
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_content},
    ]

    if log_callback:
        log_callback(f"  AI suggesting order for {len(blocks)} chapters...")

    result = api_client.call_api(
        messages, temperature=0.4, timeout=500
    )

    if not result["success"]:
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"  ✓ Order suggested via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        return json.loads(json_match.group())
    return json.loads(content)


# ── Save & Merge ─────────────────────────────────────────────────

def _split_title_body(text: str) -> tuple[str, str]:
    """Split rewritten text into (title, body).
    AI outputs title on first line. Returns (title, body_without_title).
    """
    lines = text.strip().split("\n", 1)
    title = lines[0].strip()
    body = lines[1].strip() if len(lines) > 1 else ""
    return title, body


def save_rewritten_file(output_dir: str, filename: str, text: str, lang: str = "english", index: int = None) -> str:
    """Save rewritten chapter to output directory (body only, no title)."""
    os.makedirs(output_dir, exist_ok=True)
    base = os.path.splitext(filename)[0]
    if index is not None:
        out_name = f"{lang}_{index:03d}_{base}_rewritten.txt"
    else:
        out_name = f"{lang}_{base}_rewritten.txt"
    out_path = os.path.join(output_dir, out_name)

    _, body = _split_title_body(text)
    with open(out_path, "w", encoding="utf-8") as f:
        f.write(body if body else text)

    return out_path


def merge_ordered_chapters(
    output_dir: str, status: dict, ordered_filenames: list[str]
) -> str:
    """Merge chapters in specified order into FINAL_SCRIPT.txt."""
    merged_lines = []
    separator = "\n\n" + "=" * 60 + "\n\n"

    for fname in ordered_filenames:
        ch_info = status.get("chapters", {}).get(fname, {})
        output_file = ch_info.get("output_file", "")
        if not output_file:
            continue

        out_path = os.path.join(output_dir, output_file)
        if not os.path.exists(out_path):
            continue

        with open(out_path, "r", encoding="utf-8") as f:
            content = f.read().strip()

        if merged_lines:
            merged_lines.append(separator)
        merged_lines.append(content)

    if not merged_lines:
        return ""

    merged_path = os.path.join(output_dir, "FINAL_SCRIPT.txt")
    with open(merged_path, "w", encoding="utf-8") as f:
        f.write("".join(merged_lines))

    return merged_path


def merge_from_paths(filepaths: list[str], output_path: str) -> str:
    """Merge chapter files from explicit file paths."""
    merged_lines = []

    for i, fp in enumerate(filepaths):
        if not os.path.exists(fp):
            continue
        with open(fp, "r", encoding="utf-8") as f:
            content = f.read().strip()
        if content:
            if merged_lines:
                merged_lines.append("\n\n" + "=" * 60 + "\n\n")
            # Add chapter header
            fname = os.path.splitext(os.path.basename(fp))[0]
            merged_lines.append(f"[{i+1:02d}]: {fname}\n")
            merged_lines.append("=" * 60 + "\n\n")
            merged_lines.append(content)

    if not merged_lines:
        return ""

    os.makedirs(os.path.dirname(output_path), exist_ok=True)
    with open(output_path, "w", encoding="utf-8") as f:
        f.write("".join(merged_lines))

    return output_path


