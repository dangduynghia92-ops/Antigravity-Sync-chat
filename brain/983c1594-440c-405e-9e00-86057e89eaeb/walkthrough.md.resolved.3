def _find_empty_fields(obj, prefix=""):
    """Recursively find empty/missing fields in a dict/list structure.
    Returns list of dotted paths like 'geography.distances'."""
    empties = []
    if isinstance(obj, dict):
        for k, v in obj.items():
            path = f"{prefix}.{k}" if prefix else k
            if v == "" or v == [] or v is None:
                empties.append(path)
            elif v in ("N/A", "Not mentioned", "n/a"):
                empties.append(path)
            elif isinstance(v, (dict, list)):
                empties.extend(_find_empty_fields(v, path))
    elif isinstance(obj, list):
        for i, item in enumerate(obj):
            path = f"{prefix}[{i}]"
            if isinstance(item, (dict, list)):
                empties.extend(_find_empty_fields(item, path))
            elif item in ("", "N/A", "Not mentioned", None):
                empties.append(path)
    return empties


def _deep_merge_empty(target, source):
    """Merge source into target, ONLY filling empty fields.
    Never overwrites existing non-empty content."""
    if not isinstance(source, dict) or not isinstance(target, dict):
        return
    for key, src_val in source.items():
        if key not in target:
            target[key] = src_val
            continue
        tgt_val = target[key]
        # Target field is empty → fill it
        if tgt_val in ("", None, "N/A", "Not mentioned", "n/a"):
            target[key] = src_val
        elif tgt_val == [] and isinstance(src_val, list) and src_val:
            target[key] = src_val
        elif isinstance(tgt_val, dict) and isinstance(src_val, dict):
            _deep_merge_empty(tgt_val, src_val)
        elif isinstance(tgt_val, list) and isinstance(src_val, list):
            # Try to match list items by identity key (name, claim, etc.)
            _ID_KEYS = ("claim", "name", "phase_name", "element", "title")
            for s_item in src_val:
                if not isinstance(s_item, dict):
                    continue
                # Find matching target item by identity key
                matched = False
                for id_key in _ID_KEYS:
                    if id_key in s_item:
                        for t_item in tgt_val:
                            if isinstance(t_item, dict) and t_item.get(id_key) == s_item[id_key]:
                                _deep_merge_empty(t_item, s_item)
                                matched = True
                                break
                        break  # only try first matching id_key
                if not matched:
                    # Fallback: match by index
                    s_idx = src_val.index(s_item)
                    if s_idx < len(tgt_val) and isinstance(tgt_val[s_idx], dict):
                        _deep_merge_empty(tgt_val[s_idx], s_item)
        # Non-empty target → skip (never overwrite)


def enrich_blueprint_google(
    blueprint: dict,
    gemini_keys: list,
    niche: str = "",
    lang: str = "en",
    log_callback=None,
    stop_check=None,
    use_google_search: bool = True,
) -> dict:
    """Fill empty blueprint fields using Gemini (optionally with Google Search).

    Scans blueprint for empty/missing fields, calls Gemini to get
    accurate data, then merges results into blueprint (only fills
    empty fields).

    Args:
        blueprint: blueprint dict from extract_blueprint
        gemini_keys: list of Gemini API keys
        niche: niche keyword (e.g. "battle", "mystery")
        lang: language code
        log_callback: optional logging function
        stop_check: optional callable returning True to abort
        use_google_search: if True, enables Google Search Grounding
                           for real-time web data. If False, uses
                           Gemini's training knowledge only.

    Returns: dict with 'fields_filled', 'enrichment_data', 'summary'
    """
    from core.api_client import APIClient

    def log(msg):
        if log_callback:
            log_callback(msg)

    if not gemini_keys:
        log("⚠ No Gemini API keys — skipping enrichment")
        return {"fields_filled": 0, "summary": "No API keys"}

    # Find empty fields
    empties = _find_empty_fields(blueprint)
    if not empties:
        log("✓ Blueprint is complete — no empty fields to enrich")
        return {"fields_filled": 0, "summary": "Blueprint already complete"}

    log(f"📋 Found {len(empties)} empty field(s): {', '.join(empties[:10])}"
        + (f" (+{len(empties)-10} more)" if len(empties) > 10 else ""))

    # Find niche-specific enrichment prompt
    niche_lower = (niche or "").lower()
    prompt_file = None
    for keyword, pfile in _NICHE_ENRICH_PROMPT_MAP.items():
        if keyword in niche_lower:
            prompt_file = pfile
            break

    if not prompt_file:
        log(f"⚠ No enrichment prompt for niche '{niche}' — skipping")
        return {"fields_filled": 0, "summary": f"No prompt for niche '{niche}'"}

    # Load and format prompt
    system_template = _load_prompt(prompt_file)
    core_topic = blueprint.get("core_topic", "Unknown battle")
    blueprint_json = json.dumps(blueprint, indent=2, ensure_ascii=False)

    system_prompt = (
        system_template
        .replace("{lang}", lang)
        .replace("{core_topic}", core_topic if isinstance(core_topic, str)
                 else json.dumps(core_topic, ensure_ascii=False))
        .replace("{blueprint_json}", blueprint_json)
    )

    messages = [
        {"role": "user", "content": system_prompt},
    ]

    # Call Gemini (with or without Google Search)
    _source_label = "Google Search" if use_google_search else "AI knowledge"
    api_client = APIClient([], stop_check=stop_check)
    last_error = ""

    for key_idx, api_key in enumerate(gemini_keys):
        if stop_check and stop_check():
            return {"fields_filled": 0, "summary": "Stopped by user"}

        if len(gemini_keys) > 1:
            log(f"  Using key {key_idx + 1}/{len(gemini_keys)}...")

        try:
            result = api_client.call_gemini_native(
                messages,
                gemini_api_key=api_key,
                model="gemini-2.5-flash",
                google_search=use_google_search,
                timeout=120,
                stop_check=stop_check,
            )

            if result["success"]:
                content = result["content"]
                jm = re.search(r'\{[\s\S]*\}', content)
                if jm:
                    enrichment_data = json.loads(jm.group())
                else:
                    enrichment_data = json.loads(content)

                # Count fields before merge
                new_fields = _find_empty_fields(blueprint)
                pre_count = len(new_fields)

                # Merge into blueprint (only fills empty)
                _deep_merge_empty(blueprint, enrichment_data)

                # Count fields after merge
                post_empties = _find_empty_fields(blueprint)
                fields_filled = pre_count - len(post_empties)

                model = result.get("model", "?")
                log(f"✓ Enriched {fields_filled} field(s) via {model} + {_source_label}")
                if post_empties:
                    log(f"  Still empty: {', '.join(post_empties[:5])}"
                        + (f" (+{len(post_empties)-5} more)"
                           if len(post_empties) > 5 else ""))

                return {
                    "fields_filled": fields_filled,
                    "enrichment_data": enrichment_data,
                    "summary": f"Filled {fields_filled} fields via {_source_label}",
                    "still_empty": post_empties,
                }

            last_error = result.get("error", "unknown")
            log(f"  ⚠ Key {key_idx+1} failed: {last_error}")

        except json.JSONDecodeError as e:
            last_error = f"JSON parse error: {e}"
            log(f"  ⚠ {last_error}")
        except Exception as e:
            last_error = str(e)
            log(f"  ⚠ Error: {last_error}")

    log(f"⚠ All Gemini keys failed — enrichment skipped. Last: {last_error}")
    return {"fields_filled": 0, "summary": f"All keys failed: {last_error}"}


