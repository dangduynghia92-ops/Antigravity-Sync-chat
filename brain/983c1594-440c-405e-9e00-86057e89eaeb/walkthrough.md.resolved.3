def _get_niche_prompt(step: str, niche: str) -> str:
    """Get the prompt filename for a pipeline step + niche combination.
    Raises ValueError if the niche has no prompt for this step.
    """
    step_map = _NICHE_PROMPT_MAP.get(step, {})
    niche_lower = (niche or "").lower()
    for key, fname in step_map.items():
        if key in niche_lower:
            return fname
    # No matching niche — tell user to create prompts
    known = ", ".join(step_map.keys())
    raise ValueError(
        f"No '{step}' prompt found for niche '{niche}'. "
        f"Known niches: [{known}]. "
        f"Please create a prompt file for this niche and add it to "
        f"_NICHE_PROMPT_MAP in rewriter.py."
    )


def _require_niche_prompt(step: str, niche: str, log_callback=None) -> str:
    """Get niche-specific prompt or raise RuntimeError with clear guidance.
    `step` should be WITHOUT the 'narrative_' prefix (e.g. 'outline', 'audit').
    """
    if not niche:
        raise RuntimeError(
            f"Narrative {step} requires a niche. Please set niche in style_data."
        )
    map_key = f"narrative_{step}"
    try:
        prompt_file = _get_niche_prompt(map_key, niche)
    except ValueError:
        raise RuntimeError(
            f"No narrative {step} prompt for niche '{niche}'. "
            f"Create prompts/system_narrative_{step}_<niche>.txt and add to "
            f"_NICHE_PROMPT_MAP['{map_key}']"
        )
    if log_callback:
        log_callback(f"[niche={niche}] {step} → {prompt_file}")
    return prompt_file


