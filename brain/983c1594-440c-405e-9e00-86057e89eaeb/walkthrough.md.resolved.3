def recommend_framework(
    blueprint: dict,
    style_guide: dict,
    api_client,
    lang: str = "en",
    log_callback=None,
) -> dict:
    """Score and rank all review frameworks against a blueprint.

    Returns: {products_found, topic_summary, rankings: [...],
              recommended, alternative, not_recommended}
    """
    system_template = _load_prompt("system_recommend_framework.txt")
    system_prompt = system_template.replace("{lang}", lang)

    # Build frameworks list from style guide
    frameworks = style_guide.get("frameworks", [])
    fw_list = []
    for fw in frameworks:
        fw_list.append({
            "name": fw.get("name", ""),
            "use_when": fw.get("use_when", ""),
            "evaluation_focus": fw.get("evaluation_focus", {}),
        })
    fw_list_str = json.dumps(fw_list, ensure_ascii=False, indent=2)
    system_prompt = system_prompt.replace("{frameworks_list}", fw_list_str)

    blueprint_json = json.dumps(blueprint, ensure_ascii=False, indent=2)

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": f"BLUEPRINT TO ANALYZE:\n\n{blueprint_json}"},
    ]

    if log_callback:
        log_callback("Recommending framework for blueprint...")

    result = api_client.call_api(
        messages, temperature=0.2, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"❌ Framework recommendation failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"✓ Frameworks ranked via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        return json.loads(json_match.group())
    return json.loads(content)


def check_blueprint(
    blueprint: dict,
    framework: dict,
    api_client,
    lang: str = "en",
    log_callback=None,
    niche: str = "",
) -> dict:
    """Check if blueprint has enough data for a chosen framework.

    Returns: {framework, overall_status, products_checked: [...],
              summary, recommendation}
    """
