def patch_chapter_overlap(
    chapter_text: str,
    issue: dict,
    full_context: str,
    api_client,
    log_callback=None,
) -> str:
    """Patch a specific overlap/flow issue in one chapter.
    issue: {type, detail, suggested_fix, ...}
    full_context: summary of full script for context
    Returns: patched chapter text
    """
    # ── Trim context: only keep adjacent chapters (prev + target + next) ──
    import re as _re
    # Split full_context into individual chapter blocks
    # Supports both "=== Ch.N ===" and "[CHAPTER_FILE N]" formats
    chapter_blocks = _re.split(
        r'\n*(?=(?:=== Ch\.\d+|(?:\[CHAPTER_FILE \d+\])))', full_context
    )
    chapter_blocks = [b.strip() for b in chapter_blocks if b.strip()]

    # Find which block contains the chapter_text (fuzzy match first 80 chars)
    target_snippet = chapter_text[:80].strip()
    target_idx = -1
    for i, block in enumerate(chapter_blocks):
        if target_snippet in block:
            target_idx = i
            break

    if target_idx >= 0 and len(chapter_blocks) > 3:
        # Keep only prev + target + next
        start = max(0, target_idx - 1)
        end = min(len(chapter_blocks), target_idx + 2)
        trimmed_blocks = chapter_blocks[start:end]
        adjacent_context = "\n\n".join(trimmed_blocks)
    else:
        # Fallback: use full context if can't identify target
        adjacent_context = full_context

    system_prompt = (
        "You are a script editor. You need to make a MINIMAL, TARGETED fix to one chapter.\n\n"
        "ISSUE TO FIX:\n"
        f"Type: {issue.get('type', 'overlap')}\n"
        f"Detail: {issue.get('detail', '')}\n"
        f"Fix: {issue.get('suggested_fix', '')}\n\n"
        "RULES:\n"
        "1. Make the SMALLEST possible change to fix the issue.\n"
        "2. Keep the chapter's overall structure, flow, and narrative intact.\n"
        "3. If reducing overlap, condense the overlapping section to 1-2 brief sentences.\n"
        "4. If fixing a flow break, add only a brief transition (1-2 sentences).\n"
        "5. Do NOT rewrite the entire chapter. Only modify the specific section.\n"
        "6. Do NOT include [CHAPTER_FILE] labels, filenames, or metadata in your output.\n\n"
        "ADJACENT CHAPTERS (for context only, do not modify other chapters):\n"
        f"{adjacent_context}\n\n"
        "OUTPUT: The complete chapter text with the fix applied. No comments or explanations."
    )

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": f"CHAPTER TO FIX:\n\n{chapter_text}"},
    ]

    if log_callback:
        log_callback(f"  Patching: {issue.get('type', '?')} — {issue.get('detail', '')[:60]}...")

    result = api_client.call_api(
        messages, temperature=0.3, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"  ❌ Patch failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    if log_callback:
        log_callback(f"  ✓ Patched via {result.get('model', '?')}")

    patched = result["content"].strip()
    # Strip any leaked [CHAPTER_FILE N] labels from patched content
    import re as _re
    patched = _re.sub(
        r'^\s*\[CHAPTER_FILE\s*\d+\]\s*[^\n]*\n?', '', patched
    ).strip()
    return patched


def merge_to_version(
    output_dir: str,
    version: int,
    chapters: list[dict],
    lang: str = "",
) -> str:
    """Merge chapters into a versioned output directory.
    chapters: [{filename, text}, ...]
    Creates output_dir/v{version}/ with individual files + FULL_SCRIPT.txt
    Returns: path to FULL_SCRIPT.txt
    """
    if version == 0:
        ver_dir = os.path.join(output_dir, "final")
    else:
        ver_dir = os.path.join(output_dir, f"v{version}")
    os.makedirs(ver_dir, exist_ok=True)

    # Language prefix for filenames
    prefix = f"{lang}_" if lang else ""

    # Save individual chapters (body only, no title)
    for ch in chapters:
        title, body = _split_title_body(ch["text"])
        fname = f"{prefix}{ch['filename']}"
        fpath = os.path.join(ver_dir, fname)
        with open(fpath, "w", encoding="utf-8") as f:
            f.write(body if body else ch["text"])

    # Save merged full script with formatted headers
    full_path = os.path.join(ver_dir, "FULL_SCRIPT.txt")
    with open(full_path, "w", encoding="utf-8") as f:
        for i, ch in enumerate(chapters):
            title, body = _split_title_body(ch["text"])
            if i > 0:
                f.write("\n\n" + "=" * 60 + "\n\n")
            f.write(f"[{i+1:02d}]: {title}\n")
            f.write("=" * 60 + "\n\n")
            f.write(body if body else ch["text"])

    return full_path


