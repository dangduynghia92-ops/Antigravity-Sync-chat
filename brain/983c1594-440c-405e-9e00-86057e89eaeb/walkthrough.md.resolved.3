def detect_framework(
    full_text: str,
    api_client,
    log_callback=None,
    frameworks_list: list[dict] | None = None,
) -> dict:
    """Detect which narrative/review framework the original script uses.

    Args:
        frameworks_list: Optional list of framework dicts with 'name' and
            'description' keys.  When provided the prompt is built
            dynamically so review‑mode frameworks are used instead of the
            hardcoded narrative list.

    Returns: {detected_framework: str, confidence: str, reasoning: str}
    """
    if frameworks_list:
        # Build dynamic prompt from provided frameworks
        fw_lines = []
        for i, fw in enumerate(frameworks_list, 1):
            name = fw.get("name", f"Framework {i}")
            desc = fw.get("description", fw.get("best_for", ""))
            fw_lines.append(f'{i}. "{name}" — {desc}')
        fw_block = "\n".join(fw_lines)
        system_prompt = (
            "You are a script structure analyst. Your task is to read a script "
            "and determine which FRAMEWORK it follows.\n\n"
            f"THE AVAILABLE FRAMEWORKS:\n{fw_block}\n\n"
            "INSTRUCTIONS:\n"
            "1. Read the script carefully\n"
            "2. Identify which framework BEST matches the script's structure\n"
            '3. If the script does NOT clearly match any framework above, return "None"\n\n'
            "OUTPUT FORMAT (JSON only, no other text):\n"
            "{\n"
            '  "detected_framework": "Framework Name",\n'
            '  "confidence": "high",\n'
            '  "reasoning": "2-3 sentences explaining why"\n'
            "}\n\n"
            "RULES:\n"
            "1. Output ONLY JSON — no markdown, no code fences\n"
            '2. Choose the SINGLE best match, or "None" if no framework fits\n'
            '3. "confidence" must be "high", "medium", or "low"\n'
        )
    else:
        system_prompt = _load_prompt("system_detect_framework.txt")

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": f"SCRIPT TO ANALYZE:\n\n{full_text}"},
    ]

    if log_callback:
        log_callback(f"Detecting framework ({len(full_text):,} chars)...")

    result = api_client.call_api(
        messages, temperature=0.2, timeout=500
    )

    if not result["success"]:
        if log_callback:
            log_callback(f"❌ Framework detection failed: {result.get('error', 'unknown')}")
        raise RuntimeError(f"API error: {result['error']}")

    model = result.get("model", "?")
    if log_callback:
        log_callback(f"✓ Framework detected via {model}")

    content = result["content"]
    json_match = re.search(r'\{[\s\S]*\}', content)
    if json_match:
        return json.loads(json_match.group())
    return json.loads(content)


